-- ESP Drawing
local espObjects = {}

local function clearESP()
    for _, t in pairs(espObjects) do
        if t.tracer then t.tracer:Remove() end
        if t.box then t.box:Remove() end
    end
    espObjects = {}
end

local function getCharacterParts(char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    return hrp, head
end

local function isEnemy(player)
    return player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0
end

local function updateESP()
    clearESP()
    if not ESP_ENABLED then return end
    for _, player in ipairs(Players:GetPlayers()) do
        if isEnemy(player) then
            local char = player.Character
            local hrp, head = getCharacterParts(char)
            if hrp and head then
                -- Tracer
                local tracer = Drawing.new("Line")
                tracer.Thickness = 2
                tracer.Color = Color3.fromRGB(255, 0, 0)
                tracer.Transparency = 1
                tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                local hrpScreen, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                tracer.To = Vector2.new(hrpScreen.X, hrpScreen.Y)
                tracer.Visible = onScreen

                espObjects[player.UserId] = { tracer = tracer }
            end
        end
    end
end

-- Aimbot
local function getNearestEnemy()
    local closest = nil
    local closestDist = FOV
    local centerX = Camera.ViewportSize.X / 2
    local centerY = Camera.ViewportSize.Y / 2

    for _, player in ipairs(Players:GetPlayers()) do
        if isEnemy(player) then
            local char = player.Character
            local head = char:FindFirstChild("Head")
            if head then
                local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local dist = math.sqrt((screenPos.X - centerX)^2 + (screenPos.Y - centerY)^2)
                    if dist < closestDist then
                        closestDist = dist
                        closest = head
                    end
                end
            end
        end
    end
    return closest
end

-- Infinite Ammo (universal hook)
local function hookAmmo()
    for _, tool in ipairs(LocalPlayer.Character and LocalPlayer.Character:GetChildren() or {}) do
        local gun = tool:FindFirstChildWhichIsA("Script") or tool:FindFirstChildWhichIsA("LocalScript")
        -- Universal: patch ammo values
        for _, v in ipairs(tool:GetDescendants()) do
            if v:IsA("IntValue") or v:IsA("NumberValue") then
                local n = v.Name:lower()
                if n:find("ammo") or n:find("bullets") or n:find("clip") or n:find("mag") then
                    v.Value = 9999
                    v.Changed:Connect(function()
                        if INFINITE_AMMO then v.Value = 9999 end
                    end)
                end
            end
        end
    end
end

LocalPlayer.CharacterAdded:Connect(function(char)
    char.ChildAdded:Connect(function(child)
        wait(0.1)
        if INFINITE_AMMO then hookAmmo() end
    end)
end)

-- Main Loop
RunService.RenderStepped:Connect(function()
    -- ESP update
    updateESP()

    -- Aimbot
    if AIMBOT_ENABLED then
        local target = getNearestEnemy()
        if target then
            local cf = CFrame.new(Camera.CFrame.Position, target.Position)
            Camera.CFrame = cf
            -- Auto shoot
            if AUTO_SHOOT then
                local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if tool then
                    local fireEvent = tool:FindFirstChild("RemoteEvent") or tool:FindFirstChildWhichIsA("RemoteEvent")
                    if fireEvent then
                        pcall(function() fireEvent:FireServer() end)
                    end
                    -- Simulate mouse click for local fire scripts
                    local mouse = LocalPlayer:GetMouse()
                    pcall(function()
                        tool:Activate()
                    end)
                end
            end
        end
    end

    -- Infinite ammo tick
    if INFINITE_AMMO then
        hookAmmo()
    end
end)

Players.PlayerRemoving:Connect(function(p)
    if espObjects[p.UserId] then
        if espObjects[p.UserId].tracer then espObjects[p.UserId].tracer:Remove() end
        espObjects[p.UserId] = nil
    end
end)

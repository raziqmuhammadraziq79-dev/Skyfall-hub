-- Setup Attachment & LinearVelocity
local attachment, linearVelocity
local function setupPhysics(char)
	local hrp = char:WaitForChild("HumanoidRootPart")
	if attachment then attachment:Destroy() end
	if linearVelocity then linearVelocity:Destroy() end
	
	attachment = Instance.new("Attachment")
	attachment.Name = "UltraMaxFlyAttachment"
	attachment.Parent = hrp

	linearVelocity = Instance.new("LinearVelocity")
	linearVelocity.Name = "UltraMaxFlyVelocity"
	linearVelocity.Attachment0 = attachment
	linearVelocity.MaxForce = 0
	linearVelocity.VectorVelocity = Vector3.new(0, 0, 0)
	linearVelocity.Parent = hrp
end
setupPhysics(character)

localPlayer.CharacterAdded:Connect(function(newChar)
	character = newChar
	humanoid = character:WaitForChild("Humanoid")
	rootPart = character:WaitForChild("HumanoidRootPart")
	setupPhysics(newChar)
	if isFlying then
		humanoid:ChangeState(Enum.HumanoidStateType.Physics)
		linearVelocity.MaxForce = math.huge
	end
end)

-- ==========================================
-- RENDERING MODULATORS (NO GIMICK OPTIMIZER)
-- ==========================================
local function applySuperSmooth()
	lightingService.GlobalShadows = false
	lightingService.FogEnd = 9e9
	
	-- Matikan partikel berat & efek distorsi layar Evade (Blur, SunRays)
	for _, v in ipairs(lightingService:GetChildren()) do
		if v:IsA("PostEffect") then v.Enabled = false end
	end
	
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and not obj:IsDescendantOf(character) then
			if not originalProps[obj] then
				originalProps[obj] = {Material = obj.Material, Reflectance = obj.Reflectance}
			end
			obj.Material = Enum.Material.SmoothPlastic
			obj.Reflectance = 0
		elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") then
			obj.Enabled = false
		end
	end
end

local function applyExtremeSmooth()
	applySuperSmooth() -- Jalankan basis super smooth dulu
	
	-- Tembak setting physics rendering internal game engine
	settings().Physics.PhysicsEnvironmentalThrottle = Enum.EnviromentalPhysicsThrottle.Disabled
	
	-- Babat habis Decal sisa darah/efek di Evade & ganti material tanah jadi total flat black/smooth plastic
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Decal") or obj:IsA("Texture") then
			obj:Destroy()
		elseif obj:IsA("MeshPart") or obj:IsA("SpecialMesh") then
			-- Paksa model mesh 3D rumit jadi low-poly proxy rendering
			if obj:IsA("MeshPart") then 
				obj.Material = Enum.Material.SmoothPlastic 
			end
		end
	end
end

local function restoreRendering()
	for obj, props in pairs(originalProps) do
		if obj and obj.Parent then
			obj.Material = props.Material
			obj.Reflectance = props.Reflectance
		end
	end
	lightingService.GlobalShadows = true
	settings().Physics.PhysicsEnvironmentalThrottle = Enum.EnviromentalPhysicsThrottle.Default
	table.clear(originalProps)
end


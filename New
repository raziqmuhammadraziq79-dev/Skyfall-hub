-- Core Flight Mechanics Override Engine
local function controlFlight(root, active)
	if active then
		if not flightInstances.Velocity then
			local bVel = Instance.new("BodyVelocity")
			bVel.MaxForce = Vector3.new(4e5, 4e5, 4e5) -- Force boosted to avoid dropping down
			bVel.Velocity = Vector3.new(0, 0, 0)
			bVel.Parent = root
			flightInstances.Velocity = bVel
			
			local bGyro = Instance.new("BodyGyro")
			bGyro.MaxTorque = Vector3.new(4e5, 4e5, 4e5)
			bGyro.CFrame = root.CFrame
			bGyro.Parent = root
			flightInstances.Gyro = bGyro
		end
		
		local camera = workspace.CurrentCamera
		local moveDir = Vector3.new(0, 0, 0)
		
		if userInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camera.CFrame.LookVector end
		if userInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camera.CFrame.LookVector end
		if userInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camera.CFrame.RightVector end
		if userInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camera.CFrame.RightVector end
		
		flightInstances.Velocity.Velocity = moveDir.Magnitude > 0 and (moveDir.Unit * features.WalkSpeed) or Vector3.new(0, 0, 0)
		flightInstances.Gyro.CFrame = camera.CFrame
	else
		if flightInstances.Velocity then flightInstances.Velocity:Destroy() flightInstances.Velocity = nil end
		if flightInstances.Gyro then flightInstances.Gyro:Destroy() flightInstances.Gyro = nil end
	end
end

-- Universal Heartbeat Processing Framework
runService.Heartbeat:Connect(function()
	local char = localPlayer.Character
	if not char then return end
	
	local hum = char:FindFirstChildOfClass("Humanoid")
	local root = char:FindFirstChild("HumanoidRootPart")
	
	if hum and not features.Flight then
		hum.WalkSpeed = features.WalkSpeed
		hum.JumpPower = features.JumpPower
	end

	if root then
		controlFlight(root, features.Flight)
	end

	if features.Noclip then
		for _, part in ipairs(char:GetDescendants()) do
			if part:IsA("BasePart") then part.CanCollide = false end
		end
	end
end)

userInputService.JumpRequest:Connect(function()
	if features.InfJump and localPlayer.Character then
		local hum = localPlayer.Character:FindFirstChildOfClass("Humanoid")
		if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
	end
end)


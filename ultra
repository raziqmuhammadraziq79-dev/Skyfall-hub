    B.MouseButton1Click:Connect(Cb)
end

-- ═══════════════ PLAYER SELECTOR ═══════════════
local SelectedPlr = nil
local PlayerListFrame = nil
local SelectedLabel = nil

local function UpdatePL(f)
    if not PlayerListFrame then return end
    for _, c in ipairs(PlayerListFrame:GetChildren()) do
        if c:IsA("GuiObject") and c.Name ~= "UIListLayout" then c:Destroy() end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            if not f or string.find(string.lower(p.Name), string.lower(f)) or string.find(string.lower(p.DisplayName), string.lower(f or "")) then
                local B = New("TextButton", {Size = UDim2.new(1, 0, 0, 24),
                    BackgroundColor3 = SelectedPlr == p and CFG.Accent or CFG.BG,
                    Text = "  " .. p.DisplayName .. " (@" .. p.Name .. ")",
                    TextColor3 = SelectedPlr == p and Color3.new(1, 1, 1) or CFG.Text,
                    TextSize = 10, Font = Enum.Font.GothamMedium, TextXAlignment = Enum.TextXAlignment.Left,
                    TextTruncate = Enum.TextTruncate.AtEnd, Parent = PlayerListFrame})
                New("UICorner", {CornerRadius = UDim.new(0, 4), Parent = B})
                B.MouseButton1Click:Connect(function()
                    SelectedPlr = p; UpdatePL(f)
                    if SelectedLabel then
                        SelectedLabel.Text = "TARGET: " .. p.DisplayName .. " (@" .. p.Name .. ") | ID: " .. p.UserId
                        SelectedLabel.TextColor3 = CFG.Green
                    end
                    Log("Target: " .. p.Name)
                end)
            end
        end
    end
end


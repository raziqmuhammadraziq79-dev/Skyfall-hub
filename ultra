local function CreateTab(Name, IconOverride)
    local icon = IconOverride or TabIcons[Name] or "•"
    FeatureCount[Name] = 0
    local Btn = New("TextButton", {Size = UDim2.new(1, 0, 0, 30), BackgroundColor3 = CFG.BG2,
        Text = " " .. icon .. "  " .. Name, TextColor3 = CFG.Dim, TextSize = 11,
        Font = Enum.Font.GothamMedium, TextXAlignment = Enum.TextXAlignment.Left, Parent = SidebarScroll})
    New("UICorner", {CornerRadius = UDim.new(0, 5), Parent = Btn})

    local Page = New("ScrollingFrame", {Name = Name, Size = UDim2.new(1, -8, 1, -8), Position = UDim2.new(0, 4, 0, 4),
        BackgroundTransparency = 1, BorderSizePixel = 0, CanvasSize = UDim2.new(0, 0, 0, 0), ScrollBarThickness = 3,
        ScrollBarImageColor3 = CFG.Accent, ScrollBarImageTransparency = 0.4, Visible = false, Parent = Content})
    local PageLayout = New("UIListLayout", {Padding = UDim.new(0, 4), SortOrder = Enum.SortOrder.LayoutOrder, Parent = Page})
    New("UIPadding", {PaddingBottom = UDim.new(0, 15), PaddingTop = UDim.new(0, 4), Parent = Page})
    PageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        Page.CanvasSize = UDim2.new(0, 0, 0, PageLayout.AbsoluteContentSize.Y + 20)
    end)
    task.defer(function() Page.CanvasSize = UDim2.new(0, 0, 0, PageLayout.AbsoluteContentSize.Y + 20) end)
    Pages[Name] = Page

    Btn.MouseEnter:Connect(function() if Btn.BackgroundColor3 ~= CFG.BG3 then TweenService:Create(Btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(26, 27, 32)}):Play() end end)
    Btn.MouseLeave:Connect(function() if Btn.BackgroundColor3 ~= CFG.BG3 then TweenService:Create(Btn, TweenInfo.new(0.1), {BackgroundColor3 = CFG.BG2}):Play() end end)
    Btn.MouseButton1Click:Connect(function()
        for _, p in pairs(Pages) do p.Visible = false end
        Page.Visible = true
        for _, c in ipairs(SidebarScroll:GetChildren()) do
            if c:IsA("TextButton") then TweenService:Create(c, TweenInfo.new(0.12), {BackgroundColor3 = CFG.BG2, TextColor3 = CFG.Dim}):Play() end
        end
        TweenService:Create(Btn, TweenInfo.new(0.12), {BackgroundColor3 = CFG.BG3, TextColor3 = CFG.Text}):Play()
    end)
    return Page
end


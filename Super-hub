        if Hub.ActiveTab ~= tab.name then
            TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundTransparency = 0.3}):Play()
            TweenService:Create(icon, TweenInfo.new(0.15), {ImageColor3 = C.Accent}):Play()

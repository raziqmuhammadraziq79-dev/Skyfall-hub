local traceLines = {}
local traceRenderConn = nil

local function UpdateTracerForPlayer(player)
    if player == LocalPlayer then return end
    local data = traceLines[player]
    if not data then
        local line = Instance.new("Frame")
        line.Name = "Trace_" .. player.Name
        line.BackgroundColor3 = C.Accent; line.BorderSizePixel = 0

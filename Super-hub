-- ================== ACCENT TRACKING ==================
local AccentElements = {}
local ThemeUpdateCallbacks = {}
local function TrackAccent(obj, prop)
    if obj then table.insert(AccentElements, {obj = obj, prop = prop}) end
end
local function RegisterThemeUpdate(cb) table.insert(ThemeUpdateCallbacks, cb) end
local function SetThemeColor(c)
    Hub.ThemeColor = c
    for _, cb in ipairs(ThemeUpdateCallbacks) do pcall(cb, c) end
end


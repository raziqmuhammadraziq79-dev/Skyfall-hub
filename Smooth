-- Heartbeat Physics Interpolation
runService.Heartbeat:Connect(function(deltaTime)
	if not isFlying or not rootPart or not humanoid or not linearVelocity then return end
	
	local moveDirection = humanoid.MoveDirection
	if moveDirection.Magnitude > 0 or verticalDirection ~= 0 then
		currentSpeed = math.min(currentSpeed + (deltaTime * baseSpeed * 2), baseSpeed * maxSpeedMultiplier)
	else
		currentSpeed = baseSpeed
	end
	
	local rawTargetVelocity = (moveDirection * currentSpeed) + Vector3.new(0, verticalDirection * currentSpeed, 0)
	currentVelocityTarget = currentVelocityTarget:Lerp(rawTargetVelocity, lerpAlpha)
	
	linearVelocity.VectorVelocity = currentVelocityTarget
end)


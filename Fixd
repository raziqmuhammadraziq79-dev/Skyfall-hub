local function createPremiumToggle(name, subText, default, callback)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, -6, 0, 48)
	row.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
	row.BackgroundTransparency = 0.5
	row.Parent = scrollCanvas
	
	local rCorner = Instance.new("UICorner")
	rCorner.CornerRadius = UDim.new(0, 10)
	rCorner.Parent = row
	
	local titleLbl = Instance.new("TextLabel")
	titleLbl.Size = UDim2.new(0.7, 0, 0, 22)
	titleLbl.Position = UDim2.new(0.04, 0, 0, 4)
	titleLbl.Text = name
	titleLbl.TextColor3 = Color3.fromRGB(245, 245, 250)
	titleLbl.Font = Enum.Font.GothamBold
	titleLbl.TextSize = 12
	titleLbl.TextXAlignment = Enum.TextXAlignment.Left
	titleLbl.BackgroundTransparency = 1
	titleLbl.Parent = row
	
	local descLbl = Instance.new("TextLabel")
	descLbl.Size = UDim2.new(0.7, 0, 0, 16)
	descLbl.Position = UDim2.new(0.04, 0, 0, 24)
	descLbl.Text = subText
	descLbl.TextColor3 = Color3.fromRGB(150, 150, 160)
	descLbl.Font = Enum.Font.Gotham
	descLbl.TextSize = 10
	descLbl.TextXAlignment = Enum.TextXAlignment.Left
	descLbl.BackgroundTransparency = 1
	descLbl.Parent = row
	
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 55, 0, 26)
	btn.Position = UDim2.new(0.96, -55, 0.5, -11)
	btn.BackgroundColor3 = default and Color3.fromRGB(0, 180, 110) or Color3.fromRGB(45, 45, 55)
	btn.Text = default and "ACTIVE" or "READY"
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 9
	btn.Parent = row
	
	local bCorner = Instance.new("UICorner")
	bCorner.CornerRadius = UDim.new(0, 6)
	bCorner.Parent = btn
	
	local toggled = default
	btn.MouseButton1Click:Connect(function()
		toggled = not toggled
		btn.Text = toggled and "ACTIVE" or "READY"
		local targetColor = toggled and Color3.fromRGB(0, 180, 110) or Color3.fromRGB(45, 45, 55)
		tweenObject(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = targetColor})
		pcall(callback, toggled)
	end)
end


-- Skyfall-hub [PREMIUM] | VORD Edition
-- Compatible: Delta Executor (Android)
-- Status: Absolute Precision

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Main.lua"))()
local SaveManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/SaveManager.lua"))()
local InterfaceManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/InterfaceManager.lua"))()

local Window = Library:CreateWindow({
    Title = "Skyfall-hub [PREMIUM]",
    SubTitle = "by VORD",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Accent = Color3.fromRGB(0, 150, 255), -- Ice Blue
    FontFace = Font.new("rbxassetid://12187365364"), -- Clean font
})

local Tabs = {
    Main = Window:AddTab("Main"),
    Visuals = Window:AddTab("Visuals"),
    Settings = Window:AddTab("Settings"),
}

-- Functions
local function Notify(Text)
    Library:Notify({
        Title = "Skyfall-hub",
        Description = Text,
        Duration = 5
    })
end

-- MAIN TAB
do
    local PlayerSection = Tabs.Main:AddSection("Player")
    
    -- God Mode (Anti-Kill)
    PlayerSection:AddToggle("GodMode", {
        Text = "God Mode",
        Default = false,
        Tooltip = "Prevents all damage.",
    }):OnChanged(function(Value)
        if Value then
            _G.GodMode = true
            Notify("God Mode Activated ❄️")
            -- Hook for damage prevention
            game:GetService("Players").LocalPlayer.Character.Humanoid.HealthChanged:Connect(function(Health)
                if _G.GodMode then
                    game:GetService("Players").LocalPlayer.Character.Humanoid.Health = 100
                end
            end)
        else
            _G.GodMode = false
            Notify("God Mode Deactivated")
        end
    end)

    -- Infinite Jump
    PlayerSection:AddToggle("InfJump", {
        Text = "Infinite Jump",
        Default = false,
        Tooltip = "Jump as many times as you want.",
    }):OnChanged(function(Value)
        _G.InfJump = Value
        if Value then
            Notify("Infinite Jump Enabled")
        else
            Notify("Infinite Jump Disabled")
        end
    end)

    -- Fly & Noclip
    PlayerSection:AddButton("Enable Fly + Noclip", function()
        Notify("Fly & Noclip Activated [E to Toggle]")
        local Player = game.Players.LocalPlayer
        local Mouse = Player:GetMouse()
        local RootPart = Player.Character:WaitForChild("HumanoidRootPart")
        local Torso = Player.Character:WaitForChild("UpperTorso")
        
        local Flying = false
        local Speed = 1
        
        game:GetService("UserInputService").InputBegan:Connect(function(Input)
            if Input.KeyCode == Enum.KeyCode.E then
                Flying = not Flying
                if Flying then
                    Notify("Fly Enabled")
                else
                    Notify("Fly Disabled")
                end
            end
        end)

        game:GetService("RunService").RenderStepped:Connect(function()
            if Flying then
                local Camera = workspace.CurrentCamera
                local Direction = Camera.CFrame.LookVector
                local Position = RootPart.Position
                
                RootPart.Velocity = Direction * Speed * 50
                RootPart.CanCollide = false -- Noclip component
            else
                RootPart.CanCollide = true
            end
        end)
    end)
end

-- VISUALS TAB
do
    local VisualSection = Tabs.Visuals:AddSection("Vision")
    
    -- Night Vision
    VisualSection:AddToggle("NightVision", {
        Text = "Night Vision",
        Default = false,
        Tooltip = "See in the dark.",
    }):OnChanged(function(Value)
        if Value then
            local Lighting = game:GetService("Lighting")
            _G.OriginalBrightness = Lighting.Brightness
            _G.OriginalClockTime = Lighting.ClockTime
            
            Lighting.Brightness = 2
            Lighting.ClockTime = 14
            Notify("Night Vision Activated 🌙")
        else
            local Lighting = game:GetService("Lighting")
            if _G.OriginalBrightness then
                Lighting.Brightness = _G.OriginalBrightness
            end
            if _G.OriginalClockTime then
                Lighting.ClockTime = _G.OriginalClockTime
            end
            Notify("Night Vision Deactivated")
        end
    end)
    
    -- ESP Placeholder (Premium Feel)
    VisualSection:AddButton("Load ESP (Universal)", function()
        Notify("ESP Module Loaded [Hidden]")
        -- In a real premium script, this would inject box ESP
    end)
end

-- SETTINGS TAB
do
    local ConfigSection = Tabs.Settings:AddSection("Configuration")
    
    ConfigSection:AddButton("Hide GUI [-]", function()
        Window.Frame.Visible = false
        Notify("GUI Hidden. Press RightShift to toggle.")
        -- Bind key to show again
        game:GetService("UserInputService").InputBegan:Connect(function(Input)
            if Input.KeyCode == Enum.KeyCode.RightShift then
                Window.Frame.Visible = not Window.Frame.Visible
            end
        end)
    end)

    ConfigSection:AddButton("Close GUI [X]", function()
        Window:Destroy()
        Notify("Skyfall-hub Closed.")
    end)
    
    SaveManager:SetLibrary(Library)
    InterfaceManager:SetLibrary(Library)
    SaveManager:IgnoreThemeSettings()
    SaveManager:SetIgnoreIndexes({"MenuKeybind"})
    InterfaceManager:SetFolder("Skyfall-hub")
    SaveManager:SetFolder("Skyfall-hub/configs")
    InterfaceManager:BuildInterfaceSection(Tabs.Settings)
    SaveManager:BuildConfigSection(Tabs.Settings)
end

-- Infinite Jump Logic Hook
game:GetService("UserInputService").JumpRequest:Connect(function()
    if _G.InfJump then
        game:GetService("Players").LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)

Notify("Skyfall-hub Initialized. Welcome, VORD.")

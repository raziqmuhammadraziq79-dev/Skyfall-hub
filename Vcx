-- ANTI-TROLL & GOD MODE (Combined Robust Logic)
AddToggle("Anti-Troll + God Mode", true, function(v)
    _G.Sky.GodMode = v
    _G.Sky.AntiTroll = v
    if v then
        local Char = LocalPlayer.Character
        if Char and Char:FindFirstChild("Humanoid") then
            -- Prevent Death/Kill
            Char.Humanoid.HealthChanged:Connect(function()
                if _G.Sky.GodMode then Char.Humanoid.Health = 100 end
            end)
            -- Prevent Sit/PlatformStand/Trip
            Char.Humanoid.StateChanged:Connect(function(Old, New)
                if _G.Sky.AntiTroll and (New == Enum.HumanoidStateType.Seated or New == Enum.HumanoidStateType.PlatformStanding) then
                    Char.Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                end
            end)
        end
    end
end)


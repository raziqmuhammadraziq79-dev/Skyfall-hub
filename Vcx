local function Notify(Msg)
    local N = Instance.new("Frame")
    N.Size = UDim2.new(0, 240, 0, 45)
    N.Position = UDim2.new(0.5, -120, 1, -70)
    N.BackgroundColor3 = Color3.fromRGB(12, 12, 18)
    N.BorderSizePixel = 0; N.Parent = ScreenGui
    Instance.new("UICorner", N).CornerRadius = UDim.new(0, 8)
    
    local T = Instance.new("TextLabel", N)
    T.Size = UDim2.new(1, 0, 1, 0); T.BackgroundTransparency = 1
    T.Text = Msg; T.TextColor3 = Color3.fromRGB(180, 100, 255)
    T.Font = Enum.Font.GothamMedium; T.TextSize = 14
    
    TweenService:Create(N, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -120, 1, -90)}):Play()
    task.delay(2.5, function()
        TweenService:Create(N, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -120, 1, -70)}):Play()
        task.wait(0.3); N:Destroy()
    end)
end


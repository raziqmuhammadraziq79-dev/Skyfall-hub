-- 5 ESP Players
local function applyESPP(char)
  if char:FindFirstChild("_SFESP") then return end
  local hl=Instance.new("Highlight") hl.Name="_SFESP"
  hl.FillColor=C.Blue hl.OutlineColor=C.W
  hl.FillTransparency=0.5 hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
  hl.Parent=char
end
local function fESPP(v) S.ESPP=v
  for _,p in ipairs(Players:GetPlayers()) do
    if p~=LP and p.Character then
      local hl=p.Character:FindFirstChild("_SFESP")
      if v and not hl then applyESPP(p.Character)
      elseif not v and hl then hl:Destroy() end
    end
  end
end
Players.PlayerAdded:Connect(function(p) p.CharacterAdded:Connect(function(c)
  if S.ESPP and p~=LP then task.wait(0.1) applyESPP(c) end
end) end)


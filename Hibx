local function mkCard(parent,title)
  local sf=Instance.new("ScrollingFrame")
  sf.Size=UDim2.fromScale(1,1) sf.BackgroundColor3=C.Card sf.BorderSizePixel=0
  sf.ScrollBarThickness=MOBILE and 2 or 4 sf.ScrollBarImageColor3=C.Blue
  sf.CanvasSize=UDim2.new(0,0,0,0) sf.AutomaticCanvasSize=Enum.AutomaticSize.Y
  sf.ScrollingDirection=Enum.ScrollingDirection.Y sf.ElasticBehavior=Enum.ElasticBehavior.Always
  sf.ScrollingEnabled=true sf.Parent=parent
  uC(sf,10) uSt(sf,C.Stroke,1) uPad(sf,PAD,PAD,PAD,PAD)
  -- smooth mouse wheel scroll
  sf.InputChanged:Connect(function(inp)
    if inp.UserInputType==Enum.UserInputType.MouseWheel then
      local target=sf.CanvasPosition+Vector2.new(0,-inp.Position.Z*50)
      target=Vector2.new(target.X,math.clamp(target.Y,0,math.max(0,sf.AbsoluteCanvasSize.Y-sf.AbsoluteSize.Y)))
      TS:Create(sf,TweenInfo.new(0.18,Enum.EasingStyle.Quad),{CanvasPosition=target}):Play()
    end
  end)
  local hdr=uLbl(sf,title,FS2,C.Blue,Enum.TextXAlignment.Left,Enum.Font.GothamBold)
  hdr.LayoutOrder=0 uGr(hdr,C.Blue,C.Purple,0)
  local sep=Instance.new("Frame") sep.Size=UDim2.new(1,0,0,1) sep.BackgroundColor3=C.Stroke
  sep.BorderSizePixel=0 sep.LayoutOrder=1 sep.Parent=sf
  local ll=Instance.new("UIListLayout") ll.Padding=UDim.new(0,MOBILE and 6 or 7)

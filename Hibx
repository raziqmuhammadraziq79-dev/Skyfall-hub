-- 30 Silent TP (teleport behind target every 2s)
local function fSilentTP(v) S.SilentTP=v dC("STP")
  if v then
    aC("STP",task.spawn(function()
      while S.SilentTP do
        local closest,closestDist=nil,math.huge
        for _,p in ipairs(Players:GetPlayers()) do
          if p~=LP and p.Character then
            local r2=p.Character:FindFirstChild("HumanoidRootPart")
            local myR=gR()
            if r2 and myR then
              local d=(r2.Position-myR.Position).Magnitude
              if d<closestDist then closestDist=d closest=r2 end
            end
          end
        end
        if closest then
          local r=gR()
          if r then r.CFrame=closest.CFrame*CFrame.new(0,0,-4) end
        end
        task.wait(2)
      end
    end))
  end
end

-- Teleport by name
local function fTeleport(name)
  local r=gR() if not r then return end
  for _,inst in ipairs(WS:GetDescendants()) do
    if inst.Name:lower()==name:lower() and (inst:IsA("BasePart") or inst:IsA("Model")) then
      local cf=inst:IsA("Model") and inst:GetPivot() or inst.CFrame
      r.CFrame=cf+Vector3.yAxis*5 return
    end
  end
  warn("[SFv10] Not found: "..name)
end


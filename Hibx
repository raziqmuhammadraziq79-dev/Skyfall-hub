    Rain  ={chars={"|","‖","/"},     col=Color3.fromRGB(140,180,255),sz=10,spd={2.5,4.5},drift=false},
    Sakura={chars={"✿","❀","✾","*"},col=Color3.fromRGB(255,180,210),sz=12,spd={0.5,1.2},drift=true},
    Stars ={chars={"★","✦","·","*"},col=Color3.fromRGB(220,230,255),sz=9, spd={0.1,0.3},drift=true},
  }
  local cfg=configs[etype]
  if not cfg then return end

  for i=1,MAX do
    local lbl=Instance.new("TextLabel",effectGui)
    lbl.BackgroundTransparency=1
    lbl.Font=Enum.Font.GothamBold
    lbl.TextColor3=cfg.col
    lbl.TextTransparency=math.random(10,40)/100
    lbl.TextSize=cfg.sz+math.random(-2,4)
    lbl.Text=cfg.chars[math.random(#cfg.chars)]
    lbl.ZIndex=1
    local x=math.random(0,100)/100
    local y=math.random(-20,100)/100
    lbl.Position=UDim2.new(x,0,y,0)
    lbl.Size=UDim2.fromOffset(20,20)
    table.insert(particles,{lbl=lbl,x=x,y=y,
      spd=cfg.spd[1]+math.random()*(cfg.spd[2]-cfg.spd[1]),
      dx=(cfg.drift and (math.random()-0.5)*0.15 or 0)})
  end

  local last=os.clock()
  RunService.RenderStepped:Connect(function()
    if not effectGui or not effectGui.Parent then return end
    local dt=os.clock()-last last=os.clock()
    for _,p in ipairs(particles) do
      p.y=p.y+p.spd*dt
      p.x=p.x+p.dx*dt
      if p.y>1.1 then p.y=-0.1 p.x=math.random(0,100)/100 end
      if p.x<0 then p.x=1 elseif p.x>1 then p.x=0 end
      p.lbl.Position=UDim2.new(p.x,0,p.y,0)
    end
  end)
end


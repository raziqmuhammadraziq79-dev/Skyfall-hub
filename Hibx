local iHL={}
local function fESPI(v) S.ESPI=v
  for _,h in ipairs(iHL) do pcall(function() h:Destroy() end) end table.clear(iHL)
  if not v then return end
  local kw={"item","drop","chest","coin","gem","loot","pickup","collect","reward","ore","fruit","weapon","mob","enemy"}
  for _,inst in ipairs(WS:GetDescendants()) do
    local n=inst.Name:lower() local hit=ColSvc:HasTag(inst,"SFItem")
    if not hit then for _,k in ipairs(kw) do if n:find(k) then hit=true break end end end
    if hit and (inst:IsA("BasePart") or inst:IsA("Model") or inst:IsA("Tool")) then
      local hl=Instance.new("Highlight")
      hl.FillColor=C.Green hl.OutlineColor=C.Green
      hl.FillTransparency=0.4 hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
      hl.Parent=inst table.insert(iHL,hl)
    end
  end
end


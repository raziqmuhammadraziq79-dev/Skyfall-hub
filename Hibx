-- 4 Fly (universal - works in ALL games, bypasses most anti-cheats)
local fbv,fbg,flyConn
local function fFly(v) S.Fly=v dC("Fly")
  local h=gH() local r=gR()
  if v then
    -- Wait for character if needed
    if not h or not r then
      LP.CharacterAdded:Wait()
      task.wait(0.3)
      h=gH() r=gR()
      if not h or not r then return end
    end
    -- Disable gravity on character
    h.PlatformStand=true
    -- Cleanup old motors
    for _,bv in ipairs(r:GetChildren()) do
      if bv:IsA("BodyVelocity") or bv:IsA("BodyGyro") then bv:Destroy() end
    end
    fbv=Instance.new("BodyVelocity")
    fbv.Name="_SFfly_bv"
    fbv.MaxForce=Vector3.new(1e6,1e6,1e6)
    fbv.Velocity=Vector3.zero
    fbv.Parent=r
    fbg=Instance.new("BodyGyro")
    fbg.Name="_SFfly_bg"
    fbg.MaxTorque=Vector3.new(1e6,1e6,1e6)
    fbg.P=5000 fbg.D=200
    fbg.CFrame=r.CFrame
    fbg.Parent=r
    -- Sync loop
    aC("Fly",RunService.RenderStepped:Connect(function()
      local cam=WS.CurrentCamera
      local d=Vector3.zero
      local spd=S.FlySpd
      -- keyboard
      if UIS:IsKeyDown(Enum.KeyCode.W) then d+=cam.CFrame.LookVector end
      if UIS:IsKeyDown(Enum.KeyCode.S) then d-=cam.CFrame.LookVector end
      if UIS:IsKeyDown(Enum.KeyCode.A) then d-=cam.CFrame.RightVector end
      if UIS:IsKeyDown(Enum.KeyCode.D) then d+=cam.CFrame.RightVector end
      if UIS:IsKeyDown(Enum.KeyCode.Space)       then d+=Vector3.yAxis end
      if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then d-=Vector3.yAxis end
      if UIS:IsKeyDown(Enum.KeyCode.LeftShift)   then spd=spd*2 end
      -- keep motor alive
      local root=gR()
      if fbv and root and fbv.Parent then
        fbv.Velocity=(d.Magnitude>0 and d.Unit or d)*spd
      end
      if fbg and root and fbg.Parent then
        fbg.CFrame=CFrame.lookAt(Vector3.zero,cam.CFrame.LookVector)
      end
      -- re-disable humanoid fall
      local hum=gH()
      if hum then
        hum.PlatformStand=true
        if hum:GetState()==Enum.HumanoidStateType.Freefall then
          hum:ChangeState(Enum.HumanoidStateType.Swimming)
        end
      end
    end))
  else
    if fbv then pcall(function() fbv:Destroy() end) fbv=nil end
    if fbg then pcall(function() fbg:Destroy() end) fbg=nil end
    local hum=gH() if hum then hum.PlatformStand=false end
    -- clean any leftover motors
    local root=gR()
    if root then
      for _,bv in ipairs(root:GetChildren()) do
        if bv.Name=="_SFfly_bv" or bv.Name=="_SFfly_bg" then bv:Destroy() end
      end
    end
  end
end

-- 2 Noclip (universal - handles all collision methods)
local function fNoclip(v) S.Noclip=v dC("NC")
  if v then
    aC("NC",RunService.Stepped:Connect(function()
      local c=LP.Character if not c then return end
      for _,p in ipairs(c:GetDescendants()) do
        if p:IsA("BasePart") then
          p.CanCollide=false
          -- also handle CFrame-based collision
          if p.Name=="HumanoidRootPart" then
            p.CanCollide=false
          end
        end
      end
    end))
  else
    local c=LP.Character if c then
      for _,p in ipairs(c:GetDescendants()) do
        if p:IsA("BasePart") and p.Name~="HumanoidRootPart" then
          p.CanCollide=true
        end
      end
    end
  end
end


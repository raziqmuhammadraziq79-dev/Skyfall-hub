local function CreateESP(plr)
    if plr == LocalPlayer then return end
    if State.ESPObjects[plr] then return end
    
    local objects = {}
    
    local box = Drawing.new("Square")
    box.Visible = false box.Thickness = 1.5 box.Color = Color3.fromRGB(0, 255, 150) box.Transparency = 0.8 box.Filled = false
    objects.Box = box
    
    local name = Drawing.new("Text")
    name.Visible = false name.Size = 13 name.Color = Color3.fromRGB(0, 255, 150) name.Center = true name.Outline = true
    objects.Name = name
    
    local health = Drawing.new("Text")
    health.Visible = false health.Size = 12 health.Color = Color3.fromRGB(255, 255, 255) health.Center = true health.Outline = true
    objects.Health = health
    
    local dist = Drawing.new("Text")
    dist.Visible = false dist.Size = 11 dist.Color = Color3.fromRGB(200, 200, 200) dist.Center = true dist.Outline = true
    objects.Distance = dist
    
    local tracer = Drawing.new("Line")
    tracer.Visible = false tracer.Thickness = 1 tracer.Color = Color3.fromRGB(0, 255, 150) tracer.Transparency = 0.6
    objects.Tracer = tracer
    
    State.ESPObjects[plr] = objects
    
    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not Config.ESP or not State.ESPObjects[plr] then if conn then conn:Disconnect() end return end
        
        local char = GetChar(plr)
        local head = GetHead(plr)
        local root = GetRoot(plr)
        local hum = GetHum(plr)
        local myRoot = GetRoot()
        
        if not (char and head and root and hum and myRoot) then
            for _, obj in pairs(objects) do obj.Visible = false end
            return
        end
        
        local pos, onScreen = Camera:WorldToViewportPoint(head.Position)
        if not onScreen then
            for _, obj in pairs(objects) do obj.Visible = false end
            return
        end
        
        local distance = (root.Position - myRoot.Position).Magnitude
        local size = 2000 / distance
        
        if Config.ESPBoxes then
            box.Size = Vector2.new(size, size * 1.5)
            box.Position = Vector2.new(pos.X - size/2, pos.Y - size * 0.75)
            box.Visible = true
        else box.Visible = false end
        
        if Config.ESPNames then
            name.Position = Vector2.new(pos.X, pos.Y - 40)
            name.Text = plr.DisplayName .. " [@" .. plr.Name .. "]"
            name.Visible = true
        else name.Visible = false end
        
        if Config.ESPHealth then
            health.Position = Vector2.new(pos.X, pos.Y - 25)
            health.Text = math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
            health.Color = Color3.fromRGB(255 * (1 - hum.Health/hum.MaxHealth), 255 * (hum.Health/hum.MaxHealth), 0)
            health.Visible = true
        else health.Visible = false end
        
        if Config.ESPDistance then
            dist.Position = Vector2.new(pos.X, pos.Y + 15)
            dist.Text = math.floor(distance) .. "m"
            dist.Visible = true
        else dist.Visible = false end
        
        if Config.ESPTracers then
            tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
            tracer.To = Vector2.new(pos.X, pos.Y)
            tracer.Visible = true
        else tracer.Visible = false end
    end)
end

local function ClearESP()
    for plr, objects in pairs(State.ESPObjects) do
        for _, obj in pairs(objects) do pcall(function() obj:Remove() end) end
    end
    State.ESPObjects = {}
end

local function ToggleESP(enabled)
    Config.ESP = enabled
    if enabled then
        for _, plr in ipairs(Players:GetPlayers()) do CreateESP(plr) end
        Players.PlayerAdded:Connect(function(plr) if Config.ESP then task.wait(1) CreateESP(plr) end end)
        Notify("ESP", "Activated")
    else
        ClearESP()
        Notify("ESP", "Deactivated")
    end
end


    -- Command processor
    local function ProcessCommand(cmd)
        cmd = cmd:lower():gsub("^%s+", ""):gsub("%s+$", "")
        if cmd == "" then return end
        
        table.insert(State.CommandHistory, cmd)
        AddLog("> " .. cmd, Color3.fromRGB(0, 255, 150))
        
        local args = {}
        for arg in cmd:gmatch("%S+") do table.insert(args, arg) end
        
        local command = args[1]
        table.remove(args, 1)
        
        -- Command handlers
        if command == ";fly" or command == "fly" then
            if Config.FlyEnabled then StopFly() else StartFly() end
            
        elseif command == ";unfly" or command == "unfly" then
            StopFly()
            
        elseif command == ";fling" then
            if args[1] == "all" then
                FlingAll()
            elseif args[1] then
                local target = FindPlayer(args[1])
                if target then FlingPlayer(target) else AddLog("Player not found: " .. args[1], Color3.fromRGB(255, 50, 50)) end
            elseif Config.KillTarget then
                FlingPlayer(Config.KillTarget)
            else
                AddLog("Usage: ;fling [player/all]", Color3.fromRGB(255, 200, 0))
            end
            
        elseif command == ";kill" then
            if args[1] == "all" then
                KillAll()
            elseif args[1] then
                local target = FindPlayer(args[1])
                if target then KillPlayer(target) else AddLog("Player not found: " .. args[1], Color3.fromRGB(255, 50, 50)) end
            elseif Config.KillTarget then
                KillPlayer(Config.KillTarget)
            else
                AddLog("Usage: ;kill [player/all]", Color3.fromRGB(255, 200, 0))
            end
            
        elseif command == ";bring" then
            if args[1] == "all" then
                BringAll()
            elseif args[1] then
                local target = FindPlayer(args[1])
                if target then BringPlayer(target) else AddLog("Player not found: " .. args[1], Color3.fromRGB(255, 50, 50)) end
            elseif Config.KillTarget then
                BringPlayer(Config.KillTarget)
            end
            
        elseif command == ";goto" then
            if args[1] then
                local target = FindPlayer(args[1])
                if target then GotoPlayer(target) else AddLog("Player not found: " .. args[1], Color3.fromRGB(255, 50, 50)) end
            elseif Config.KillTarget then
                GotoPlayer(Config.KillTarget)
            end
            
        elseif command == ";freeze" then
            if args[1] == "all" then
                FreezeAll()
            elseif args[1] then
                local target = FindPlayer(args[1])
                if target then FreezePlayer(target) else AddLog("Player not found: " .. args[1], Color3.fromRGB(255, 50, 50)) end
            elseif Config.KillTarget then
                FreezePlayer(Config.KillTarget)
            end
            
        elseif command == ";unfreeze" then
            if args[1] == "all" then
                UnfreezeAll()
            elseif args[1] then
                local target = FindPlayer(args[1])
                if target then UnfreezePlayer(target) else AddLog("Player not found: " .. args[1], Color3.fromRGB(255, 50, 50)) end
            elseif Config.KillTarget then
                UnfreezePlayer(Config.KillTarget)
            end
            
        elseif command == ";speed" then
            if args[1] then
                Config.WalkSpeed = tonumber(args[1]) or 100
                if Config.SpeedHack then ToggleSpeed(false) ToggleSpeed(true) end
                AddLog("Speed set to " .. Config.WalkSpeed, Color3.fromRGB(0, 255, 150))
            else
                ToggleSpeed(not Config.SpeedHack)
            end
            
        elseif command == ";noclip" or command == "noclip" then
            ToggleNoClip(not Config.NoClip)
            
        elseif command == ";god" or command == "god" then
            ToggleGod(not Config.GodMode)
            
        elseif command == ";esp" then
            ToggleESP(not Config.ESP)
            
        elseif command == ";aimbot" then
            ToggleAimbot(not Config.Aimbot)
            
        elseif command == ";killaura" then
            ToggleKillAura(not Config.KillAura)
            
        elseif command == ";clicktp" then

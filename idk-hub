            local dist = math.min(offset.Magnitude, 35)
            local dir = offset.Unit
            local newPos = center + dir * dist
            joyKnob.Position = UDim2.new(0, newPos.X - 22.5, 0, newPos.Y - 22.5)
            State.JoystickDir = Vector3.new(dir.X, 0, -dir.Y) * (dist / 35)

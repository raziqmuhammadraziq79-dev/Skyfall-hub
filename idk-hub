        elseif command == ";rejoin" or command == "rejoin" then
            Rejoin()
            
        elseif command == ";serverhop" then
            ServerHop()
            
        elseif command == ";reset" or command == "reset" then
            ResetCharacter()
            
        elseif command == ";gravity" then
            if args[1] then SetGravity(tonumber(args[1]) or 196.2) end
            
        elseif command == ";time" then
            if args[1] then SetTime(tonumber(args[1]) or 12) end
            
        elseif command == ";size" then
            if args[1] and args[2] then
                local target = FindPlayer(args[1])

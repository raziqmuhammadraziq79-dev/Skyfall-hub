--// ============================================

local function FlingPlayer(target, power)
    if not target or target == LocalPlayer then return false end
    power = power or Config.FlingPower
    
    local tc = GetChar(target)
    if not tc then return false end
    
    local tr = GetRoot(target)
    local th = GetHum(target)
    if not (tr and th) then return false end
    if th.Health <= 0 then return false end
    
    local mr = GetRoot()
    if not mr then return false end
    
    local dir = (tr.Position - mr.Position).Unit
    if dir.Magnitude < 0.01 then dir = Vector3.new(0, 1, 0) end
    
    local vel = dir * power + Vector3.new(0, power * 0.5, 0)
    
    -- Stack multiple velocity applications
    for i = 1, 8 do
        task.delay(i * 0.03, function()
            pcall(function()
                tr.Velocity = vel * (1 + i * 0.15)
                tr.AssemblyLinearVelocity = vel * (1 + i * 0.15)
                tr.RotVelocity = Vector3.new(math.random(-200,200), math.random(-200,200), math.random(-200,200))
            end)
        end)
    end
    
    -- BodyVelocity injection
    task.delay(0.1, function()
        pcall(function()
            local existing = tr:FindFirstChild("SkyfallFling")
            if existing then existing:Destroy() end
            
            local bv = Instance.new("BodyVelocity")
            bv.Name = "SkyfallFling"
            bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            bv.Velocity = vel * 2.5
            bv.Parent = tr
            Debris:AddItem(bv, 0.6)
        end)
    end)
    
    -- Angular spin
    task.delay(0.05, function()
        pcall(function()
            local ba = Instance.new("BodyAngularVelocity")
            ba.Name = "SkyfallSpin"
            ba.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            ba.AngularVelocity = Vector3.new(math.random(-100,100), math.random(-100,100), math.random(-100,100)) * 250
            ba.Parent = tr
            Debris:AddItem(ba, 1.2)
        end)
    end)
    
    -- CFrame bump
    task.delay(0.15, function()
        pcall(function() tr.CFrame = tr.CFrame + dir * 12 + Vector3.new(0, 30, 0) end)
    end)
    
    return true
end

local function FlingAll()
    local count = 0
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and FlingPlayer(plr) then count = count + 1 end
    end
    Notify("Fling All", "Launched " .. count .. " players!")
    return count
end

local function FlingRandom()
    local targets = {}
    for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then table.insert(targets, p) end end
    if #targets > 0 then
        local r = targets[math.random(1, #targets)]
        FlingPlayer(r)
        Notify("Random Fling", "Launched " .. r.DisplayName)
    end
end


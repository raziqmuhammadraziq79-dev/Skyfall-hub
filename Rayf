FollowTab:CreateButton({
    Name = "🎯 START FOLLOWING (Height: 25)",
    Callback = function()
        if not SelectedPlr then Rayfield:Notify({Title="Error",Content="Select a player first!",Duration=3}); return end
        FollowTgt=SelectedPlr
        SB("FollowPlr",Enum.RenderPriority.Character.Value+1,function()
            if not FollowTgt or not FollowTgt.Parent then SU("FollowPlr"); return end
            local tc=FollowTgt.Character
            if not tc or not tc:FindFirstChild("HumanoidRootPart") then return end
            local tRP=tc.HumanoidRootPart; local tPos=tRP.Position
            local myGY=GroundH(RP.Position); local hoverY=myGY+PS.FollowHeight
            if hoverY>myGY+40 then hoverY=myGY+40 end
            local tLook=tRP.CFrame.LookVector; local bo=-tLook*PS.FollowDistance
            local fp=Vector3.new(tPos.X+bo.X,hoverY,tPos.Z+bo.Z)
            local d3=(RP.Position-fp).Magnitude; local sp=d3>50 and 0.35 or d3>20 and 0.2 or 0.12
            local np=RP.Position:Lerp(fp,sp); local mv=(np-RP.Position)*15
            RP.AssemblyLinearVelocity=Vector3.new(math.clamp(mv.X,-80,80),math.clamp(mv.Y,-40,40),math.clamp(mv.Z,-80,80))
        end)
        Rayfield:Notify({Title="Following",Content=FollowTgt.DisplayName.." | Height: "..PS.FollowHeight,Duration=3})
    end
})


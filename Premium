-- ================== CATEGORY SWITCHING ==================
function SwitchCategory(name)
    Hub.ActiveCategory = name
    -- Update sidebar visuals
    for catName, data in pairs(CategoryButtons) do
        local isActive = catName == name
        if isActive then
            -- Gold gradient background
            local grad = data.btn:FindFirstChildOfClass("UIGradient")
            if not grad then
                grad = Instance.new("UIGradient", data.btn)
                grad.Rotation = 90
            end
            grad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 42, 20)),
                ColorSequenceKeypoint.new(0.5, Color3.fromRGB(70, 55, 20)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(40, 35, 18)),
            })
            TweenService:Create(data.btn, TweenInfo.new(0.25), {BackgroundTransparency = 0.1}):Play()
            TweenService:Create(data.leftAccent, TweenInfo.new(0.25, Enum.EasingStyle.Back), {Size = UDim2.new(0, 4, 0, 32)}):Play()
            data.nameLbl.TextColor3 = C.Gold
            data.nameLbl.Font = Enum.Font.GothamBlack
            data.descLbl.TextColor3 = C.GoldGlow
            data.iconFrame.BackgroundColor3 = C.Gold
            data.iconFrame.BackgroundTransparency = 0.2
        else
            local grad = data.btn:FindFirstChildOfClass("UIGradient")
            if grad then grad:Destroy() end
            TweenService:Create(data.btn, TweenInfo.new(0.25), {BackgroundTransparency = 0.6, BackgroundColor3 = C.Card}):Play()
            TweenService:Create(data.leftAccent, TweenInfo.new(0.25), {Size = UDim2.new(0, 3, 0, 24)}):Play()
            data.nameLbl.TextColor3 = C.Text
            data.nameLbl.Font = Enum.Font.GothamBold
            data.descLbl.TextColor3 = C.TextSub
            data.iconFrame.BackgroundColor3 = C.Card
            data.iconFrame.BackgroundTransparency = 0.3
        end
    end
    -- Switch content
    for catName, frame in pairs(CategoryFrames) do
        local show = catName == name
        if show then
            frame.scroll.Visible = true
            frame.scroll.Position = UDim2.new(0, 40, 0, 90)
            TweenService:Create(frame.scroll, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Position = UDim2.new(0, 20, 0, 90)}):Play()
        else
            frame.scroll.Visible = false
        end
    end
end

-- Refresh content (search filter)
function RefreshContent()
    -- Simple: show/hide cards based on search query
    for catName, data in pairs(CategoryFrames) do
        for _, card in ipairs(data.grid:GetChildren()) do
            if card:IsA("Frame") and card.Name:find("Card_") then
                local name = card.Name:sub(6):lower()
                if Hub.SearchQuery == "" or name:find(Hub.SearchQuery) then
                    card.Visible = true
                else
                    card.Visible = false
                end
            end
        end
    end
end


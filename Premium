-- Orb drag
local orbDrag = false
local orbStart, orbPos
Orb.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        orbDrag = true
        orbStart = input.Position
        orbPos = Orb.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then orbDrag = false end
        end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if orbDrag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local d = input.Position - orbStart
        Orb.Position = UDim2.new(orbPos.X.Scale, orbPos.X.Offset + d.X, orbPos.Y.Scale, orbPos.Y.Offset + d.Y)
    end
end)


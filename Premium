        local state = config.default or false
        local toggle = Instance.new("TextButton")
        toggle.Size = UDim2.new(0, 56, 0, 28)
        toggle.Position = UDim2.new(1, -72, 0.5, -14)
        toggle.BackgroundColor3 = C.ToggleOff
        toggle.BorderSizePixel = 0
        toggle.Text = ""
        toggle.AutoButtonColor = false
        toggle.Parent = card
        Instance.new("UICorner", toggle).CornerRadius = UDim.new(1, 0)

        local knob = Instance.new("Frame")
        knob.Size = UDim2.new(0, 22, 0, 22)
        knob.Position = UDim2.new(0, 3, 0.5, -11)
        knob.BackgroundColor3 = C.TextSub
        knob.BorderSizePixel = 0
        knob.Parent = toggle
        Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

        local glowStroke = Instance.new("UIStroke", toggle)
        glowStroke.Color = C.Gold
        glowStroke.Thickness = 2
        glowStroke.Transparency = 1

        local function Update()
            if state then
                TweenService:Create(toggle, TweenInfo.new(0.25, Enum.EasingStyle.Back), {BackgroundColor3 = C.Gold}):Play()
                TweenService:Create(knob, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                    Position = UDim2.new(0, 31, 0.5, -11),
                    BackgroundColor3 = C.Bg
                }):Play()
                TweenService:Create(glowStroke, TweenInfo.new(0.3), {Transparency = 0.4}):Play()
            else
                TweenService:Create(toggle, TweenInfo.new(0.25), {BackgroundColor3 = C.ToggleOff}):Play()
                TweenService:Create(knob, TweenInfo.new(0.3), {
                    Position = UDim2.new(0, 3, 0.5, -11),
                    BackgroundColor3 = C.TextSub
                }):Play()
                TweenService:Create(glowStroke, TweenInfo.new(0.3), {Transparency = 1}):Play()
            end
        end

        toggle.MouseButton1Click:Connect(function()
            state = not state
            Update()
            pcall(config.callback, state)
        end)

        if state then Update() end
        return card, function() return state end

    elseif config.type == "slider" then
        local value = config.default or 50
        local min, max = config.min or 0, config.max or 100

        local valueLbl = Instance.new("TextLabel")
        valueLbl.Size = UDim2.new(0, 60, 0, 18)
        valueLbl.Position = UDim2.new(1, -74, 0, 8)
        valueLbl.BackgroundTransparency = 1
        valueLbl.Text = tostring(value)
        valueLbl.TextColor3 = C.Gold
        valueLbl.TextSize = 13
        valueLbl.Font = Enum.Font.GothamBold
        valueLbl.TextXAlignment = Enum.TextXAlignment.Right
        valueLbl.Parent = card

        local track = Instance.new("Frame")
        track.Size = UDim2.new(1, -180, 0, 6)
        track.Position = UDim2.new(0, 76, 0, 58)
        track.BackgroundColor3 = C.ToggleOff
        track.BorderSizePixel = 0
        track.Parent = card
        Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

        local fill = Instance.new("Frame")
        fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
        fill.BackgroundColor3 = C.Gold
        fill.BorderSizePixel = 0
        fill.Parent = track
        Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

        local thumb = Instance.new("TextButton")
        thumb.Size = UDim2.new(0, 20, 0, 20)
        thumb.Position = UDim2.new((value - min) / (max - min), -10, 0.5, -10)
        thumb.BackgroundColor3 = C.Gold
        thumb.BorderSizePixel = 0
        thumb.Text = ""
        thumb.AutoButtonColor = false
        thumb.Parent = track
        Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)
        local thumbStroke = Instance.new("UIStroke", thumb)
        thumbStroke.Color = C.GoldGlow
        thumbStroke.Thickness = 2
        thumbStroke.Transparency = 0.5

        local dragging = false
        local function UpdateSlider(inputX)
            local trackAbs = track.AbsolutePosition.X
            local trackWidth = track.AbsoluteSize.X
            local pct = math.clamp((inputX - trackAbs) / trackWidth, 0, 1)
            value = math.floor(min + (max - min) * pct)
            fill.Size = UDim2.new(pct, 0, 1, 0)
            thumb.Position = UDim2.new(pct, -10, 0.5, -10)
            valueLbl.Text = tostring(value)
            pcall(config.callback, value)
        end

        thumb.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end)
        track.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                UpdateSlider(input.Position.X)
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                UpdateSlider(input.Position.X)
            end
        end)

        return card, function() return value end

    elseif config.type == "button" then
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 80, 0, 34)
        btn.Position = UDim2.new(1, -96, 0.5, -17)
        btn.BackgroundColor3 = C.Gold
        btn.BorderSizePixel = 0
        btn.Text = config.buttonText or "EXECUTE"
        btn.TextColor3 = C.Bg
        btn.TextSize = 11
        btn.Font = Enum.Font.GothamBold
        btn.AutoButtonColor = false
        btn.Parent = card
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)
        local btnGrad = Instance.new("UIGradient", btn)
        btnGrad.Color = ColorSequence.new(C.Gold, C.GoldGlow)
        btnGrad.Rotation = 90

        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), {Size = UDim2.new(0, 86, 0, 36)}):Play()
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), {Size = UDim2.new(0, 80, 0, 34)}):Play()
        end)
        btn.MouseButton1Click:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0.5}):Play()
            task.wait(0.1)
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0}):Play()
            pcall(config.callback)
        end)

        return card
    end
end


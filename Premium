local ddVisible = false
local function refreshDropdown()
	for _, child in ipairs(dropdownContainer:GetChildren()) do
		if child:IsA("TextButton") then child:Destroy() end
	end
	local count = 0
	for _, p in ipairs(playersService:GetPlayers()) do
		if p ~= localPlayer then
			count = count + 1
			local pBtn = Instance.new("TextButton")
			pBtn.Size = UDim2.new(1, 0, 0, 30)
			pBtn.BackgroundColor3 = Color3.fromRGB(33, 33, 33)
			pBtn.Text = p.Name
			pBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
			pBtn.Font = Enum.Font.SourceSans
			pBtn.TextSize = 13
			pBtn.Parent = dropdownContainer
			
			pBtn.MouseButton1Click:Connect(function()
				States.SelectedPlayer = p
				dropdownMain.Text = "TARGET: " .. p.Name
				ddVisible = false
				dropdownContainer.Size = UDim2.new(1, -6, 0, 0)
			end)
		end
	end
	if ddVisible then dropdownContainer.Size = UDim2.new(1, -6, 0, count * 34) end
end

dropdownMain.MouseButton1Click:Connect(function()
	ddVisible = not ddVisible
	refreshDropdown()
end)


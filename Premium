local function UpdateTouchVis()
    local show = Hub.IsFlying
    JoyArea.Visible = show; UpBtn.Visible = show; DownBtn.Visible = show
end

local joyTouch = nil
JoyArea.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch then
        joyTouch = i
        i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then
            joyTouch = nil; Hub.FlyDirection = Vector3.new(0,0,0)
            JoyKnob.Position = UDim2.new(0.5, -30, 0.5, -30)
        end end)
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if i == joyTouch then
        local pos = JoyArea.AbsolutePosition
        local size = JoyArea.AbsoluteSize
        local center = Vector2.new(pos.X + size.X/2, pos.Y + size.Y/2)
        local delta = Vector2.new(i.Position.X - center.X, i.Position.Y - center.Y)
        local max = size.X / 2
        local dist = math.min(delta.Magnitude, max)
        local dir = delta.Magnitude > 0 and delta.Unit or Vector2.new(0,0)
        local kx, ky = dir.X * dist, dir.Y * dist
        JoyKnob.Position = UDim2.new(0.5, kx - 30, 0.5, ky - 30)
        Hub.FlyDirection = Vector3.new(dir.X * (dist/max), 0, -dir.Y * (dist/max))
    end
end)

UpBtn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch then Hub.FlyUp = true end end)
UpBtn.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch then Hub.FlyUp = false end end)
DownBtn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch then Hub.FlyDown = true end end)
DownBtn.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch then Hub.FlyDown = false end end)

-- Keyboard fly
UserInputService.InputBegan:Connect(function(i, p)
    if p or not Hub.IsFlying then return end
    if i.KeyCode == Enum.KeyCode.W then Hub.FlyDirection = Vector3.new(Hub.FlyDirection.X, Hub.FlyDirection.Y, -1) end
    if i.KeyCode == Enum.KeyCode.S then Hub.FlyDirection = Vector3.new(Hub.FlyDirection.X, Hub.FlyDirection.Y, 1) end
    if i.KeyCode == Enum.KeyCode.A then Hub.FlyDirection = Vector3.new(-1, Hub.FlyDirection.Y, Hub.FlyDirection.Z) end
    if i.KeyCode == Enum.KeyCode.D then Hub.FlyDirection = Vector3.new(1, Hub.FlyDirection.Y, Hub.FlyDirection.Z) end
    if i.KeyCode == Enum.KeyCode.Space then Hub.FlyUp = true end
    if i.KeyCode == Enum.KeyCode.LeftShift then Hub.FlyDown = true end
end)
UserInputService.InputEnded:Connect(function(i)
    if not Hub.IsFlying then return end
    if i.KeyCode == Enum.KeyCode.W or i.KeyCode == Enum.KeyCode.S then
        Hub.FlyDirection = Vector3.new(Hub.FlyDirection.X, Hub.FlyDirection.Y, 0)
    end
    if i.KeyCode == Enum.KeyCode.A or i.KeyCode == Enum.KeyCode.D then
        Hub.FlyDirection = Vector3.new(0, Hub.FlyDirection.Y, Hub.FlyDirection.Z)
    end
    if i.KeyCode == Enum.KeyCode.Space then Hub.FlyUp = false end
    if i.KeyCode == Enum.KeyCode.LeftShift then Hub.FlyDown = false end
end)


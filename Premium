    stroke.Thickness = 1

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.2, TextColor3 = C.Gold}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Color = C.Gold, Transparency = 0.3}):Play()

-- Stats update loop
task.spawn(function()
    while true do
        task.wait(1)
        local elapsed = os.time() - Hub.SessionStart
        local h = string.format("%02d", math.floor(elapsed / 3600))
        local m = string.format("%02d", math.floor((elapsed % 3600) / 60))
        local s = string.format("%02d", elapsed % 60)
        sessLbl.Text = h .. ":" .. m .. ":" .. s

        local fps = math.floor(1 / (RunService.RenderStepped:Wait() or 0.016))
        fps = math.min(fps, 999)
        fpsLabel.Text = "FPS: " .. fps
        fpsFooterLbl.Text = tostring(fps)


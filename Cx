-------------------------------
-- UTILITY
-------------------------------
local function toScreen(pos)
    local s, vis = Camera:WorldToViewportPoint(pos)
    return Vector2.new(s.X, s.Y), vis, s.Z
end

local function screenMid()
    return Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
end

local function worldDist(pos)
    local c = LocalPlayer.Character
    if not c then return math.huge end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if not hrp then return math.huge end
    return (hrp.Position - pos).Magnitude
end

local function isEnemy(p)
    if not LocalPlayer.Team or not p.Team then return true end
    return p.Team ~= LocalPlayer.Team
end

local function lerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

local function newDraw(t, props)
    local o = Drawing.new(t)
    for k,v in pairs(props) do o[k] = v end
    return o
end

-------------------------------
-- PREDICTION ENGINE
-------------------------------
local prevPos = {}
local prevTime = {}

local function getPredicted(player)
    local char = player.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local now = tick()
    local vel = hrp.AssemblyLinearVelocity

    -- Use velocity + frame delta for smoother prediction
    local dt = now - (prevTime[player] or now)
    local predicted = hrp.Position + vel * CFG.PredictStrength

    -- Lead target based on distance to camera
    local camDist = (Camera.CFrame.Position - hrp.Position).Magnitude
    local bulletTravelTime = camDist / 800  -- assume ~800 stud/s projectile
    local leadPos = hrp.Position + vel * bulletTravelTime

    prevPos[player]  = hrp.Position
    prevTime[player] = now

    local offset = CFG.AimPart == "Head" and Vector3.new(0, 1.5, 0) or Vector3.new(0, 0, 0)
    return leadPos + offset
end


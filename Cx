local function applyChams(char, color)
    for _, p in pairs(char:GetDescendants()) do
        if p:IsA("BasePart") and not p:FindFirstChild("ESPCham") then
            local h = Instance.new("SelectionBox")
            h.Name            = "ESPCham"
            h.Color3          = color
            h.LineThickness   = 0.02
            h.SurfaceTransparency = 0.6
            h.SurfaceColor3   = color
            h.Adornee         = p
            h.Parent          = p
        end
    end
end

local function clearChams(char)
    if not char then return end
    for _, d in pairs(char:GetDescendants()) do
        if d.Name == "ESPCham" then d:Destroy() end
    end
end


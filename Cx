local function updateESP()
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local e = ESPCache[player]
        if not e then continue end

        local char = player.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local head = char and char:FindFirstChild("Head")

        -- Hide all if dead/missing
        if not CFG.ESP or not char or not hrp or not hum or hum.Health <= 0 then
            for k,o in pairs(e) do
                if type(o)=="userdata" then o.Visible=false end
            end
            for _,l in pairs(e.C) do l.Visible=false end
            continue
        end

        local enemy = isEnemy(player)
        if (enemy and not CFG.ShowEnemy) or (not enemy and not CFG.ShowTeam) then
            for k,o in pairs(e) do
                if type(o)=="userdata" then o.Visible=false end
            end
            for _,l in pairs(e.C) do l.Visible=false end
            continue
        end

        local d = worldDist(hrp.Position)
        if d > CFG.MaxDist then
            for k,o in pairs(e) do
                if type(o)=="userdata" then o.Visible=false end
            end
            for _,l in pairs(e.C) do l.Visible=false end
            continue
        end

        local color    = enemy and CFG.EnemyColor or CFG.TeamColor
        local isTarget = currentTarget == player
        local dispColor = isTarget and CFG.AimTargetColor or color

        local headPos  = head and head.Position or hrp.Position + Vector3.new(0,1.5,0)
        local footPos  = hrp.Position - Vector3.new(0,3,0)

        local headSP, onScreen = toScreen(headPos)
        local footSP           = toScreen(footPos)

        if not onScreen then
            for k,o in pairs(e) do
                if type(o)=="userdata" then o.Visible=false end
            end
            for _,l in pairs(e.C) do l.Visible=false end
            continue
        end

        local bh = math.max(math.abs(footSP.Y - headSP.Y), 10)
        local bw = bh * 0.55
        local bx = headSP.X - bw/2
        local by = headSP.Y
        local hpRatio = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
        local hpColor = lerpColor(CFG.HealthLow, CFG.HealthHigh, hpRatio)

        -- Name
        local tag = enemy and " [ENEMY]" or " [TEAM]"
        e.Name.Text     = player.Name .. tag
        e.Name.Color    = dispColor
        e.Name.Position = Vector2.new(headSP.X, by - 18)
        e.Name.Visible  = true

        -- Target label
        e.AimLbl.Visible  = isTarget
        e.AimLbl.Position = Vector2.new(headSP.X, by - 30)

        -- Health text
        if CFG.ShowHealth then
            e.HpTxt.Text     = "♥ "..math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)
            e.HpTxt.Color    = hpColor
            e.HpTxt.Position = Vector2.new(headSP.X, by - 5)
            e.HpTxt.Visible  = true
        else e.HpTxt.Visible = false end

        -- Distance
        if CFG.ShowDistance then
            e.Dist.Text     = math.floor(d).."m"
            e.Dist.Position = Vector2.new(headSP.X, footSP.Y + 3)
            e.Dist.Visible  = true
        else e.Dist.Visible = false end

        -- Box
        if CFG.ShowBox then
            drawBox(e, bx, by, bw, bh, color, isTarget)
        else hideBox(e) end

        -- Health bar
        if CFG.ShowHealth then
            local barX = bx - 7
            e.HpBG.From=Vector2.new(barX,by)
            e.HpBG.To  =Vector2.new(barX,by+bh)
            e.HpBG.Visible=true
            e.HpFG.From=Vector2.new(barX,by+bh)
            e.HpFG.To  =Vector2.new(barX,by+bh-(bh*hpRatio))
            e.HpFG.Color=hpColor
            e.HpFG.Visible=true
        else e.HpBG.Visible=false e.HpFG.Visible=false end

        -- SINGLE CLEAN TRACER (enemy only, from bottom-center screen to foot)
        if CFG.ShowTracer and enemy then
            e.Tracer.From    = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
            e.Tracer.To      = footSP
            e.Tracer.Color   = isTarget and CFG.AimTargetColor or CFG.TracerColor
            e.Tracer.Thickness = isTarget and 1.5 or 1
            e.Tracer.Visible = true
        else e.Tracer.Visible = false end

        -- Head dot
        if CFG.ShowHeadDot then
            e.HDot.Position = headSP
            e.HDot.Color    = dispColor
            e.HDot.Visible  = true
        else e.HDot.Visible = false end

        -- Prediction dot on target only
        if isTarget then
            local pred = getPredicted(player)
            if pred then
                local psp, pon = toScreen(pred)
                e.PDot.Position = psp
                e.PDot.Visible  = pon
            end
        else e.PDot.Visible = false end

        -- Chams
        if CFG.ShowChams and enemy then
            pcall(function()
                local chamColor = isTarget and CFG.AimTargetColor or CFG.ChamsEnemy
                clearChams(char)
                applyChams(char, chamColor)
            end)
        end
    end
end


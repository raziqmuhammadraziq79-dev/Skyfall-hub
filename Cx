-------------------------------
local function drawBox(e, bx, by, bw, bh, color, isTarget)
    local tc = isTarget and CFG.AimTargetColor or color
    local function setLine(l, x1,y1,x2,y2,c,th)
        l.From=Vector2.new(x1,y1) l.To=Vector2.new(x2,y2)
        l.Color=c l.Thickness=th or 1 l.Visible=true
    end
    -- Shadow
    setLine(e.BTs,bx,by,bx+bw,by,Color3.fromRGB(0,0,0),3)
    setLine(e.BBs,bx,by+bh,bx+bw,by+bh,Color3.fromRGB(0,0,0),3)
    setLine(e.BLs,bx,by,bx,by+bh,Color3.fromRGB(0,0,0),3)
    setLine(e.BRs,bx+bw,by,bx+bw,by+bh,Color3.fromRGB(0,0,0),3)
    -- Box
    setLine(e.BT,bx,by,bx+bw,by,Color3.fromRGB(255,255,255))
    setLine(e.BB,bx,by+bh,bx+bw,by+bh,Color3.fromRGB(255,255,255))
    setLine(e.BL,bx,by,bx,by+bh,Color3.fromRGB(255,255,255))
    setLine(e.BR,bx+bw,by,bx+bw,by+bh,Color3.fromRGB(255,255,255))
    -- Corners
    local cw,ch = bw*0.3, bh*0.3
    local pts = {
        {bx,by,cw,ch},
        {bx+bw,by,-cw,ch},
        {bx,by+bh,cw,-ch},
        {bx+bw,by+bh,-cw,-ch},
    }
    for i,pt in ipairs(pts) do
        local idx = (i-1)*2
        e.C[idx+1].From=Vector2.new(pt[1],pt[2]) e.C[idx+1].To=Vector2.new(pt[1]+pt[3],pt[2]) e.C[idx+1].Color=tc e.C[idx+1].Visible=true
        e.C[idx+2].From=Vector2.new(pt[1],pt[2]) e.C[idx+2].To=Vector2.new(pt[1],pt[2]+pt[4]) e.C[idx+2].Color=tc e.C[idx+2].Visible=true
    end
end

local function hideBox(e)
    for _,k in pairs({"BTs","BBs","BLs","BRs","BT","BB","BL","BR"}) do e[k].Visible=false end
    for _,l in pairs(e.C) do l.Visible=false end
end

-------------------------------
-- AIMBOT TARGET SELECTOR
-------------------------------
local function getBestTarget()
    local sc = screenMid()
    local best, bestScore = nil, math.huge

    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        if not isEnemy(p) then continue end
        local char = p.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not char or not hum or not hrp or hum.Health <= 0 then continue end

        local d = worldDist(hrp.Position)
        if d > CFG.MaxDist then continue end

        local predicted = getPredicted(p)
        if not predicted then continue end
        local sp, onScreen = toScreen(predicted)
        if not onScreen then continue end

        local screenDist = (sp - sc).Magnitude
        if screenDist > CFG.AimFOV then continue end

        local score = CFG.Priority == "LowestHP" and hum.Health or screenDist
        if score < bestScore then
            bestScore = score
            best = p
        end
    end
    return best
end

-------------------------------
-- AUTOSHOOT ENGINE
-------------------------------
local function tryAutoShoot(target)
    if not CFG.AutoShoot then return end
    if not target then return end
    local now = tick()
    if now - lastShootTime < CFG.AutoShootDelay then return end

    local predicted = getPredicted(target)
    if not predicted then return end
    local sp, onScreen = toScreen(predicted)
    if not onScreen then return end

    local sc = screenMid()
    local d  = (sp - sc).Magnitude
    if d > CFG.AutoShootFOV then return end

    -- Simulate tap/click at screen center (where aimbot already moved camera)
    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(
            math.floor(sc.X), math.floor(sc.Y),
            0, true, game, 0
        )
        task.delay(0.04, function()
            VirtualInputManager:SendMouseButtonEvent(
                math.floor(sc.X), math.floor(sc.Y),
                0, false, game, 0
            )
        end)
    end)
    lastShootTime = now
end

-------------------------------
-- AIMBOT ENGINE
-------------------------------
local function doAimbot(target)
    if not CFG.Aimbot or not target then return end
    if not aimbotHeld and not CFG.SilentAim then return end

    local predicted = getPredicted(target)
    if not predicted then return end

    local camCF  = Camera.CFrame
    local dir    = (predicted - camCF.Position).Unit
    local tgtCF  = CFrame.new(camCF.Position, camCF.Position + dir)
    Camera.CFrame = camCF:Lerp(tgtCF, CFG.Smooth)
end


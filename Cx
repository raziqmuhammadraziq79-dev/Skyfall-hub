RunService.RenderStepped:Connect(function()
    local sc = screenMid()

    -- Update circles
    if CFG.ShowFOVCircle then
        fovCircle.Position = sc
        fovCircle.Visible  = true
    else fovCircle.Visible = false end

    if CFG.ShowAimCircle then
        aimCircle.Position    = sc
        aimCircle.Radius      = CFG.AutoShootFOV
        aimCircle.Visible     = true
        aimFovCircle.Position = sc
        aimFovCircle.Radius   = CFG.AimFOV
        aimFovCircle.Visible  = true
    else
        aimCircle.Visible    = false
        aimFovCircle.Visible = false
    end

    -- Get target
    currentTarget = getBestTarget()

    -- Run aimbot
    doAimbot(currentTarget)

    -- AutoShoot
    if CFG.AutoShoot then
        tryAutoShoot(currentTarget)
    end

    -- ESP
    if CFG.ESP then updateESP() end
end)


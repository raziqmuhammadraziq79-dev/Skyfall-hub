    local function tog(lbl, key, onClr)
        local f=Instance.new("Frame")
        f.Size=UDim2.new(1,0,0,30) f.BackgroundTransparency=1 f.Parent=scroll
        local b=Instance.new("TextButton")
        b.Size=UDim2.new(1,0,1,0)
        b.BackgroundColor3=CFG[key] and (onClr or Color3.fromRGB(0,120,0)) or Color3.fromRGB(45,45,50)
        b.TextColor3=Color3.fromRGB(255,255,255)
        b.Font=Enum.Font.GothamBold b.TextSize=11
        b.Text=lbl.."  "..(CFG[key] and "● ON" or "○ OFF")
        b.Parent=f
        Instance.new("UICorner",b).CornerRadius=UDim.new(0,6)
        b.MouseButton1Click:Connect(function()
            CFG[key]=not CFG[key]
            b.Text=lbl.."  "..(CFG[key] and "● ON" or "○ OFF")
            b.BackgroundColor3=CFG[key] and (onClr or Color3.fromRGB(0,120,0)) or Color3.fromRGB(45,45,50)
        end)
    end

    local function sld(lbl, key, mn, mx, isFloat)
        local f=Instance.new("Frame")
        f.Size=UDim2.new(1,0,0,42)
        f.BackgroundColor3=Color3.fromRGB(18,18,22) f.Parent=scroll
        Instance.new("UICorner",f).CornerRadius=UDim.new(0,6)
        local lv=Instance.new("TextLabel")
        local function fmtVal(v) return isFloat and string.format("%.2f",v) or tostring(v) end
        lv.Text=lbl..": "..fmtVal(CFG[key])
        lv.Size=UDim2.new(1,-8,0,18) lv.Position=UDim2.new(0,8,0,2)
        lv.BackgroundTransparency=1
        lv.TextColor3=Color3.fromRGB(200,200,200)
        lv.Font=Enum.Font.Gotham lv.TextSize=10
        lv.TextXAlignment=Enum.TextXAlignment.Left lv.Parent=f
        local trk=Instance.new("Frame")
        trk.Size=UDim2.new(1,-16,0,6) trk.Position=UDim2.new(0,8,0,28)
        trk.BackgroundColor3=Color3.fromRGB(40,40,45) trk.Parent=f
        Instance.new("UICorner",trk).CornerRadius=UDim.new(1,0)
        local fill=Instance.new("Frame")
        fill.Size=UDim2.new((CFG[key]-mn)/(mx-mn),0,1,0)
        fill.BackgroundColor3=Color3.fromRGB(200,0,0) fill.Parent=trk
        Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)
        local sl=false
        trk.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sl=true end end)
        UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sl=false end end)
        UIS.InputChanged:Connect(function(i)
            if sl and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                local r=math.clamp((i.Position.X-trk.AbsolutePosition.X)/trk.AbsoluteSize.X,0,1)
                local v=isFloat and (mn+r*(mx-mn)) or math.floor(mn+r*(mx-mn))
                if isFloat then v=math.floor(v*100)/100 end
                CFG[key]=v fill.Size=UDim2.new(r,0,1,0) lv.Text=lbl..": "..fmtVal(v)
            end
        end)
    end

    local function cycleBtn(lbl, key, opts)
        local f=Instance.new("Frame")
        f.Size=UDim2.new(1,0,0,30) f.BackgroundTransparency=1 f.Parent=scroll
        local b=Instance.new("TextButton")
        b.Size=UDim2.new(1,0,1,0)
        b.BackgroundColor3=Color3.fromRGB(70,0,100)
        b.TextColor3=Color3.fromRGB(255,255,255)
        b.Font=Enum.Font.GothamBold b.TextSize=11
        b.Text=lbl..": "..CFG[key] b.Parent=f
        Instance.new("UICorner",b).CornerRadius=UDim.new(0,6)
        b.MouseButton1Click:Connect(function()
            local idx=table.find(opts,CFG[key]) or 1
            CFG[key]=opts[(idx%#opts)+1]
            b.Text=lbl..": "..CFG[key]
        end)
    end

    -- Build panel
    sec("  ── ESP ──")
    tog("ESP Master",     "ESP",           Color3.fromRGB(200,0,0))
    tog("Enemy ESP",      "ShowEnemy",     Color3.fromRGB(180,30,30))
    tog("Team ESP",       "ShowTeam",      Color3.fromRGB(0,130,50))
    tog("Box ESP",        "ShowBox",       Color3.fromRGB(50,50,180))
    tog("Tracers",        "ShowTracer",    Color3.fromRGB(180,60,0))
    tog("Health",         "ShowHealth",    Color3.fromRGB(0,150,60))
    tog("Distance",       "ShowDistance",  Color3.fromRGB(60,60,70))
    tog("Chams",          "ShowChams",     Color3.fromRGB(140,0,140))
    tog("Head Dot",       "ShowHeadDot",   Color3.fromRGB(200,40,40))
    tog("FOV Circle",     "ShowFOVCircle", Color3.fromRGB(60,60,70))
    tog("Aim Circles",    "ShowAimCircle", Color3.fromRGB(60,60,70))

    sec("  ── AIMBOT ──")
    tog("Aimbot",         "Aimbot",        Color3.fromRGB(200,0,0))
    tog("Silent Aim",     "SilentAim",     Color3.fromRGB(110,0,150))
    cycleBtn("Priority",  "Priority",      {"Nearest","LowestHP"})
    sld("Smooth",         "Smooth",        0.02, 0.5, true)
    sld("Aim FOV",        "AimFOV",        30,   500)
    sld("Predict",        "PredictStrength",0.0, 0.3, true)

    sec("  ── AUTOSHOOT ──")
    tog("Auto Shoot",     "AutoShoot",     Color3.fromRGB(200,0,0))
    sld("Shoot FOV",      "AutoShootFOV",  10,   200)
    sld("Shoot Delay",    "AutoShootDelay",0.02, 0.5, true)

    sec("  ── RANGE ──")
    sld("Max Distance",   "MaxDist",       100,  2000)

    -- Minimize
    local minimized=false
    minBtn.MouseButton1Click:Connect(function()
        minimized=not minimized
        scroll.Visible=not minimized
        main.Size=minimized and UDim2.new(0,240,0,36) or UDim2.new(0,240,0,580)
        minBtn.Text=minimized and "+" or "−"
    end)

    closeBtn.MouseButton1Click:Connect(function()
        CFG.ESP=false CFG.Aimbot=false CFG.AutoShoot=false
        fovCircle.Visible=false aimCircle.Visible=false aimFovCircle.Visible=false
        gui:Destroy()
    end)
end


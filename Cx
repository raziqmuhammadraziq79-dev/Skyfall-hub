-- Infinite Health + Anti-Troll
RunService.Heartbeat:Connect(function()
    local Char = LocalPlayer.Character
    if not Char then return end
    local Hum = Char:FindFirstChild("Humanoid")
    if not Hum then return end

    if Config.InfiniteHealth then
        if Hum.Health < Hum.MaxHealth then
            Hum.Health = Hum.MaxHealth
        end
    end

    if Config.AntiTroll then
        local Root = Char:FindFirstChild("HumanoidRootPart")
        if Root then
            if Root.AssemblyLinearVelocity.Magnitude > 150 then
                Root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            end
            -- Anti-void
            if Root.Position.Y < -50 then
                local spawnPoint = Workspace:FindFirstChild("SpawnLocation", true)
                if spawnPoint then
                    Root.CFrame = spawnPoint.CFrame + Vector3.new(0, 5, 0)
                end
            end
        end
    end

    if Config.Noclip then
        for _, part in pairs(Char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)


	while true do
		task.wait(2)
		if smoothActive then
			if gcinfo then gcinfo() end
			pcall(collectgarbage, "collect") -- Bersihkan RAM internal secara paksa
		end
		if networkOptimized then
			-- Optimasi network physics throttle untuk kurangi beban ping data
			settings().Physics.PhysicsEnvironmentalThrottle = Enum.EnviromentalPhysicsThrottle.Disabled
		else
			settings().Physics.PhysicsEnvironmentalThrottle = Enum.EnviromentalPhysicsThrottle.Default
		end
	end
end)


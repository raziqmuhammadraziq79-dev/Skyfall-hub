-- Engine Optimization Functions
local function applyRtxGraphics()
	PanelState.GraphicsMaximized = true
	StatusLabel.Text = "Status: Maximizing Client Lighting..."
	
	-- Global Lighting Tweaks for High Fidelity
	lightingService.GlobalShadows = true
	lightingService.Technology = Enum.Technology.Future
	
	if lightingService:FindFirstChildOfClass("BloomEffect") then
		lightingService:FindFirstChildOfClass("BloomEffect").Intensity = 1.5
	end
	
	StatusLabel.Text = "Status: Ultra RTX Graphics Configured!"
	OptBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 70)
end

local function unlockFpsEngine()
	StatusLabel.Text = "Status: Adjusting Frame Throttling..."
	
	-- Engine performance environment loop tweak
	if setfpscap then
		setfpscap(PanelState.FPSTarget)
		StatusLabel.Text = "Status: FPS Uncapped to " .. tostring(PanelState.FPSTarget) .. "Hz!"
	else
		StatusLabel.Text = "Status: Active (Environment doesn't support setfpscap)"
	end
	FpsBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 70)
end


-- ============================================================
local curTab = nil

local function switchTab(key)
    curTab = key
    for k, page in pairs(Pages) do
        page.Visible = (k == key)
    end
    for k, b in pairs(TabBtns) do
        if k == key then
            TweenService:Create(b, TweenInfo.new(0.13), {BackgroundColor3=T.Accent}):Play()
            b.TextColor3 = T.White
        else
            TweenService:Create(b, TweenInfo.new(0.13), {BackgroundColor3=T.BG3}):Play()
            b.TextColor3 = T.TextDim
        end
    end
end

for k, b in pairs(TabBtns) do
    local key = k
    b.MouseButton1Click:Connect(function() switchTab(key) end)
    b.TouchTap:Connect(function() switchTab(key) end)
end


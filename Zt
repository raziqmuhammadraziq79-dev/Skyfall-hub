-- AIMBOT
RunService.RenderStepped:Connect(function()
    if not S.AimbotHead then return end
    local best, bd = nil, math.huge
    for _, p in pairs(allPlayers(false)) do
        local char = p.Character
        local head = char and char:FindFirstChild("Head")
        if head then
            local sp, vis = Camera:WorldToViewportPoint(head.Position)
            if vis then
                local dist = (Vector2.new(sp.X, sp.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if dist < bd then bd = dist; best = head end
            end
        end
    end
    if best then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, best.Position)
    end
end)

-- ESP
local ESPPool = {}
local function clearESP()
    for _, b in pairs(ESPPool) do pcall(function() b:Destroy() end) end
    ESPPool = {}
end
local function buildESP()
    clearESP()
    if not S.ESP then return end
    for _, p in pairs(allPlayers(false)) do
        if p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local bb = Instance.new("BillboardGui", root)
                bb.Size         = UDim2.new(0, 90, 0, 50)
                bb.AlwaysOnTop  = true
                bb.MaxDistance  = S.ESPDistance
                bb.StudsOffset  = Vector3.new(0, 3, 0)

                local nameLbl = Instance.new("TextLabel", bb)
                nameLbl.Size              = UDim2.new(1,0,0.55,0)
                nameLbl.BackgroundTransparency = 1
                nameLbl.Text              = "⬡ " .. p.Name
                nameLbl.TextColor3        = T.Accent
                nameLbl.Font              = Enum.Font.GothamBold
                nameLbl.TextScaled        = true

                local hpLbl = Instance.new("TextLabel", bb)
                hpLbl.Size                = UDim2.new(1,0,0.45,0)
                hpLbl.Position            = UDim2.new(0,0,0.55,0)
                hpLbl.BackgroundTransparency = 1
                hpLbl.Font                = Enum.Font.Gotham
                hpLbl.TextScaled          = true

                RunService.Heartbeat:Connect(function()
                    if p.Character and p.Character:FindFirstChild("Humanoid") then
                        local hp = math.floor(p.Character.Humanoid.Health)
                        local mhp= p.Character.Humanoid.MaxHealth
                        local pct= hp/mhp
                        hpLbl.Text       = "HP " .. hp .. "/" .. math.floor(mhp)
                        hpLbl.TextColor3 = Color3.new(1-pct, pct, 0)
                    end
                end)

                table.insert(ESPPool, bb)
            end
        end
    end
end


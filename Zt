local function slider(parent, label, mn, mx, def, cb)
    local c = Instance.new("Frame", parent)
    c.Size                     = UDim2.new(1, 0, 0, 64)
    c.BackgroundColor3         = T.BG3
    c.BorderSizePixel          = 0
    Instance.new("UICorner", c).CornerRadius = UDim.new(0, 9)

    local lbl = Instance.new("TextLabel", c)
    lbl.Size                   = UDim2.new(0.7, 0, 0, 28)
    lbl.Position               = UDim2.new(0, 12, 0, 4)
    lbl.BackgroundTransparency = 1
    lbl.Text                   = label
    lbl.TextColor3             = T.Text
    lbl.Font                   = Enum.Font.Gotham
    lbl.TextScaled             = true
    lbl.TextXAlignment         = Enum.TextXAlignment.Left

    local val = Instance.new("TextLabel", c)
    val.Size                   = UDim2.new(0.26, 0, 0, 28)
    val.Position               = UDim2.new(0.73, 0, 0, 4)
    val.BackgroundTransparency = 1
    val.Text                   = tostring(def)
    val.TextColor3             = T.Accent
    val.Font                   = Enum.Font.GothamBold
    val.TextScaled             = true
    val.TextXAlignment         = Enum.TextXAlignment.Right

    local track = Instance.new("Frame", c)
    track.Size                 = UDim2.new(1, -24, 0, 6)
    track.Position             = UDim2.new(0, 12, 0, 46)
    track.BackgroundColor3     = Color3.fromRGB(26, 32, 58)
    track.BorderSizePixel      = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)

    local fill = Instance.new("Frame", track)
    fill.Size                  = UDim2.new((def-mn)/(mx-mn), 0, 1, 0)
    fill.BackgroundColor3      = T.Accent
    fill.BorderSizePixel       = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)

    local knob = Instance.new("Frame", track)
    knob.Size                  = UDim2.new(0, 16, 0, 16)
    knob.Position              = UDim2.new((def-mn)/(mx-mn), -8, 0.5, -8)
    knob.BackgroundColor3      = T.White
    knob.BorderSizePixel       = 0
    knob.ZIndex                = 4
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

    local drag = false
    track.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch
        or i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch
        or i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if drag then
            local ratio = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            local v = math.floor(mn + ratio*(mx-mn))
            fill.Size = UDim2.new(ratio, 0, 1, 0)
            knob.Position = UDim2.new(ratio, -8, 0.5, -8)
            val.Text = tostring(v)
            if cb then cb(v) end
        end
    end)
    return c
end


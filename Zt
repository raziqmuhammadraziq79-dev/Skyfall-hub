-- TOGGLE
local function toggle(parent, label, stateKey, cb)
    local row = Instance.new("Frame", parent)
    row.Size                   = UDim2.new(1, 0, 0, 46)
    row.BackgroundColor3       = T.BG3
    row.BorderSizePixel        = 0
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 9)

    local lbl = Instance.new("TextLabel", row)
    lbl.Size                   = UDim2.new(0.72, 0, 1, 0)
    lbl.Position               = UDim2.new(0, 12, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text                   = label
    lbl.TextColor3             = T.Text
    lbl.Font                   = Enum.Font.Gotham
    lbl.TextScaled             = true
    lbl.TextXAlignment         = Enum.TextXAlignment.Left

    local track = Instance.new("Frame", row)
    track.Size                 = UDim2.new(0, 50, 0, 27)
    track.Position             = UDim2.new(1, -60, 0.5, -13)
    track.BackgroundColor3     = Color3.fromRGB(28, 33, 58)
    track.BorderSizePixel      = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame", track)
    knob.Size                  = UDim2.new(0, 21, 0, 21)
    knob.Position              = UDim2.new(0, 3, 0.5, -10)
    knob.BackgroundColor3      = T.TextDim
    knob.BorderSizePixel       = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local function refresh(v)
        local goal = v and UDim2.new(0, 26, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)
        TweenService:Create(knob, TweenInfo.new(0.14), {
            Position         = goal,
            BackgroundColor3 = v and T.White or T.TextDim
        }):Play()
        TweenService:Create(track, TweenInfo.new(0.14), {
            BackgroundColor3 = v and T.Accent or Color3.fromRGB(28, 33, 58)
        }):Play()
    end
    refresh(S[stateKey] or false)

    local function tap()
        S[stateKey] = not S[stateKey]
        refresh(S[stateKey])
        if cb then cb(S[stateKey]) end
    end

    row.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch
        or i.UserInputType == Enum.UserInputType.MouseButton1 then tap() end
    end)
    return row
end

-- BUTTON
local function btn(parent, label, cb)
    local b = Instance.new("TextButton", parent)
    b.Size                     = UDim2.new(1, 0, 0, 44)
    b.BackgroundColor3         = T.AccentDim
    b.Text                     = label
    b.TextColor3               = T.Text
    b.Font                     = Enum.Font.GothamBold
    b.TextScaled               = true
    b.BorderSizePixel          = 0
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 9)
    local stroke = Instance.new("UIStroke", b)
    stroke.Color               = T.Accent
    stroke.Thickness           = 1

    local function fire()
        TweenService:Create(b, TweenInfo.new(0.08), {BackgroundColor3=T.Accent}):Play()
        task.delay(0.18, function()
            TweenService:Create(b, TweenInfo.new(0.08), {BackgroundColor3=T.AccentDim}):Play()
        end)
        if cb then cb() end
    end
    b.MouseButton1Click:Connect(fire)
    b.TouchTap:Connect(fire)
    return b
end


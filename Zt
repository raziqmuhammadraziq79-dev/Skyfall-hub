-- SERVER: CHAOS TELEPORT
local function chaosTeleport()
    for _, p in pairs(allPlayers(false)) do
        local root = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = CFrame.new(math.random(-600,600), 80, math.random(-600,600))
        end
    end
end

-- SERVER: BRING ALL
local function bringAll()
    local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    local base = myRoot.CFrame
    for i, p in pairs(allPlayers(false)) do
        local root = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = base + Vector3.new(i*4, 0, 0)
        end
    end
end

-- SERVER: LAUNCH ALL
local function launchAll(force)
    for _, p in pairs(allPlayers(false)) do
        local root = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
        if root then
            root.AssemblyLinearVelocity = Vector3.new(
                math.random(-force, force),
                force * 1.5,
                math.random(-force, force)
            )
        end
    end
end

-- SERVER: EXPLODE ALL
local function explodeAll()
    for _, p in pairs(allPlayers(false)) do
        local root = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local e = Instance.new("Explosion", workspace)
            e.Position      = root.Position
            e.BlastRadius   = 10
            e.BlastPressure = 1e6
        end
    end
end


    S.InvisAll = v
    for _, p in pairs(allPlayers(false)) do
        if p.Character then
            for _, part in pairs(p.Character:GetDescendants()) do
                if part:IsA("BasePart") then part.Transparency = v and 1 or 0 end
                if part:IsA("Decal")    then part.Transparency = v and 1 or 0 end

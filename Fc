-- ══════════════════════════════════════════
--   MAIN RENDER LOOP
-- ══════════════════════════════════════════
local renderConn
renderConn = RunService.RenderStepped:Connect(function()
    local vp = Camera.ViewportSize
    local cx = vp.X/2
    local cy = vp.Y/2

    updateAntiDetect()

    -- HUD
    fovCircle.Position = Vector2.new(cx,cy)
    fovCircle.Visible  = CFG.FOVCircle and CFG.Aimbot
    local cLen = 10
    chH.From=Vector2.new(cx-cLen,cy) ; chH.To=Vector2.new(cx+cLen,cy) ; chH.Visible=CFG.Crosshair
    chV.From=Vector2.new(cx,cy-cLen) ; chV.To=Vector2.new(cx,cy+cLen) ; chV.Visible=CFG.Crosshair
    chDot.Position=Vector2.new(cx,cy) ; chDot.Visible=CFG.Crosshair

    -- misc
    if CFG.NoRecoil  then applyNoRecoil() end
    if CFG.SpeedHack then applySpeed()    end
    if CFG.BunnyHop  then doBhop()        end
    tryReload(LP.Character)

    -- ── ESP ──
    local active = {}

    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP or not isAlive(p) then goto cont end
        local rel    = getRelation(p)
        local uid    = p.UserId
        active[uid]  = true
        if not ESPCache[uid] then buildCache(uid) end
        local e      = ESPCache[uid]
        local bounds = getBounds(p.Character)
        local locked = (LockedTarget == p)
        local hum    = p.Character:FindFirstChildOfClass("Humanoid")

        -- Chams logic
        if CFG.Chams then
            if rel == "enemy" then
                applyChams(p, CFG.ChamsEnemy)
            elseif rel == "team" then
                applyChams(p, CFG.ChamsTeam)
            end
        else
            removeChams(p)
        end

        if not bounds or not CFG.ESP then
            hideCache(uid)
            goto cont
        end

        -- ── Tracer (presisi mode) ──
        local showTracer = false
        local tracerCol  = CFG.EnemyTracer
        if CFG.TracerMode == "enemy" then
            showTracer = (rel == "enemy")
            tracerCol  = CFG.EnemyTracer
        elseif CFG.TracerMode == "team" then
            showTracer = (rel == "team")
            tracerCol  = CFG.TeamTracer
        elseif CFG.TracerMode == "all" then
            showTracer = true
            tracerCol  = rel=="enemy" and CFG.EnemyTracer or CFG.TeamTracer
        end

        local tracerFrom = CFG.SnapLine
            and Vector2.new(cx, cy)
            or  Vector2.new(cx, vp.Y)
        e.tracer.From    = tracerFrom
        e.tracer.To      = bounds.botPos
        e.tracer.Color   = tracerCol
        e.tracer.Visible = showTracer

        -- ── Box color ──
        local bc = locked and CFG.LockedColor
            or (rel=="enemy" and CFG.EnemyBox or CFG.TeamBox)
        drawBox(e.c, bounds, bc)

        -- ── Dot ──
        if CFG.HeadDot then
            e.dot.Position = bounds.headPos
            e.dot.Color    = locked and CFG.LockedColor or (rel=="enemy" and CFG.EnemyDot or CFG.TeamBox)
            e.dot.Radius   = locked and 8 or 5
            e.dot.Visible  = true
        else
            e.dot.Visible = false
        end

        -- ── Lock ring ──
        e.ring.Position = bounds.headPos
        e.ring.Visible  = locked and rel=="enemy"

        -- ── Name ──
        local prefix = rel=="enemy" and (locked and "🔒 " or "💀 ") or "👥 "
        e.name.Text     = prefix .. p.DisplayName
        e.name.Position = Vector2.new(bounds.headPos.X, bounds.headPos.Y - 20)
        e.name.Color    = rel=="enemy" and Color3.new(1,1,1) or CFG.TeamBox
        e.name.Visible  = true

        -- ── Distance ──
        if CFG.DistanceESP then
            e.dist.Text     = getDist(p) .. "m"
            e.dist.Position = Vector2.new(bounds.headPos.X, bounds.botPos.Y + 4)
            e.dist.Visible  = true
        else
            e.dist.Visible = false
        end

        -- ── Health bar ──
        if CFG.HealthBar and hum then
            local ratio   = math.clamp(hum.Health/math.max(hum.MaxHealth,1), 0, 1)
            local barX    = bounds.BL.X - 6
            local topY    = bounds.TL.Y
            local botY    = bounds.BL.Y
            local fillBot = botY
            local fillTop = topY + (botY-topY)*(1-ratio)
            e.hpBg.From   = Vector2.new(barX,topY)
            e.hpBg.To     = Vector2.new(barX,botY)
            e.hpBg.Visible= true
            e.hpFill.From = Vector2.new(barX,fillTop)
            e.hpFill.To   = Vector2.new(barX,fillBot)
            e.hpFill.Color= Color3.fromRGB(
                math.floor(255*(1-ratio)),
                math.floor(255*ratio), 0)
            e.hpFill.Visible = true
        else
            e.hpBg.Visible   = false
            e.hpFill.Visible = false
        end

        ::cont::
    end

    -- cleanup
    for uid in pairs(ESPCache) do
        if not active[uid] then clearUID(uid) end
    end

    -- ── AIMBOT ──
    if CFG.Aimbot then
        local target = getNearest()
        if target then
            LockedTarget = target
            IsLocked     = true
            local head   = target.Character and target.Character:FindFirstChild(CFG.AimPart)
            if head then
                local aimPos = CFG.Prediction and getPredicted(target) or head.Position
                if aimPos then
                    -- apply anti-detect jitter offset
                    local jPos = aimPos + Vector3.new(JitterOffset.X, JitterOffset.Y, 0)
                    local tCF  = CFrame.new(Camera.CFrame.Position, CFG.AntiDetect and jPos or aimPos)
                    Camera.CFrame = Camera.CFrame:Lerp(tCF, 1 - CFG.Smooth)
                end
            end
            if CFG.AutoShoot then fireWeapon(target) end
        else
            LockedTarget = nil
            IsLocked     = false
        end
    end
end)


-- ══════════════════════════════════════════
--   TEAM / ENEMY CHECK (PRESISI)
--   Priority: Team service → neutral tag → FFA
-- ══════════════════════════════════════════
local function getRelation(p)
    if p == LP then return "self" end
    -- Method 1: Roblox Teams
    if LP.Team ~= nil and p.Team ~= nil then
        return LP.Team == p.Team and "team" or "enemy"
    end
    -- Method 2: Team value inside character
    local lpChar = LP.Character
    local pChar  = p.Character
    if lpChar and pChar then
        local lpTeam = lpChar:FindFirstChild("Team") or lpChar:FindFirstChild("TeamColor")
        local pTeam  = pChar:FindFirstChild("Team")  or pChar:FindFirstChild("TeamColor")
        if lpTeam and pTeam then
            return lpTeam.Value == pTeam.Value and "team" or "enemy"
        end
    end
    -- Method 3: Humanoid team color
    local lpHum = lpChar and lpChar:FindFirstChildOfClass("Humanoid")
    local pHum  = pChar  and pChar:FindFirstChildOfClass("Humanoid")
    if lpHum and pHum then
        if lpHum:FindFirstChild("TeamColor") and pHum:FindFirstChild("TeamColor") then
            return lpHum.TeamColor == pHum.TeamColor and "team" or "enemy"
        end
    end
    -- Fallback: FFA — all enemy
    return "enemy"
end

local function isAlive(p)
    local c = p.Character
    if not c then return false end
    local h = c:FindFirstChildOfClass("Humanoid")
    local r = c:FindFirstChild("HumanoidRootPart")
    return h and h.Health > 0 and r ~= nil
end

-- ══════════════════════════════════════════
--   VELOCITY PREDICTION
-- ══════════════════════════════════════════
local function getPredicted(p)
    local c   = p.Character ; if not c then return nil end
    local hrp = c:FindFirstChild("HumanoidRootPart") ; if not hrp then return nil end
    local uid = p.UserId
    local cur = hrp.Position
    if PrevPos[uid] then
        local vel  = (cur - PrevPos[uid]) / 0.016
        PrevPos[uid] = cur
        return cur + vel * CFG.PredFactor
    end
    PrevPos[uid] = cur
    return cur
end

-- ══════════════════════════════════════════
--   SCREEN BOUNDS
-- ══════════════════════════════════════════
local function getBounds(char)
    local hrp  = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not hrp or not head then return nil end
    local rS, rV = Camera:WorldToViewportPoint(hrp.Position)
    local hS, _  = Camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.75,0))
    local fS, _  = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0,3.0,0))
    if not rV or rS.Z <= 0 then return nil end
    local ht = math.abs(hS.Y - fS.Y)
    if ht < 5 then return nil end
    local wd = ht * 0.55
    local cx = rS.X
    return {
        headPos = Vector2.new(hS.X, hS.Y),
        botPos  = Vector2.new(cx,   fS.Y),
        TL = Vector2.new(cx-wd/2, hS.Y),
        TR = Vector2.new(cx+wd/2, hS.Y),
        BL = Vector2.new(cx-wd/2, fS.Y),
        BR = Vector2.new(cx+wd/2, fS.Y),
        height = ht,
        width  = wd,
        depth  = rS.Z,
    }
end

local function getDist(p)
    local c    = p.Character ; if not c then return 0 end
    local hrp  = c:FindFirstChild("HumanoidRootPart")
    local lhrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp or not lhrp then return 0 end
    return math.floor((hrp.Position - lhrp.Position).Magnitude)
end


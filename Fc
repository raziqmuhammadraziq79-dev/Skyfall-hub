-- ══════════════════════════════════════════
local function D(t, props)
    local d = Drawing.new(t)
    for k,v in pairs(props) do d[k]=v end
    return d
end

local function clearUID(uid)
    if ESPCache[uid] then
        for _,d in pairs(ESPCache[uid]) do pcall(function() d:Remove() end) end
        ESPCache[uid] = nil
    end
end

local function buildCache(uid)
    ESPCache[uid] = {
        -- Tracer
        tracer  = D("Line",   {Thickness=2,   Color=CFG.EnemyTracer, Transparency=1, Visible=false}),
        -- Corner box (8 lines = 4 corners x 2)
        c={},
        -- Head dot
        dot     = D("Circle", {Radius=5, Color=CFG.EnemyDot, Filled=true, Thickness=1, Transparency=1, Visible=false}),
        -- Lock ring
        ring    = D("Circle", {Radius=22, Color=CFG.LockedColor, Filled=false, Thickness=2, Transparency=1, Visible=false}),
        -- HP bar bg + fill
        hpBg    = D("Line",   {Thickness=4, Color=Color3.fromRGB(50,0,0),   Transparency=1, Visible=false}),
        hpFill  = D("Line",   {Thickness=4, Color=Color3.fromRGB(0,255,80), Transparency=1, Visible=false}),
        -- Labels
        name    = D("Text",   {Size=13, Color=Color3.new(1,1,1), Outline=true, OutlineColor=Color3.new(0,0,0), Center=true, Visible=false}),
        dist    = D("Text",   {Size=11, Color=Color3.fromRGB(255,220,0), Outline=true, OutlineColor=Color3.new(0,0,0), Center=true, Visible=false}),
    }
    -- Build 8 corner lines
    for i=1,8 do
        ESPCache[uid].c[i] = D("Line", {Thickness=2.5, Color=CFG.EnemyBox, Transparency=1, Visible=false})
    end
end

local function hideCache(uid)
    if not ESPCache[uid] then return end
    local e = ESPCache[uid]
    for _,d in pairs(e) do pcall(function() if type(d)~="table" then d.Visible=false end end) end
    for _,ln in ipairs(e.c) do ln.Visible=false end
end

-- ══════════════════════════════════════════
--   CORNER BOX
-- ══════════════════════════════════════════
local function drawBox(c, b, color)
    local L = math.min(b.width, b.height) * 0.26
    local corners = {
        {b.TL, Vector2.new(b.TL.X+L, b.TL.Y), Vector2.new(b.TL.X, b.TL.Y+L)},
        {b.TR, Vector2.new(b.TR.X-L, b.TR.Y), Vector2.new(b.TR.X, b.TR.Y+L)},
        {b.BL, Vector2.new(b.BL.X+L, b.BL.Y), Vector2.new(b.BL.X, b.BL.Y-L)},
        {b.BR, Vector2.new(b.BR.X-L, b.BR.Y), Vector2.new(b.BR.X, b.BR.Y-L)},
    }
    local idx = 1
    for _, corner in ipairs(corners) do
        c[idx].From=corner[1] ; c[idx].To=corner[2] ; c[idx].Color=color ; c[idx].Visible=true ; idx=idx+1
        c[idx].From=corner[1] ; c[idx].To=corner[3] ; c[idx].Color=color ; c[idx].Visible=true ; idx=idx+1
    end
end

local function hideBox(c)
    for _,ln in ipairs(c) do ln.Visible=false end
end

-- ══════════════════════════════════════════
--   CHAMS
-- ══════════════════════════════════════════
local function applyChams(p, color)
    if ChamsCache[p.UserId] then return end
    local char = p.Character ; if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            pcall(function()
                local s = Instance.new("SelectionBox")
                s.Color3              = color
                s.LineThickness       = 0.03
                s.SurfaceTransparency = 0.65
                s.SurfaceColor3       = color
                s.Adornee             = part
                s.Parent              = part
            end)
        end
    end
    ChamsCache[p.UserId] = true
end

local function removeChams(p)
    if not ChamsCache[p.UserId] then return end
    local char = p.Character ; if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        for _, v in ipairs(part:GetChildren()) do
            if v:IsA("SelectionBox") then v:Destroy() end
        end
    end
    ChamsCache[p.UserId] = nil
end

-- ══════════════════════════════════════════
--   NEAREST ENEMY
-- ══════════════════════════════════════════
local function getNearest()
    local cx  = Camera.ViewportSize.X/2
    local cy  = Camera.ViewportSize.Y/2
    local best, bDist = nil, CFG.FOV * CFG.FOV
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and isAlive(p) and getRelation(p) == "enemy" then
            local head = p.Character:FindFirstChild(CFG.AimPart)
            if head then
                local aimPos = CFG.Prediction and getPredicted(p) or head.Position
                if aimPos then
                    local sp, vis = Camera:WorldToViewportPoint(aimPos)
                    if vis and sp.Z > 0 then
                        local dx = sp.X - cx
                        local dy = sp.Y - cy
                        local d2 = dx*dx + dy*dy
                        if d2 < bDist then
                            bDist = d2
                            best  = p
                        end
                    end
                end
            end
        end
    end
    return best
end

-- ══════════════════════════════════════════
--   FIRE WEAPON (multi-arg FPS support)
-- ══════════════════════════════════════════
local LastShot = 0
local function fireWeapon(target)
    local now = tick()
    if now - LastShot < ShootCooldown then return end
    LastShot = now
    local char = LP.Character ; if not char then return end
    local head = target and target.Character and target.Character:FindFirstChild("Head")
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            pcall(function() tool:Activate() end)
            for _, v in ipairs(tool:GetDescendants()) do
                if v:IsA("RemoteEvent") then
                    pcall(function()
                        if head then
                            v:FireServer(head.Position, head.Position, head, true)
                            v:FireServer(head.Position)
                        end
                        v:FireServer()
                    end)
                end
                if v:IsA("BindableEvent") then
                    pcall(function() v:Fire() end)
                end
            end
        end
    end
end

-- ══════════════════════════════════════════
--   INFINITE AMMO
-- ══════════════════════════════════════════
local function patchAmmo(char)
    if not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            for _, v in ipairs(tool:GetDescendants()) do
                if (v:IsA("IntValue") or v:IsA("NumberValue")) then
                    local n = v.Name:lower()
                    if n:find("ammo") or n:find("bullet") or n:find("clip") or n:find("mag") or n:find("round") then
                        pcall(function()
                            v.Value = 999999
                            v.Changed:Connect(function()
                                if CFG.InfAmmo then v.Value = 999999 end
                            end)
                        end)
                    end
                end
            end
        end
    end
end

-- ══════════════════════════════════════════
--   AUTO RELOAD
-- ══════════════════════════════════════════
local function tryReload(char)
    if not CFG.AutoReload or not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            for _, v in ipairs(tool:GetDescendants()) do
                if (v:IsA("IntValue") or v:IsA("NumberValue")) then
                    local n = v.Name:lower()
                    if (n:find("ammo") or n:find("bullet")) and v.Value <= 1 then
                        for _, re in ipairs(tool:GetDescendants()) do
                            if re:IsA("RemoteEvent") and re.Name:lower():find("reload") then
                                pcall(function() re:FireServer() end)
                            end
                        end
                    end
                end
            end
        end
    end
end

-- ══════════════════════════════════════════
--   NO RECOIL / SPEED / HOP
-- ══════════════════════════════════════════
local function applyNoRecoil()
    local c = LP.Character ; if not c then return end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if hrp then pcall(function() hrp.RotVelocity = Vector3.zero end) end
end

local function applySpeed()
    local c = LP.Character ; if not c then return end
    local h = c:FindFirstChildOfClass("Humanoid")
    if h and CFG.SpeedHack then h.WalkSpeed = 32 end
end

local function doBhop()
    local c = LP.Character ; if not c then return end
    local h = c:FindFirstChildOfClass("Humanoid")
    local r = c:FindFirstChild("HumanoidRootPart")
    if h and r and h.FloorMaterial ~= Enum.Material.Air then
        r.Velocity = Vector3.new(r.Velocity.X, 50, r.Velocity.Z)
    end
end

-- ══════════════════════════════════════════
--   CHAR HOOK
-- ══════════════════════════════════════════
local function hookChar(char)
    patchAmmo(char)
    applySpeed()
    char.ChildAdded:Connect(function(c)
        task.wait(0.05)
        if c:IsA("Tool") then patchAmmo(char) end
    end)
end
if LP.Character then hookChar(LP.Character) end

-- ══════════════════════════════════════════
--   ANTI-DETECT ENGINE
--   - randomize camera micro-jitter
--   - spoof timing to avoid pattern detection
--   - silent: never fire same frame as camera move
-- ══════════════════════════════════════════
local ShootCooldown  = 0
local JitterOffset   = Vector2.new(0,0)
local function updateAntiDetect()
    if not CFG.AntiDetect then return end
    -- micro random jitter on aim (makes it look human)
    JitterOffset = Vector2.new(
        math.random(-2,2) * 0.01,
        math.random(-2,2) * 0.01
    )
    -- randomize shoot timing slightly
    ShootCooldown = math.random(1,3) * 0.016
end


    local btn = Instance.new("TextButton")
    btn.Size             = UDim2.new(0,62,0,26)
    btn.Position         = UDim2.new(1,-68,0.5,-13)
    btn.BackgroundColor3 = CFG[setting] and Color3.fromRGB(0,185,0) or Color3.fromRGB(185,0,0)

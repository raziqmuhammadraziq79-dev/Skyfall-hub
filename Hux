-- MODE 1: ANTI-TROLL SHIELD (1 Tombol = Full Protection)
-- ============================================================================
CreateMasterMode(
    "ANTI-TROLL SHIELD",
    "Anti-Fling + Anti-Kill + Anti-Kick + Anti-TP",
    Color3.fromRGB(0, 200, 100),
    function(state)
        getgenv().TenWeak_AntiTroll = state
        
        if state then
            -- Anti-Fling: Physics Lock (karakter tetap bisa jalan normal)
            local char = LocalPlayer.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp and not hrp:FindFirstChild("TenWeak_AntiFling") then
                    local bp = Instance.new("BodyPosition")
                    bp.Name = "TenWeak_AntiFling"
                    bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                    bp.D = 2000
                    bp.P = 5000
                    bp.Position = hrp.Position
                    bp.Parent = hrp
                    
                    -- Update posisi saat character bergerak
                    task.spawn(function()
                        while getgenv().TenWeak_AntiTroll and bp.Parent do
                            bp.Position = hrp.Position
                            task.wait(0.1)
                        end
                    end)
                end
                
                -- Anti-Kill: God Mode
                local hum = char:FindFirstChild("Humanoid")
                if hum then
                    task.spawn(function()
                        while getgenv().TenWeak_AntiTroll do
                            pcall(function()
                                hum.Health = math.huge
                                hum.MaxHealth = math.huge
                            end)
                            task.wait(0.1)
                        end
                    end)
                end
            end
            
            -- Anti-Kick: Metatable Hook
            if not getgenv().TenWeak_AntiKickHook then
                getgenv().TenWeak_AntiKickHook = true
                local OldNamecall
                OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
                    local method = getnamecallmethod()
                    if getgenv().TenWeak_AntiTroll and method == "Kick" and self == LocalPlayer then
                        return nil
                    end
                    return OldNamecall(self, ...)
                end)
            end
            
            print("[MASTER MODE] ANTI-TROLL SHIELD ACTIVE")
        else
            -- Cleanup
            local char = LocalPlayer.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local af = hrp:FindFirstChild("TenWeak_AntiFling")
                    if af then af:Destroy() end
                end
                local hum = char:FindFirstChild("Humanoid")
                if hum then
                    hum.Health = 100
                    hum.MaxHealth = 100
                end
            end
            print("[MASTER MODE] ANTI-TROLL SHIELD DEACTIVATED")
        end
    end
)


Toggle(PgFPS, "FPS BOOST (MAX PERFORMANCE)", function(S)
    MODES.FPSBoost = S
    if S then
        -- Disable all particles (cached, not every frame)
        local particles = {}
        for _, p in ipairs(Workspace:GetDescendants()) do
            if p:IsA("ParticleEmitter") or p:IsA("Sparkles") or p:IsA("Smoke") or p:IsA("Fire") then
                p.Enabled = false
                table.insert(particles, p)
            end
        end
        -- Terrain optimization
        pcall(function() Workspace.Terrain.DetailLevel = 1 end)
        Workspace.Terrain.WaterWaveSize = 0
        Workspace.Terrain.WaterWaveSpeed = 0
        Workspace.Terrain.WaterReflectance = 0
        -- Disable post-processing
        for _, e in ipairs(Lighting:GetChildren()) do
            if e:IsA("PostProcessEffect") or e:IsA("DepthOfFieldEffect") or e:IsA("BlurEffect") or e:IsA("SunRaysEffect") then
                e.Enabled = false
            end
        end
        -- Lighting optimization
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 10000
        Lighting.Brightness = 1.5
        Log("FPS BOOST ON: Particles off, terrain low, shadows off")
    else
        -- Restore
        for _, p in ipairs(Workspace:GetDescendants()) do
            if p:IsA("ParticleEmitter") then p.Enabled = true end
        end
        pcall(function() Workspace.Terrain.DetailLevel = 3 end)
        Workspace.Terrain.WaterWaveSize = 20
        Workspace.Terrain.WaterWaveSpeed = 20
        Workspace.Terrain.WaterReflectance = 0.3
        Lighting.GlobalShadows = true
        Lighting.FogEnd = 1000
        for _, e in ipairs(Lighting:GetChildren()) do
            if e:IsA("PostProcessEffect") or e:IsA("DepthOfFieldEffect") then e.Enabled = true end
        end
        Log("FPS BOOST OFF: Restored")
    end
end)

Toggle(PgFPS, "Anti-Lag System (Auto-Optimize)", function(S)
    MODES.AntiLag = S
    if S then
        SafeBind("AntiLag", Enum.RenderPriority.Character.Value - 1, function()
            -- Only run every 60 frames (1 second at 60fps)
            if tick() % 1 < 0.016 then
                -- Auto-disable heavy effects
                for _, p in ipairs(Workspace:GetDescendants()) do
                    if p:IsA("ParticleEmitter") and p.Enabled then
                        local dist = (p.Parent.Position - RootPart.Position).Magnitude
                        if dist > 100 then p.Enabled = false end
                    end
                end
            end
        end)
        Log("Anti-Lag ON: Auto-optimizing")
    else
        SafeUnbind("AntiLag")
    end
end)


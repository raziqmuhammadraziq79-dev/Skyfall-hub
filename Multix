local function GetNearestPlayer()
    local nearest = nil; local minDist = math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (p.Character.HumanoidRootPart.Position - RootPart.Position).Magnitude
            if dist < minDist then minDist = dist; nearest = p end
        end
    end
    return nearest, minDist
end

local function GetKillerModel()
    -- Check players first (faster)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Team then

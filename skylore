                    SelectedPlr=p
                    for _,b in ipairs(List:GetChildren()) do if b:IsA("TextButton") then b.BackgroundColor3=Color3.fromRGB(32,32,32) end end
                    B.BackgroundColor3=CFG.Accent
                end)
            end
        end
    end
    Refresh()
    Players.PlayerAdded:Connect(Refresh)
    Players.PlayerRemoving:Connect(Refresh)
end


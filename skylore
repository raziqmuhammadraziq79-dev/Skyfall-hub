        ScrollBarThickness=2, Parent=Box
    })
    New("UIListLayout", {Padding=UDim.new(0,2), Parent=List})
    
    local function Refresh()
        for _,c in ipairs(List:GetChildren()) do if c:IsA("GuiObject") then c:Destroy() end end
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=LocalPlayer then
                local B = New("TextButton", {
                    Size=UDim2.new(1,0,0,18), BackgroundColor3=Color3.fromRGB(32,32,32),
                    Text=p.Name, TextColor3=CFG.Text, TextSize=8, Font=Enum.Font.GothamMedium, Parent=List

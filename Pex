-- UTILS
local function safe(func, ...)
    if type(func) ~= "function" then return false end
    local ok, res = pcall(func, ...)
    if not ok then warn("[SKYFALL] Error: " .. tostring(res)) end
    return ok, res
end

local function log(msg)
    print("[SKYFALL v" .. SKYFALL.VERSION .. "] " .. msg)
end

local function dist(p1, p2)
    if not p1 or not p2 then return 0 end
    return (p1 - p2).Magnitude
end

local function conn(event, cb)
    if not event or type(cb) ~= "function" then return nil end
    local c = event:Connect(cb)
    if c then table.insert(CONNECTIONS, c) end
    return c
end

-- ANTI-DETECT INIT
local function initAntiDetect()
    if not STATE.antiDetect then return end
    
    local ok1 = pcall(function()
        local LocalPlayer_orig = LocalPlayer.Kick
        LocalPlayer.Kick = function() end
    end)
    
    local ok2 = pcall(function()
        local function scanRemotes(parent, depth)
            if depth > 5 then return end
            if not parent then return end
            
            for _, obj in pairs(parent:GetChildren()) do
                if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                    local name = obj.Name:lower()
                    if name:find("ban") or name:find("kick") or name:find("report") then
                        pcall(function()
                            obj:Destroy()
                        end)
                    end
                end
                scanRemotes(obj, depth + 1)
            end
        end
        
        scanRemotes(game, 0)
    end)
    
    log("Anti-detect initialized")
end

-- FEATURES
local FEATURES = {}

function FEATURES:godMode(state)
    STATE.godMode = state
    if not state then return end
    
    local c
    c = conn(RunService.Heartbeat, function()
        if not STATE.godMode then return end
        safe(function()
            if Humanoid and Humanoid.Health <= 0 then
                Humanoid.Health = Humanoid.MaxHealth
            end
        end)
    end)
end

function FEATURES:infiniteJump(state)
    STATE.infiniteJump = state
    if not state then return end
    
    conn(UserInputService.InputBegan, function(input, gp)
        if gp then return end
        if input.KeyCode == Enum.KeyCode.Space and STATE.infiniteJump then
            safe(function()
                if Humanoid then
                    Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end)
        end
    end)
end

function FEATURES:noclip(state)
    STATE.noclip = state
    
    local c
    c = conn(RunService.Heartbeat, function()
        if not STATE.noclip then return end
        
        safe(function()
            if Character then
                for _, p in pairs(Character:GetDescendants()) do
                    if p:IsA("BasePart") then
                        p.CanCollide = false
                    end
                end
            end
        end)
    end)
end

function FEATURES:fly(state)
    STATE.fly = state
    if not state then return end
    
    local speed = 50
    local moveDir = Vector3.new(0, 0, 0)
    local isFlying = true
    
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.Parent = RootPart
    
    local wConn = conn(UserInputService.InputBegan, function(inp, gp)
        if gp then return end
        if inp.KeyCode == Enum.KeyCode.W then
            moveDir = moveDir + RootPart.CFrame.LookVector
        elseif inp.KeyCode == Enum.KeyCode.S then
            moveDir = moveDir - RootPart.CFrame.LookVector
        elseif inp.KeyCode == Enum.KeyCode.A then
            moveDir = moveDir - RootPart.CFrame.RightVector
        elseif inp.KeyCode == Enum.KeyCode.D then
            moveDir = moveDir + RootPart.CFrame.RightVector
        elseif inp.KeyCode == Enum.KeyCode.Space then
            moveDir = moveDir + Vector3.new(0, 1, 0)
        elseif inp.KeyCode == Enum.KeyCode.LeftControl then
            moveDir = moveDir - Vector3.new(0, 1, 0)
        end
    end)
    
    local fConn = conn(RunService.RenderStepped, function()
        if not STATE.fly then
            safe(function() bv:Destroy() end)
            return
        end
        safe(function()
            if moveDir.Magnitude > 0 then
                bv.Velocity = moveDir.Unit * speed
            else
                bv.Velocity = Vector3.new(0, 0, 0)
            end
        end)
    end)
end

function FEATURES:aimbot(state)
    STATE.aimbot = state
    if not state then return end
    
    conn(RunService.RenderStepped, function()
        if not STATE.aimbot then return end
        
        safe(function()
            local closest = nil
            local closestDist = 500
            
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local d = dist(RootPart.Position, hrp.Position)
                        if d < closestDist then
                            closestDist = d
                            closest = p
                        end
                    end
                end
            end
            
            if closest and closest.Character then
                local hrp = closest.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    RootPart.CFrame = CFrame.new(RootPart.Position, hrp.Position + hrp.CFrame.LookVector * 5)
                end
            end
        end)
    end)
end

function FEATURES:esp(state)
    STATE.esp = state
    
    safe(function()
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local old = hrp:FindFirstChild("SkyESP")
                    if old then old:Destroy() end
                    
                    if state then
                        local bb = Instance.new("BillboardGui")
                        bb.Name = "SkyESP"
                        bb.Size = UDim2.new(4, 0, 4, 0)
                        bb.MaxDistance = STATE.espDist
                        bb.Parent = hrp
                        
                        local txt = Instance.new("TextLabel")
                        txt.BackgroundTransparency = 1
                        txt.Size = UDim2.new(1, 0, 1, 0)
                        txt.Text = p.Name .. " [" .. math.floor(dist(RootPart.Position, hrp.Position)) .. "m]"
                        txt.TextColor3 = SKYFALL.ACCENT
                        txt.TextSize = 12
                        txt.Font = Enum.Font.GothamBold
                        txt.Parent = bb
                    end
                end
            end
        end
    end)
end

function FEATURES:invisible(state)
    STATE.invisible = state
    
    safe(function()
        if Character then
            for _, p in pairs(Character:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.Transparency = state and 0.8 or 0
                end
            end
        end
    end)
end

function FEATURES:setWalkSpeed(speed)
    STATE.walkSpeed = speed
    safe(function()
        if Humanoid then Humanoid.WalkSpeed = speed end
    end)
end

function FEATURES:setJumpPower(power)
    STATE.jumpPower = power
    safe(function()
        if Humanoid then Humanoid.JumpPower = power end
    end)
end

function FEATURES:fpsBoost(state)
    if not state then return end
    safe(function()
        if game:GetService("RunService") then
            game:GetService("RunService"):Set3dRenderingEnabled(true)
        end
        if workspace.CurrentCamera then
            workspace.CurrentCamera.MaxAxisAlignedBoundingBoxSize = 5000
        end
    end)
end

function FEATURES:memoryClean(state)
    if not state then return end
    conn(RunService.Heartbeat, function()
        if tick() % 60 == 0 then
            safe(function() collectgarbage("collect") end)
        end
    end)
end


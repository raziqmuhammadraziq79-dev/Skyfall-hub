--// ============================================
--// ESP (DRAWING API — DELTA SAFE)
--// ============================================

local function CreateESP(plr)
    if plr == LocalPlayer then return end
    if State.ESPObjects[plr] then return end
    
    local objects = {}
    
    local box = Drawing.new("Square")
    box.Visible = false
    box.Thickness = 1.5
    box.Color = Color3.fromRGB(0, 255, 150)
    box.Transparency = 0.8
    box.Filled = false
    objects.Box = box
    
    local name = Drawing.new("Text")
    name.Visible = false
    name.Size = 13
    name.Color = Color3.fromRGB(0, 255, 150)
    name.Center = true
    name.Outline = true
    objects.Name = name
    
    local health = Drawing.new("Text")
    health.Visible = false
    health.Size = 12
    health.Color = Color3.fromRGB(255, 255, 255)
    health.Center = true
    health.Outline = true
    objects.Health = health
    
    local dist = Drawing.new("Text")
    dist.Visible = false
    dist.Size = 11
    dist.Color = Color3.fromRGB(200, 200, 200)
    dist.Center = true
    dist.Outline = true
    objects.Distance = dist
    
    State.ESPObjects[plr] = objects
    
    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not Config.ESP or not State.ESPObjects[plr] then
            if conn then conn:Disconnect() end
            return
        end
        
        local char = GetChar(plr)
        local head = GetHead(plr)
        local root = GetRoot(plr)
        local hum = GetHum(plr)
        local myRoot = GetRoot()
        
        if not (char and head and root and hum and myRoot) then
            for _, obj in pairs(objects) do obj.Visible = false end
            return
        end
        
        local pos, onScreen = Camera:WorldToViewportPoint(head.Position)
        if not onScreen then
            for _, obj in pairs(objects) do obj.Visible = false end
            return
        end
        
        local distance = (root.Position - myRoot.Position).Magnitude
        
        local size = 2000 / distance
        box.Size = Vector2.new(size, size * 1.5)
        box.Position = Vector2.new(pos.X - size/2, pos.Y - size * 0.75)
        box.Visible = true
        
        name.Position = Vector2.new(pos.X, pos.Y - 40)
        name.Text = plr.DisplayName .. " [@" .. plr.Name .. "]"
        name.Visible = true
        
        health.Position = Vector2.new(pos.X, pos.Y - 25)
        health.Text = math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
        health.Color = Color3.fromRGB(255 * (1 - hum.Health/hum.MaxHealth), 255 * (hum.Health/hum.MaxHealth), 0)
        health.Visible = true
        
        dist.Position = Vector2.new(pos.X, pos.Y + 15)
        dist.Text = math.floor(distance) .. "m"
        dist.Visible = true
    end)
end

local function ClearESP()
    for plr, objects in pairs(State.ESPObjects) do
        for _, obj in pairs(objects) do
            pcall(function() obj:Remove() end)
        end
    end
    State.ESPObjects = {}
end

local function ToggleESP(enabled)
    Config.ESP = enabled
    if enabled then
        for _, plr in ipairs(Players:GetPlayers()) do
            CreateESP(plr)
        end
        Players.PlayerAdded:Connect(function(plr)
            if Config.ESP then
                task.wait(1)
                CreateESP(plr)
            end
        end)
    else
        ClearESP()
    end
end

--// ============================================
--// AIMBOT (SIMPLE — DELTA SAFE)
--// ============================================

local function GetClosestPlayer()
    local closest = nil
    local minDist = 200
    local myRoot = GetRoot()
    if not myRoot then return nil end
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and IsAlive(plr) then
            local head = GetHead(plr)
            if head then
                local pos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if dist < minDist then
                        minDist = dist
                        closest = plr
                    end
                end
            end
        end
    end
    
    return closest
end

local function ToggleAimbot(enabled)
    Config.Aimbot = enabled
    if enabled then
        State.Connections.Aimbot = RunService.RenderStepped:Connect(function()
            if not Config.Aimbot then return end
            local target = GetClosestPlayer()
            if target then
                local head = GetHead(target)
                if head then
                    local targetCF = CFrame.new(Camera.CFrame.Position, head.Position)
                    Camera.CFrame = Camera.CFrame:Lerp(targetCF, 0.5)
                end
            end
        end)
    else
        if State.Connections.Aimbot then
            State.Connections.Aimbot:Disconnect()
            State.Connections.Aimbot = nil
        end
    end
end


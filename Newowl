--// UTILITIES
local function GetChar(plr)
    plr = plr or LocalPlayer
    return plr and plr.Character
end

local function GetRoot(plr)
    local c = GetChar(plr)
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function GetHum(plr)
    local c = GetChar(plr)
    return c and c:FindFirstChildOfClass("Humanoid")
end

local function GetHead(plr)
    local c = GetChar(plr)
    return c and c:FindFirstChild("Head")
end

local function IsAlive(plr)
    local hum = GetHum(plr)
    return hum and hum.Health > 0
end

local function Notify(title, text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = 3
        })
    end)
end

--// NETWORK CLAIM
local function ClaimNetwork()
    local c = GetChar()
    if not c then return end
    for _, p in ipairs(c:GetDescendants()) do
        if p:IsA("BasePart") then
            pcall(function() p:SetNetworkOwner(LocalPlayer) end)
        end
    end
end

--// ============================================
--// FLY ENGINE — DELTA SAFE
--// ============================================

local function StartFly()
    if Config.FlyEnabled then return end
    Config.FlyEnabled = true
    
    local root = GetRoot()
    local hum = GetHum()
    if not (root and hum) then return end
    
    ClaimNetwork()
    
    Workspace.Gravity = 0
    hum.WalkSpeed = 0
    hum.JumpPower = 0
    
    local bg = Instance.new("BodyGyro")
    bg.Name = "SkyfallGyro"
    bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bg.P = 20000
    bg.D = 1000
    bg.CFrame = root.CFrame
    bg.Parent = root
    
    local bv = Instance.new("BodyVelocity")
    bv.Name = "SkyfallVel"
    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bv.Velocity = Vector3.zero
    bv.Parent = root
    
    State.BodyMovers.Gyro = bg
    State.BodyMovers.Vel = bv
    
    -- Noclip
    State.Connections.Noclip = RunService.Stepped:Connect(function()
        if not Config.FlyEnabled then return end
        local c = GetChar()
        if c then
            for _, p in ipairs(c:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.CanCollide = false
                end
            end
        end
    end)
    
    -- Control loop
    State.Connections.Fly = RunService.RenderStepped:Connect(function()
        if not Config.FlyEnabled then return end
        local r = GetRoot()
        if not r then StopFly() return end
        
        local move = Vector3.zero
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            move = move + Camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            move = move - Camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            move = move - Camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            move = move + Camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            move = move + Vector3.new(0, 1, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            move = move - Vector3.new(0, 1, 0)
        end
        
        -- Mobile joystick
        if State.JoystickDir.Magnitude > 0.1 then
            local cl = Camera.CFrame.LookVector
            local cr = Camera.CFrame.RightVector
            move = move + (cl * State.JoystickDir.Y + cr * State.JoystickDir.X)
            move = move + Vector3.new(0, State.JoystickDir.Y * 0.5, 0)
        end
        
        if move.Magnitude > 0 then
            move = move.Unit * Config.FlySpeed * 60
        end
        
        bv.Velocity = move
        bg.CFrame = Camera.CFrame
        
        if tick() % 2 < 0.05 then
            ClaimNetwork()
        end
    end)
    
    Notify("Skyfall", "Fly activated!")
    UpdateFlyBtn(true)
end

local function StopFly()
    if not Config.FlyEnabled then return end
    Config.FlyEnabled = false
    
    if State.Connections.Fly then
        State.Connections.Fly:Disconnect()
        State.Connections.Fly = nil
    end
    if State.Connections.Noclip then
        State.Connections.Noclip:Disconnect()
        State.Connections.Noclip = nil
    end
    
    if State.BodyMovers.Gyro then
        pcall(function() State.BodyMovers.Gyro:Destroy() end)
        State.BodyMovers.Gyro = nil
    end
    if State.BodyMovers.Vel then
        pcall(function() State.BodyMovers.Vel:Destroy() end)
        State.BodyMovers.Vel = nil
    end
    
    Workspace.Gravity = 196.2
    
    local hum = GetHum()
    if hum then
        hum.WalkSpeed = 16
        hum.JumpPower = 50
    end
    
    local c = GetChar()
    if c then
        for _, p in ipairs(c:GetDescendants()) do
            if p:IsA("BasePart") then
                p.CanCollide = true
            end
        end
    end
    
    Notify("Skyfall", "Fly stopped")
    UpdateFlyBtn(false)
end

--// ============================================
--// FLING — DELTA SAFE (NO METATABLE HOOKS)
--// ============================================

local function FlingPlayer(target)
    if not target or target == LocalPlayer then return false end
    
    local tc = GetChar(target)
    if not tc then return false end
    
    local tr = GetRoot(target)
    local th = GetHum(target)
    if not (tr and th) then return false end
    if th.Health <= 0 then return false end
    
    local mr = GetRoot()
    if not mr then return false end
    
    local dir = (tr.Position - mr.Position).Unit
    if dir.Magnitude == 0 then dir = Vector3.new(0, 1, 0) end
    
    local vel = dir * Config.FlingPower + Vector3.new(0, Config.FlingPower * 0.5, 0)
    
    -- Stack multiple attempts
    for i = 1, 5 do
        task.delay(i * 0.05, function()
            pcall(function()
                tr.Velocity = vel
                tr.AssemblyLinearVelocity = vel
                tr.RotVelocity = Vector3.new(math.random(-100,100), math.random(-100,100), math.random(-100,100))
            end)
        end)
    end
    
    -- BodyVelocity injection
    pcall(function()
        local existing = tr:FindFirstChild("SkyfallFling")
        if existing then existing:Destroy() end
        
        local bv = Instance.new("BodyVelocity")
        bv.Name = "SkyfallFling"
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.Velocity = vel * 2
        bv.Parent = tr
        
        game:GetService("Debris"):AddItem(bv, 0.5)
    end)
    
    -- Spin
    pcall(function()
        local ba = Instance.new("BodyAngularVelocity")
        ba.Name = "SkyfallSpin"
        ba.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        ba.AngularVelocity = Vector3.new(math.random(-50,50), math.random(-50,50), math.random(-50,50)) * 200
        ba.Parent = tr
        game:GetService("Debris"):AddItem(ba, 1)
    end)
    
    -- CFrame bump
    pcall(function()
        tr.CFrame = tr.CFrame + dir * 10 + Vector3.new(0, 20, 0)
    end)
    
    return true
end

local function FlingAll()
    local count = 0
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            if FlingPlayer(plr) then
                count = count + 1
            end
        end
    end
    Notify("Fling All", "Hit " .. count .. " players!")
    return count
end

--// Kill
local function KillPlayer(target)
    if not target then return false end
    local th = GetHum(target)
    if not th then return false end
    
    pcall(function() th.Health = 0 end)
    pcall(function() th:TakeDamage(9e9) end)
    
    local c = GetChar(target)
    if c then
        pcall(function() c:BreakJoints() end)
    end
    
    local tr = GetRoot(target)
    if tr then
        pcall(function() tr.CFrame = CFrame.new(0, -500, 0) end)
    end
    
    return true
end


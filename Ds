-- ══════════════════════════════════════════
--         CORNER BOX HELPER
-- ══════════════════════════════════════════
local function updateCornerBox(e, b, color, locked)
    local cLen = math.min(b.TR.X - b.TL.X, b.BL.Y - b.TL.Y) * 0.25
    local c = locked and CFG.LockedColor or color

    -- TL
    e.cTL1.From=b.TL ; e.cTL1.To=Vector2.new(b.TL.X+cLen, b.TL.Y) ; e.cTL1.Color=c ; e.cTL1.Visible=true
    e.cTL2.From=b.TL ; e.cTL2.To=Vector2.new(b.TL.X, b.TL.Y+cLen) ; e.cTL2.Color=c ; e.cTL2.Visible=true
    -- TR
    e.cTR1.From=b.TR ; e.cTR1.To=Vector2.new(b.TR.X-cLen, b.TR.Y) ; e.cTR1.Color=c ; e.cTR1.Visible=true
    e.cTR2.From=b.TR ; e.cTR2.To=Vector2.new(b.TR.X, b.TR.Y+cLen) ; e.cTR2.Color=c ; e.cTR2.Visible=true
    -- BL
    e.cBL1.From=b.BL ; e.cBL1.To=Vector2.new(b.BL.X+cLen, b.BL.Y) ; e.cBL1.Color=c ; e.cBL1.Visible=true
    e.cBL2.From=b.BL ; e.cBL2.To=Vector2.new(b.BL.X, b.BL.Y-cLen) ; e.cBL2.Color=c ; e.cBL2.Visible=true
    -- BR
    e.cBR1.From=b.BR ; e.cBR1.To=Vector2.new(b.BR.X-cLen, b.BR.Y) ; e.cBR1.Color=c ; e.cBR1.Visible=true
    e.cBR2.From=b.BR ; e.cBR2.To=Vector2.new(b.BR.X, b.BR.Y-cLen) ; e.cBR2.Color=c ; e.cBR2.Visible=true
end

local function hideCorners(e)
    for _, k in ipairs({"cTL1","cTL2","cTR1","cTR2","cBL1","cBL2","cBR1","cBR2"}) do
        e[k].Visible = false
    end
end

-- ══════════════════════════════════════════
--         MAIN RENDER LOOP
-- ══════════════════════════════════════════
RunService.RenderStepped:Connect(function()
    local vp      = Camera.ViewportSize
    local centerX = vp.X / 2
    local centerY = vp.Y

    -- misc features
    if CFG.NoRecoil  then applyNoRecoil() end
    if CFG.SpeedHack then applySpeed()    end
    if CFG.BunnyHop  then doBunnyHop()   end

    -- ── ESP LOOP ──
    local activePlayers = {}

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and isAlive(p) then
            local enemy  = isEnemy(p)
            activePlayers[p.UserId] = true

            if not ESPCache[p.UserId] then buildESP(p.UserId) end
            local e      = ESPCache[p.UserId]
            local bounds = getBounds(p.Character)
            local locked = (LockedTarget == p)

            -- Chams
            if CFG.Chams and enemy then
                applyChams(p)
            elseif not enemy then
                removeChams(p)
            end

            if bounds and CFG.ESP then
                local hum     = p.Character:FindFirstChildOfClass("Humanoid")
                local hp      = hum and math.floor(hum.Health) or 0
                local maxHp   = hum and math.floor(hum.MaxHealth) or 100
                local hpColor = Color3.fromRGB(
                    math.floor(255 * (1 - hp/maxHp)),
                    math.floor(255 * (hp/maxHp)),
                    0
                )

                if enemy then
                    -- ── ENEMY: red tracer + red corner box ──
                    local bc = locked and CFG.LockedColor or CFG.BoxColor

                    -- Tracer (enemy only)
                    e.tracer.From    = Vector2.new(centerX, centerY)
                    e.tracer.To      = bounds.botPos
                    e.tracer.Color   = CFG.TracerColor
                    e.tracer.Visible = true

                    -- Corner box (enemy only)
                    updateCornerBox(e, bounds, CFG.BoxColor, locked)

                    -- Full box lines hidden (using corner style)
                    e.bTop.Visible = false
                    e.bBot.Visible = false
                    e.bL.Visible   = false
                    e.bR.Visible   = false

                    -- Dot
                    e.dot.Position = bounds.headPos
                    e.dot.Color    = locked and CFG.LockedColor or CFG.DotColor
                    e.dot.Radius   = locked and 8 or 5
                    e.dot.Visible  = true

                    -- Lock ring
                    e.ring.Position = bounds.headPos
                    e.ring.Visible  = locked

                    -- Name
                    e.name.Text     = p.DisplayName .. (locked and " 🔒" or "")
                    e.name.Position = Vector2.new(bounds.headPos.X, bounds.headPos.Y - 20)
                    e.name.Color    = Color3.new(1,1,1)
                    e.name.Visible  = true

                    -- HP
                    e.health.Text     = hp .. "/" .. maxHp
                    e.health.Position = Vector2.new(bounds.headPos.X, bounds.botPos.Y + 4)
                    e.health.Color    = hpColor
                    e.health.Visible  = true

                else
                    -- ── FRIENDLY: blue box only, no tracer ──
                    e.tracer.Visible = false
                    hideCorners(e)
                    e.dot.Visible    = false
                    e.ring.Visible   = false

                    e.bTop.From=bounds.TL ; e.bTop.To=bounds.TR ; e.bTop.Color=CFG.FriendlyColor ; e.bTop.Visible=true
                    e.bBot.From=bounds.BL ; e.bBot.To=bounds.BR ; e.bBot.Color=CFG.FriendlyColor ; e.bBot.Visible=true
                    e.bL.From=bounds.TL   ; e.bL.To=bounds.BL   ; e.bL.Color=CFG.FriendlyColor   ; e.bL.Visible=true
                    e.bR.From=bounds.TR   ; e.bR.To=bounds.BR   ; e.bR.Color=CFG.FriendlyColor   ; e.bR.Visible=true

                    e.name.Text     = "👥 " .. p.DisplayName
                    e.name.Position = Vector2.new(bounds.headPos.X, bounds.headPos.Y - 20)
                    e.name.Color    = CFG.FriendlyColor
                    e.name.Visible  = true
                    e.health.Visible= false
                end

            else
                -- off screen: hide all
                for _, d in pairs(e) do pcall(function() d.Visible = false end) end
                hideCorners(e)
            end
        end
    end

    -- cleanup dead/left
    for uid in pairs(ESPCache) do
        if not activePlayers[uid] then clearPlayer(uid) end
    end

    -- ── AIMBOT ──
    if CFG.Aimbot then
        local target = getNearestEnemy()
        if target then
            LockedTarget = target
            IsLocked     = true

            local head = target.Character and target.Character:FindFirstChild(CFG.AimPart)
            if head then
                local aimPos = CFG.Prediction and getPredictedPosition(target) or head.Position
                if aimPos then
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, aimPos)
                end
            end

            if CFG.AutoShoot then
                fireWeapon(target)
            end
        else
            LockedTarget = nil
            IsLocked     = false
        end
    end
end)


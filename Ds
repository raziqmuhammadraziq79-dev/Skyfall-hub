-- ══════════════════════════════════════════
--         CHAMS (see through wall)
-- ══════════════════════════════════════════
local ChamsApplied = {}

local function applyChams(p)
    if ChamsApplied[p.UserId] then return end
    local c = p.Character
    if not c then return end
    for _, part in ipairs(c:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            pcall(function()
                local sel = Instance.new("SelectionBox")
                sel.Color3         = CFG.ChamsColor
                sel.LineThickness  = 0.04
                sel.SurfaceTransparency = 0.6
                sel.SurfaceColor3  = CFG.ChamsColor
                sel.Adornee        = part
                sel.Parent         = part
            end)
        end
    end
    ChamsApplied[p.UserId] = true
end

local function removeChams(p)
    if not p.Character then return end
    for _, part in ipairs(p.Character:GetDescendants()) do
        for _, v in ipairs(part:GetChildren()) do
            if v:IsA("SelectionBox") then v:Destroy() end
        end
    end
    ChamsApplied[p.UserId] = nil
end

-- ══════════════════════════════════════════
--         NEAREST ENEMY
-- ══════════════════════════════════════════
local function getNearestEnemy()
    local cx, cy  = Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2
    local best     = nil
    local bDist    = CFG.FOV

    for _, p in ipairs(Players:GetPlayers()) do
        if isEnemyAlive(p) then
            local c    = p.Character
            local head = c and c:FindFirstChild(CFG.AimPart)
            if head then
                local pos = CFG.Prediction and getPredictedPosition(p) or head.Position
                if pos then
                    local sp, onScreen = Camera:WorldToViewportPoint(pos)
                    if onScreen and sp.Z > 0 then
                        local dist = math.sqrt((sp.X-cx)^2 + (sp.Y-cy)^2)
                        if dist < bDist then
                            bDist = dist
                            best  = p
                        end
                    end
                end
            end
        end
    end
    return best
end

-- ══════════════════════════════════════════
--         SILENT AIM
-- ══════════════════════════════════════════
-- hooks tool fire remote to redirect bullet to enemy head
local SilentHooked = {}

local function hookSilentAim(tool)
    if SilentHooked[tool] then return end
    SilentHooked[tool] = true
    for _, v in ipairs(tool:GetDescendants()) do
        if v:IsA("RemoteEvent") then
            local oldFire
            pcall(function()
                oldFire = v.OnClientEvent
            end)
            -- wrap FireServer
            local mt = getrawmetatable and getrawmetatable(v)
            if mt then
                local old_index = mt.__index
                local old_newindex = mt.__newindex
                pcall(function()
                    setreadonly(mt, false)
                    mt.__newindex = function(self, key, val)
                        old_newindex(self, key, val)
                    end
                    setreadonly(mt, true)
                end)
            end
        end
    end
end

-- ══════════════════════════════════════════
--         AUTO SHOOT + SILENT AIM FIRE
-- ══════════════════════════════════════════
local function fireWeapon(target)
    local char = LP.Character
    if not char then return end
    local head = target and target.Character and target.Character:FindFirstChild("Head")

    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            -- Silent aim: redirect all remote fire to head pos
            if CFG.SilentAim and head then
                for _, v in ipairs(tool:GetDescendants()) do
                    if v:IsA("RemoteEvent") then
                        pcall(function()
                            v:FireServer(head.Position, head.Position, head)
                        end)
                    end
                end
            end
            -- Normal activate
            pcall(function() tool:Activate() end)
        end
    end
end


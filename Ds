    btn.Size             = UDim2.new(0.3, 0, 0.65, 0)
    btn.Position         = UDim2.new(0.67, 0, 0.17, 0)
    btn.BackgroundColor3 = CFG[setting] and Color3.fromRGB(0,190,0) or Color3.fromRGB(190,0,0)
    btn.Text             = CFG[setting] and "ON" or "OFF"
    btn.TextColor3       = Color3.new(1,1,1)
    btn.Font             = Enum.Font.GothamBold
    btn.TextSize         = 13
    btn.Parent           = row
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    btn.MouseButton1Click:Connect(function()
        CFG[setting]         = not CFG[setting]
        btn.BackgroundColor3 = CFG[setting] and Color3.fromRGB(0,190,0) or Color3.fromRGB(190,0,0)
        btn.Text             = CFG[setting] and "ON" or "OFF"
    end)
end


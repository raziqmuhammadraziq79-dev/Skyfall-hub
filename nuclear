                for i = 1, 5 do
                    targetHRP.AssemblyLinearVelocity = Vector3.new(0, -500, 0)
                    targetHRP.AssemblyAngularVelocity = Vector3.new(math.random(-100,100), math.random(-100,100), math.random(-100,100))

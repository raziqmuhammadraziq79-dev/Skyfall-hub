-- ═══════ KILL AURA CORE ═══════
local function GetValidTargets()
    local targets = {}
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return targets end
    
    local myPos = char.HumanoidRootPart.Position
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetChar = player.Character
            local hrp = targetChar:FindFirstChild("HumanoidRootPart")
            local humanoid = targetChar:FindFirstChild("Humanoid")
            
            if hrp and humanoid and humanoid.Health > 0 then
                local dist = (hrp.Position - myPos).Magnitude
                if dist <= Nuclear.KillRange then
                    -- Team check bypass
                    if player.Team ~= LocalPlayer.Team or not player.Team then
                        table.insert(targets, {
                            Character = targetChar,
                            Humanoid = humanoid,
                            HRP = hrp,
                            Distance = dist,
                            Player = player
                        })
                    end
                end
            end
        end
    end
    
    -- Sort by distance (closest first)
    table.sort(targets, function(a, b) return a.Distance < b.Distance end)
    return targets
end

local function ExecuteKillAura()
    local targets = GetValidTargets()
    
    for _, target in ipairs(targets) do
        -- Visual confirmation beam
        local beam = Instance.new("Beam")
        beam.Color = ColorSequence.new(Color3.fromRGB(255, 0, 0), Color3.fromRGB(255, 100, 0))

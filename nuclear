-- ═══════ REMOTE DISCOVERY ENGINE ═══════
local function DiscoverRemotes()
    local remotes = {}
    
    local function Scan(instance)
        for _, child in ipairs(instance:GetDescendants()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                local name = child.Name:lower()
                -- Score remote based on naming patterns
                local score = 0
                if name:find("damage") or name:find("hit") or name:find("attack") then score = score + 10 end
                if name:find("combat") or name:find("weapon") or name:find("tool") then score = score + 8 end
                if name:find("replicate") or name:find("sync") then score = score + 6 end
                if name:find("player") or name:find("character") then score = score + 4 end
                
                table.insert(remotes, {
                    Remote = child,
                    Score = score,
                    Type = child.ClassName
                })
            end
        end
    end
    
    Scan(ReplicatedStorage)
    Scan(Workspace)
    
    -- Sort by relevance score
    table.sort(remotes, function(a, b) return a.Score > b.Score end)
    
    Nuclear.RemoteCache = remotes
    return remotes
end


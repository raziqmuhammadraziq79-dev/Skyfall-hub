-- ═══════════════ UTILITY ═══════════════
local function New(C, P)
    local O = Instance.new(C)
    for i, v in pairs(P) do if i ~= "Parent" then O[i] = v end end
    if P.Parent then O.Parent = P.Parent end
    return O
end

local function Log(msg) print("[SKYFALL] " .. os.date("%H:%M:%S") .. " | " .. msg) end

local function SafeBind(name, priority, func)
    pcall(function() RunService:UnbindFromRenderStep(name) end)
    RunService:BindToRenderStep(name, priority, func)
    ActiveBindings[name] = true
end

local function SafeUnbind(name)
    pcall(function() RunService:UnbindFromRenderStep(name) end)
    ActiveBindings[name] = nil
end

local function SendChat(msg)
    pcall(function()
        if TextChatService.ChatVersion == Enum.ChatVersion.LegacyChatService then
            local ce = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
            if ce then local sm = ce:FindFirstChild("SayMessageRequest")
                if sm then sm:FireServer(msg, "All") end
            end
        else
            local ch = TextChatService:FindFirstChild("TextChannels") and TextChatService.TextChannels:FindFirstChild("RBXGeneral")
            if ch then ch:SendAsync(msg) end
        end
    end)
end

local function FindRemote(keyword)
    for _, d in ipairs(ReplicatedStorage:GetDescendants()) do
        if d:IsA("RemoteEvent") and string.find(string.lower(d.Name), string.lower(keyword)) then return d end
    end
    return nil
end

local function GetNearestPlayer()
    local nearest = nil; local minDist = math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (p.Character.HumanoidRootPart.Position - RootPart.Position).Magnitude
            if dist < minDist then minDist = dist; nearest = p end
        end
    end
    return nearest, minDist
end

local function GetKillerModel()
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and not Players:GetPlayerFromCharacter(obj) then
            local n = string.lower(obj.Name)
            if string.find(n, "killer") or string.find(n, "nextbot") or string.find(n, "monster") or string.find(n, "enemy") or string.find(n, "boss") then
                return obj
            end
        end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Team then
            local tn = string.lower(tostring(p.Team.Name))
            if string.find(tn, "killer") or string.find(tn, "murderer") or string.find(tn, "spy") then
                return p.Character
            end
        end
    end
    return nil
end

local function FindExitDoor()
    local exitNames = {"exit", "escape", "gate", "door", "end", "finish", "leave", "win", "victory", "checkpoint"}
    local found = nil; local minDist = math.huge
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Model") then
            local n = string.lower(obj.Name)
            for _, ename in ipairs(exitNames) do
                if string.find(n, ename) then
                    local pos = obj:IsA("Model") and obj:GetPivot().Position or obj.Position
                    local dist = (pos - RootPart.Position).Magnitude
                    if dist < minDist then minDist = dist; found = {obj = obj, pos = pos, dist = dist, name = obj.Name} end
                end
            end
        end
    end
    return found
end


        TextXAlignment = Enum.TextXAlignment.Left, Parent = B})
    local Tk = New("Frame", {Size = UDim2.new(1, -16, 0, 5), Position = UDim2.new(0, 8, 1, -10),
        BackgroundColor3 = Color3.fromRGB(38, 39, 44), Parent = B})
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Tk})
    local Fl = New("Frame", {Size = UDim2.new((Def - Min) / (Max - Min), 0, 1, 0), BackgroundColor3 = CFG.Accent, Parent = Tk})
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Fl})
    local Drag = false
    local function Upd(I)
        local P = math.clamp((I.Position.X - Tk.AbsolutePosition.X) / Tk.AbsoluteSize.X, 0, 1)
        local V = math.floor(Min + (Max - Min) * P)
        Fl.Size = UDim2.new(P, 0, 1, 0); L.Text = Name .. ": " .. V; Cb(V)
    end
    Tk.InputBegan:Connect(function(I)
        if I.UserInputType == Enum.UserInputType.Touch or I.UserInputType == Enum.UserInputType.MouseButton1 then Drag = true; Upd(I) end
    end)
    UserInputService.InputChanged:Connect(function(I)
        if Drag and (I.UserInputType == Enum.UserInputType.Touch or I.UserInputType == Enum.UserInputType.MouseMovement) then Upd(I) end
    end)
    UserInputService.InputEnded:Connect(function(I)
        if I.UserInputType == Enum.UserInputType.Touch or I.UserInputType == Enum.UserInputType.MouseButton1 then Drag = false end
    end)
end


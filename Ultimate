            local killer = GetKillerModel()
            if killer and killer:FindFirstChild("HumanoidRootPart") then
                local dist = (killer.HumanoidRootPart.Position - RootPart.Position).Magnitude
                local pos = killer.HumanoidRootPart.Position
                local dir = (killer.HumanoidRootPart.Position - RootPart.Position).Unit
                local angle = math.deg(math.atan2(dir.X, dir.Z))
                local compass = "N"
                if angle > -22.5 and angle <= 22.5 then compass = "N"
                elseif angle > 22.5 and angle <= 67.5 then compass = "NE"
                elseif angle > 67.5 and angle <= 112.5 then compass = "E"
                elseif angle > 112.5 and angle <= 157.5 then compass = "SE"
                elseif angle > 157.5 or angle <= -157.5 then compass = "S"
                elseif angle > -157.5 and angle <= -112.5 then compass = "SW"
                elseif angle > -112.5 and angle <= -67.5 then compass = "W"
                elseif angle > -67.5 and angle <= -22.5 then compass = "NW"
                end
                TrackerDist.Text = string.format("Distance: %d studs", math.floor(dist))
                TrackerDist.TextColor3 = dist < 15 and CFG.Red or dist < 30 and CFG.Orange or CFG.Green
                TrackerPos.Text = string.format("Position: %d, %d, %d", math.floor(pos.X), math.floor(pos.Y), math.floor(pos.Z))
                TrackerDir.Text = "Direction: " .. compass .. " (" .. math.floor(angle) .. "°)"
            else
                TrackerDist.Text = "Distance: No killer"
                TrackerPos.Text = "Position: ---"
                TrackerDir.Text = "Direction: ---"
            end
        end)

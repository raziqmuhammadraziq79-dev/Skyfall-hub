-- ANTI-DETECTION ENGINE
-- ═══════════════════════════════════════════════════════════

local function InitializeAntiDetection()
    local success = pcall(function()
        local RemoteEvent = Instance.new("RemoteEvent")
        local oldFireServer = RemoteEvent.FireServer
        
        RemoteEvent.FireServer = function(self, ...)
            if not self or not self.Name then return end
            
            local eventName = tostring(self.Name):lower()
            
            local blockedPatterns = {
                "anti", "detect", "cheat", "check", "verify", "auth",
                "ban", "kick", "punish", "report", "flag", "suspicious"
            }
            
            for _, pattern in pairs(blockedPatterns) do
                if eventName:find(pattern) then
                    return nil
                end
            end
            
            task.delay(math.random(50, 200) / 1000, function()
                pcall(function()
                    oldFireServer(self, ...)
                end)
            end)
        end
    end)
    
    return success
end

InitializeAntiDetection()


-- HELPER: TOGGLE
local function AddToggle(Name, Default, Callback)
    local Container = Instance.new("Frame", Content)
    Container.Size = UDim2.new(1, 0, 0, 32)
    Container.BackgroundTransparency = 1
    Container.LayoutOrder = #Content:GetChildren()
    
    local Label = Instance.new("TextLabel", Container)
    Label.Size = UDim2.new(1, -45, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = Name
    Label.TextColor3 = Color3.fromRGB(220, 220, 220)
    Label.Font = Enum.Font.GothamMedium
    Label.TextSize = 13
    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    local ToggleBg = Instance.new("Frame", Container)
    ToggleBg.Size = UDim2.new(0, 34, 0, 16)
    ToggleBg.Position = UDim2.new(1, -34, 0.5, -8)
    ToggleBg.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    ToggleBg.BorderSizePixel = 0
    Instance.new("UICorner", ToggleBg).CornerRadius = UDim.new(1, 0)
    
    local Knob = Instance.new("Frame", ToggleBg)
    Knob.Size = UDim2.new(0, 12, 0, 12)
    Knob.Position = UDim2.new(0, 2, 0.5, -6)
    Knob.BackgroundColor3 = Color3.fromRGB(140, 140, 140)
    Knob.BorderSizePixel = 0
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)
    
    local Active = Default
    local function Update()
        ToggleBg.BackgroundColor3 = Active and Color3.fromRGB(138, 43, 226) or Color3.fromRGB(35, 35, 45)
        Knob.Position = Active and UDim2.new(0, 20, 0.5, -6) or UDim2.new(0, 2, 0.5, -6)
        Knob.BackgroundColor3 = Active and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(140, 140, 140)
    end
    Update()
    
    Instance.new("TextButton", Container).Size = UDim2.new(1, 0, 1, 0)
    Container:FindFirstChild("TextButton").BackgroundTransparency = 1
    Container:FindFirstChild("TextButton").Text = ""
    Container:FindFirstChild("TextButton").MouseButton1Click:Connect(function()
        Active = not Active; Update(); Callback(Active)
    end)
end

-- HELPER: SLIDER
local function AddSlider(Name, Min, Max, Default, Callback)
    local Container = Instance.new("Frame", Content)
    Container.Size = UDim2.new(1, 0, 0, 40)
    Container.BackgroundTransparency = 1
    
    local Label = Instance.new("TextLabel", Container)
    Label.Size = UDim2.new(1, -10, 0, 14)
    Label.BackgroundTransparency = 1
    Label.Text = Name .. ": " .. tostring(Default)
    Label.TextColor3 = Color3.fromRGB(220, 220, 220)
    Label.Font = Enum.Font.GothamMedium
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    local Track = Instance.new("Frame", Container)
    Track.Size = UDim2.new(1, -10, 0, 5)
    Track.Position = UDim2.new(0, 5, 0, 22)
    Track.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    Track.BorderSizePixel = 0
    Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)
    
    local Fill = Instance.new("Frame", Track)
    Fill.Size = UDim2.new((Default - Min) / (Max - Min), 0, 1, 0)
    Fill.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
    Fill.BorderSizePixel = 0
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)
    
    local Thumb = Instance.new("Frame", Track)
    Thumb.Size = UDim2.new(0, 10, 0, 10)
    Thumb.Position = UDim2.new((Default - Min) / (Max - Min), -5, 0.5, -5)
    Thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Thumb.BorderSizePixel = 0
    Instance.new("UICorner", Thumb).CornerRadius = UDim.new(1, 0)
    
    local Val = Default; local Updating = false
    local function Update(X)
        local Rel = math.clamp((X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
        Val = math.floor(Min + (Max - Min) * Rel + 0.5)
        Fill.Size = UDim2.new(Rel, 0, 1, 0)
        Thumb.Position = UDim2.new(Rel, -5, 0.5, -5)
        Label.Text = Name .. ": " .. tostring(Val)
        if not Updating then Callback(Val) end
    end
    
    Thumb.InputBegan:Connect(function(I) if I.UserInputType == Enum.UserInputType.MouseButton1 or I.UserInputType == Enum.UserInputType.Touch then Updating = true end end)
    Thumb.InputEnded:Connect(function(I) if I.UserInputType == Enum.UserInputType.MouseButton1 or I.UserInputType == Enum.UserInputType.Touch then Updating = false end end)
    UserInputService.InputChanged:Connect(function(I)
        if Updating and (I.UserInputType == Enum.UserInputType.MouseMovement or I.UserInputType == Enum.UserInputType.Touch) then Update(I.Position.X) end
    end)
end


    T.Text = Msg; T.TextColor3 = Color3.fromRGB(160, 80, 255)
    T.Font = Enum.Font.GothamMedium; T.TextSize = 13
    
    TweenService:Create(N, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -110, 1, -80)}):Play()
    task.delay(2.5, function()
        TweenService:Create(N, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -110, 1, -60)}):Play()
        task.wait(0.3); N:Destroy()
    end)
end


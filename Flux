--------------------------------------------------------------------------------
-- CORE EXPLOIT MECHANICS (FLY, NOCLIP, INFJUMP)
--------------------------------------------------------------------------------

Connections.InfJump = userInputService.JumpRequest:Connect(function()
	if States.InfJump and localPlayer.Character then
		local humanoid = localPlayer.Character:FindFirstChildOfClass("Humanoid")
		if humanoid then humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end
	end
end)

Connections.Noclip = runService.Stepped:Connect(function()
	if States.Noclip and localPlayer.Character then
		for _, part in ipairs(localPlayer.Character:GetDescendants()) do
			if part:IsA("BasePart") and part.CanCollide then
				part.CanCollide = false
			end
		end
	end
end)

local function toggleFlightEngine(enable)
	local char = localPlayer.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end
	local root = char.HumanoidRootPart
	local hum = char:FindFirstChildOfClass("Humanoid")
	
	if enable then
		FlyBodyVelocity = Instance.new("BodyVelocity")
		FlyBodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
		FlyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
		FlyBodyVelocity.Parent = root
		
		FlyBodyGyro = Instance.new("BodyGyro")
		FlyBodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
		FlyBodyGyro.CFrame = root.CFrame
		FlyBodyGyro.Parent = root
		
		if hum then hum.PlatformStand = true end
		
		Connections.FlightLoop = runService.RenderStepped:Connect(function()
			if not States.Fly or not localPlayer.Character then return end
			local moveDirection = hum and hum.MoveDirection or Vector3.new(0,0,0)
			local camCFrame = camera.CFrame
			
			if moveDirection.Magnitude > 0 then
				local dir = (camCFrame.LookVector * moveDirection.Z) + (camCFrame.RightVector * moveDirection.X)
				FlyBodyVelocity.Velocity = dir.Unit * States.FlySpeed
			else
				FlyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
			end
			FlyBodyGyro.CFrame = camCFrame
		end)
	else
		if Connections.FlightLoop then Connections.FlightLoop:Disconnect() end
		if FlyBodyVelocity then FlyBodyVelocity:Destroy() end
		if FlyBodyGyro then FlyBodyGyro:Destroy() end
		if hum then hum.PlatformStand = false end
	end
end

--------------------------------------------------------------------------------
-- HIGH-PERFORMANCE DRAWING ESP SYSTEM
--------------------------------------------------------------------------------

local function createEsp(player)
	if player == localPlayer then return end
	
	local box = Drawing.new("Square")
	box.Visible = false
	box.Color = Color3.fromRGB(0, 255, 150)
	box.Thickness = 1.5
	box.Filled = false
	
	local name = Drawing.new("Text")
	name.Visible = false
	name.Color = Color3.fromRGB(255, 255, 255)
	name.Size = 14
	name.Center = true
	name.Outline = true
	
	EspObjects[player] = {Box = box, Name = name}
	
	local conn
	conn = runService.RenderStepped:Connect(function()
		if not States.Esp or not player.Parent or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
			box.Visible = false
			name.Visible = false
			if not player.Parent then
				box:Remove()
				name:Remove()
				EspObjects[player] = nil
				conn:Disconnect()
			end
			return
		end
		
		local rootPart = player.Character.HumanoidRootPart
		local pos, onScreen = camera:WorldToViewportPoint(rootPart.Position)
		
		if onScreen then
			-- Kalkulasi dimensi Box berdasarkan jarak kamera
			local scale = 1000 / pos.Z
			local w, h = 3 * scale, 4.5 * scale
			
			box.Position = Vector2.new(pos.X - w/2, pos.Y - h/2)
			box.Size = Vector2.new(w, h)
			box.Visible = true
			
			name.Position = Vector2.new(pos.X, pos.Y - h/2 - 15)
			name.Text = player.Name .. " [" .. math.round(pos.Z) .. "m]"
			name.Visible = true
		else
			box.Visible = false
			name.Visible = false
		end
	end)
end

for _, p in ipairs(playersService:GetPlayers()) do createEsp(p) end
playersService.PlayerAdded:Connect(createEsp)

--------------------------------------------------------------------------------
-- BYPASS TELEPORT ENGINE
--------------------------------------------------------------------------------

local function teleportToPlayer(targetName)
	if targetName == "" then return end
	local targetPlayer = nil
	
	for _, p in ipairs(playersService:GetPlayers()) do
		if string.sub(string.lower(p.Name), 1, #targetName) == string.lower(targetName) then
			targetPlayer = p
			break
		end
	end
	
	if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
		local localChar = localPlayer.Character
		if localChar and localChar:FindFirstChild("HumanoidRootPart") then
			-- PivotTo bypass anticheat rubberbanding di beberapa game engine
			localChar:PivotTo(targetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 2, 0))
			print("[TELEPORT] Swapped position to: " .. targetPlayer.Name)
		end
	end
end


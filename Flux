local function createToggle(name, default, layoutOrder, callback)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0, 36)
	btn.BackgroundColor3 = default and Color3.fromRGB(25, 35, 25) or Color3.fromRGB(20, 20, 25)
	btn.Text = name .. (default and " : ACTIVE" or " : OFF")
	btn.TextColor3 = default and Color3.fromRGB(100, 242, 100) or Color3.fromRGB(242, 100, 100)
	btn.Font = Enum.Font.SourceSansBold
	btn.TextSize = 14
	btn.LayoutOrder = layoutOrder
	btn.Parent = container
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 6)
	btnCorner.Parent = btn
	
	local active = default
	btn.MouseButton1Click:Connect(function()
		active = not active
		if active then
			btn.Text = name .. " : ACTIVE"
			btn.TextColor3 = Color3.fromRGB(100, 242, 100)
			btn.BackgroundColor3 = Color3.fromRGB(25, 35, 25)
		else
			btn.Text = name .. " : OFF"
			btn.TextColor3 = Color3.fromRGB(242, 100, 100)
			btn.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
		end
		callback(active)
	end)
end


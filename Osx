-- // UTILITY
local function IsEnemy(player)
    if player == LocalPlayer then return false end
    if Settings.TeamCheck then
        if player.Team and LocalPlayer.Team then
            if player.Team == LocalPlayer.Team then return false end
        end
    end
    return true
end

local function GetCharacter(player)
    return player.Character
end

local function GetRootPart(character)
    return character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso"))
end

local function GetHead(character)
    return character and character:FindFirstChild("Head")
end

local function GetHumanoid(character)
    return character and character:FindFirstChildOfClass("Humanoid")
end

local function IsAlive(player)
    local char = GetCharacter(player)
    if not char then return false end
    local hum = GetHumanoid(char)
    return hum and hum.Health > 0
end

local function WorldToViewport(pos)
    local screenPos, onScreen = Camera:WorldToViewportPoint(pos)
    return Vector2.new(screenPos.X, screenPos.Y), onScreen, screenPos.Z
end

local function GetDistance(player)
    local char = GetCharacter(player)
    if not char then return math.huge end
    local root = GetRootPart(char)
    if not root then return math.huge end
    local myChar = LocalPlayer.Character
    if not myChar then return math.huge end
    local myRoot = GetRootPart(myChar)
    if not myRoot then return math.huge end
    return (root.Position - myRoot.Position).Magnitude
end

-- // ESP DRAWING
local function CreateESPForPlayer(player)
    if ESPObjects[player] then return end

    local drawings = {}

    -- Tracer (line from bottom screen to enemy root)
    local tracer = Drawing.new("Line")
    tracer.Visible = false
    tracer.Color = Settings.TracerColor
    tracer.Thickness = 2
    tracer.Transparency = 1
    drawings.Tracer = tracer

    -- Box (4 lines)
    local box = {}
    for i = 1, 4 do
        local line = Drawing.new("Line")
        line.Visible = false
        line.Color = Settings.BoxColor
        line.Thickness = 1.5
        line.Transparency = 1
        box[i] = line
    end
    drawings.Box = box

    -- Name
    local name = Drawing.new("Text")
    name.Visible = false
    name.Color = Settings.NameColor
    name.Size = 13
    name.Center = true
    name.Outline = true
    name.OutlineColor = Color3.fromRGB(0, 0, 0)
    name.Text = player.Name
    drawings.Name = name

    -- Distance
    local dist = Drawing.new("Text")
    dist.Visible = false
    dist.Color = Color3.fromRGB(255, 100, 100)
    dist.Size = 11
    dist.Center = true
    dist.Outline = true
    dist.OutlineColor = Color3.fromRGB(0, 0, 0)
    drawings.Dist = dist

    ESPObjects[player] = drawings
end

local function RemoveESPForPlayer(player)
    if not ESPObjects[player] then return end
    local drawings = ESPObjects[player]
    if drawings.Tracer then drawings.Tracer:Remove() end
    if drawings.Box then
        for _, line in pairs(drawings.Box) do
            line:Remove()
        end
    end
    if drawings.Name then drawings.Name:Remove() end
    if drawings.Dist then drawings.Dist:Remove() end
    ESPObjects[player] = nil
end

local function UpdateESP()
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not IsEnemy(player) then
            if ESPObjects[player] then RemoveESPForPlayer(player) end
            continue
        end

        if not ESPObjects[player] then
            CreateESPForPlayer(player)
        end

        local drawings = ESPObjects[player]
        if not drawings then continue end

        local char = GetCharacter(player)
        local root = char and GetRootPart(char)
        local head = char and GetHead(char)
        local hum = char and GetHumanoid(char)

        if not char or not root or not hum or hum.Health <= 0 or not Settings.ESP then
            drawings.Tracer.Visible = false
            if drawings.Box then for _, l in pairs(drawings.Box) do l.Visible = false end end
            drawings.Name.Visible = false
            drawings.Dist.Visible = false
            continue
        end

        local rootPos, rootOnScreen, rootDepth = WorldToViewport(root.Position)
        if not rootOnScreen or rootDepth <= 0 then
            drawings.Tracer.Visible = false
            if drawings.Box then for _, l in pairs(drawings.Box) do l.Visible = false end end
            drawings.Name.Visible = false
            drawings.Dist.Visible = false
            continue
        end

        local distance = GetDistance(player)
        local screenHeight = Camera.ViewportSize.Y
        local screenWidth = Camera.ViewportSize.X

        -- TRACER
        if Settings.Tracers then
            drawings.Tracer.Visible = true
            drawings.Tracer.From = Vector2.new(screenWidth / 2, screenHeight)
            drawings.Tracer.To = rootPos
            drawings.Tracer.Color = Settings.TracerColor
        else
            drawings.Tracer.Visible = false
        end

        -- BOX (estimate size based on distance)
        if Settings.Boxes and head then
            local headPos, headOnScreen = WorldToViewport(head.Position + Vector3.new(0, 0.7, 0))
            if headOnScreen then
                local boxHeight = math.abs(headPos.Y - rootPos.Y) * 2
                local boxWidth = boxHeight * 0.5
                local topLeft = Vector2.new(rootPos.X - boxWidth / 2, headPos.Y)
                local topRight = Vector2.new(rootPos.X + boxWidth / 2, headPos.Y)
                local botLeft = Vector2.new(rootPos.X - boxWidth / 2, rootPos.Y + boxHeight / 2)
                local botRight = Vector2.new(rootPos.X + boxWidth / 2, rootPos.Y + boxHeight / 2)

                -- Top
                drawings.Box[1].From = topLeft drawings.Box[1].To = topRight drawings.Box[1].Visible = true drawings.Box[1].Color = Settings.BoxColor
                -- Bottom
                drawings.Box[2].From = botLeft drawings.Box[2].To = botRight drawings.Box[2].Visible = true drawings.Box[2].Color = Settings.BoxColor
                -- Left
                drawings.Box[3].From = topLeft drawings.Box[3].To = botLeft drawings.Box[3].Visible = true drawings.Box[3].Color = Settings.BoxColor
                -- Right
                drawings.Box[4].From = topRight drawings.Box[4].To = botRight drawings.Box[4].Visible = true drawings.Box[4].Color = Settings.BoxColor
            end
        else
            if drawings.Box then for _, l in pairs(drawings.Box) do l.Visible = false end end
        end

        -- NAME
        if Settings.Names then
            drawings.Name.Visible = true
            drawings.Name.Position = Vector2.new(rootPos.X, rootPos.Y - 30)
            drawings.Name.Text = player.Name .. " [" .. math.floor(hum.Health) .. "HP]"
        else
            drawings.Name.Visible = false
        end

        -- DISTANCE
        drawings.Dist.Visible = true
        drawings.Dist.Position = Vector2.new(rootPos.X, rootPos.Y + 10)
        drawings.Dist.Text = math.floor(distance) .. "m"
    end
end

-- // AIMBOT
local function GetNearestEnemy()
    local nearest = nil
    local nearestDist = math.huge
    local centerScreen = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in pairs(Players:GetPlayers()) do
        if not IsEnemy(player) then continue end
        if not IsAlive(player) then continue end

        local char = GetCharacter(player)
        local targetPart = Settings.HeadTargeting and GetHead(char) or GetRootPart(char)
        if not targetPart then continue end

        local screenPos, onScreen, depth = WorldToViewport(targetPart.Position)
        if not onScreen or depth <= 0 then continue end

        local distFromCenter = (screenPos - centerScreen).Magnitude
        if distFromCenter < Settings.AimbotFOV and distFromCenter < nearestDist then
            nearestDist = distFromCenter
            nearest = player
        end
    end

    return nearest
end

local function AimbotStep()
    if not Settings.AimbotEnabled then CurrentTarget = nil return end

    CurrentTarget = GetNearestEnemy()
    if not CurrentTarget then return end

    local char = GetCharacter(CurrentTarget)
    if not char then return end

    local targetPart = Settings.HeadTargeting and GetHead(char) or GetRootPart(char)
    if not targetPart then return end

    local targetPos, onScreen, depth = WorldToViewport(targetPart.Position)
    if not onScreen or depth <= 0 then return end

    -- Fast camera lock to head
    local currentCF = Camera.CFrame
    local targetCF = CFrame.new(currentCF.Position, targetPart.Position)

    Camera.CFrame = currentCF:Lerp(targetCF, Settings.AimbotSmoothing * 10)
end

-- // AUTO SHOOT
local function FindTool()
    local char = LocalPlayer.Character
    if not char then return nil end
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("Tool") then return v end
    end
    return nil
end

local function TryShoot()
    if not Settings.AutoShoot then return end
    if not CurrentTarget then return end
    if not IsAlive(CurrentTarget) then return end

    local tool = FindTool()
    if not tool then return end

    local fireEvent = tool:FindFirstChild("RemoteEvent") or
                      tool:FindFirstChild("Fire") or
                      tool:FindFirstChildOfClass("RemoteEvent")

    -- Universal fire attempt
    if fireEvent and fireEvent:IsA("RemoteEvent") then
        pcall(function()
            fireEvent:FireServer()
        end)
    end

    -- Simulate click via mouse
    pcall(function()
        Mouse1Click()
    end)
end

-- // INFINITE AMMO
local function SetupInfiniteAmmo()
    local function PatchTool(tool)
        -- Patch gun configs
        local function ScanForAmmo(obj)
            for _, v in pairs(obj:GetDescendants()) do
                if v:IsA("IntValue") or v:IsA("NumberValue") then
                    local name = v.Name:lower()
                    if name:find("ammo") or name:find("clip") or name:find("magazine") or name:find("bullets") then
                        v.Value = 999
                        v.Changed:Connect(function()
                            if Settings.InfiniteAmmo then
                                v.Value = 999
                            end
                        end)
                    end
                end
            end
        end
        ScanForAmmo(tool)
    end

    local char = LocalPlayer.Character
    if char then
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("Tool") then PatchTool(v) end
        end
        char.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then
                task.wait(0.1)
                PatchTool(child)
            end
        end)
    end

    LocalPlayer.CharacterAdded:Connect(function(newChar)
        task.wait(0.5)
        for _, v in pairs(newChar:GetChildren()) do
            if v:IsA("Tool") then PatchTool(v) end
        end
        newChar.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then
                task.wait(0.1)
                PatchTool(child)
            end
        end)
    end)
end


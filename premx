    label.BackgroundTransparency = 1
    label.Text = tab.name
    label.TextColor3 = C.TextSub
    label.TextSize = 8
    label.Font = Enum.Font.GothamMedium
    label.Parent = btn

    btn.MouseEnter:Connect(function()
        if Hub.ActiveTab ~= tab.name then
            TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundTransparency = 0.4}):Play()
        end
    end)
    btn.MouseLeave:Connect(function()
        if Hub.ActiveTab ~= tab.name then
            TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundTransparency = 0.7}):Play()
        end
    end)

    btn.MouseButton1Click:Connect(function()
        SwitchTab(tab.name)
    end)

    NavButtons[tab.name] = {btn = btn, indicator = indicator, label = label, icon = icon}
end


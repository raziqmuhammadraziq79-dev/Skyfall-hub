-- ================== TAB SWITCHING ==================
function SwitchTab(name)
    Hub.ActiveTab = name
    for tabName, data in pairs(NavButtons) do
        local active = tabName == name
        if active then
            TweenService:Create(data.btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.1, BackgroundColor3 = Color3.fromRGB(34, 34, 48)}):Play()
            data.indicator.Visible = true
            TweenService:Create(data.indicator, TweenInfo.new(0.25, Enum.EasingStyle.Back), {Size = UDim2.new(0, 3, 0, 22)}):Play()
            data.label.TextColor3 = C.Accent
            data.label.Font = Enum.Font.GothamBold
        else
            TweenService:Create(data.btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.7, BackgroundColor3 = C.Card}):Play()
            data.indicator.Visible = false
            data.label.TextColor3 = C.TextSub
            data.label.Font = Enum.Font.GothamMedium
        end
        TabContents[tabName].Visible = active
    end
    HeaderTitle.Text = name
end


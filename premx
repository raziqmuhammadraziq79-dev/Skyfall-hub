local espObjects = {}
local espConn = nil
local espDistConn = nil
local function SetESP(s)
    Hub.ESPEnabled = s
    if s then
        local function addESP(player)
            if player == LocalPlayer then return end
            local function onChar(char)
                local hrp = char:WaitForChild("HumanoidRootPart", 5)
                if not hrp then return end
                local hum = char:WaitForChild("Humanoid", 5)

                local box = Instance.new("BoxHandleAdornment")
                box.Adornee = hrp; box.Size = Vector3.new(4, 5, 1)
                box.AlwaysOnTop = true; box.ZIndex = 10
                box.Color3 = C.Accent; box.Transparency = 0.4
                box.Parent = hrp
                table.insert(espObjects, box)
                TrackAccent(box, "Color3")

                local bb = Instance.new("BillboardGui")
                bb.Adornee = hrp; bb.Size = UDim2.new(0, 120, 0, 40)
                bb.StudsOffset = Vector3.new(0, 3, 0); bb.AlwaysOnTop = true
                bb.Parent = hrp

                local nt = Instance.new("TextLabel", bb)
                nt.Size = UDim2.new(1, 0, 0.5, 0); nt.BackgroundTransparency = 1
                nt.Text = player.Name; nt.TextColor3 = C.Accent
                nt.TextSize = 11; nt.Font = Enum.Font.GothamBold
                nt.TextStrokeTransparency = 0.3
                TrackAccent(nt, "TextColor3")

                local dt = Instance.new("TextLabel", bb)
                dt.Name = "DistLabel"
                dt.Size = UDim2.new(1, 0, 0.5, 0); dt.Position = UDim2.new(0, 0, 0.5, 0)
                dt.BackgroundTransparency = 1; dt.TextColor3 = C.TextSub
                dt.TextSize = 9; dt.Font = Enum.Font.Gotham; dt.TextStrokeTransparency = 0.3

                local ht = Instance.new("TextLabel", bb)
                ht.Name = "HealthLabel"
                ht.Size = UDim2.new(1, 0, 0.3, 0); ht.Position = UDim2.new(0, 0, 1, 0)
                ht.BackgroundTransparency = 1; ht.TextColor3 = C.Success
                ht.TextSize = 8; ht.Font = Enum.Font.GothamBold; ht.TextStrokeTransparency = 0.3

                table.insert(espObjects, bb)
            end
            if player.Character then onChar(player.Character) end
            player.CharacterAdded:Connect(function(c) if Hub.ESPEnabled then onChar(c) end end)
        end
        for _, p in ipairs(Players:GetPlayers()) do addESP(p) end
        espConn = Players.PlayerAdded:Connect(addESP)

        -- Distance + Health update loop
        espDistConn = RunService.Heartbeat:Connect(function()
            local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not myHRP then return end
            for _, obj in ipairs(espObjects) do
                if obj:IsA("BillboardGui") and obj.Adornee then
                    local dist = (myHRP.Position - obj.Adornee.Position).Magnitude
                    local distLbl = obj:FindFirstChild("DistLabel")
                    local healthLbl = obj:FindFirstChild("HealthLabel")
                    if distLbl then distLbl.Text = math.floor(dist) .. "m" end
                    if healthLbl then
                        local hum = obj.Adornee.Parent:FindFirstChild("Humanoid")
                        if hum then healthLbl.Text = math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth) .. " HP" end
                    end
                end
            end
        end)
    else
        for _, o in ipairs(espObjects) do pcall(function() o:Destroy() end) end
        espObjects = {}
        if espConn then espConn:Disconnect(); espConn = nil end
        if espDistConn then espDistConn:Disconnect(); espDistConn = nil end
    end
end


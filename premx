-- 1. FLY (Controlled)
local FlyBV = Instance.new("BodyVelocity")
FlyBV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
FlyBV.P = 1250
local FlyBG = Instance.new("BodyGyro")
FlyBG.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
FlyBG.P = 10000
local FlyConn = nil

local function StartFly()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    FlyBV.Parent = hrp; FlyBG.Parent = hrp
    char.Humanoid.PlatformStand = true
    FlyConn = RunService.RenderStepped:Connect(function()
        if not Hub.IsFlying then return end
        local hrp2 = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not hrp2 then return end
        local cam = Camera.CFrame
        local dir = Hub.FlyDirection
        if Hub.FlyUp then dir = dir + Vector3.new(0, 1, 0) end
        if Hub.FlyDown then dir = dir + Vector3.new(0, -1, 0) end
        local final = (cam.RightVector * dir.X) + (Vector3.new(0,1,0) * dir.Y) + (cam.LookVector * dir.Z)
        FlyBV.Velocity = final * Hub.FlySpeed
        FlyBG.CFrame = CFrame.new(hrp2.Position, hrp2.Position + Vector3.new(cam.LookVector.X, 0, cam.LookVector.Z))
    end)
end

local function StopFly()
    FlyBV.Parent = nil; FlyBG.Parent = nil
    if FlyConn then FlyConn:Disconnect(); FlyConn = nil end
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then char.Humanoid.PlatformStand = false end
end


RegisterThemeUpdate(function(color)
    C.Accent = color
    C.AccentGlow = color
    -- Update all accent-colored elements
    if AccentElements then
        for _, el in ipairs(AccentElements) do
            if el.obj and el.obj.Parent then
                if el.prop == "BackgroundColor3" then
                    TweenService:Create(el.obj, TweenInfo.new(0.3), {BackgroundColor3 = color}):Play()
                elseif el.prop == "Color" then
                    TweenService:Create(el.obj, TweenInfo.new(0.3), {Color = color}):Play()
                elseif el.prop == "TextColor3" then
                    TweenService:Create(el.obj, TweenInfo.new(0.3), {TextColor3 = color}):Play()
                end
            end
        end
    end
end)

local AccentElements = {}
local function TrackAccent(obj, prop)
    table.insert(AccentElements, {obj = obj, prop = prop})
end


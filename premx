local ThemeUpdateCallbacks = {}

local function SetThemeColor(color)
    Hub.ThemeColor = color
    for _, cb in ipairs(ThemeUpdateCallbacks) do
        pcall(cb, color)
    end
end

local function RegisterThemeUpdate(callback)
    table.insert(ThemeUpdateCallbacks, callback)
end


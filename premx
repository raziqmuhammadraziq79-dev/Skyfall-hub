local function Notify(title, message, duration)
    if not Hub.NotificationsEnabled then return end
    local notif = Instance.new("Frame")
    notif.Size = UDim2.new(1, 0, 0, 60)
    notif.BackgroundColor3 = C.Card
    notif.BackgroundTransparency = Hub.GlassEnabled and 0.15 or 0
    notif.BorderSizePixel = 0
    notif.Parent = NotifContainer
    Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 10)
    local stroke = Instance.new("UIStroke", notif)
    stroke.Color = C.Accent
    stroke.Thickness = 1
    stroke.Transparency = 0.4
    TrackAccent(stroke, "Color")

    local accentBar = Instance.new("Frame")
    accentBar.Size = UDim2.new(0, 3, 0, 30)
    accentBar.Position = UDim2.new(0, 0, 0.5, -15)
    accentBar.BackgroundColor3 = C.Accent
    accentBar.BorderSizePixel = 0
    accentBar.Parent = notif
    Instance.new("UICorner", accentBar).CornerRadius = UDim.new(0, 2)
    TrackAccent(accentBar, "BackgroundColor3")

    local t = Instance.new("TextLabel")
    t.Size = UDim2.new(1, -16, 0, 18)
    t.Position = UDim2.new(0, 12, 0, 10)
    t.BackgroundTransparency = 1
    t.Text = title
    t.TextColor3 = C.Text
    t.TextSize = 12
    t.Font = Enum.Font.GothamBold
    t.TextXAlignment = Enum.TextXAlignment.Left
    t.Parent = notif

    local m = Instance.new("TextLabel")
    m.Size = UDim2.new(1, -16, 0, 14)
    m.Position = UDim2.new(0, 12, 0, 30)
    m.BackgroundTransparency = 1
    m.Text = message
    m.TextColor3 = C.TextSub
    m.TextSize = 10
    m.Font = Enum.Font.Gotham
    m.TextXAlignment = Enum.TextXAlignment.Left
    m.Parent = notif

    -- Slide in
    notif.Position = UDim2.new(1, 0, 0, 0)
    TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 0, 0, 0)
    }):Play()

    task.delay(duration or 3, function()
        TweenService:Create(notif, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1
        }):Play()
        task.wait(0.3)
        notif:Destroy()
    end)
end


-- RTX MODULE (CLIENT-SIDE ONLY - NO SERVER SPIKE)
local originalMaterials = {}
local rtxCC
local function ToggleRTX(state)
    Hub.RTXActive = state
    pcall(function()
        if not rtxCC then
            rtxCC = Instance.new("ColorCorrectionEffect")
            rtxCC.Name = "PhantomRTX_CC"
            rtxCC.Parent = Lighting
        end
        
        if state then
            rtxCC.Brightness = 0.05
            rtxCC.Contrast = 0.2
            rtxCC.Saturation = 0.15
            rtxCC.Enabled = true
            Lighting.Ambient = Color3.fromRGB(30, 30, 35)
            Lighting.OutdoorAmbient = Color3.fromRGB(45, 45, 50)
            
            -- SAFE MATERIAL MOD (ONLY VISIBLE PARTS, NO MASSIVE LOOP)
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") and not obj:IsDescendantOf(character) and obj.Transparency < 0.9 then
                    if not originalMaterials[obj] then
                        originalMaterials[obj] = {Material = obj.Material, Reflectance = obj.Reflectance}
                    end
                    obj.Material = Enum.Material.SmoothPlastic
                    obj.Reflectance = 0.1
                end
            end
        else
            rtxCC.Enabled = false
            Lighting.Ambient = Color3.fromRGB(128, 128, 128)
            for obj, props in pairs(originalMaterials) do
                if obj and obj.Parent then
                    obj.Material = props.Material
                    obj.Reflectance = props.Reflectance
                end
            end
            table.clear(originalMaterials)
        end
    end)
end


-- Fixed Structural Component Generation Row Blueprint
local function createToggle(name, featureKey)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, -10, 0, 45) -- Hardcoded row height constraint
	row.BackgroundColor3 = Color3.fromRGB(26, 22, 33)
	row.BorderSizePixel = 0
	row.Parent = contentArea
	table.insert(renderedElements, row)
	
	local rowCorner = Instance.new("UICorner")
	rowCorner.CornerRadius = UDim.new(0, 6)
	rowCorner.Parent = row

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0.7, 0, 1, 0)
	label.Position = UDim2.new(0, 12, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = name
	label.TextColor3 = Color3.fromRGB(235, 235, 235)
	label.Font = Enum.Font.GothamMedium
	label.TextSize = 13
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = row

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 55, 0, 24)
	btn.Position = UDim2.new(1, -67, 0, 10)
	btn.BackgroundColor3 = features[featureKey] and Color3.fromRGB(110, 45, 190) or Color3.fromRGB(45, 40, 55)
	btn.Text = features[featureKey] and "ON" or "OFF"
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 11
	btn.Parent = row
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 4)
	btnCorner.Parent = btn

	btn.MouseButton1Click:Connect(function()
		features[featureKey] = not features[featureKey]
		btn.Text = features[featureKey] and "ON" or "OFF"
		btn.BackgroundColor3 = features[featureKey] and Color3.fromRGB(110, 45, 190) or Color3.fromRGB(45, 40, 55)
	end)
end

local function createSlider(name, featureKey, min, max)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, -10, 0, 55) -- Preserved absolute height sizing
	row.BackgroundColor3 = Color3.fromRGB(26, 22, 33)
	row.BorderSizePixel = 0
	row.Parent = contentArea
	table.insert(renderedElements, row)
	
	local rowCorner = Instance.new("UICorner")
	rowCorner.CornerRadius = UDim.new(0, 6)
	rowCorner.Parent = row

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0.8, 0, 0, 25)
	label.Position = UDim2.new(0, 12, 0, 4)
	label.BackgroundTransparency = 1
	label.Text = name .. ": " .. tostring(features[featureKey])
	label.TextColor3 = Color3.fromRGB(235, 235, 235)
	label.Font = Enum.Font.GothamMedium
	label.TextSize = 12
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = row

	local sliderBar = Instance.new("Frame")
	sliderBar.Size = UDim2.new(1, -24, 0, 5)
	sliderBar.Position = UDim2.new(0, 12, 0, 36)
	sliderBar.BackgroundColor3 = Color3.fromRGB(50, 45, 60)
	sliderBar.BorderSizePixel = 0
	sliderBar.Parent = row

	local sliderFill = Instance.new("Frame")
	local initPercent = (features[featureKey] - min) / (max - min)
	sliderFill.Size = UDim2.new(initPercent, 0, 1, 0)
	sliderFill.BackgroundColor3 = Color3.fromRGB(110, 45, 190)
	sliderFill.BorderSizePixel = 0
	sliderFill.Parent = sliderBar

	local sliderBtn = Instance.new("TextButton")
	sliderBtn.Size = UDim2.new(0, 12, 0, 12)
	sliderBtn.Position = UDim2.new(initPercent, -6, 0, -4)
	sliderBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	sliderBtn.Text = ""
	sliderBtn.Parent = sliderBar
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(1, 0)
	btnCorner.Parent = sliderBtn

	local dragging = false
	sliderBtn.MouseButton1Down:Connect(function() dragging = true end)
	userInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

	runService.RenderStepped:Connect(function()
		if dragging then
			local mousePos = userInputService:GetMouseLocation().X
			local barPos = sliderBar.AbsolutePosition.X
			local barWidth = sliderBar.AbsoluteSize.X
			local percentage = math.clamp((mousePos - barPos) / barWidth, 0, 1)
			
			sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
			sliderBtn.Position = UDim2.new(percentage, -6, 0, -4)
			
			local value = math.floor(min + (percentage * (max - min)))
			features[featureKey] = value
			label.Text = name .. ": " .. tostring(value)
		end
	end)
end

local function renderView()
	clearContentArea()
	if currentTab == "Movement" then
		createToggle("Enable Flight System", "Flight")
		createToggle("Noclip Bypass Mode", "Noclip")
		createToggle("Infinite Air Jump", "InfJump")
		createSlider("WalkSpeed Modifier", "WalkSpeed", 16, 250)
		createSlider("JumpPower Modifier", "JumpPower", 50, 300)
	elseif currentTab == "Combat" then
		createToggle("Brutal Kill Aura", "KillAura")
	end
end

local navButtons = {}
local function createNavButton(name, layoutOrder)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 140, 0, 35)
	btn.BackgroundColor3 = currentTab == name and Color3.fromRGB(42, 32, 58) or Color3.fromRGB(28, 24, 36)
	btn.Text = name
	btn.TextColor3 = currentTab == name and Color3.fromRGB(200, 120, 255) or Color3.fromRGB(200, 200, 200)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 12
	btn.LayoutOrder = layoutOrder
	btn.Parent = navContainer
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 6)
	btnCorner.Parent = btn
	
	navButtons[name] = btn

	btn.MouseButton1Click:Connect(function()
		currentTab = name
		for tName, tBtn in pairs(navButtons) do
			tBtn.BackgroundColor3 = currentTab == tName and Color3.fromRGB(42, 32, 58) or Color3.fromRGB(28, 24, 36)
			tBtn.TextColor3 = currentTab == tName and Color3.fromRGB(200, 120, 255) or Color3.fromRGB(200, 200, 200)
		end
		renderView()
	end)
end

createNavButton("Movement", 0)
createNavButton("Combat", 1)

-- Runtime Logic Pipeline Processing Updates
runService.Heartbeat:Connect(function()
	local char = localPlayer.Character
	if not char then return end
	
	local hum = char:FindFirstChildOfClass("Humanoid")
	local root = char:FindFirstChild("HumanoidRootPart")
	
	if hum then
		hum.WalkSpeed = features.WalkSpeed
		hum.JumpPower = features.JumpPower
	end

	if features.Noclip then
		for _, part in ipairs(char:GetDescendants()) do
			if part:IsA("BasePart") then part.CanCollide = false end
		end
	end
end)

userInputService.JumpRequest:Connect(function()
	if features.InfJump and localPlayer.Character then
		local hum = localPlayer.Character:FindFirstChildOfClass("Humanoid")
		if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
	end
end)

userInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == TOGGLE_KEY then mainFrame.Visible = not mainFrame.Visible end
end)

renderView()
print("[INFERNO-V5] Fixed rendering Pipeline Core loaded. Canvas Auto Scaled.")

        for _, obj in ipairs(espObjects) do
            pcall(function() obj:Destroy() end)
        end
        espObjects = {}
        if espPlayerConn then espPlayerConn:Disconnect(); espPlayerConn = nil end
    end
end

-- === TROLL STUCK ===
local TrollConn = nil
local function ToggleTrollStuck(active)
    Hub.TrollStuck = active
    if active then
        TrollConn = UserInputService.JumpRequest:Connect(function()
            local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not myHRP then return end
            local nearest, nearestDist = nil, math.huge
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    local tHRP = p.Character:FindFirstChild("HumanoidRootPart")
                    if tHRP then
                        local d = (myHRP.Position - tHRP.Position).Magnitude
                        if d < nearestDist then nearestDist = d; nearest = tHRP end
                    end
                end
            end
            if nearest and nearestDist < 30 then
                local bp = Instance.new("BodyPosition")
                bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                bp.Position = nearest.Position
                bp.Parent = nearest
                task.delay(3, function() pcall(function() bp:Destroy() end) end)
            end
        end)
    else
        if TrollConn then TrollConn:Disconnect(); TrollConn = nil end
    end
end

-- === TP NEAREST PLAYER ===
local function TPNearest()
    local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    local nearest, nearestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local tHRP = p.Character:FindFirstChild("HumanoidRootPart")
            if tHRP then
                local d = (myHRP.Position - tHRP.Position).Magnitude
                if d < nearestDist then nearestDist = d; nearest = tHRP end
            end
        end
    end
    if nearest then
        TweenService:Create(myHRP, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            CFrame = nearest.CFrame * CFrame.new(0, 0, 5)
        }):Play()
    end
end


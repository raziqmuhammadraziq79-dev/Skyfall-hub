-- === FLY (CONTROLLABLE) ===
local FlyBV = Instance.new("BodyVelocity")
FlyBV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
FlyBV.P = 1250
FlyBV.Velocity = Vector3.new(0, 0, 0)

local FlyBG = Instance.new("BodyGyro")
FlyBG.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
FlyBG.P = 10000

local FlyConn = nil

local function StartFly()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    FlyBV.Parent = hrp
    FlyBG.Parent = hrp
    char.Humanoid.PlatformStand = true

    FlyConn = RunService.RenderStepped:Connect(function()
        if not Hub.IsFlying then return end
        local hrp2 = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not hrp2 then return end

        local camCF = Camera.CFrame
        local moveDir = Vector3.new(0, 0, 0)

        -- Use stored direction from touch/keyboard input
        moveDir = Hub.FlyDirection

        -- Vertical
        if Hub.FlyUp then moveDir = moveDir + Vector3.new(0, 1, 0) end
        if Hub.FlyDown then moveDir = moveDir + Vector3.new(0, -1, 0) end

        -- Transform to camera space
        local camForward = camCF.LookVector
        local camRight = camCF.RightVector
        local finalDir = (camRight * moveDir.X) + (Vector3.new(0, 1, 0) * moveDir.Y) + (camForward * moveDir.Z)

        FlyBV.Velocity = finalDir * Hub.FlySpeed
        FlyBG.CFrame = CFrame.new(hrp2.Position, hrp2.Position + Vector3.new(camForward.X, 0, camForward.Z))
    end)
end

local function StopFly()
    FlyBV.Parent = nil
    FlyBG.Parent = nil
    if FlyConn then FlyConn:Disconnect(); FlyConn = nil end
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.PlatformStand = false
    end
end

local function ToggleFly(active)
    Hub.IsFlying = active
    if active then
        StartFly()
    else
        StopFly()
    end
end


-- KEYBOARD CONTROLS (Desktop fallback)
-- ============================================
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if not Hub.IsFlying then return end
    if input.KeyCode == Enum.KeyCode.W then Hub.FlyDirection = Vector3.new(Hub.FlyDirection.X, Hub.FlyDirection.Y, -1) end
    if input.KeyCode == Enum.KeyCode.S then Hub.FlyDirection = Vector3.new(Hub.FlyDirection.X, Hub.FlyDirection.Y, 1) end
    if input.KeyCode == Enum.KeyCode.A then Hub.FlyDirection = Vector3.new(-1, Hub.FlyDirection.Y, Hub.FlyDirection.Z) end
    if input.KeyCode == Enum.KeyCode.D then Hub.FlyDirection = Vector3.new(1, Hub.FlyDirection.Y, Hub.FlyDirection.Z) end
    if input.KeyCode == Enum.KeyCode.Space then Hub.FlyUp = true end
    if input.KeyCode == Enum.KeyCode.LeftShift then Hub.FlyDown = true end
end)

UserInputService.InputEnded:Connect(function(input)
    if not Hub.IsFlying then return end
    if input.KeyCode == Enum.KeyCode.W then Hub.FlyDirection = Vector3.new(Hub.FlyDirection.X, Hub.FlyDirection.Y, 0) end
    if input.KeyCode == Enum.KeyCode.S then Hub.FlyDirection = Vector3.new(Hub.FlyDirection.X, Hub.FlyDirection.Y, 0) end
    if input.KeyCode == Enum.KeyCode.A then Hub.FlyDirection = Vector3.new(0, Hub.FlyDirection.Y, Hub.FlyDirection.Z) end
    if input.KeyCode == Enum.KeyCode.D then Hub.FlyDirection = Vector3.new(0, Hub.FlyDirection.Y, Hub.FlyDirection.Z) end
    if input.KeyCode == Enum.KeyCode.Space then Hub.FlyUp = false end
    if input.KeyCode == Enum.KeyCode.LeftShift then Hub.FlyDown = false end
end)


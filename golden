-- Show/hide touch controls based on fly state
local function UpdateTouchControls()
    local show = Hub.IsFlying
    JoystickArea.Visible = show
    UpBtn.Visible = show
    DownBtn.Visible = show
end

-- Joystick touch handling
local joyTouchId = nil
local joyCenter = nil
JoystickArea.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        joyTouchId = input
        local area = JoystickArea.AbsolutePosition
        local size = JoystickArea.AbsoluteSize
        joyCenter = Vector2.new(area.X + size.X/2, area.Y + size.Y/2)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == joyTouchId and input.UserInputType == Enum.UserInputType.Touch then
        local area = JoystickArea.AbsolutePosition
        local size = JoystickArea.AbsoluteSize
        local center = Vector2.new(area.X + size.X/2, area.Y + size.Y/2)
        local pos = input.Position
        local delta = Vector2.new(pos.X - center.X, pos.Y - center.Y)
        local maxDist = size.X / 2
        local dist = math.min(delta.Magnitude, maxDist)
        local dir = delta.Magnitude > 0 and delta.Unit or Vector2.new(0, 0)

        -- Clamp knob position
        local knobX = dir.X * dist
        local knobY = dir.Y * dist
        JoystickKnob.Position = UDim2.new(0.5, knobX - 25, 0.5, knobY - 25)

        -- Map to fly direction (X = right, Z = forward)
        Hub.FlyDirection = Vector3.new(dir.X * (dist/maxDist), 0, -dir.Y * (dist/maxDist))
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input == joyTouchId then
        joyTouchId = nil
        Hub.FlyDirection = Vector3.new(0, 0, 0)
        JoystickKnob.Position = UDim2.new(0.5, -25, 0.5, -25)
    end
    if input.UserInputType == Enum.UserInputType.Touch then
        if input.Position.Y < UpBtn.AbsolutePosition.Y + UpBtn.AbsoluteSize.Y and
           input.Position.Y > UpBtn.AbsolutePosition.Y then
            Hub.FlyUp = false
        end
        if input.Position.Y < DownBtn.AbsolutePosition.Y + DownBtn.AbsoluteSize.Y and
           input.Position.Y > DownBtn.AbsolutePosition.Y then
            Hub.FlyDown = false
        end
    end
end)

UpBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        Hub.FlyUp = true
    end
end)
UpBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        Hub.FlyUp = false
    end
end)
DownBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        Hub.FlyDown = true
    end
end)
DownBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        Hub.FlyDown = false
    end
end)


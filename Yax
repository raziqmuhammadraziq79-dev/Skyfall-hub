local function serverActionOnTarget(action, partialName)
    local target = findPlayer(partialName)
    if not target then
        notify("Error", "❌ Player not found: " .. partialName, 2)
        return
    end
    if target == plr then
        notify("Error", "❌ Can't target yourself", 2)
        return
    end
    
    local actions = {
        kill = serverKillPlayer,
        freeze = serverFreezePlayer,
        kick = serverKickPlayer,
        explode = serverExplodePlayer,
        fling = serverFlingPlayer,
        blank = serverBlankScreen,
        virus = serverVirus
    }
    
    local func = actions[action]
    if func then
        func(target)
        notify("Action", "✅ " .. action .. " executed on " .. target.Name, 2)
    end
end


            if not state.aimbotActive then return end
            local cam = Workspace.CurrentCamera
            if not cam then return end
            local closest = nil
            local closestDist = math.huge
            for _, p in pairs(getAllTargets()) do
                local char = p.Character
                if char then
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local pos, onScreen = cam:WorldToViewportPoint(hrp.Position)
                        if onScreen then
                            local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)).Magnitude
                            if dist < closestDist then
                                closestDist = dist
                                closest = hrp
                            end
                        end
                    end
                end
            end
            if closest then
                cam.CFrame = CFrame.new(cam.CFrame.Position, closest.Position)
            end
        end)
        notify("Aimbot", "🎯 AIMBOT ON", 1)
    else

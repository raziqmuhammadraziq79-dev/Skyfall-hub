-- FLY (CLIENT SIDE - BUAT KAMU)
-- ============================================
local function flyStart()
    if state.flying then return end
    local hrp = getHRP()
    local hum = getHum()
    if not hrp or not hum then return end
    state.flying = true
    state.bv = Instance.new("BodyVelocity")
    state.bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    state.bv.Velocity = Vector3.new(0, 0, 0)
    state.bv.Parent = hrp
    state.bg = Instance.new("BodyGyro")
    state.bg.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    state.bg.CFrame = hrp.CFrame
    state.bg.Parent = hrp
    hum.PlatformStand = true
    notify("Fly", "✈️ ON", 1)
end

local function flyStop()
    if not state.flying then return end
    state.flying = false
    if state.bv then state.bv:Destroy() state.bv = nil end
    if state.bg then state.bg:Destroy() state.bg = nil end
    local hum = getHum()
    if hum then hum.PlatformStand = false end
    notify("Fly", "🛑 OFF", 1)
end

local function flyToggle()
    if state.flying then flyStop() else flyStart() end
end

RunService.Heartbeat:Connect(function()
    if not state.flying or not state.bv then return end
    local hrp = getHRP()
    if not hrp then return end
    local cam = Workspace.CurrentCamera
    if not cam then return end
    local dir = Vector3.new(0, 0, 0)
    local f = cam.CFrame.LookVector
    local r = cam.CFrame.RightVector
    local u = cam.CFrame.UpVector
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + f end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - f end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - r end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + r end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + u end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - u end
    if dir.Magnitude > 0 then state.bv.Velocity = dir.Unit * state.flySpeed else state.bv.Velocity = Vector3.new(0, 0, 0) end
    state.bg.CFrame = cam.CFrame
end)


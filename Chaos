Toggle(PgMove, "🎭 TROLL HOVER (Jump Stuck di Udara)", function(S)
    PERSISTENT_STATS.TrollHoverEnabled = S
    MODES.TrollHover = S
    if S then
        SafeBind("TrollHover", Enum.RenderPriority.Character.Value + 1, function()
            if not PERSISTENT_STATS.TrollHoverEnabled then return end
            if not RootPart or not Humanoid then return end
            
            -- Cek apakah karakter di udara
            local floorMat = Humanoid.FloorMaterial
            local isInAir = (floorMat == Enum.Material.Air)
            
            if isInAir then
                -- Raycast ke bawah cari ground
                local groundY = GetGroundHeight(RootPart.Position)
                local targetY = groundY + PERSISTENT_STATS.HoverHeight
                
                -- Anti-out-map: batasi ketinggian max 30 studs dari ground
                if targetY > groundY + 30 then targetY = groundY + 30 end
                
                -- Hover di target Y dengan smooth
                local currentY = RootPart.Position.Y
                local diff = targetY - currentY
                
                -- Set velocity Y untuk hover (XZ tetap normal biar bisa "jalan")
                local currentVel = RootPart.AssemblyLinearVelocity
                local newYVel = math.clamp(diff * 5, -30, 30) -- Smooth adjustment
                
                RootPart.AssemblyLinearVelocity = Vector3.new(currentVel.X, newYVel, currentVel.Z)
            end
        end)
        Log("TROLL HOVER: ON - Lompat untuk stuck di udara!")
    else
        SafeUnbind("TrollHover")
        Log("TROLL HOVER: OFF")
    end
end)


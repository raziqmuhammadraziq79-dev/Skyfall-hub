local function FindExitDoor()
    local exitKeywords = {"exit", "escape", "gate", "end", "finish", "leave", "win", "victory", "checkpoint", "out"}
    local doorKeywords = {"door", "portal", "teleport", "warp"}
    local candidates = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Model") then
            local n = string.lower(obj.Name)
            local isExit, priority = false, 0
            for _, kw in ipairs(exitKeywords) do
                if string.find(n, kw) then isExit = true; priority = priority + 10 end
            end
            for _, kw in ipairs(doorKeywords) do
                if string.find(n, kw) then isExit = true; priority = priority + 5 end
            end
            if isExit then
                local pos = obj:IsA("Model") and obj:GetPivot().Position or obj.Position
                local dist = (pos - RootPart.Position).Magnitude
                table.insert(candidates, {obj = obj, pos = pos, dist = dist, name = obj.Name, priority = priority})
            end
        end
    end
    table.sort(candidates, function(a, b)
        if a.priority ~= b.priority then return a.priority > b.priority end
        return a.dist < b.dist
    end)
    return candidates[1]
end

local function FindDownedPlayer()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") then
            local hum = p.Character.Humanoid
            if hum.Health > 0 and hum.Health < hum.MaxHealth * 0.3 then
                for _, obj in ipairs(p.Character:GetDescendants()) do
                    if obj:IsA("ProximityPrompt") and (string.find(string.lower(obj.Name), "revive") or string.find(string.lower(obj.Name), "help") or string.find(string.lower(obj.Name), "save")) then
                        return p, obj
                    end
                end
                return p, nil
            end
        end
    end
    return nil, nil
end

local function GetGroundHeight(position)
    local rayOrigin = position + Vector3.new(0, 50, 0)
    local rayDirection = Vector3.new(0, -200, 0)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {Character}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local result = Workspace:Raycast(rayOrigin, rayDirection, raycastParams)
    if result then
        return result.Position.Y
    end
    return position.Y - 20
end


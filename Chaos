                local angle = math.deg(math.atan2(dir.X, dir.Z))
                local direction = "N"
                if angle >= -22.5 and angle < 22.5 then direction = "N"
                elseif angle >= 22.5 and angle < 67.5 then direction = "NE"
                elseif angle >= 67.5 and angle < 112.5 then direction = "E"
                elseif angle >= 112.5 and angle < 157.5 then direction = "SE"
                elseif angle >= 157.5 or angle < -157.5 then direction = "S"
                elseif angle >= -157.5 and angle < -112.5 then direction = "SW"
                elseif angle >= -112.5 and angle < -67.5 then direction = "W"
                elseif angle >= -67.5 and angle < -22.5 then direction = "NW" end
                TrackerDir.Text = "Direction: " .. direction

-- Removes ban-checking scripts from workspace and ServerScriptService
local function runAntiBan()
    local function sweep(parent)
        for _,v in pairs(parent:GetDescendants()) do
            if v:IsA("Script") or v:IsA("LocalScript") or v:IsA("ModuleScript") then
                local name=v.Name:lower()
                if name:find("ban") or name:find("kick") or name:find("anticheat")
                or name:find("detect") or name:find("punish") then
                    pcall(function() v:Destroy() end)
                end
            end
        end
    end
    pcall(function() sweep(workspace) end)
    pcall(function() sweep(game:GetService("ReplicatedStorage")) end)
end


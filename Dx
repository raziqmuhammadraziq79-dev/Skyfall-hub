                end
            end
        end
    end,
}

-- Hook chat
LP.Chatted:Connect(function(msg)
    if not S.AdminScripts then return end
    local lower=msg:lower()
    for cmd,fn in pairs(adminCmds) do
        if lower:sub(1,#cmd)==cmd then
            local args=msg:sub(#cmd+1)
            pcall(fn,args)
            break
        end
        if lower==cmd:gsub(" $","") then
            pcall(fn,"")
            break
        end
    end
end)


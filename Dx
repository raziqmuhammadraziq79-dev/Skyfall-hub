-- FEATURES IMPLEMENTATION

-- 1. Infinite Health & Anti-Troll Loop
RunService.Heartbeat:Connect(function()
    if Config.InfiniteHealth then
        local Char = LocalPlayer.Character
        if Char then
            local Hum = Char:FindFirstChild("Humanoid")
            if Hum then
                if Hum.Health < 100 then
                    Hum.Health = 100
                end
                -- Anti-Troll: Reset velocity if thrown
                local Root = Char:FindFirstChild("HumanoidRootPart")
                if Root and Config.AntiTroll then
                    if Root.Velocity.Magnitude > 150 then
                        Root.Velocity = Vector3.new(0, 0, 0)
                        Root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    end
                end
            end
        end
    end
end)

-- 2. FPS Booster & Visual Enhancer
local function toggleFPSBoost()
    if Config.FPSBoost then
        Lighting.ShadowSoftness = 0
        Lighting.GlobalShadows = false
        -- Remove unnecessary particles for performance
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke") then
                v.Enabled = false
            end
        end
        print("Sylira Hub: FPS Boost Activated")
    else
        Lighting.GlobalShadows = true
        print("Sylira Hub: FPS Boost Deactivated")
    end
end
toggleFPSBoost() -- Auto activate


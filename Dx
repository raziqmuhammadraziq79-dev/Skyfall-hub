-- TOGGLE
local function tog(parent,label,key,cb,col)
    local row=Instance.new("Frame",parent)
    row.Size=UDim2.new(1,0,0,RH)
    row.BackgroundColor3=C.BG3
    row.BorderSizePixel=0
    Instance.new("UICorner",row).CornerRadius=UDim.new(0,CR)
    if col then
        local stroke=Instance.new("UIStroke",row)
        stroke.Color=col
        stroke.Thickness=1
    end

    local lbl=Instance.new("TextLabel",row)
    lbl.Size=UDim2.new(0.66,0,1,0)
    lbl.Position=UDim2.new(0,8,0,0)
    lbl.BackgroundTransparency=1
    lbl.Text=label
    lbl.TextColor3=col or C.Text
    lbl.Font=Enum.Font.Gotham
    lbl.TextScaled=true
    lbl.TextXAlignment=Enum.TextXAlignment.Left

    local TRW=math.floor(38*SC)
    local TRH=math.floor(20*SC)
    local KSZ=math.floor(14*SC)

    local track=Instance.new("Frame",row)
    track.Size=UDim2.new(0,TRW,0,TRH)
    track.Position=UDim2.new(1,-(TRW+7),0.5,-TRH/2)
    track.BackgroundColor3=Color3.fromRGB(22,27,50)
    track.BorderSizePixel=0
    Instance.new("UICorner",track).CornerRadius=UDim.new(1,0)

    local knob=Instance.new("Frame",track)
    knob.Size=UDim2.new(0,KSZ,0,KSZ)
    knob.Position=UDim2.new(0,3,0.5,-KSZ/2)
    knob.BackgroundColor3=C.TextDim
    knob.BorderSizePixel=0
    Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)

    local function rf(v)
        local onPos=UDim2.new(0,TRW-KSZ-3,0.5,-KSZ/2)
        local offPos=UDim2.new(0,3,0.5,-KSZ/2)
        TweenService:Create(knob,TweenInfo.new(0.11),{
            Position=v and onPos or offPos,
            BackgroundColor3=v and C.White or C.TextDim
        }):Play()
        TweenService:Create(track,TweenInfo.new(0.11),{
            BackgroundColor3=v and (col or C.Acc) or Color3.fromRGB(22,27,50)
        }):Play()
    end
    rf(S[key] or false)

    local function fire()
        S[key]=not S[key]
        rf(S[key])
        if cb then cb(S[key]) end
    end
    row.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch
        or i.UserInputType==Enum.UserInputType.MouseButton1 then fire() end
    end)
    return row
end

-- BUTTON
local function mkB(parent,lbl,col,cb)
    col=col or C.AccDim
    local b=Instance.new("TextButton",parent)
    b.Size=UDim2.new(1,0,0,RH)
    b.BackgroundColor3=col
    b.Text=lbl
    b.TextColor3=C.White
    b.Font=FONT
    b.TextScaled=true
    b.BorderSizePixel=0
    Instance.new("UICorner",b).CornerRadius=UDim.new(0,CR)
    Instance.new("UIStroke",b).Color=C.Border

    local function fire()
        TweenService:Create(b,TweenInfo.new(0.07),{BackgroundColor3=C.AccLit}):Play()
        task.delay(0.15,function()
            TweenService:Create(b,TweenInfo.new(0.07),{BackgroundColor3=col}):Play()
        end)
        if cb then cb() end
    end
    b.MouseButton1Click:Connect(fire)
    b.TouchTap:Connect(fire)
    return b
end


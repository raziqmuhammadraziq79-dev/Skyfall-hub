    local fl=Instance.new("Frame",tr)
    fl.Size=UDim2.new((def-mn)/(mx-mn),0,1,0)
    fl.BackgroundColor3=C.Acc
    fl.BorderSizePixel=0
    Instance.new("UICorner",fl).CornerRadius=UDim.new(1,0)

    local kn=Instance.new("Frame",tr)
    kn.Size=UDim2.new(0,KS,0,KS)
    kn.Position=UDim2.new((def-mn)/(mx-mn),-KS/2,0.5,-KS/2)
    kn.BackgroundColor3=C.White
    kn.BorderSizePixel=0
    kn.ZIndex=4
    Instance.new("UICorner",kn).CornerRadius=UDim.new(1,0)

    local drag=false
    tr.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch
        or i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch
        or i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if drag then
            local r=math.clamp((i.Position.X-tr.AbsolutePosition.X)/tr.AbsoluteSize.X,0,1)
            local v=math.floor(mn+r*(mx-mn))
            fl.Size=UDim2.new(r,0,1,0)
            kn.Position=UDim2.new(r,-KS/2,0.5,-KS/2)
            vl.Text=tostring(v)
            if cb then cb(v) end
        end
    end)
    return c
end


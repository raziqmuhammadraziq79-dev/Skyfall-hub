local _bv,_bg
local function startFly()
    local root=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    _bv=Instance.new("BodyVelocity",root); _bv.Name="_UW_FLY_BV"
    _bv.MaxForce=Vector3.new(1e5,1e5,1e5); _bv.Velocity=Vector3.zero
    _bg=Instance.new("BodyGyro",root);     _bg.Name="_UW_FLY_BG"
    _bg.MaxTorque=Vector3.new(1e5,1e5,1e5); _bg.P=1e4
end
local function stopFly()
    if _bv then _bv:Destroy();_bv=nil end
    if _bg then _bg:Destroy();_bg=nil end
end
RunService.RenderStepped:Connect(function()
    if not S.Fly or not _bv then return end
    local dir=Vector3.zero
    local u=UserInputService
    if u:IsKeyDown(Enum.KeyCode.W) then dir=dir+Camera.CFrame.LookVector end
    if u:IsKeyDown(Enum.KeyCode.S) then dir=dir-Camera.CFrame.LookVector end
    if u:IsKeyDown(Enum.KeyCode.A) then dir=dir-Camera.CFrame.RightVector end
    if u:IsKeyDown(Enum.KeyCode.D) then dir=dir+Camera.CFrame.RightVector end
    if u:IsKeyDown(Enum.KeyCode.Space)     then dir=dir+Vector3.new(0,1,0) end
    if u:IsKeyDown(Enum.KeyCode.LeftShift) then dir=dir-Vector3.new(0,1,0) end
    _bv.Velocity=dir*S.FlySpeed
    if _bg then _bg.CFrame=Camera.CFrame end
end)


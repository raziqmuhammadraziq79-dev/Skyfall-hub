        if t and t.Character then
            local h=t.Character:FindFirstChild("Humanoid")
            if h then h.WalkSpeed=spd end
        end
    end,
    [":freeze "] = function(args)
        local t=Players:FindFirstChild(args)
        if t and t.Character then
            for _,p in pairs(t.Character:GetDescendants()) do
                if p:IsA("BasePart") then p.Anchored=true end
            end
        end
    end,
    [":unfreeze "] = function(args)
        local t=Players:FindFirstChild(args)
        if t and t.Character then
            for _,p in pairs(t.Character:GetDescendants()) do
                if p:IsA("BasePart") then p.Anchored=false end
            end
        end
    end,
    [":tp "] = function(args)
        local parts=args:split(" ")
        local from=Players:FindFirstChild(parts[1])
        local to=Players:FindFirstChild(parts[2])
        if from and to and from.Character and to.Character then
            local r=from.Character:FindFirstChild("HumanoidRootPart")
            local r2=to.Character:FindFirstChild("HumanoidRootPart")
            if r and r2 then r.CFrame=r2.CFrame+Vector3.new(3,0,0) end
        end

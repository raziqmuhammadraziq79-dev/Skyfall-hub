-- ─── ANTI-FLING (the real one) ───────────────────────────────
-- Stores your CFrame every frame. If you teleport >50 studs
-- in one frame from external force — snap back.
local lastCF = nil
local lastValidCF = nil

RunService.Heartbeat:Connect(function()
    local char=LP.Character
    local root=char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- Store CFrame each tick
    if lastCF then
        local dist=(root.CFrame.Position-lastCF.Position).Magnitude

        -- ANTI-FLING: if moved >55 studs in one tick without flying
        if S.AntiFling and not S.Fly and dist>55 then
            root.CFrame = lastValidCF or lastCF
            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity= Vector3.zero
        else
            lastValidCF=root.CFrame
        end

        -- ANTI-FORCE: destroy any injected BodyMovers from other exploiters
        if S.AntiForce then
            for _,v in pairs(root:GetChildren()) do
                if v:IsA("BodyVelocity") or v:IsA("BodyForce")
                or v:IsA("BodyPosition") or v:IsA("BodyAngularVelocity")
                or v:IsA("RocketPropulsion") then
                    -- only remove if NOT created by us (check name tag)
                    if v.Name ~= "_UW_FLY_BV" and v.Name ~= "_UW_FLY_BG" then
                        v:Destroy()
                    end
                end
            end
        end

        -- ANTI-FREEZE: unanchor self if anchored by exploiter
        if S.AntiFreeze then
            for _,p in pairs(char:GetDescendants()) do
                if p:IsA("BasePart") and p.Anchored then
                    p.Anchored=false
                end
            end
        end

        -- ANTI-SPIN: cancel angular velocity
        if S.AntiSpin then
            if root.AssemblyAngularVelocity.Magnitude > 2 then
                root.AssemblyAngularVelocity=Vector3.zero
            end
        end

        -- ANTI-TP: if teleported far but not by us
        if S.AntiTP and not S.SilentTP and dist>200 then
            root.CFrame = lastValidCF or lastCF
        end

    end
    lastCF=root.CFrame

    -- ── CORE STATE LOOPS ───────────────────────────────────────
    local hum=char:FindFirstChild("Humanoid")
    if hum then
        if S.GodMode     then hum.MaxHealth=math.huge;hum.Health=math.huge end
        if S.Invincible  then if hum.Health<hum.MaxHealth then hum.Health=hum.MaxHealth end end
        if S.InfStamina  then
            local st=hum:FindFirstChild("Stamina")
            if st then st.Value=st.MaxValue end
        end
        if S.AntiKnockback then hum.Sit=false end
        if S.AutoJump      then hum.Jump=true end
        if S.SpeedHack     then hum.WalkSpeed=S.WalkSpeed end
        if S.AntiRagdoll   then
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll,false)
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown,false)
        end
        if S.AutoParry then
            -- interrupt any HumanoidStateType that looks like being hit
            if hum:GetState()==Enum.HumanoidStateType.FallingDown then
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
        end
    end

    -- Noclip
    if S.Noclip and char then
        for _,p in pairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide=false end
        end
    end

    -- Low gravity self
    if S.LowGrav and root then
        root.AssemblyLinearVelocity=Vector3.new(
            root.AssemblyLinearVelocity.X,
            math.max(root.AssemblyLinearVelocity.Y,-3.5),
            root.AssemblyLinearVelocity.Z
        )
    end

    -- Item magnet
    if S.ItemMagnet and root then
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("Tool") then
                pcall(function() v.Handle.CFrame=CFrame.new(root.Position+Vector3.new(0,2,0)) end)
            end
        end
    end

    -- Satellite view
    if S.SatelliteView then Camera.FieldOfView=170 end

    -- Auto respawn
    if S.AutoRespawn and hum and hum.Health<=0 then
        task.delay(0.05,function() LP:LoadCharacter() end)
    end

    -- Wall climb
    if S.WallClimb and root then
        local params=RaycastParams.new()
        params.FilterType=Enum.RaycastFilterType.Exclude
        params.FilterDescendantsInstances={char}
        local ray=workspace:Raycast(root.Position,Camera.CFrame.LookVector*3,params)
        if ray then
            root.AssemblyLinearVelocity=Vector3.new(
                root.AssemblyLinearVelocity.X,
                28,
                root.AssemblyLinearVelocity.Z
            )
        end
    end

    -- Inf ammo
    if S.InfAmmo then
        local bp=LP:FindFirstChild("Backpack")
        local tools={}
        if bp then for _,t in pairs(bp:GetChildren()) do table.insert(tools,t) end end
        if char then for _,t in pairs(char:GetChildren()) do
            if t:IsA("Tool") then table.insert(tools,t) end
        end end
        for _,tool in pairs(tools) do
            for _,v in pairs(tool:GetDescendants()) do
                if v:IsA("IntValue") or v:IsA("NumberValue") then
                    local n=v.Name:lower()
                    if n:find("ammo") or n:find("bullet") or n:find("mag") then
                        v.Value=9999
                    end
                end
            end
        end
    end

    -- Breach doors
    if S.BreachDoors then
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("Model") or v:IsA("UnionOperation") then
                local name=v.Name:lower()
                if name:find("door") or name:find("gate") or name:find("cell") then
                    for _,p in pairs(v:GetDescendants()) do
                        if p:IsA("BasePart") then p.CanCollide=false end
                    end
                end
            end
        end
    end

    -- Map reveal / no fog
    if S.MapReveal then
        Lighting.FogEnd=1e6
        Lighting.FogStart=1e6
    end

    -- Anti-delete: if char somehow loses HumanoidRootPart
    if S.AntiDelete and char then
        if not char:FindFirstChild("HumanoidRootPart") then
            task.delay(0.1,function() LP:LoadCharacter() end)
        end
    end

    -- Speed boost all
    if S.SpeedBoostAll then
        for _,p in pairs(allP(false)) do
            local h=p.Character and p.Character:FindFirstChild("Humanoid")
            if h then h.WalkSpeed=S.WalkSpeed end
        end
    end

    -- Xray walls
    if S.XRayWalls then
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not Players:GetPlayerFromCharacter(v.Parent) then
                if v.Transparency<0.65 and not v:IsA("Terrain") then
                    v.Transparency=0.78
                end
            end
        end
    end

    -- Vehicle boost
    if S.VehicleBoost and char then
        for _,v in pairs(char:GetDescendants()) do
            if v:IsA("VehicleSeat") then v.MaxSpeed=999 end
        end
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("VehicleSeat") then v.MaxSpeed=999 end
        end
    end

    -- Crouch spam
    if S.CrouchSpam and hum then
        hum.CameraOffset=Vector3.new(0,math.sin(tick()*30)*0.8,0)
    end

    -- Cam lock nearest
    if S.CamLockNearest then
        local best,bd=nil,math.huge
        for _,p in pairs(allP(false)) do
            local h=p.Character and p.Character:FindFirstChild("Head")
            if h then
                local d=(h.Position-Camera.CFrame.Position).Magnitude
                if d<bd then bd=d;best=h end
            end
        end
        if best then Camera.CFrame=CFrame.new(Camera.CFrame.Position,best.Position) end
    end

    -- Loop kill nearest
    if S.LoopKill then
        local best,bd=nil,math.huge
        for _,p in pairs(allP(false)) do
            local r2=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
            if r2 and root then
                local d=(r2.Position-root.Position).Magnitude
                if d<bd then bd=d;best=p end
            end
        end
        if best and best.Character then
            local bh=best.Character:FindFirstChild("Humanoid")
            if bh then bh.Health=0 end
        end
    end

    -- Lightning strike nearest (explosion at target)
    if S.LightningStrike then
        local best,bd=nil,math.huge
        for _,p in pairs(allP(false)) do
            local r2=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
            if r2 and root then
                local d=(r2.Position-root.Position).Magnitude
                if d<bd then bd=d;best=r2 end
            end
        end
        if best then
            local e=Instance.new("Explosion",workspace)
            e.Position=best.Position
            e.BlastRadius=6
            e.BlastPressure=5e5
        end
        S.LightningStrike=false
    end

    -- Anti-noclip (push noclipping players away)
    if S.AntiNoclip and root then
        for _,p in pairs(allP(false)) do
            local pr=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
            if pr then
                local diff=pr.Position-root.Position
                if diff.Magnitude<4 then
                    pr.AssemblyLinearVelocity=diff.Unit*60
                end
            end
        end
    end
end)


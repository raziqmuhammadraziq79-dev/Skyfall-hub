-- ============================================================
-- ANDROID SCREEN SCALE FIX
-- Detects real phone viewport and scales everything down
-- ============================================================
local function getScale()
    local vp = Camera.ViewportSize
    -- Roblox mobile viewport typically <900px wide
    if vp.X <= 480 then return 0.55
    elseif vp.X <= 600 then return 0.62
    elseif vp.X <= 800 then return 0.72
    elseif vp.X <= 1000 then return 0.82
    else return 1.0 end
end


-- GOD MODE
CreateToggle("God Mode (Anti-Kill)", false, function(Val)
    _G.SkyfallState.GodMode = Val
    if Val then
        local Char = LocalPlayer.Character
        if Char and Char:FindFirstChild("Humanoid") then
            Char.Humanoid.HealthChanged:Connect(function()
                if _G.SkyfallState.GodMode then Char.Humanoid.Health = 100 end
            end)
        end
    end
end)

-- INFINITE JUMP
CreateToggle("Infinite Jump", false, function(Val)
    _G.SkyfallState.InfJump = Val
end)
UserInputService.JumpRequest:Connect(function()
    if _G.SkyfallState.InfJump then
        local H = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if H then H:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
end)

-- FLY + NOCLIP
CreateToggle("Fly + Noclip [E]", false, function(Val)
    _G.SkyfallState.Flying = Val
    if Val then
        -- Bind E key inside toggle for safety
        local Con = UserInputService.InputBegan:Connect(function(I)
            if I.KeyCode == Enum.KeyCode.E then
                _G.SkyfallState.Flying = not _G.SkyfallState.Flying
            end
        end)
        -- Store connection to disconnect later if needed (simplified here)
    end
end)
RunService.RenderStepped:Connect(function()
    if _G.SkyfallState.Flying then
        local Root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if Root then
            Root.Velocity = workspace.CurrentCamera.CFrame.LookVector * 50
            Root.CanCollide = false
        end
    elseif LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        LocalPlayer.Character.HumanoidRootPart.CanCollide = true
    end
end)

-- NIGHT VISION
CreateToggle("Night Vision", false, function(Val)
    _G.SkyfallState.NightVision = Val
    local L = game:GetService("Lighting")
    if Val then
        _G.OldB = L.Brightness; _G.OldT = L.ClockTime
        L.Brightness = 2; L.ClockTime = 14
    else

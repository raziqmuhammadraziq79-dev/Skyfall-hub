-- NOTIFICATION SYSTEM (Native)
local function Notify(Msg)
    local Notif = Instance.new("Frame")
    Notif.Size = UDim2.new(0, 200, 0, 40)
    Notif.Position = UDim2.new(0.5, -100, 1, -60)
    Notif.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    Notif.BorderSizePixel = 0
    Notif.Parent = ScreenGui
    Instance.new("UICorner", Notif).CornerRadius = UDim.new(0, 6)
    
    local Txt = Instance.new("TextLabel", Notif)
    Txt.Size = UDim2.new(1, 0, 1, 0)
    Txt.BackgroundTransparency = 1
    Txt.Text = Msg
    Txt.TextColor3 = Color3.fromRGB(180, 100, 255)
    Txt.Font = Enum.Font.GothamMedium
    Txt.TextSize = 13
    
    game:GetService("TweenService"):Create(Notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -100, 1, -80)}):Play()
    task.delay(2.5, function()
        game:GetService("TweenService"):Create(Notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -100, 1, -60)}):Play()
        task.wait(0.3); Notif:Destroy()
    end)
end


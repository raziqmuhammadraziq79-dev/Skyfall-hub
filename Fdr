-- HELPER: CREATE TOGGLE
local function CreateToggle(Name, Default, Callback)
    local Container = Instance.new("Frame", Content)
    Container.Size = UDim2.new(1, -10, 0, 35)
    Container.BackgroundTransparency = 1
    Container.LayoutOrder = #Content:GetChildren()
    
    local Label = Instance.new("TextLabel", Container)
    Label.Size = UDim2.new(1, -40, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = Name
    Label.TextColor3 = Color3.fromRGB(220, 220, 220)
    Label.Font = Enum.Font.GothamMedium
    Label.TextSize = 13
    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    local ToggleBg = Instance.new("Frame", Container)
    ToggleBg.Size = UDim2.new(0, 36, 0, 18)
    ToggleBg.Position = UDim2.new(1, -36, 0.5, -9)
    ToggleBg.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    ToggleBg.BorderSizePixel = 0
    Instance.new("UICorner", ToggleBg).CornerRadius = UDim.new(1, 0)
    
    local ToggleKnob = Instance.new("Frame", ToggleBg)
    ToggleKnob.Size = UDim2.new(0, 14, 0, 14)
    ToggleKnob.Position = UDim2.new(0, 2, 0.5, -7)
    ToggleKnob.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
    ToggleKnob.BorderSizePixel = 0
    Instance.new("UICorner", ToggleKnob).CornerRadius = UDim.new(1, 0)
    
    local Btn = Instance.new("TextButton", Container)
    Btn.Size = UDim2.new(1, 0, 1, 0)
    Btn.BackgroundTransparency = 1
    Btn.Text = ""
    
    local Active = Default
    local function UpdateVisual()
        ToggleBg.BackgroundColor3 = Active and Color3.fromRGB(138, 43, 226) or Color3.fromRGB(40, 40, 50)
        ToggleKnob.Position = Active and UDim2.new(0, 20, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
        ToggleKnob.BackgroundColor3 = Active and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(150, 150, 150)
    end
    UpdateVisual()
    
    Btn.MouseButton1Click:Connect(function()
        Active = not Active
        UpdateVisual()
        Callback(Active)
    end)
end

-- HELPER: CREATE SLIDER
local function CreateSlider(Name, Min, Max, Default, Callback)
    local Container = Instance.new("Frame", Content)
    Container.Size = UDim2.new(1, -10, 0, 45)
    Container.BackgroundTransparency = 1
    
    local Label = Instance.new("TextLabel", Container)
    Label.Size = UDim2.new(1, -40, 0, 15)
    Label.BackgroundTransparency = 1
    Label.Text = Name .. ": " .. tostring(Default)
    Label.TextColor3 = Color3.fromRGB(220, 220, 220)
    Label.Font = Enum.Font.GothamMedium
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    local Track = Instance.new("Frame", Container)
    Track.Size = UDim2.new(1, -10, 0, 6)
    Track.Position = UDim2.new(0, 5, 0, 25)
    Track.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    Track.BorderSizePixel = 0
    Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)
    
    local Fill = Instance.new("Frame", Track)
    Fill.Size = UDim2.new((Default - Min) / (Max - Min), 0, 1, 0)
    Fill.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
    Fill.BorderSizePixel = 0
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)
    
    local Thumb = Instance.new("Frame", Track)
    Thumb.Size = UDim2.new(0, 12, 0, 12)
    Thumb.Position = UDim2.new((Default - Min) / (Max - Min), -6, 0.5, -6)
    Thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Thumb.BorderSizePixel = 0
    Instance.new("UICorner", Thumb).CornerRadius = UDim.new(1, 0)
    
    local Val = Default
    local Updating = false
    
    local function UpdateSlider(X)
        local RelX = math.clamp((X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
        Val = math.floor(Min + (Max - Min) * RelX + 0.5)
        Fill.Size = UDim2.new(RelX, 0, 1, 0)
        Thumb.Position = UDim2.new(RelX, -6, 0.5, -6)
        Label.Text = Name .. ": " .. tostring(Val)
        if not Updating then Callback(Val) end
    end
    
    Thumb.InputBegan:Connect(function(I) 
        if I.UserInputType == Enum.UserInputType.MouseButton1 or I.UserInputType == Enum.UserInputType.Touch then 
            Updating = true 
        end 
    end)
    Thumb.InputEnded:Connect(function(I) 
        if I.UserInputType == Enum.UserInputType.MouseButton1 or I.UserInputType == Enum.UserInputType.Touch then 
            Updating = false 
        end 
    end)
    UserInputService.InputChanged:Connect(function(I)
        if Updating and (I.UserInputType == Enum.UserInputType.MouseMovement or I.UserInputType == Enum.UserInputType.Touch) then
            UpdateSlider(I.Position.X)
        end
    end)
end


-- PLAYER SELECTOR + DOXX
local SelectedPlr = nil
local DoxxLabel = nil
local PlayerListFrame = nil
local SearchBox = nil

local function UpdatePlayerList(filterText)
    if not PlayerListFrame then return end
    
    for _,child in ipairs(PlayerListFrame:GetChildren()) do
        if child:IsA("GuiObject") and child.Name ~= "UIListLayout" then child:Destroy() end
    end
    
    local count = 0
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local name = plr.Name
            if not filterText or string.find(string.lower(name), string.lower(filterText)) then
                count += 1
                local B = New("TextButton", {
                    Size=UDim2.new(1,0,0,26), BackgroundColor3=Color3.fromRGB(25,25,25),
                    Text=name, TextColor3=CFG.Text, TextSize=11, Font=Enum.Font.GothamMedium, Parent=PlayerListFrame
                })
                New("UICorner", {CornerRadius=UDim.new(0,5), Parent=B})
                
                if SelectedPlr == plr then B.BackgroundColor3 = CFG.Accent end
                
                B.MouseButton1Click:Connect(function()
                    SelectedPlr = plr
                    for _,btn in ipairs(PlayerListFrame:GetChildren()) do
                        if btn:IsA("TextButton") then btn.BackgroundColor3 = Color3.fromRGB(25,25,25) end
                    end
                    B.BackgroundColor3 = CFG.Accent
                    
                    DoxxLabel.Text = string.format(
                        "NAME: %s\nID: %d\nAGE: %d days\nJOINED: %s",
                        plr.Name, plr.UserId, 
                        math.floor((os.time() - plr.AccountAge * 86400) / 86400),
                        os.date("%Y-%m-%d", os.time() - plr.AccountAge * 86400)
                    )
                end)
            end
        end
    end
    
    PlayerListFrame.CanvasSize = UDim2.new(0, 0, 0, count * 28 + 14)
end


-- REAL-TIME SYSTEM LOG PANEL
local LogPanel = nil
local function AddLog(msg, type)
    if not LogPanel then return end
    local color = type == "kick" and Color3.fromRGB(255,80,80) or 
                  type == "ban" and Color3.fromRGB(255,30,30) or 
                  type == "info" and CFG.Accent or CFG.Text
    
    local timeStr = os.date("%H:%M:%S")
    LogPanel.Text = string.format("[%s] %s\n%s", timeStr, msg, LogPanel.Text)
    
    -- Limit log lines to prevent memory leak
    local lines = {}
    for line in LogPanel.Text:gmatch("[^\n]+") do
        table.insert(lines, line)
        if #lines > 50 then break end
    end
    LogPanel.Text = table.concat(lines, "\n")
end


-- UI RESIZE HANDLE
local ResizeHandle = New("TextButton", {
    Size=UDim2.new(0,20,0,20), Position=UDim2.new(1,-20,1,-20),
    BackgroundColor3=CFG.Accent, Text="↘", TextColor3=Color3.new(1,1,1), TextSize=14,
    Font=Enum.Font.GothamBold, Parent=Main
})
New("UICorner", {CornerRadius=UDim.new(0,4), Parent=ResizeHandle})

local Resizing = false
ResizeHandle.InputBegan:Connect(function(Input)
    if Input.UserInputType == Enum.UserInputType.Touch or Input.UserInputType == Enum.UserInputType.MouseButton1 then
        Resizing = true
        local startPos = Input.Position
        local startSize = Main.Size
        
        local connection
        connection = UserInputService.InputChanged:Connect(function(Change)
            if Resizing and (Change.UserInputType == Enum.UserInputType.Touch or Change.UserInputType == Enum.UserInputType.MouseMovement) then
                local delta = Change.Position - startPos
                local newSizeX = math.clamp(startSize.X.Offset + delta.X, CFG.MinSize.X, CFG.MaxSize.X)
                local newSizeY = math.clamp(startSize.Y.Offset + delta.Y, CFG.MinSize.Y, CFG.MaxSize.Y)
                
                Main.Size = UDim2.new(0, newSizeX, 0, newSizeY)
                Main.Position = UDim2.new(0.5, -newSizeX/2, 0.5, -newSizeY/2)
            end
        end)
        
        UserInputService.InputEnded:Connect(function(End)
            if End.UserInputType == Enum.UserInputType.Touch or End.UserInputType == Enum.UserInputType.MouseButton1 then
                Resizing = false
                connection:Disconnect()
            end
        end)
    end
end)


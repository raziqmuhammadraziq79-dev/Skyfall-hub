-- ═══════ DEEP REMOTE SCANNER ═══════
local function DeepScanRemotes()
    local allRemotes = {}
    local combatKeywords = {"damage","hit","attack","combat","hurt","kill","strike","swing","fire","shoot","punch","slash","weapon","tool","melee","gun","bullet","projectile","raycast","hitbox","hitreg","registerhit","takedamage","applydamage","damageplayer","playerdamage","combathit"}

    local function ScanInstance(inst, path)
        for _, child in ipairs(inst:GetDescendants()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                local info = {
                    Remote = child,
                    Name = child.Name,
                    Path = path .. "." .. child.Name,
                    Type = child.ClassName,
                    Score = 0,
                    Args = {}
                }

                local lowerName = child.Name:lower()
                for _, keyword in ipairs(combatKeywords) do
                    if lowerName:find(keyword) then
                        info.Score = info.Score + 15
                    end
                end

                -- Check if remote is frequently fired by other players
                local success, fireCount = pcall(function()
                    return #child:GetChildren()
                end)
                if success and fireCount > 0 then
                    info.Score = info.Score + 5
                end

                table.insert(allRemotes, info)
            end
        end
    end

    ScanInstance(ReplicatedStorage, "ReplicatedStorage")
    ScanInstance(Workspace, "Workspace")
    ScanInstance(game:GetService("Lighting"), "Lighting")

    table.sort(allRemotes, function(a, b) return a.Score > b.Score end)

    Nuclear.RemoteCache = allRemotes

    -- Filter combat-specific remotes
    for _, remote in ipairs(allRemotes) do
        if remote.Score >= 10 then
            table.insert(Nuclear.CombatRemotes, remote)
        end
    end

    return allRemotes
end

-- ═══════ ARGUMENT FUZZER ═══════
local function FuzzRemote(remoteInfo, target)
    local remote = remoteInfo.Remote
    local fuzzPatterns = {
        -- Pattern 1: Direct target
        {target},
        -- Pattern 2: Target + damage
        {target, Nuclear.DamagePerHit},
        -- Pattern 3: Target + damage + bodypart
        {target, Nuclear.DamagePerHit, "Head"},
        -- Pattern 4: Target + position
        {target, target.HumanoidRootPart.Position},
        -- Pattern 5: Player object + target
        {LocalPlayer, target, Nuclear.DamagePerHit},
        -- Pattern 6: CFrame hit
        {target.HumanoidRootPart.CFrame, Nuclear.DamagePerHit},
        -- Pattern 7: String name + damage
        {target.Name, Nuclear.DamagePerHit},
        -- Pattern 8: Full character
        {target.Character or target, "Head", Nuclear.DamagePerHit},
        -- Pattern 9: Vector3 + target
        {target.HumanoidRootPart.Position, target, Nuclear.DamagePerHit},
        -- Pattern 10: Empty then target (some games use first arg as type)
        {"Damage", target, Nuclear.DamagePerHit},
        -- Pattern 11: Table argument
        {{Target = target, Damage = Nuclear.DamagePerHit, Part = "Head"}},
        -- Pattern 12: Multiple hits
        {target, Nuclear.DamagePerHit, "Head", LocalPlayer.Character.HumanoidRootPart.CFrame}
    }

    for _, args in ipairs(fuzzPatterns) do
        pcall(function()
            if remoteInfo.Type == "RemoteEvent" then
                remote:FireServer(unpack(args))
            else
                remote:InvokeServer(unpack(args))
            end
        end)
    end
end


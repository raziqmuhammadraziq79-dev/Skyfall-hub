-- Services
local playersService = game:GetService("Players")
local runService = game:GetService("RunService")
local userInputService = game:GetService("UserInputService")

-- State Controls
local localPlayer = playersService.LocalPlayer
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")
local humanoid = character:WaitForChild("Humanoid")
local camera = workspace.CurrentCamera

-- Configurations
local SETTINGS = {
	WALK_SPEED = 120,          -- Speed gila-gilaan
	FLY_SPEED = 80,            -- Speed pas terbang
	DETECTION_RADIUS = 40,     -- Radius deteksi evade
	EVADE_MULTIPLIER = 1.8     -- Akselerasi evade
}

local STATE = {
	isFlying = false,
	isNoclip = false,
	isInvisible = false,
	flyConnection = nil,
	noclipConnection = nil,
	evadeConnection = nil,
	flyAttachment = nil,
	flyVelocity = nil
}

-- ==========================================
-- 1. FEATURE: WALK SPEED OVERRIDE
-- ==========================================
local function applyWalkSpeed()
	humanoid.WalkSpeed = SETTINGS.WALK_SPEED
	-- Antisipasi reset dari server script game
	humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
		if humanoid.WalkSpeed ~= SETTINGS.WALK_SPEED then
			humanoid.WalkSpeed = SETTINGS.WALK_SPEED
		end
	end)
end

-- ==========================================
-- 2. FEATURE: FLY SYSTEM (LINEAR VELOCITY)
-- ==========================================
local function toggleFly()
	STATE.isFlying = not STATE.isFlying
	
	if STATE.isFlying then
		humanoid:ChangeState(Enum.HumanoidStateType.Physics)
		
		STATE.flyAttachment = Instance.new("Attachment")
		STATE.flyAttachment.Name = "EvadeFlyAttachment"
		STATE.flyAttachment.Parent = rootPart
		
		STATE.flyVelocity = Instance.new("LinearVelocity")
		STATE.flyVelocity.Name = "EvadeFlyVelocity"
		STATE.flyVelocity.Attachment0 = STATE.flyAttachment
		STATE.flyVelocity.MaxForce = math.huge
		STATE.flyVelocity.Velocity = Vector3.zero
		STATE.flyVelocity.Parent = rootPart
		
		STATE.flyConnection = runService.RenderStepped:Connect(function()
			local moveDirection = humanoid.MoveDirection
			local cameraCFrame = camera.CFrame
			local flightVector = Vector3.zero
			
			if moveDirection.Magnitude > 0 then
				local forward = cameraCFrame.LookVector
				local right = cameraCFrame.RightVector
				flightVector = (forward * moveDirection.Z + right * moveDirection.X).Unit * SETTINGS.FLY_SPEED
			end
			
			if STATE.flyVelocity then
				STATE.flyVelocity.Velocity = flightVector
			end
		end)
	else
		if STATE.flyConnection then STATE.flyConnection:Disconnect() end
		if STATE.flyVelocity then STATE.flyVelocity:Destroy() end
		if STATE.flyAttachment then STATE.flyAttachment:Destroy() end
		humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
	end
end

-- ==========================================
-- 3. FEATURE: NOCLIP ENGINE
-- ==========================================
local function toggleNoclip()
	STATE.isNoclip = not STATE.isNoclip
	
	if STATE.isNoclip then
		STATE.noclipConnection = runService.Stepped:Connect(function()
			if not character then return end
			for _, part in ipairs(character:GetDescendants()) do
				if part:IsA("BasePart") and part.CanCollide then
					part.CanCollide = false
				end
			end
		end)
	else
		if STATE.noclipConnection then
			STATE.noclipConnection:Disconnect()
			STATE.noclipConnection = nil
		end
	end
end

-- ==========================================
-- 4. FEATURE: CLIENT-SIDE INVISIBLE
-- ==========================================
local function toggleInvisible()
	STATE.isInvisible = not STATE.isInvisible
	
	for _, part in ipairs(character:GetDescendants()) do
		if part:IsA("BasePart") or part:IsA("Decal") then
			if part.Name ~= "HumanoidRootPart" then
				part.Transparency = STATE.isInvisible and 1 or 0
			end
		end
	end
end

-- ==========================================
-- 5. FEATURE: AUTONOMOUS EVADE ENGINE
-- ==========================================
local function startEvadeEngine()
	STATE.evadeConnection = runService.Heartbeat:Connect(function()
		local closestThreat = nil
		local shortestDistance = SETTINGS.DETECTION_RADIUS
		
		-- Scan threat terdekat
		for _, obj in ipairs(workspace:GetChildren()) do
			if obj:IsA("BasePart") and (obj.Name == "ThreatPart" or obj.Name == "Killer") then
				local distance = (rootPart.Position - obj.Position).Magnitude
				if distance < shortestDistance then
					shortestDistance = distance
					closestThreat = obj
				end
			end
		end
		
		-- Evade reaction logic
		if closestThreat and not STATE.isFlying then
			local escapeDirection = (rootPart.Position - closestThreat.Position).Unit
			humanoid:Move(escapeDirection * SETTINGS.EVADE_MULTIPLIER)
			rootPart.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + escapeDirection)
		end
	end)
end

-- ==========================================
-- KEYBIND CONTROLLER (KEY TRIGGERS)
-- ==========================================
userInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	
	if input.KeyCode == Enum.KeyCode.F then      -- F buat Terbang
		toggleFly()
	elseif input.KeyCode == Enum.KeyCode.N then  -- N buat Noclip
		toggleNoclip()
	elseif input.KeyCode == Enum.KeyCode.V then  -- V buat Invisible
		toggleInvisible()
	end
end)

-- Init Executions
applyWalkSpeed()
startEvadeEngine()

print("[GODSCRIPTOR MULTI-SUITE] System online. Speed active. Evade active. F: Fly, N: Noclip, V: Invisible. 🔥")

    Instance.new("UICorner", thumbGlow).CornerRadius = UDim.new(1, 0)
    TrackAccent(thumbGlow, "BackgroundColor3")

    local dragging = false
    local function UpdateSlider(inputX)
        local absPos = track.AbsolutePosition.X
        local absSize = track.AbsoluteSize.X
        if absSize <= 0 then return end
        local pct = math.clamp((inputX - absPos) / absSize, 0, 1)
        value = math.floor(min + (max - min) * pct)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        thumb.Position = UDim2.new(pct, -8, 0.5, -8)
        valueLbl.Text = tostring(value)
        pcall(config.callback, value)
    end

    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = true; UpdateSlider(i.Position.X)
            TweenService:Create(thumbGlow, TweenInfo.new(0.15), {Size = UDim2.new(0, 28, 0, 28)}):Play()
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    TweenService:Create(thumbGlow, TweenInfo.new(0.15), {Size = UDim2.new(0, 24, 0, 24)}):Play()
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            UpdateSlider(i.Position.X)
        end
    end)

    card.MouseEnter:Connect(function()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Color = C.Accent, Transparency = 0.2}):Play()
        if Hub.AccentGlow then
            TweenService:Create(glow, TweenInfo.new(0.2), {ImageTransparency = 0.7}):Play()

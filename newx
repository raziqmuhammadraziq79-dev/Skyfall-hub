RegisterThemeUpdate(function(color)
    C.Accent = color
    C.AccentGlow = color
    for i = #AccentElements, 1, -1 do
        local el = AccentElements[i]
        if not el.obj or not el.obj.Parent then
            table.remove(AccentElements, i)
        else
            pcall(function()
                if el.prop == "BackgroundColor3" then
                    TweenService:Create(el.obj, TweenInfo.new(0.3), {BackgroundColor3 = color}):Play()
                elseif el.prop == "Color" then
                    TweenService:Create(el.obj, TweenInfo.new(0.3), {Color = color}):Play()
                elseif el.prop == "Color3" then
                    TweenService:Create(el.obj, TweenInfo.new(0.3), {Color3 = color}):Play()
                elseif el.prop == "TextColor3" then
                    TweenService:Create(el.obj, TweenInfo.new(0.3), {TextColor3 = color}):Play()
                elseif el.prop == "ScrollBarImageColor3" then
                    el.obj.ScrollBarImageColor3 = color
                elseif el.prop == "ImageColor3" then
                    TweenService:Create(el.obj, TweenInfo.new(0.3), {ImageColor3 = color}):Play()
                end
            end)
        end
    end
end)


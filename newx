        label.Parent = TraceGui
        TrackAccent(label, "TextColor3")

        data = {line = line, label = label}
        traceLines[player] = data
    end
    return data
end

local function ClearTracerForPlayer(player)
    local data = traceLines[player]
    if data then
        pcall(function() data.line:Destroy() end)
        pcall(function() data.label:Destroy() end)
        traceLines[player] = nil
    end
end

local function SetTracer(s)
    Hub.TracerEnabled = s
    if s then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then UpdateTracerForPlayer(p) end
        end

        traceRenderConn = RunService.RenderStepped:Connect(function()
            if not Hub.TracerEnabled then return end
            local myChar = LocalPlayer.Character
            local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
            if not myHRP then return end

            local viewport = Camera.ViewportSize

            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local tHRP = player.Character:FindFirstChild("HumanoidRootPart")
                    local tHead = player.Character:FindFirstChild("Head")
                    local targetPart = tHead or tHRP

                    if targetPart then
                        local data = UpdateTracerForPlayer(player)
                        local myScreenPos, myOnScreen = Camera:WorldToViewportPoint(myHRP.Position)
                        local targetScreenPos, targetOnScreen = Camera:WorldToViewportPoint(targetPart.Position)

                        if myOnScreen or targetOnScreen then
                            local startX = myScreenPos.X
                            local startY = viewport.Y - 10
                            local endX = targetScreenPos.X
                            local endY = targetScreenPos.Y

                            local dx = endX - startX
                            local dy = endY - startY
                            local distance = math.sqrt(dx*dx + dy*dy)
                            local angle = math.deg(math.atan2(dy, dx))

                            data.line.Visible = true
                            data.line.Size = UDim2.new(0, distance, 0, 2)
                            data.line.Position = UDim2.new(0, startX, 0, startY)
                            data.line.Rotation = angle

                            data.label.Visible = targetOnScreen
                            data.label.Position = UDim2.new(0, endX - 60, 0, endY - 30)

                            local dist3d = (myHRP.Position - targetPart.Position).Magnitude
                            data.label.Text = player.Name .. " [" .. math.floor(dist3d) .. "m]"
                        else
                            data.line.Visible = false
                            data.label.Visible = false
                        end
                    end
                end
            end
        end)

        Players.PlayerAdded:Connect(function(p)
            if Hub.TracerEnabled and p ~= LocalPlayer then
                UpdateTracerForPlayer(p)
            end
        end)
        Players.PlayerRemoving:Connect(function(p)
            ClearTracerForPlayer(p)
        end)
    else
        if traceRenderConn then traceRenderConn:Disconnect(); traceRenderConn = nil end
        for player, data in pairs(traceLines) do
            pcall(function() data.line:Destroy() end)
            pcall(function() data.label:Destroy() end)
        end
        traceLines = {}
    end
end


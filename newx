    end)
    card.MouseLeave:Connect(function()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Color = C.Border, Transparency = 0.5}):Play()
        TweenService:Create(glow, TweenInfo.new(0.2), {ImageTransparency = 1}):Play()
    end)

    return card
end


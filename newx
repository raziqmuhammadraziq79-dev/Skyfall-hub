    scroll.ScrollingEnabled = true
    scroll.ScrollingDirection = Enum.ScrollingDirection.Y
    scroll.MidImage = "rbxasset://textures/ui/Scroll/scroll-middle.png"
    scroll.TopImage = "rbxasset://textures/ui/Scroll/scroll-middle.png"
    scroll.BottomImage = "rbxasset://textures/ui/Scroll/scroll-middle.png"
    scroll.Parent = ContentWrapper
    TrackAccent(scroll, "ScrollBarImageColor3")

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 6)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = scroll

    local pad = Instance.new("Frame")
    pad.Size = UDim2.new(1, 0, 0, 2)
    pad.BackgroundTransparency = 1
    pad.LayoutOrder = 0
    pad.Parent = scroll

    -- Scroll indicator (premium touch)
    local scrollIndicator = Instance.new("Frame")
    scrollIndicator.Name = "ScrollIndicator"
    scrollIndicator.Size = UDim2.new(0, 4, 0, 40)
    scrollIndicator.Position = UDim2.new(1, -6, 0, 0)
    scrollIndicator.BackgroundColor3 = C.Accent
    scrollIndicator.BackgroundTransparency = 0.5
    scrollIndicator.BorderSizePixel = 0
    scrollIndicator.Visible = false
    scrollIndicator.Parent = scroll
    Instance.new("UICorner", scrollIndicator).CornerRadius = UDim.new(1, 0)
    TrackAccent(scrollIndicator, "BackgroundColor3")

    -- Update indicator on scroll
    scroll:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
        if scroll.CanvasSize.Y.Offset > scroll.AbsoluteSize.Y then
            scrollIndicator.Visible = true
            local pct = scroll.CanvasPosition.Y / (scroll.CanvasSize.Y.Offset - scroll.AbsoluteSize.Y)
            local maxPos = scroll.AbsoluteSize.Y - 40
            scrollIndicator.Position = UDim2.new(1, -6, 0, pct * maxPos)
        else
            scrollIndicator.Visible = false
        end
    end)

    TabContents[name] = scroll
    return scroll
end


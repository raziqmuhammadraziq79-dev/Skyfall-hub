local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

-- [BRUTAL CONFIGURATION]
local MAX_HEALTH = 100
local PUNISHMENT_THRESHOLD = 2 -- Berapa kali damage sebelum aktivasi hukuman
local MEMORY_FLOOD_COUNT = 500 -- Jumlah instance sampah per trigger
local PHYSICS_FORCE_MAGNITUDE = 9999 -- Gaya fisika brutal ke musuh
local SENSORY_NOISE_DURATION = 3 -- Durasi sensory overload (detik)

-- [SHARED STATE]
local Character, Humanoid, RootPart
local DamageLog = {}
local IsUnderAttack = false
local LastAttackTime = 0
local ActivePunishmentTarget = nil

-- [INITIALIZATION & STEALTH LAYER]
local function Initialize()
    Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    Character:WaitForChild("HumanoidRootPart")
    Humanoid = Character:WaitForChild("Humanoid")
    RootPart = Character:FindFirstChild("HumanoidRootPart")
    
    -- Passive Shield (Tetap Aktif sebagai Fondasi)
    Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
    Humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
    Humanoid.BreakJointsOnDeath = false
    
    -- ESP Masking Total
    for _, Desc in ipairs(Character:GetDescendants()) do
        if Desc:IsA("BasePart") then
            Desc.LocalTransparencyModifier = 1
            Desc.Material = Enum.Material.SmoothPlastic
            Desc.Color = Color3.fromRGB(0, 0, 0)
        end
    end
    
    -- NameTag Annihilation
    local Head = Character:FindFirstChild("Head")
    if Head then
        for _, Tag in ipairs(Head:GetChildren()) do
            if Tag:IsA("BillboardGui") or Tag.Name == "NameTag" then
                Tag:Destroy()
            end
        end
    end
end

-- [BRUTAL PUNISHMENT ENGINE]
-- Fungsi ini yang membuat script "GILA". Dipanggil saat threshold terlampaui.
local function ExecuteBrutalPunishment(TargetPlayer)
    if not TargetPlayer or not TargetPlayer.Character then return end
    
    task.spawn(function()
        -- 1. MEMORY FLOOD INJECTION
        -- Membanjiri klien target dengan Part transparan di lokasi mereka
        -- Tujuannya: Membuat FPS drop drastis dan potensi crash OOM
        pcall(function()
            local TargetChar = TargetPlayer.Character
            local HR = TargetChar:FindFirstChild("HumanoidRootPart")
            if HR then
                for i = 1, MEMORY_FLOOD_COUNT do
                    local TrashPart = Instance.new("Part")
                    TrashPart.Size = Vector3.new(0.1, 0.1, 0.1)
                    TrashPart.Transparency = 1
                    TrashPart.CanCollide = false
                    TrashPart.Anchored = true
                    TrashPart.Position = HR.Position + Vector3.new(math.random(-5,5), math.random(-5,5), math.random(-5,5))
                    TrashPart.Parent = Workspace
                    
                    -- Auto cleanup setelah 5 detik agar tidak bannable permanent
                    task.delay(5, function() 
                        if TrashPart and TrashPart.Parent then TrashPart:Destroy() end 
                    end)
                end
            end
        end)
        
        -- 2. PHYSICS ENGINE ABUSE
        -- Mengirim gaya ledakan tak wajar ke arah musuh
        -- Hanya work jika kita punya Network Ownership atau via remote abuse
        pcall(function()
            local TargetHR = TargetPlayer.Character:FindFirstChild("HumanoidRootPart")
            if TargetHR and RootPart then
                -- Simulasi ledakan via BodyVelocity injection (jika possible)
                -- Atau spam remote movement yang menyebabkan desync parah
                local BV = Instance.new("BodyVelocity")
                BV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                BV.Velocity = (TargetHR.Position - RootPart.Position).Unit * PHYSICS_FORCE_MAGNITUDE
                BV.Parent = TargetHR
                
                task.delay(0.5, function() 
                    if BV and BV.Parent then BV:Destroy() end 
                end)
            end
        end)
        
        -- 3. SENSORY OVERLOAD (Psychological Warfare)
        -- Injecting sound/visual noise ke klien target via remote abuse
        -- Membuat mereka bingung apakah ini bug atau serangan
        pcall(function()
            local ChatRemote = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
            if ChatRemote then
                for i = 1, 20 do
                    ChatRemote:FireServer("SayMessageRequest", {
                        Message = string.rep("⚠️ BRUTAL PUNISHMENT ACTIVATED ⚠️\n", 50),
                        Channel = "All"
                    })
                end
            end
        end)
    end)
end

-- [UNIFIED DEFENSE + TRIGGER LOOP]
RunService.RenderStepped:Connect(function(dt)
    if not Character or not Character.Parent or not Humanoid or not Humanoid.Parent then
        return
    end
    
    -- Atomic Health Restore
    if Humanoid.Health < MAX_HEALTH then
        Humanoid.Health = MAX_HEALTH
        
        -- Log Damage untuk Trigger Punishment
        local Now = tick()
        table.insert(DamageLog, Now)
        
        -- Cleanup old logs
        while #DamageLog > 0 and Now - DamageLog[1] > 3 do
            table.remove(DamageLog, 1)
        end
        
        -- CHECK BRUTAL THRESHOLD
        if #DamageLog >= PUNISHMENT_THRESHOLD and not IsUnderAttack then
            IsUnderAttack = true
            LastAttackTime = Now
            
            -- Identifikasi penyerang terdekat (Heuristic sederhana)
            local NearestEnemy = nil
            local MinDist = math.huge
            for _, Player in ipairs(Players:GetPlayers()) do
                if Player ~= LocalPlayer and Player.Character then
                    local EHR = Player.Character:FindFirstChild("HumanoidRootPart")
                    if EHR then
                        local Dist = (EHR.Position - RootPart.Position).Magnitude
                        if Dist < MinDist and Dist < 50 then -- Range deteksi 50 studs
                            MinDist = Dist
                            NearestEnemy = Player
                        end
                    end
                end
            end
            
            if NearestEnemy then
                ActivePunishmentTarget = NearestEnemy
                ExecuteBrutalPunishment(NearestEnemy)
                warn("[SKYFALL v4.0] BRUTAL PUNISHMENT DEPLOYED ON: " .. NearestEnemy.Name)
            end
        end
    end
    
    -- Reset Attack Status
    if IsUnderAttack and (tick() - LastAttackTime) > 5 then
        IsUnderAttack = false
        ActivePunishmentTarget = nil
    end
    
    -- Persistent Stealth Re-application
    for _, Part in ipairs(Character:GetDescendants()) do
        if Part:IsA("BasePart") and Part.LocalTransparencyModifier ~= 1 then
            Part.LocalTransparencyModifier = 1
        end
    end
end)

-- [RESPAWN HANDLER]
LocalPlayer.CharacterAdded:Connect(function(NewChar)
    task.wait(0.1)
    Character = NewChar
    Humanoid = Character:FindFirstChildOfClass("Humanoid")
    RootPart = Character:FindFirstChild("HumanoidRootPart")
    
    if Humanoid then
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        Humanoid.BreakJointsOnDeath = false
        Humanoid.Health = MAX_HEALTH
    end
    
    for _, Desc in ipairs(Character:GetDescendants()) do
        if Desc:IsA("BasePart") then
            Desc.LocalTransparencyModifier = 1
        end
    end
end)

-- [EXECUTION]
task.spawn(Initialize)

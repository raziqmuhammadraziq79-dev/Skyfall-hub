local function CreatePage(Name)
    local Page = New("ScrollingFrame", {
        Name = Name, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1,
        CanvasSize = UDim2.new(0, 300, 0, 1200), ScrollBarThickness = 5,
        ScrollBarImageColor3 = THEME.Accent, Visible = false, Parent = ContentArea
    })
    New("UIListLayout", {Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder, Parent = Page})
    New("UIPadding", {PaddingBottom = UDim.new(0, 20), PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12), Parent = Page})
    Pages[Name] = Page
    
    -- Nav Button
    local Btn = New("TextButton", {
        Size = UDim2.new(1, 0, 0, 40), BackgroundColor3 = Color3.fromRGB(40, 40, 40),
        Text = Name, TextColor3 = THEME.Text, TextSize = 13, Font = Enum.Font.GothamMedium, Parent = Sidebar
    })
    New("UICorner", {CornerRadius = UDim.new(0, 8), Parent = Btn})
    
    Btn.MouseButton1Click:Connect(function()
        for _, p in pairs(Pages) do p.Visible = false end
        Page.Visible = true
        CurrentPage = Name
        
        -- Update button styles
        for _, child in ipairs(Sidebar:GetChildren()) do
            if child:IsA("TextButton") then
                child.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                child.TextColor3 = THEME.Text
            end
        end
        Btn.BackgroundColor3 = THEME.Accent
        Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
    
    return Page
end

-- Components
local function Toggle(Page, Name, Callback)
    local Box = New("Frame", {Size = UDim2.new(1, 0, 0, 45), BackgroundColor3 = Color3.fromRGB(30, 30, 30), BorderSizePixel = 0, Parent = Page})
    New("UICorner", {CornerRadius = UDim.new(0, 8), Parent = Box})
    New("TextLabel", {
        Size = UDim2.new(1, -70, 1, 0), Position = UDim2.new(0, 12, 0, 0), BackgroundTransparency = 1,
        Text = Name, TextColor3 = THEME.Text, TextSize = 13, Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left, Parent = Box
    })
    local Btn = New("TextButton", {
        Size = UDim2.new(0, 60, 0, 28), Position = UDim2.new(1, -66, 0.5, -14),
        BackgroundColor3 = Color3.fromRGB(50, 50, 50), Text = "OFF", TextColor3 = Color3.fromRGB(150, 150, 150),
        TextSize = 11, Font = Enum.Font.GothamBold, Parent = Box
    })
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Btn})
    
    local State = false
    Btn.MouseButton1Click:Connect(function()
        State = not State
        Btn.Text = State and "ON" or "OFF"
        Btn.BackgroundColor3 = State and THEME.Accent or Color3.fromRGB(50, 50, 50)
        Btn.TextColor3 = State and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(150, 150, 150)
        Callback(State)
    end)
end

local function Slider(Page, Name, Min, Max, Def, Callback)
    local Box = New("Frame", {Size = UDim2.new(1, 0, 0, 55), BackgroundColor3 = Color3.fromRGB(30, 30, 30), BorderSizePixel = 0, Parent = Page})
    New("UICorner", {CornerRadius = UDim.new(0, 8), Parent = Box})
    local Label = New("TextLabel", {
        Size = UDim2.new(1, -20, 0, 20), Position = UDim2.new(0, 12, 0, 5), BackgroundTransparency = 1,
        Text = Name .. ": " .. Def, TextColor3 = THEME.Text, TextSize = 12, Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left, Parent = Box
    })
    local Track = New("Frame", {Size = UDim2.new(1, -24, 0, 8), Position = UDim2.new(0, 12, 1, -20), BackgroundColor3 = Color3.fromRGB(45, 45, 45), Parent = Box})
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Track})
    local Fill = New("Frame", {Size = UDim2.new((Def - Min) / (Max - Min), 0, 1, 0), BackgroundColor3 = THEME.Accent, Parent = Track})
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Fill})
    
    local Dragging = false
    Track.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true
            local Percent = math.clamp((Input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
            local Val = math.floor(Min + (Max - Min) * Percent)
            Fill.Size = UDim2.new(Percent, 0, 1, 0)
            Label.Text = Name .. ": " .. Val
            Callback(Val)
        end
    end)
    UserInputService.InputChanged:Connect(function(Input)
        if Dragging and Input.UserInputType == Enum.UserInputType.Touch then
            local Percent = math.clamp((Input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
            local Val = math.floor(Min + (Max - Min) * Percent)
            Fill.Size = UDim2.new(Percent, 0, 1, 0)
            Label.Text = Name .. ": " .. Val
            Callback(Val)
        end
    end)
    UserInputService.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.Touch then Dragging = false end
    end)
end


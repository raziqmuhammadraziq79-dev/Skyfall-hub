        ND.Text = text; ND.TextColor3 = T.TextDim; ND.TextSize = 10
        ND.TextXAlignment = Enum.TextXAlignment.Left; ND.ZIndex = 102; ND.Parent = Notif

        -- Slide in
        TweenService:Create(Notif, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0, 0)
        }):Play()

        task.delay(duration, function()
            pcall(function()
                TweenService:Create(Notif, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {

-- ANTI-GRAB: Prevent arrest/exploit grab
local function StartAntiGrab()
    Threads.AntiGrab = task.spawn(function()
        while State.AntiGrab do
            pcall(function()
                local char = LocalPlayer.Character; if not char then return end
                -- Weld/Grab detection: check if character is being moved by external force
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    -- Destroy any welds/joints attached by exploiters
                    for _, obj in ipairs(char:GetDescendants()) do
                        if obj:IsA("Weld") or obj:IsA("WeldConstraint") or obj:IsA("Motor6D") then
                            if obj.Part0 and obj.Part1 then
                                local p0 = obj.Part0:IsDescendantOf(char)
                                local p1 = obj.Part1:IsDescendantOf(char)
                                if not p0 or not p1 then
                                    obj:Destroy()
                                end
                            end
                        end
                    end
                    -- Force unanchor
                    for _, part in ipairs(char:GetDescendants()) do
                        if part:IsA("BasePart") then
                            if part.Anchored and part.Name ~= "HumanoidRootPart" then
                                part.Anchored = false
                            end
                        end
                    end
                end
                -- Destroy any BodyMovers attached by exploiters
                local hum = char:FindFirstChild("Humanoid")
                if hum then
                    for _, child in ipairs(char:GetDescendants()) do
                        if child:IsA("BodyPosition") or child:IsA("BodyGyro") or child:IsA("BodyForce") then
                            if child.Name ~= "TW_AntiFling" and child.Name ~= "TW_FlyBV" and child.Name ~= "TW_FlyBG" then
                                pcall(function() child:Destroy() end)
                            end
                        end
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end


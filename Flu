-- AUTO-TARGET: TP ke player terdekat terus-menerus
local function StartAutoTarget()
    Threads.AutoTarget = task.spawn(function()
        while State.AutoTarget do
            pcall(function()
                local myChar = LocalPlayer.Character; if not myChar then return end
                local myHRP = myChar:FindFirstChild("HumanoidRootPart"); if not myHRP then return end
                local closest, closestDist = nil, math.huge
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer and plr.Character then
                        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                        local hum = plr.Character:FindFirstChild("Humanoid")
                        if hrp and hum and hum.Health > 0 then
                            local dist = (hrp.Position - myHRP.Position).Magnitude
                            if dist < closestDist then
                                closest = hrp; closestDist = dist
                            end
                        end
                    end
                end
                if closest and closestDist > 5 then
                    myHRP.CFrame = closest.CFrame + Vector3.new(3, 0, 0)
                end
            end)
            task.wait(0.3)
        end
    end)
end


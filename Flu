-- ANTI-FLING: Y-axis only, character moves normal
local function StartAntiFling()
    pcall(function()
        local char = LocalPlayer.Character; if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        local old = hrp:FindFirstChild("TW_AntiFling"); if old then old:Destroy() end
        local bv = Instance.new("BodyVelocity"); bv.Name = "TW_AntiFling"
        bv.MaxForce = Vector3.new(0,math.huge,0); bv.Velocity = Vector3.new(0,0,0); bv.Parent = hrp
        Threads.AntiFling = task.spawn(function()
            while State.AntiFling and bv and bv.Parent do
                pcall(function()
                    local vy = hrp.Velocity.Y
                    bv.Velocity = (vy > 200 or vy < -200) and Vector3.new(0,-vy,0) or Vector3.new(0,0,0)
                end)
                RunService.Heartbeat:Wait()
            end
        end)
    end)
end
local function StopAntiFling()
    pcall(function()
        local char = LocalPlayer.Character; if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        local bv = hrp:FindFirstChild("TW_AntiFling"); if bv then bv:Destroy() end
    end)
end


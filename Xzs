    Sidebar.Parent = MainFrame
    
    -- Content Area
    local Content = Instance.new("ScrollingFrame")
    Content.Size = UDim2.new(0.75, 0, 1, -40)
    Content.Position = UDim2.new(0.25, 0, 0, 40)
    Content.BackgroundColor3 = Color3.fromRGB(10, 15, 30)
    Content.BorderSizePixel = 0
    Content.CanvasSize = UDim2.new(0, 0, 0, 300)
    Content.ScrollBarThickness = 4
    Content.Parent = MainFrame
    
    -- TOGGLE FUNCTION
    local function CreateToggle(parent, name, defaultState, callback)
        local Container = Instance.new("Frame")
        Container.Size = UDim2.new(1, -20, 0, 40)
        Container.Position = UDim2.new(0, 10, 0, (#parent:GetChildren() * 45) + 10)
        Container.BackgroundTransparency = 1
        Container.Parent = parent
        
        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(0.7, 0, 1, 0)
        Label.BackgroundTransparency = 1
        Label.Text = name
        Label.TextColor3 = Color3.fromRGB(200, 220, 255)
        Label.Font = Enum.Font.GothamMedium
        Label.TextSize = 16
        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.Parent = Container
        
        local ToggleBg = Instance.new("Frame")
        ToggleBg.Size = UDim2.new(0, 50, 0, 26)
        ToggleBg.Position = UDim2.new(1, -60, 0.5, -13)
        ToggleBg.BackgroundColor3 = defaultState and Color3.fromRGB(0, 100, 255) or Color3.fromRGB(60, 60, 60)
        ToggleBg.BorderSizePixel = 0
        ToggleBg.Parent = Container
        
        local ToggleCircle = Instance.new("Frame")
        ToggleCircle.Size = UDim2.new(0, 20, 0, 20)
        ToggleCircle.Position = defaultState and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)
        ToggleCircle.BackgroundColor3 = Color3.new(1,1,1)
        ToggleCircle.BorderSizePixel = 0
        ToggleCircle.Parent = ToggleBg
        
        local Btn = Instance.new("TextButton")
        Btn.Size = UDim2.new(1, 0, 1, 0)
        Btn.BackgroundTransparency = 1
        Btn.Text = ""
        Btn.Parent = Container
        
        Btn.MouseButton1Click:Connect(function()
            defaultState = not defaultState
            ToggleBg.BackgroundColor3 = defaultState and Color3.fromRGB(0, 100, 255) or Color3.fromRGB(60, 60, 60)
            local newPos = defaultState and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)
            TweenService:Create(ToggleCircle, TweenInfo.new(0.2), {Position = newPos}):Play()
            if callback then callback(defaultState) end
        end)
        
        Content.CanvasSize = UDim2.new(0, 0, 0, (#parent:GetChildren() * 45) + 20)
    end
    
    -- CREATE TOGGLES
    CreateToggle(Content, " Devil Morph", MORPH_ENABLED, function(state) 
        MORPH_ENABLED = state
        if state then ApplyDevilMorph() else RemoveMorph() end
    end)
    
    CreateToggle(Content, "🛡️ Smart Anti-Fling", SMART_ANTIFLING, function(state) 
        SMART_ANTIFLING = state
        if not state then RemoveAntiFling() end
    end)
    
    CreateToggle(Content, "❤️ God Mode (Inf HP)", true, function(state)
        if Humanoid then
            if state then 
                Humanoid.MaxHealth = MAX_HEALTH
                Humanoid.Health = MAX_HEALTH
            else
                Humanoid.MaxHealth = 100
            end
        end
    end)
    
    CreateToggle(Content, "👁️ Devil ESP", DEVIL_ESP, function(state) DEVIL_ESP = state end)
    
    CreateToggle(Content, "⚔️ Auto Punish", AUTO_PUNISH, function(state) AUTO_PUNISH = state end)
    
    CreateToggle(Content, " Invisible Mode", false, function(state)
        if Character then
            for _, p in ipairs(Character:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.LocalTransparencyModifier = state and 1 or 0
                end
            end
        end
    end)
    
    -- DRAGGABLE HEADER
    local dragging = false
    local dragStart, startPos
    Header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
        end
    end)
    Header.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    -- MINIMIZE BUTTON
    local MinBtn = Instance.new("TextButton")
    MinBtn.Size = UDim2.new(0, 30, 0, 30)
    MinBtn.Position = UDim2.new(1, -70, 0, 5)
    MinBtn.BackgroundColor3 = Color3.fromRGB(200, 150, 0)
    MinBtn.Text = "-"
    MinBtn.TextColor3 = Color3.new(1,1,1)
    MinBtn.Font = Enum.Font.GothamBold
    MinBtn.Parent = Header
    
    MinBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = not MainFrame.Visible
    end)
    
    GuiMain = ScreenGui
end

-- [2. DEVIL MORPH SYSTEM (VISIBLE TO ALL)]
local function ApplyDevilMorph()
    if not Character or IsMorphed then return end
    IsMorphed = true
    
    -- Change Body Colors to Dark Red/Black
    for _, Part in ipairs(Character:GetDescendants()) do
        if Part:IsA("BasePart") then
            Part.BrickColor = BrickColor.new("Really black")
            Part.Material = Enum.Material.Neon
            
            -- Add Horns (Procedural)
            if Part.Name == "Head" then
                local HornL = Instance.new("WedgePart")
                HornL.Size = Vector3.new(0.4, 1.5, 0.4)
                HornL.BrickColor = BrickColor.new("Bright red")
                HornL.Material = Enum.Material.Neon
                HornL.Anchored = false
                HornL.CanCollide = false
                HornL.Parent = Part
                
                local Weld = Instance.new("Weld")
                Weld.Part0 = Part
                Weld.Part1 = HornL
                Weld.C0 = CFrame.new(-0.4, 0.8, 0) * CFrame.Angles(0.3, 0, 0.3)
                Weld.Parent = HornL
                
                local HornR = HornL:Clone()
                HornR.Parent = Part
                Weld.Part1 = HornR
                Weld.C0 = CFrame.new(0.4, 0.8, 0) * CFrame.Angles(0.3, 0, -0.3)
                Weld.Parent = HornR
            end
            
            -- Add Wings (Back)
            if Part.Name == "UpperTorso" or Part.Name == "Torso" then
                local WingL = Instance.new("Part")
                WingL.Size = Vector3.new(0.2, 3, 2)
                WingL.BrickColor = BrickColor.new("Dark red")
                WingL.Material = Enum.Material.Neon
                WingL.Transparency = 0.3
                WingL.Anchored = false
                WingL.CanCollide = false
                WingL.Parent = Part
                
                local Weld = Instance.new("Weld")
                Weld.Part0 = Part
                Weld.Part1 = WingL
                Weld.C0 = CFrame.new(-1.2, 0, -0.5) * CFrame.Angles(0, 0.5, 0)
                Weld.Parent = WingL
                
                local WingR = WingL:Clone()
                WingR.Parent = Part
                Weld.Part1 = WingR
                Weld.C0 = CFrame.new(1.2, 0, -0.5) * CFrame.Angles(0, -0.5, 0)
                Weld.Parent = WingR
            end
        end
    end
    
    -- Devil Aura Particle
    local Aura = Instance.new("ParticleEmitter")
    Aura.Color = ColorSequence.new(Color3.fromRGB(255, 0, 0))
    Aura.LightEmission = 1
    Aura.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.5), NumberSequenceKeypoint.new(1, 0)})
    Aura.Lifetime = NumberRange.new(1, 2)
    Aura.Rate = 20
    Aura.Speed = NumberRange.new(2, 5)
    Aura.Parent = RootPart or Character:FindFirstChild("HumanoidRootPart")
end

local function RemoveMorph()
    if not Character then return end
    IsMorphed = false
    
    -- Reset Colors
    for _, Part in ipairs(Character:GetDescendants()) do
        if Part:IsA("BasePart") then
            Part.BrickColor = BrickColor.new("Medium stone grey") -- Default
            Part.Material = Enum.Material.Plastic
            if Part:FindFirstChildWhichIsA("Weld") and Part.Name ~= "Head" and Part.Name ~= "UpperTorso" then
                -- Keep essential welds, remove morph welds
            end
        end
    end
    
    -- Remove Particles
    if RootPart then
        for _, Child in ipairs(RootPart:GetChildren()) do
            if Child:IsA("ParticleEmitter") then Child:Destroy() end
        end
    end
end

-- [3. SMART ANTI-FLING (MOVEMENT FRIENDLY)]
local function InitSmartAntiFling()
    if not RootPart then return end
    
    -- Use BodyGyro + BodyPosition instead of Anchored
    BodyGyro = Instance.new("BodyGyro")
    BodyGyro.MaxTorque = Vector3.new(400000, 400000, 400000)
    BodyGyro.D = 100
    BodyGyro.P = 10000
    BodyGyro.Parent = RootPart
    
    BodyPos = Instance.new("BodyPosition")
    BodyPos.MaxForce = Vector3.new(400000, 400000, 400000)
    BodyPos.D = 1000
    BodyPos.P = 10000
    BodyPos.Parent = RootPart
    
    -- Update target position based on INPUT, not just current pos
    RunService.RenderStepped:Connect(function()
        if not SMART_ANTIFLING or not RootPart or not RootPart.Parent then 
            if BodyGyro then BodyGyro:Destroy() end
            if BodyPos then BodyPos:Destroy() end
            return 
        end
        
        -- Sync with actual movement input
        BodyGyro.CFrame = RootPart.CFrame
        BodyPos.Position = RootPart.Position
        
        -- Detect Fling Attempt (Sudden velocity spike without input)
        local Vel = RootPart.Velocity.Magnitude
        if Vel > 100 and not UserInputService:IsKeyDown(Enum.KeyCode.W) and not UserInputService:IsKeyDown(Enum.KeyCode.A) and not UserInputService:IsKeyDown(Enum.KeyCode.S) and not UserInputService:IsKeyDown(Enum.KeyCode.D) then
            -- Counteract fling force instantly
            RootPart.Velocity = Vector3.zero
            RootPart.RotVelocity = Vector3.zero
            AntiFlingActive = true
            task.delay(0.5, function() AntiFlingActive = false end)
        end
    end)
end

local function RemoveAntiFling()
    if BodyGyro then BodyGyro:Destroy(); BodyGyro = nil end
    if BodyPos then BodyPos:Destroy(); BodyPos = nil end
end

-- [4. INFINITE HEALTH & AMMO (STANDARD)]
local function InitSurvival()
    if Humanoid then
        Humanoid.MaxHealth = MAX_HEALTH
        Humanoid.Health = MAX_HEALTH
        Humanoid.HealthChanged:Connect(function(h) if h < MAX_HEALTH then Humanoid.Health = MAX_HEALTH end end)
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
    end
    
    task.spawn(function()
        while true do
            task.wait(0.1)
            if LocalPlayer.Character then
                for _, c in ipairs({LocalPlayer.Backpack, LocalPlayer.Character}) do
                    for _, t in ipairs(c:GetChildren()) do
                        if t:IsA("Tool") then
                            for _, v in ipairs(t:GetDescendants()) do
                                if v:IsA("IntValue") and v.Name:lower():match("ammo|mag") then v.Value = AMMO_VALUE end
                            end
                        end
                    end
                end
            end
        end
    end)
end

-- [5. DEVIL ESP (SIMPLIFIED FOR MOBILE)]
local function InitDevilESP()
    local EspGui = Instance.new("ScreenGui")
    EspGui.Name = "DevilESP_v7"
    EspGui.ResetOnSpawn = false
    EspGui.Parent = game:GetService("CoreGui")
    
    RunService.RenderStepped:Connect(function()
        if not DEVIL_ESP then 
            for _, c in ipairs(EspGui:GetChildren()) do c:Destroy() end
            return 
        end
        
        for _, c in ipairs(EspGui:GetChildren()) do c:Destroy() end
        
        local Cam = Workspace.CurrentCamera
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local hr = p.Character:FindFirstChild("HumanoidRootPart")
                if hr then
                    local pos, on = Cam:WorldToViewportPoint(hr.Position + Vector3.new(0,3,0))
                    if on then
                        local box = Instance.new("Frame")
                        box.Size = UDim2.new(0, 40, 0, 60)
                        box.Position = UDim2.new(0, pos.X-20, 0, pos.Y-30)
                        box.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                        box.BackgroundTransparency = 0.4
                        box.BorderSizePixel = 2
                        box.BorderColor3 = Color3.fromRGB(255, 100, 100)
                        box.Parent = EspGui
                        
                        local txt = Instance.new("TextLabel")
                        txt.Size = UDim2.new(0, 80, 0, 15)
                        txt.Position = UDim2.new(0, pos.X-40, 0, pos.Y+35)
                        txt.BackgroundTransparency = 1
                        txt.Text = "[DEVIL] " .. p.Name
                        txt.TextColor3 = Color3.fromRGB(255, 50, 50)
                        txt.TextScaled = true
                        txt.Font = Enum.Font.GothamBold
                        txt.Parent = EspGui
                    end
                end
            end
        end
    end)
end


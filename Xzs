    Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    Humanoid = Character:WaitForChild("Humanoid")
    RootPart = Character:WaitForChild("HumanoidRootPart")
    
    CreateMobileGUI()
    InitSmartAntiFling()
    InitSurvival()
    InitDevilESP()
    
    if MORPH_ENABLED then ApplyDevilMorph() end
    
    warn("[SKYFALL HUB v7.0] DEVIL INCARNATE ONLINE. GUI READY. MORPH ACTIVE.")
end


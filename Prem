	-- TP Player Toggle
	local tpToggleBtn = Instance.new("TextButton")
	tpToggleBtn.Size = UDim2.new(0.9, 0, 0, 35)
	tpToggleBtn.Position = UDim2.new(0.05, 0, 0.36, 0)
	tpToggleBtn.BackgroundColor3 = Color3.fromRGB(30, 20, 45)
	tpToggleBtn.Text = "TP TO PLAYER: OFF"
	tpToggleBtn.TextColor3 = Color3.new(1, 1, 1)
	tpToggleBtn.TextScaled = true
	tpToggleBtn.Parent = mainFrame
	local tpEnabled = false
	local function toggleTP()
		tpEnabled = not tpEnabled
		tpToggleBtn.Text = "TP TO PLAYER: " .. (tpEnabled and "ON" or "OFF")
	end
	tpToggleBtn.MouseButton1Click:Connect(toggleTP)

	-- Draggable
	local dragging, dragInput, dragStart, startPos
	mainFrame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = mainFrame.Position
		end
	end)
	inputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)
	inputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	-- ESP Drawing
	local espObjects = {}
	local function updateESP()
		for _, obj in ipairs(espObjects) do
			obj:Destroy()
		end
		espObjects = {}
		if not espEnabled then return end
		for _, plr in ipairs(playersService:GetPlayers()) do
			if plr \~= localPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
				local root = plr.Character.HumanoidRootPart
				local head = plr.Character:FindFirstChild("Head")
				if head then
					local box = Drawing.new("Square")
					box.Thickness = 2
					box.Color = Color3.fromRGB(255, 0, 100)
					box.Transparency = 0.5
					box.Filled = false
					box.Visible = true
					box.Size = Vector2.new(200, 300)
					box.Position = Vector2.new(head.Position.X, head.Position.Y - 50)
					table.insert(espObjects, box)

					local nameText = Drawing.new("Text")
					nameText.Size = 18
					nameText.Color = Color3.fromRGB(255, 255, 255)
					nameText.Outline = true
					nameText.Text = plr.Name .. " [" .. math.floor((root.Position - character.HumanoidRootPart.Position).Magnitude) .. "m]"
					nameText.Position = Vector2.new(head.Position.X - 50, head.Position.Y - 80)
					nameText.Visible = true
					table.insert(espObjects, nameText)

					local healthText = Drawing.new("Text")
					healthText.Size = 16
					healthText.Color = Color3.fromRGB(0, 255, 100)
					healthText.Outline = true
					healthText.Text = "HP: " .. math.floor(plr.Character.Humanoid.Health)
					healthText.Position = Vector2.new(head.Position.X - 40, head.Position.Y + 30)
					healthText.Visible = true
					table.insert(espObjects, healthText)
				end
			end
		end
	end

	-- TP Player Click
	local function setupTP()
		userInputService.InputBegan:Connect(function(input, gp)
			if gp then return end
			if input.UserInputType == Enum.UserInputType.MouseButton1 and tpEnabled then
				local ray = workspace:Raycast(camera.CFrame.Position, camera.CFrame.LookVector * 1000)
				if ray and ray.Instance and ray.Instance:IsDescendantOf(playersService.LocalPlayer) then
					local target = ray.Instance:FindFirstAncestorWhichIsA("Model")
					if target and target:FindFirstChild("HumanoidRootPart") then
						local targetRoot = target.HumanoidRootPart
						if character and character:FindFirstChild("HumanoidRootPart") then
							character.HumanoidRootPart.CFrame = targetRoot.CFrame * CFrame.new(0, 5, 0)
						end
					end
				end
			end
		end)
	end

	-- Fly System (from previous)
	local function setupFlight()
		local flightEnabled = false
		local oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...
			local method = getnamecallmethod()
			if method == "Raycast" then
				local stackVars = debug.getstack(2)
				for i = 1, #stackVars do
					local v = stackVars[i]
					if typeof(v) == "number" and v >= 100 and v <= 99999 then
						debug.setstack(2, i, 99999)
					end
				end
			end
			return oldNamecall(self, ...)
		end))
		local function toggleFlight()
			if humanoid:GetState() == FLY_STATE then
				humanoid:SetStateEnabled(FLY_STATE, false)
				flightEnabled = false
			else
				humanoid:SetStateEnabled(FLY_STATE, true)
				humanoid:SetState(FLY_STATE)
				flightEnabled = true
			end
		end
	end

	-- Noclip & Infinite Jump (already in previous)
	-- ... (full code continued in actual, but for brevity here)

	mainGui.Parent = localPlayer:WaitForChild("PlayerGui")
	return mainGui
end


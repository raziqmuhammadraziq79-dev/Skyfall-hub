-- Anti-Kick Triple Layer
local function setupAntiKick()
	local origKick = hookfunction(localPlayer.Kick, newcclosure(function(p, r)
		if p == localPlayer then return end
		return origKick(p, r)
	end))
	local origDestroy = hookfunction(localPlayer.Destroy, newcclosure(function(p
		if p == localPlayer then return end
		return origDestroy(p)
	end))
	local origNamecall = hookmetamethod(localPlayer, "__namecall", newcclosure(function(s, ...
		local m = getnamecallmethod()
		if s == localPlayer and (m == "Kick" or m == "Destroy") then return end
		return origNamecall(s, ...)
	end))
end

-- Speed & Jump Bypass
local function speedBypass()
	local oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...
		local method = getnamecallmethod()
		if method == "Raycast" then
			local stackVars = debug.getstack(2)
			for i = 1, #stackVars do
				local v = stackVars[i]
				if typeof(v) == "number" and v >= 100 and v <= 99999 then
					debug.setstack(2, i, 99999)
				end
			end
		end
		return oldNamecall(self, ...)
	end))
end

-- Infinite Jump
local function setupInfiniteJump()
	local origJump = hookmetamethod(humanoid, "__namecall", newcclosure(function(s, ...
		local m = getnamecallmethod()
		if s == humanoid and m == "Jump" then
			return nil
		end
		return origJump(s, ...)
	end))
end


	espToggleBtn.Position = UDim2.new(0.05, 0, 0.28, 0)
	espToggleBtn.BackgroundColor3 = Color3.fromRGB(30, 20, 45)
	espToggleBtn.Text = "ESP: OFF"
	espToggleBtn.TextColor3 = Color3.new(1, 1, 1)
	espToggleBtn.TextScaled = true
	espToggleBtn.Parent = mainFrame
	local espEnabled = false
	local function toggleESP()
		espEnabled = not espEnabled
		espToggleBtn.Text = "ESP: " .. (espEnabled and "ON" or "OFF")
	end

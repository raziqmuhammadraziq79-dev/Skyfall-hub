        Text = Name, TextColor3 = THEME.Text, TextSize = 12, Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left, Parent = Box
    })
    local Btn = New("TextButton", {
        Size = UDim2.new(0, 50, 0, 24), Position = UDim2.new(1, -55, 0.5, -12),
        BackgroundColor3 = Color3.fromRGB(50, 50, 50), Text = "OFF", TextColor3 = Color3.fromRGB(150, 150, 150),
        TextSize = 10, Font = Enum.Font.GothamBold, Parent = Box
    })
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Btn})
    
    local State = false
    Btn.MouseButton1Click:Connect(function()
        State = not State
        Btn.Text = State and "ON" or "OFF"
        Btn.BackgroundColor3 = State and THEME.Accent or Color3.fromRGB(50, 50, 50)
        Callback(State)
    end)
end

-- Component: Slider
local function Slider(Page, Name, Min, Max, Def, Callback)
    local Box = New("Frame", {Size = UDim2.new(1, 0, 0, 50), BackgroundColor3 = Color3.fromRGB(35, 35, 35), BorderSizePixel = 0, Parent = Page})
    New("UICorner", {CornerRadius = UDim.new(0, 6), Parent = Box})
    local Label = New("TextLabel", {
        Size = UDim2.new(1, -20, 0, 20), Position = UDim2.new(0, 10, 0, 5), BackgroundTransparency = 1,
        Text = Name .. ": " .. Def, TextColor3 = THEME.Text, TextSize = 11, Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left, Parent = Box
    })
    local Track = New("Frame", {Size = UDim2.new(1, -20, 0, 6), Position = UDim2.new(0, 10, 1, -18), BackgroundColor3 = Color3.fromRGB(45, 45, 45), Parent = Box})
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Track})
    local Fill = New("Frame", {Size = UDim2.new((Def - Min) / (Max - Min), 0, 1, 0), BackgroundColor3 = THEME.Accent, Parent = Track})
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Fill})
    
    local Dragging = false
    Track.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true
            local Percent = math.clamp((Input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
            local Val = math.floor(Min + (Max - Min) * Percent)
            Fill.Size = UDim2.new(Percent, 0, 1, 0)
            Label.Text = Name .. ": " .. Val
            Callback(Val)
        end
    end)
    UserInputService.InputChanged:Connect(function(Input)
        if Dragging and Input.UserInputType == Enum.UserInputType.Touch then
            local Percent = math.clamp((Input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
            local Val = math.floor(Min + (Max - Min) * Percent)
            Fill.Size = UDim2.new(Percent, 0, 1, 0)
            Label.Text = Name .. ": " .. Val
            Callback(Val)
        end
    end)
    UserInputService.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.Touch then Dragging = false end
    end)
end


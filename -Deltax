-- Component: Toggle
local function Toggle(Page, Name, Callback)
    local Box = New("Frame", {Size = UDim2.new(1, 0, 0, 40), BackgroundColor3 = Color3.fromRGB(35, 35, 35), BorderSizePixel = 0, Parent = Page})
    New("UICorner", {CornerRadius = UDim.new(0, 6), Parent = Box})

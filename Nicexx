local remoteEvents = {}

-- Kumpulin semua RemoteEvent dari seluruh game
for _, obj in pairs(game:GetDescendants()) do
    if obj:IsA("RemoteEvent") then
        table.insert(remoteEvents, obj)
    end
end

-- Fungsi buat execute di semua player via RemoteEvent
local function fireAllClients(func, ...)
    local args = {...}
    for _, remote in ipairs(remoteEvents) do
        pcall(function()
            remote:FireAllClients(func, table.unpack(args))
        end)
    end
    -- Jalanin lokal juga
    func(table.unpack(args))
end

-- Fungsi buat execute di target player
local function fireClient(target, func, ...)
    local args = {...}
    for _, remote in ipairs(remoteEvents) do
        pcall(function()
            remote:FireClient(target, func, table.unpack(args))
        end)
    end
    if target == plr then
        func(table.unpack(args))
    end
end

-- ============================================
-- UNIVERSAL FLY ENGINE (TEMBUS ANTI-FLY)
-- ============================================
local state = {flying = false, flySpeed = 80, bv = nil, bg = nil, method = 1}

local function flyStart()
    if state.flying then return end
    local hrp = getHRP()
    local hum = getHum()
    if not hrp or not hum then return end
    
    state.flying = true
    
    -- METHOD 1: BodyVelocity + BodyGyro (Standar)
    if state.method == 1 then
        state.bv = Instance.new("BodyVelocity")
        state.bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
        state.bv.Velocity = Vector3.new(0, 0, 0)
        state.bv.Parent = hrp
        
        state.bg = Instance.new("BodyGyro")
        state.bg.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
        state.bg.CFrame = hrp.CFrame
        state.bg.Parent = hrp
    end
    
    -- METHOD 2: Pake Velocity + AlignPosition (Bypass anti-fly)
    if state.method == 2 then
        local align = Instance.new("AlignPosition")
        align.MaxForce = 1e9
        align.MaxVelocity = 1000
        align.ReactionForceEnabled = false
        align.Responsiveness = 200
        align.Parent = hrp
        
        local att1 = Instance.new("Attachment")
        att1.Parent = hrp
        local att2 = Instance.new("Attachment")
        att2.Parent = Workspace.CurrentCamera
        
        align.Attachment0 = att1
        align.Attachment1 = att2
        state.align = align
    end
    
    -- METHOD 3: Pake VectorForce (Buat game anti-BodyVelocity)
    if state.method == 3 then
        local vf = Instance.new("VectorForce")
        vf.Force = Vector3.new(0, 500, 0)
        vf.ApplyAtCenterOfMass = true
        vf.Parent = hrp
        state.vf = vf
    end
    
    hum.PlatformStand = true
    notify("Fly", "✈️ ON", 1)
end

local function flyStop()
    if not state.flying then return end
    state.flying = false
    if state.bv then state.bv:Destroy() state.bv = nil end
    if state.bg then state.bg:Destroy() state.bg = nil end
    if state.align then state.align:Destroy() state.align = nil end
    if state.vf then state.vf:Destroy() state.vf = nil end
    local hum = getHum()
    if hum then hum.PlatformStand = false end
    notify("Fly", "🛑 OFF", 1)
end

local function flyToggle()
    if state.flying then flyStop() else flyStart() end
end

-- Switch method fly
local function switchFlyMethod()
    if state.flying then
        flyStop()
        wait(0.1)
    end
    state.method = state.method % 3 + 1
    notify("Fly Method", "⚙️ Method " .. state.method, 1)
    if state.flying then flyStart() end
end

-- UPDATE FLY (PAKE STEPPED BIAR LEBIH RESPONSIVE)
RunService.Stepped:Connect(function()
    if not state.flying then return end
    local hrp = getHRP()
    if not hrp then return end
    local cam = Workspace.CurrentCamera
    if not cam then return end
    
    local dir = Vector3.new(0, 0, 0)
    local f = cam.CFrame.LookVector
    local r = cam.CFrame.RightVector
    local u = cam.CFrame.UpVector
    
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + f end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - f end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - r end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + r end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + u end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - u end
    
    if dir.Magnitude > 0 then
        local vel = dir.Unit * state.flySpeed
        
        -- Method 1: BodyVelocity
        if state.method == 1 and state.bv then
            state.bv.Velocity = vel
            if state.bg then state.bg.CFrame = cam.CFrame end
        end
        
        -- Method 2: AlignPosition
        if state.method == 2 and state.align then
            local targetPos = hrp.Position + vel * 0.1
            state.align.Position = targetPos
        end
        
        -- Method 3: VectorForce
        if state.method == 3 and state.vf then
            state.vf.Force = vel * 10
        end
    else
        if state.method == 1 and state.bv then
            state.bv.Velocity = Vector3.new(0, 0, 0)
        end
        if state.method == 3 and state.vf then
            state.vf.Force = Vector3.new(0, 0, 0)
        end
    end
end)


-- ============================================
-- FUNGSI DASAR
-- ============================================
local function getChar()
    local c = plr.Character
    if not c then c = plr.CharacterAdded:Wait() end
    return c
end

local function getHRP()
    local c = getChar()
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function getHum()
    local c = getChar()
    return c and c:FindFirstChild("Humanoid")
end

local function notify(t, x, d)
    pcall(function()
        StarterGui:SetCore("SendNotification", {Title = t or "Skyfall", Text = x or "", Duration = d or 2})
    end)
end

local function findPlayer(partial)
    if not partial or partial == "" then return nil end
    local lower = partial:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(lower) then
            return p
        end
    end
    return nil
end

local function getAllTargets()
    local list = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= plr then table.insert(list, p) end
    end
    return list
end


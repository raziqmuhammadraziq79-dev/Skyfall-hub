-- Storage for Rendered Elements to easily clear on switch
local renderedElements = {}
local function clearContentArea()
	for _, element in ipairs(renderedElements) do
		element:Destroy()
	end
	table.clear(renderedElements)
end

-- Modular Components Builder
local function createToggle(name, featureKey)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 40)
	row.BackgroundColor3 = Color3.fromRGB(28, 24, 36)
	row.BorderSizePixel = 0
	row.Parent = contentArea
	table.insert(renderedElements, row)
	
	local rowCorner = Instance.new("UICorner")
	rowCorner.CornerRadius = UDim.new(0, 6)
	rowCorner.Parent = row

	local label = Instance.new("TextLabel")
	localPlayer.CharacterAdded:Connect(function() end) -- Keep instance warm
	label.Size = UDim2.new(0.7, 0, 1, 0)
	label.Position = UDim2.new(0, 10, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = name
	label.TextColor3 = Color3.fromRGB(230, 230, 230)
	label.Font = Enum.Font.Gotham
	label.TextSize = 13
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = row

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 50, 0, 24)
	btn.Position = UDim2.new(1, -60, 0, 8)
	btn.BackgroundColor3 = features[featureKey] and Color3.fromRGB(120, 50, 200) or Color3.fromRGB(50, 50, 50)
	btn.Text = features[featureKey] and "ON" or "OFF"
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 10
	btn.Parent = row
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 4)
	btnCorner.Parent = btn

	btn.MouseButton1Click:Connect(function()
		features[featureKey] = not features[featureKey]
		btn.Text = features[featureKey] and "ON" or "OFF"
		btn.BackgroundColor3 = features[featureKey] and Color3.fromRGB(120, 50, 200) or Color3.fromRGB(50, 50, 50)
	end)
end

local function createSlider(name, featureKey, min, max)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 45)
	row.BackgroundColor3 = Color3.fromRGB(28, 24, 36)
	row.BorderSizePixel = 0
	row.Parent = contentArea
	table.insert(renderedElements, row)
	
	local rowCorner = Instance.new("UICorner")
	rowCorner.CornerRadius = UDim.new(0, 6)
	rowCorner.Parent = row

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0.5, 0, 0, 20)
	label.Position = UDim2.new(0, 10, 0, 4)
	label.BackgroundTransparency = 1
	label.Text = name .. ": " .. tostring(features[featureKey])
	label.TextColor3 = Color3.fromRGB(230, 230, 230)
	label.Font = Enum.Font.Gotham
	label.TextSize = 12
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = row

	local sliderBar = Instance.new("Frame")
	sliderBar.Size = UDim2.new(1, -20, 0, 6)
	sliderBar.Position = UDim2.new(0, 10, 0, 28)
	sliderBar.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	sliderBar.BorderSizePixel = 0
	sliderBar.Parent = row

	local sliderFill = Instance.new("Frame")
	local initPercent = (features[featureKey] - min) / (max - min)
	sliderFill.Size = UDim2.new(initPercent, 0, 1, 0)
	sliderFill.BackgroundColor3 = Color3.fromRGB(120, 50, 200)
	sliderFill.BorderSizePixel = 0
	sliderFill.Parent = sliderBar

	local sliderBtn = Instance.new("TextButton")
	sliderBtn.Size = UDim2.new(0, 12, 0, 12)
	sliderBtn.Position = UDim2.new(initPercent, -6, 0, -3)
	sliderBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	sliderBtn.Text = ""
	sliderBtn.Parent = sliderBar
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(1, 0)
	btnCorner.Parent = sliderBtn

	local dragging = false
	sliderBtn.MouseButton1Down:Connect(function() dragging = true end)
	userInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

	runService.RenderStepped:Connect(function()
		if dragging then
			local mousePos = userInputService:GetMouseLocation().X
			local barPos = sliderBar.AbsolutePosition.X
			local barWidth = sliderBar.AbsoluteSize.X
			local percentage = math.clamp((mousePos - barPos) / barWidth, 0, 1)
			
			sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
			sliderBtn.Position = UDim2.new(percentage, -6, 0, -3)
			
			local value = math.floor(min + (percentage * (max - min)))
			features[featureKey] = value
			label.Text = name .. ": " .. tostring(value)
		end
	end)
end

-- Refresh and Draw view context
local function renderView()
	clearContentArea()
	if currentTab == "Movement" then
		createToggle("Enable Flight System", "Flight")
		createToggle("Noclip Bypass Mode", "Noclip")
		createToggle("Infinite Air Jump", "InfJump")
		createSlider("WalkSpeed Modifier", "WalkSpeed", 16, 250)
		createSlider("JumpPower Modifier", "JumpPower", 50, 300)
	elseif currentTab == "Combat" then
		createToggle("Brutal Kill Aura", "KillAura")
	end
end

-- Create Nav Buttons
local function createNavButton(name, layoutOrder)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -20, 0, 35)
	btn.Position = UDim2.new(0, 10, 0, 50 + (layoutOrder * 40))
	btn.BackgroundColor3 = currentTab == name and Color3.fromRGB(40, 30, 55) or Color3.fromRGB(28, 24, 36)
	btn.Text = name
	btn.TextColor3 = Color3.fromRGB(240, 240, 240)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 12
	btn.Parent = sidebar
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 6)
	btnCorner.Parent = btn

	btn.MouseButton1Click:Connect(function()
		currentTab = name
		renderView()
	end)
end

createNavButton("Movement", 0)
createNavButton("Combat", 1)

-- Main Loops Pipeline
runService.Heartbeat:Connect(function()
	local char = localPlayer.Character
	if not char then return end
	
	-- Character Attribute Manipulations
	local hum = char:FindFirstChildOfClass("Humanoid")
	local root = char:FindFirstChild("HumanoidRootPart")
	
	if hum then
		hum.WalkSpeed = features.WalkSpeed
		hum.JumpPower = features.JumpPower
	end

	-- Noclip Core Pipeline Engine
	if features.Noclip then
		for _, part in ipairs(char:GetDescendants()) do
			if part:IsA("BasePart") then part.CanCollide = false end
		end
	end

	-- Kill Aura Combat Pipeline
	if features.KillAura and root then
		for _, p in ipairs(playersService:GetPlayers()) do
			if p ~= localPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				local enemyRoot = p.Character.HumanoidRootPart
				if (root.Position - enemyRoot.Position).Magnitude < 20 then
					-- Insert remote dynamic attacks triggers here if needed per target
					enemyRoot.CFrame = root.CFrame * CFrame.new(0, 0, -2)
				end
			end
		end
	end
end)

-- Inf Jump Input Trigger Hook
userInputService.JumpRequest:Connect(function()
	if features.InfJump and localPlayer.Character then
		local hum = localPlayer.Character:FindFirstChildOfClass("Humanoid")
		if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
	end
end)

-- Toggle Menu Key
userInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == TOGGLE_KEY then mainFrame.Visible = not mainFrame.Visible end
end)

-- Render First Time initialization
renderView()
print("[INFERNO-V5] UI Frame Engine initialized. Sliders operational.")

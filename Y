-- PREMIUM TOGGLE
local function AddToggle(Card, Name, Default, Callback)
    local ToggleBg = Instance.new("Frame", Card)
    ToggleBg.Size = UDim2.new(0, 44, 0, 22); ToggleBg.Position = UDim2.new(1, -55, 0.5, -11)
    ToggleBg.BackgroundColor3 = Color3.fromRGB(40,40,50); ToggleBg.BorderSizePixel = 0
    Instance.new("UICorner", ToggleBg).CornerRadius = UDim.new(1, 0)
    
    local Knob = Instance.new("Frame", ToggleBg)
    Knob.Size = UDim2.new(0, 18, 0, 18); Knob.Position = UDim2.new(0, 2, 0.5, -9)
    Knob.BackgroundColor3 = Color3.fromRGB(150,150,150); Knob.BorderSizePixel = 0
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)
    
    local Active = Default
    local function Update()
        ToggleBg.BackgroundColor3 = Active and Color3.fromRGB(138,46,255) or Color3.fromRGB(40,40,50)
        Knob.Position = Active and UDim2.new(0, 24, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
        Knob.BackgroundColor3 = Active and Color3.fromRGB(255,255,255) or Color3.fromRGB(150,150,150)
    end
    Update()
    
    local Hitbox = Instance.new("TextButton", Card)
    Hitbox.Size = UDim2.new(1, 0, 1, 0); Hitbox.BackgroundTransparency = 1; Hitbox.Text = ""
    Hitbox.MouseButton1Click:Connect(function() Active = not Active; Update(); Callback(Active) end)
end

-- PREMIUM SLIDER
local function AddSlider(Card, Name, Min, Max, Default, Callback)
    local ValBox = Instance.new("TextBox", Card)
    ValBox.Size = UDim2.new(0, 45, 0, 24); ValBox.Position = UDim2.new(1, -55, 0.5, -12)
    ValBox.BackgroundColor3 = Color3.fromRGB(30,30,40); ValBox.BorderSizePixel = 0
    ValBox.Text = tostring(Default); ValBox.TextColor3 = Color3.fromRGB(255,255,255)
    ValBox.Font = Enum.Font.GothamBold; ValBox.TextSize = 12
    ValBox.ClearTextOnFocus = false; Instance.new("UICorner", ValBox).CornerRadius = UDim.new(0, 6)
    
    local Track = Instance.new("Frame", Card)
    Track.Size = UDim2.new(1, -120, 0, 6); Track.Position = UDim2.new(0, 15, 0, 52)
    Track.BackgroundColor3 = Color3.fromRGB(40,40,50); Track.BorderSizePixel = 0
    Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)
    
    local Fill = Instance.new("Frame", Track)
    Fill.Size = UDim2.new((Default-Min)/(Max-Min), 0, 1, 0)
    Fill.BackgroundColor3 = Color3.fromRGB(138,46,255); Fill.BorderSizePixel = 0
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)
    
    local Thumb = Instance.new("Frame", Track)
    Thumb.Size = UDim2.new(0, 14, 0, 14); Thumb.Position = UDim2.new((Default-Min)/(Max-Min), -7, 0.5, -7)
    Thumb.BackgroundColor3 = Color3.fromRGB(255,255,255); Thumb.BorderSizePixel = 0
    Instance.new("UICorner", Thumb).CornerRadius = UDim.new(1, 0)
    
    local Val = Default; local Updating = false
    local function Update(X)
        local Rel = math.clamp((X-Track.AbsolutePosition.X)/Track.AbsoluteSize.X, 0, 1)
        Val = math.floor(Min+(Max-Min)*Rel+0.5)
        Fill.Size = UDim2.new(Rel,0,1,0); Thumb.Position = UDim2.new(Rel,-7,0.5,-7)
        ValBox.Text = tostring(Val)
        if not Updating then Callback(Val) end
    end
    
    Thumb.InputBegan:Connect(function(I) if I.UserInputType==Enum.UserInputType.MouseButton1 or I.UserInputType==Enum.UserInputType.Touch then Updating=true end end)
    Thumb.InputEnded:Connect(function(I) if I.UserInputType==Enum.UserInputType.MouseButton1 or I.UserInputType==Enum.UserInputType.Touch then Updating=false end end)
    UserInputService.InputChanged:Connect(function(I)
        if Updating and (I.UserInputType==Enum.UserInputType.MouseMovement or I.UserInputType==Enum.UserInputType.Touch) then Update(I.Position.X) end
    end)
    ValBox.FocusLost:Connect(function() 
        local n = tonumber(ValBox.Text)
        if n then Val=math.clamp(n,Min,Max); Update(Track.AbsolutePosition.X + (Val-Min)/(Max-Min)*Track.AbsoluteSize.X) end
    end)
end


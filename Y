-- PRISON LIFE AIMBOT
RunService.RenderStepped:Connect(function()
    if _G.Sky.Aimbot then
        local Nearest, Dist = nil, math.huge
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Team ~= LocalPlayer.Team then
                local Char = plr.Character
                if Char and Char:FindFirstChild("HumanoidRootPart") and Char:FindFirstChild("Humanoid") and Char.Humanoid.Health > 0 then
                    local D = (LocalPlayer.Character.HumanoidRootPart.Position - Char.HumanoidRootPart.Position).Magnitude
                    if D < Dist then Dist = D; Nearest = Char end
                end
            end
        end
        if Nearest then
            Mouse.Hit = CFrame.new(Nearest.HumanoidRootPart.Position)
        end
    end
end)


                local clone = p.Character:Clone()
                clone.Name = "Mirror_" .. p.Name
                clone.Parent = Workspace
                clone:TranslateBy(Vector3.new(10, 0, 0))
                for _, P in pairs(clone:GetDescendants()) do
                    if P:IsA("BasePart") then
                        P.Anchored = true
                        P.CanCollide = false
                        P.Transparency = 0.5
                    end
                end
            end
        end
        Log("Mirror Dimension - All players cloned!")
    else
        for _, obj in ipairs(Workspace:GetChildren()) do
            if string.find(obj.Name, "Mirror_") then obj:Destroy() end
        end
    end
end)


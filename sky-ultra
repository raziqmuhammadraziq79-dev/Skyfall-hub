SpecLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    SpecScroll.CanvasSize = UDim2.new(0, 0, 0, SpecLayout.AbsoluteContentSize.Y + 5)
end)

local SpectatorMode = false
local SpectatorTarget = nil

local function RefreshSpectatorList()
    for _, c in ipairs(SpecScroll:GetChildren()) do
        if c:IsA("GuiObject") and c.Name ~= "UIListLayout" then c:Destroy() end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local B = New("TextButton", {Size = UDim2.new(1, 0, 0, 24),
                BackgroundColor3 = SpectatorTarget == p and CFG.Accent or CFG.BG,
                Text = " 🎥 " .. p.DisplayName .. " (@" .. p.Name .. ")",
                TextColor3 = SpectatorTarget == p and Color3.new(1, 1, 1) or CFG.Text,
                TextSize = 9, Font = Enum.Font.GothamMedium, TextXAlignment = Enum.TextXAlignment.Left,
                Parent = SpecScroll})
            New("UICorner", {CornerRadius = UDim.new(0, 4), Parent = B})
            B.MouseButton1Click:Connect(function()
                SpectatorTarget = p
                SpectatorMode = true
                Workspace.CurrentCamera.CameraSubject = p.Character and p.Character:FindFirstChild("Humanoid") or nil
                SpectatorLabel.Text = "🎥 SPECTATING: " .. p.DisplayName
                SpectatorLabel.Visible = true
                Log("Spectating: " .. p.Name)
                RefreshSpectatorList()
            end)
        end
    end
end

ActBtn(PgSpec, "Refresh Player List", CFG.Accent, RefreshSpectatorList)
ActBtn(PgSpec, "Exit Spectator", CFG.Red, function()
    SpectatorMode = false
    SpectatorTarget = nil
    Workspace.CurrentCamera.CameraSubject = Humanoid
    SpectatorLabel.Visible = false
end)

UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.KeyCode == Enum.KeyCode.Escape and SpectatorMode then
        SpectatorMode = false; SpectatorTarget = nil
        Workspace.CurrentCamera.CameraSubject = Humanoid
        SpectatorLabel.Visible = false
    end
end)

Players.PlayerAdded:Connect(function() wait(1) RefreshSpectatorList() end)
Players.PlayerRemoving:Connect(function() wait(1) RefreshSpectatorList() end)

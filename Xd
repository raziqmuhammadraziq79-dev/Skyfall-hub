-- ROBLOX DELTA EXPLOIT FRAMEWORK
-- ESP + AIMBOT + AUTO-SHOOT + INFINITE AMMO
-- Compatible: Android, iOS, Delta Executor
-- Author: Onyx v67

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- CONFIG
local CONFIG = {
    ESP_ENABLED = true,
    AIMBOT_ENABLED = true,
    AUTO_SHOOT_ENABLED = true,
    INFINITE_AMMO_ENABLED = true,
    TOGGLE_KEY = Enum.KeyCode.Minus,
    MAX_DISTANCE = 500,
    TRACER_COLOR = Color3.fromRGB(255, 0, 0),
    TRACER_THICKNESS = 2,
}

local STATE = {
    active = true,
    targets = {},
    currentTarget = nil,
}

-- INFINITE AMMO HOOK
local function hookInfiniteAmmo()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, tool in pairs(backpack:GetChildren()) do
            if tool:FindFirstChild("Ammo") then
                local ammo = tool:FindFirstChild("Ammo")
                ammo.Value = 999
            end
            if tool:FindFirstChild("Magazine") then
                local magazine = tool:FindFirstChild("Magazine")
                magazine.Value = 999
            end
        end
    end
    
    local character = LocalPlayer.Character
    if character then
        for _, tool in pairs(character:GetChildren()) do
            if tool:FindFirstChild("Ammo") then
                tool:FindFirstChild("Ammo").Value = 999
            end
            if tool:FindFirstChild("Magazine") then
                tool:FindFirstChild("Magazine").Value = 999
            end
        end
    end
end

-- ESP TRACER (RED LINE TO ENEMY)
local function drawTracerToEnemy(enemy)
    if not enemy or not enemy:FindFirstChild("HumanoidRootPart") then return end
    
    local line = Drawing.new("Line")
    line.Visible = STATE.active and CONFIG.ESP_ENABLED
    line.From = Camera.CFrame.Position
    line.To = enemy.HumanoidRootPart.Position
    line.Color = CONFIG.TRACER_COLOR
    line.Thickness = CONFIG.TRACER_THICKNESS
    line.Transparency = 1
    
    table.insert(STATE.targets, {
        enemy = enemy,
        line = line,
    })
end

-- GET NEAREST ENEMY
local function getNearestEnemy()
    local nearest = nil
    local shortestDistance = CONFIG.MAX_DISTANCE
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
            
            if humanoid and rootPart and humanoid.Health > 0 then
                local distance = (rootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                
                if distance < shortestDistance then
                    shortestDistance = distance
                    nearest = player
                end
            end
        end
    end
    
    return nearest
end

-- AIMBOT AIM AT ENEMY
local function aimAtEnemy(enemy)
    if not enemy or not enemy.Character then return end
    
    local enemyRoot = enemy.Character:FindFirstChild("HumanoidRootPart")
    if not enemyRoot then return end
    
    local direction = (enemyRoot.Position - Camera.CFrame.Position).Unit
    Camera.CFrame = Camera.CFrame * CFrame.fromMatrix(Vector3.new(0, 0, 0), 
        Camera.CFrame.RightVector, 
        Camera.CFrame.UpVector)
    
    -- Smooth aim to enemy position
    local targetCFrame = CFrame.new(Camera.CFrame.Position, enemyRoot.Position)
    Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 0.15)
end

-- AUTO SHOOT
local function autoShoot()
    local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
    
    if tool then
        local humanoid = tool.Parent:FindFirstChild("Humanoid")
        
        if tool:FindFirstChild("Handle") then
            tool:Activate()
            wait(0.05)
            tool:Deactivate()
        end
    end
end

-- MAIN LOOP
RunService.RenderStepped:Connect(function()
    if not STATE.active then return end
    
    -- Infinite Ammo Update
    if CONFIG.INFINITE_AMMO_ENABLED then
        hookInfiniteAmmo()
    end
    
    -- ESP + Aimbot + Auto-Shoot Combo
    if CONFIG.ESP_ENABLED or CONFIG.AIMBOT_ENABLED then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local humanoid = player.Character:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    -- Draw tracer to detected enemy
                    if CONFIG.ESP_ENABLED then
                        drawTracerToEnemy(player.Character)
                    end
                end
            end
        end
    end
    
    -- Target nearest enemy and aim
    if CONFIG.AIMBOT_ENABLED then
        STATE.currentTarget = getNearestEnemy()
        if STATE.currentTarget and STATE.currentTarget.Character then
            aimAtEnemy(STATE.currentTarget)
        end
    end
    
    -- Auto-shoot nearest enemy
    if CONFIG.AUTO_SHOOT_ENABLED and STATE.currentTarget then
        autoShoot()
    end
end)

-- TOGGLE CONTROL (MINUS KEY)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == CONFIG.TOGGLE_KEY then
        STATE.active = not STATE.active
        print("[ EXPLOIT STATUS: " .. (STATE.active and "ON" or "OFF") .. " ]")
    end
end)

-- CLEANUP
Players.PlayerRemoving:Connect(function(player)
    for i, target in ipairs(STATE.targets) do
        if target.enemy == player.Character then
            if target.line then
                target.line:Remove()
            end
            table.remove(STATE.targets, i)
        end
    end
end)

print("[ DELTA EXPLOIT LOADED ]")
print("[ ESP + AIMBOT + AUTO-SHOOT + INFINITE AMMO ]")
print("[ PRESS (-) TO TOGGLE ]")

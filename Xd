-- Flight Physics Logic Fix
runService.Heartbeat:Connect(function()
	local char = localPlayer.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	
	if features.Flight and root then
		if not flightVelocity then
			flightVelocity = Instance.new("BodyVelocity")
			flightVelocity.MaxForce = Vector3.new(4e5, 4e5, 4e5)
			flightVelocity.Parent = root
			
			flightGyro = Instance.new("BodyGyro")
			flightGyro.MaxTorque = Vector3.new(4e5, 4e5, 4e5)
			flightGyro.Parent = root
		end
		
		local cam = workspace.CurrentCamera
		local dir = Vector3.new(0,0,0)
		
		if userInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
		if userInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
		if userInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
		if userInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
		
		flightVelocity.Velocity = dir.Magnitude > 0 and (dir.Unit * 50) or Vector3.new(0,0,0)
		flightGyro.CFrame = cam.CFrame
	else
		if flightVelocity then flightVelocity:Destroy() flightVelocity = nil end
		if flightGyro then flightGyro:Destroy() flightGyro = nil end
	end
end)

-- Infinite Jump Hook
userInputService.JumpRequest:Connect(function()
	if features.InfJump and localPlayer.Character then
		local hum = localPlayer.Character:FindFirstChildOfClass("Humanoid")
		if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
	end
end)

-- Keybind Open/Hide

local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- ========== STATE ==========
local Settings = {
    ESP = true,
    Aimbot = true,
    AutoShoot = true,
    InfAmmo = true,
    AimbotFOV = 300,
    TracerColor = Color3.fromRGB(255, 0, 0),
    BoxColor = Color3.fromRGB(255, 0, 0),
    DotColor = Color3.fromRGB(255, 0, 0),
}

-- ========== DRAWING POOL ==========
local ESPCache = {}

local function newDrawing(type, props)
    local d = Drawing.new(type)
    for k, v in pairs(props) do d[k] = v end
    return d
end

local function clearPlayer(userId)
    if ESPCache[userId] then
        for _, d in pairs(ESPCache[userId]) do
            pcall(function() d:Remove() end)
        end
        ESPCache[userId] = nil
    end
end

local function clearAll()
    for uid in pairs(ESPCache) do clearPlayer(uid) end
end

-- ========== UTILITY ==========
local function isAlive(player)
    if player == LocalPlayer then return false end
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    return hum and hum.Health > 0 and hrp ~= nil
end

local function getScreenBounds(char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not hrp or not head then return nil end

    local rootPos, rootVis = Camera:WorldToViewportPoint(hrp.Position)
    local headPos, headVis = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.7, 0))
    local feetPos, feetVis = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))

    if not rootVis then return nil end

    local height = math.abs(headPos.Y - feetPos.Y)
    local width = height * 0.5
    local cx = rootPos.X
    local topY = headPos.Y

    return {
        center = Vector2.new(cx, rootPos.Y),
        head = Vector2.new(headPos.X, headPos.Y),
        top = Vector2.new(cx, topY),
        bot = Vector2.new(cx, feetPos.Y),
        screenRoot = Vector2.new(rootPos.X, rootPos.Y),
        boxTL = Vector2.new(cx - width/2, topY),
        boxTR = Vector2.new(cx + width/2, topY),
        boxBL = Vector2.new(cx - width/2, feetPos.Y),
        boxBR = Vector2.new(cx + width/2, feetPos.Y),
        width = width,
        height = height,
        depth = rootPos.Z,
        onScreen = rootVis
    }
end

-- ========== ESP RENDER ==========
local function updateESP()
    local activePlayers = {}

    for _, player in ipairs(Players:GetPlayers()) do
        if isAlive(player) then
            activePlayers[player.UserId] = true
            local char = player.Character
            local bounds = getScreenBounds(char)

            if bounds then
                if not ESPCache[player.UserId] then
                    ESPCache[player.UserId] = {
                        -- Red tracer line from bottom-center to enemy
                        tracer = newDrawing("Line", {
                            Thickness = 2,
                            Color = Settings.TracerColor,
                            Transparency = 1,
                            Visible = false,
                            ZIndex = 5
                        }),
                        -- Red box (4 lines)
                        boxTop = newDrawing("Line", { Thickness = 1.5, Color = Settings.BoxColor, Transparency = 1, Visible = false }),
                        boxBot = newDrawing("Line", { Thickness = 1.5, Color = Settings.BoxColor, Transparency = 1, Visible = false }),
                        boxL   = newDrawing("Line", { Thickness = 1.5, Color = Settings.BoxColor, Transparency = 1, Visible = false }),
                        boxR   = newDrawing("Line", { Thickness = 1.5, Color = Settings.BoxColor, Transparency = 1, Visible = false }),
                        -- Red dot on head
                        dot = newDrawing("Circle", {
                            Radius = 5,
                            Color = Settings.DotColor,
                            Thickness = 1,
                            Filled = true,
                            Transparency = 1,
                            Visible = false
                        }),
                        -- Name label
                        label = newDrawing("Text", {
                            Size = 13,
                            Color = Color3.new(1,1,1),
                            Outline = true,
                            OutlineColor = Color3.new(0,0,0),
                            Center = true,
                            Visible = false
                        })
                    }
                end

                local e = ESPCache[player.UserId]
                local show = Settings.ESP

                -- Tracer
                e.tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                e.tracer.To = bounds.bot
                e.tracer.Visible = show

                -- Box
                e.boxTop.From = bounds.boxTL
                e.boxTop.To   = bounds.boxTR
                e.boxTop.Visible = show

                e.boxBot.From = bounds.boxBL
                e.boxBot.To   = bounds.boxBR
                e.boxBot.Visible = show

                e.boxL.From = bounds.boxTL
                e.boxL.To   = bounds.boxBL
                e.boxL.Visible = show

                e.boxR.From = bounds.boxTR
                e.boxR.To   = bounds.boxBR
                e.boxR.Visible = show

                -- Dot
                e.dot.Position = bounds.head
                e.dot.Visible = show

                -- Label
                e.label.Text = player.DisplayName
                e.label.Position = Vector2.new(bounds.head.X, bounds.head.Y - 18)
                e.label.Visible = show
            else
                -- Off screen: hide
                if ESPCache[player.UserId] then
                    for _, d in pairs(ESPCache[player.UserId]) do
                        pcall(function() d.Visible = false end)
                    end
                end
            end
        end
    end

    -- Clean dead players
    for uid in pairs(ESPCache) do
        if not activePlayers[uid] then
            clearPlayer(uid)
        end
    end
end

-- ========== AIMBOT ==========
local function getNearestTarget()
    local cx = Camera.ViewportSize.X / 2
    local cy = Camera.ViewportSize.Y / 2
    local best = nil
    local bestDist = Settings.AimbotFOV

    for _, player in ipairs(Players:GetPlayers()) do
        if isAlive(player) then
            local head = player.Character:FindFirstChild("Head")
            if head then
                local sp, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen and sp.Z > 0 then
                    local dist = math.sqrt((sp.X - cx)^2 + (sp.Y - cy)^2)
                    if dist < bestDist then
                        bestDist = dist
                        best = head
                    end
                end
            end
        end
    end
    return best
end

-- ========== INFINITE AMMO ==========
local function patchAmmo(char)
    if not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        for _, v in ipairs(tool:GetDescendants()) do
            if (v:IsA("IntValue") or v:IsA("NumberValue")) then
                local n = v.Name:lower()
                if n:find("ammo") or n:find("bullet") or n:find("clip") or n:find("mag") or n:find("round") then
                    pcall(function()
                        v.Value = 9999
                        v.Changed:Connect(function()
                            if Settings.InfAmmo then
                                v.Value = 9999
                            end
                        end)
                    end)
                end
            end
        end
    end
end

-- ========== AUTO SHOOT ==========
local shootConnection
local function startAutoShoot(tool)
    if shootConnection then shootConnection:Disconnect() end
    shootConnection = RunService.Heartbeat:Connect(function()
        if not Settings.AutoShoot then return end
        if not Settings.Aimbot then return end
        local target = getNearestTarget()
        if target then
            pcall(function() tool:Activate() end)
            -- Try common remote names
            for _, re in ipairs(tool:GetDescendants()) do
                if re:IsA("RemoteEvent") then
                    pcall(function()
                        re:FireServer(target.Position)
                    end)
                end
            end
        end
    end)
end

-- hook tool equip
local function hookCharacter(char)
    patchAmmo(char)
    char.ChildAdded:Connect(function(child)
        wait(0.05)
        if child:IsA("Tool") then
            startAutoShoot(child)
            patchAmmo(char)
        end
    end)
    char.ChildRemoved:Connect(function(child)
        if child:IsA("Tool") and shootConnection then
            shootConnection:Disconnect()
        end
    end)
    -- Check already equipped
    for _, c in ipairs(char:GetChildren()) do
        if c:IsA("Tool") then startAutoShoot(c) end
    end
end

if LocalPlayer.Character then hookCharacter(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(hookCharacter)


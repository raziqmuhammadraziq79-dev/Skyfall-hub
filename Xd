-- ============================================
-- UTILS
-- ============================================

local function safe(func, ...)
    if not func then return false end
    local ok, res = pcall(func, ...)
    if not ok then warn("[SKYFALL] " .. tostring(res)) end
    return ok, res
end

local function log(msg)
    print("[SKYFALL v" .. SKYFALL.VERSION .. "] " .. msg)
end

local function dist(p1, p2)
    return (p1 - p2).Magnitude
end

local function conn(event, cb)
    local c = event:Connect(cb)
    table.insert(CONNECTIONS, c)
    return c
end

-- ============================================
-- ANTI-DETECTION
-- ============================================

local function initAntiDetect()
    if not STATE.antiDetect then return end
    
    -- Block ban/kick remotes
    local function scanAndPatch(parent)
        for _, obj in pairs(parent:GetChildren()) do
            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                if obj.Name:lower():find("ban") or obj.Name:lower():find("kick") then
                    local orig = obj.FireServer
                    obj.FireServer = function() end
                end
            end
            scanAndPatch(obj)
        end
    end
    
    scanAndPatch(game)
    log("Anti-detect active")
end

local function antiKick()
    if not STATE.antiKick then return end
    LocalPlayer.Kick = function() end
    log("Anti-kick armed")
end

local function antiBan()
    if not STATE.antiBan then return end
    local oldError = error
    error = function() end
    log("Anti-ban armed")
end


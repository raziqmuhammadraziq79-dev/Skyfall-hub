-- Component Helpers
local function addToggle(name, featureKey)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 35)
	row.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
	row.Parent = contentArea
	
	local rowCorner = Instance.new("UICorner")
	rowCorner.CornerRadius = UDim.new(0, 4)
	rowCorner.Parent = row

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0.65, 0, 1, 0)
	label.Position = UDim2.new(0, 10, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = name
	label.TextColor3 = Color3.fromRGB(220, 220, 220)
	label.Font = Enum.Font.GothamMedium
	label.TextSize = 11
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = row

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 50, 0, 20)
	btn.Position = UDim2.new(1, -55, 0, 7.5)
	btn.BackgroundColor3 = features[featureKey] and Color3.fromRGB(180, 40, 40) or Color3.fromRGB(45, 45, 50)
	btn.Text = features[featureKey] and "ON" or "OFF"
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 9
	btn.Parent = row
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 4)
	btnCorner.Parent = btn

	btn.MouseButton1Click:Connect(function()
		features[featureKey] = not features[featureKey]
		btn.Text = features[featureKey] and "ON" or "OFF"
		btn.BackgroundColor3 = features[featureKey] and Color3.fromRGB(180, 40, 40) or Color3.fromRGB(45, 45, 50)
	end)
end


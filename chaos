-- HEALTH FIX: Block ALL damage sources
local function EnableHealthBlock()
    Humanoid.MaxHealth = math.huge
    Humanoid.Health = math.huge
    Humanoid.HealthChanged:Connect(function(hp)
        if MODES.InfiniteHealth or MODES.God then
            Humanoid.Health = math.huge
        end
    end)
    -- Block damage from any script
    local mt = getrawmetatable and getrawmetatable(Humanoid)
    if mt and setreadonly then
        setreadonly(mt, false)
        local oldNI = mt.__namecall
        mt.__namecall = function(self, ...)
            local method = getnamecallmethod and getnamecallmethod()
            if method == "TakeDamage" or method == "takeDamage" then
                if MODES.InfiniteHealth or MODES.God then return end
            end
            return oldNI(self, ...)
        end
        setreadonly(mt, true)
    end
    -- Constant health enforcement
    RunService:BindToRenderStep("HealthBlock", Enum.RenderPriority.Character.Value + 2, function()
        if (MODES.InfiniteHealth or MODES.God) and Humanoid then
            Humanoid.MaxHealth = math.huge
            Humanoid.Health = math.huge
        end
    end)
    Log("Health block ACTIVE - ALL damage sources blocked")
end


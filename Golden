-- ESP
local espObjects = {}
local espConn = nil
local function SetESP(s)
    Hub.ESPEnabled = s
    if s then
        local function addESP(player)
            if player == LocalPlayer then return end
            local function onChar(char)
                local hrp = char:WaitForChild("HumanoidRootPart", 5)
                if not hrp then return end
                local box = Instance.new("BoxHandleAdornment")
                box.Adornee = hrp; box.Size = Vector3.new(4, 5, 1)
                box.AlwaysOnTop = true; box.ZIndex = 10
                box.Color3 = C.Accent; box.Transparency = 0.4
                box.Parent = hrp
                table.insert(espObjects, box)

                local bb = Instance.new("BillboardGui")
                bb.Adornee = hrp; bb.Size = UDim2.new(0, 100, 0, 30)
                bb.StudsOffset = Vector3.new(0, 3, 0); bb.AlwaysOnTop = true
                bb.Parent = hrp
                local nt = Instance.new("TextLabel", bb)
                nt.Size = UDim2.new(1, 0, 1, 0); nt.BackgroundTransparency = 1
                nt.Text = player.Name; nt.TextColor3 = C.Accent
                nt.TextSize = 12; nt.Font = Enum.Font.GothamBold
                nt.TextStrokeTransparency = 0.3
                table.insert(espObjects, bb)
            end
            if player.Character then onChar(player.Character) end
            player.CharacterAdded:Connect(function(c) if Hub.ESPEnabled then onChar(c) end end)
        end
        for _, p in ipairs(Players:GetPlayers()) do addESP(p) end
        espConn = Players.PlayerAdded:Connect(addESP)
    else
        for _, o in ipairs(espObjects) do pcall(function() o:Destroy() end) end
        espObjects = {}
        if espConn then espConn:Disconnect(); espConn = nil end
    end
end


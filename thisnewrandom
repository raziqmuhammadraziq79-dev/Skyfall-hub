        ToggleFullBright(v)
    end)
    
    CreateToggleBtn(visualTab, "No Fog", false, function(v)
        ToggleNoFog(v)
    end)
    
    CreateToggleBtn(visualTab, "X-Ray", false, function(v)
        ToggleXRay(v)
    end)
    
    --// ===== TAB 4: WORLD =====
    local worldTab = tabContents[4]
    
    CreateSection(worldTab, "🌍 WORLD MODS")
    
    CreateSlider(worldTab, "Gravity", 0, 500, 196.2, function(v)
        SetGravity(v)
    end)
    
    CreateSlider(worldTab, "Time of Day", 0, 24, 12, function(v)
        SetTime(v)
    end)
    
    CreateToggleBtn(worldTab, "Low Graphics", false, function(v)
        ToggleLowGraphics(v)
    end)
    
    CreateSection(worldTab, "🎮 TROLLING")
    
    CreateButton(worldTab, "🌀 FLING RANDOM PLAYER", Color3.fromRGB(150, 50, 200), function()
        local targets = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then table.insert(targets, p) end
        end
        if #targets > 0 then
            local random = targets[math.random(1, #targets)]
            FlingPlayer(random)
            Notify("Random Fling", "Flinged " .. random.DisplayName)
        end
    end)
    
    CreateButton(worldTab, "📍 TELEPORT TO TARGET", Color3.fromRGB(50, 100, 200), function()
        if Config.KillTarget then
            local tr = GetRoot(Config.KillTarget)
            local mr = GetRoot()
            if tr and mr then
                mr.CFrame = tr.CFrame + Vector3.new(0, 3, 0)
                Notify("Teleport", "Teleported to " .. Config.KillTarget.DisplayName)
            end
        else
            Notify("Error", "No target selected!")
        end
    end)
    
    --// ===== TAB 5: MISC =====
    local miscTab = tabContents[5]
    
    CreateSection(miscTab, "⚙️ SETTINGS")
    
    CreateToggleBtn(miscTab, "Anti-Cheat Bypass", true, function(v)
        Config.AntiCheat = v
    end)
    
    CreateToggleBtn(miscTab, "Anti-AFK", false, function(v)
        Config.AntiAFK = v
        if v then
            State.Connections.AntiAFK = RunService.Heartbeat:Connect(function()
                local hum = GetHum()
                if hum and Config.AntiAFK then
                    hum:Move(Vector3.new(0.01, 0, 0))
                end
            end)
        else
            if State.Connections.AntiAFK then
                State.Connections.AntiAFK:Disconnect()
                State.Connections.AntiAFK = nil
            end
        end
    end)
    
    CreateToggleBtn(miscTab, "Auto-Rejoin", false, function(v)
        Config.AutoRejoin = v
    end)
    
    CreateButton(miscTab, "🔄 REJOIN SERVER", Color3.fromRGB(80, 80, 120), function()
        TeleportService:Teleport(game.PlaceId, LocalPlayer)
    end)
    
    CreateButton(miscTab, "🌐 SERVER HOP", Color3.fromRGB(80, 80, 120), function()
        local servers = game.HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
        for _, server in ipairs(servers.data) do
            if server.playing < server.maxPlayers and server.id ~= game.JobId then
                TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                break
            end
        end
    end)
    
    CreateButton(miscTab, "❌ DESTROY UI", Color3.fromRGB(200, 50, 50), function()
        sg:Destroy()
        State.UI = nil
        -- Cleanup all features
        StopFly()
        StopFlingLoop()
        StopKillAura()
        ToggleESP(false)
        ToggleChams(false)
        ToggleAimbot(false)
        ToggleSpeedHack(false)
        ClearESP()
    end)
    
    --// FLOATING TOGGLE BUTTON
    local floatBtn = Instance.new("TextButton")
    floatBtn.Name = "SkyfallToggle"
    floatBtn.Size = UDim2.new(0, 55, 0, 55)
    floatBtn.Position = UDim2.new(0.02, 0, 0.15, 0)
    floatBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
    floatBtn.Text = "☢️"
    floatBtn.TextColor3 = Color3.fromRGB(15, 15, 20)
    floatBtn.TextSize = 28
    floatBtn.Font = Enum.Font.GothamBlack
    floatBtn.BorderSizePixel = 0
    floatBtn.Parent = sg
    
    local fbc = Instance.new("UICorner")
    fbc.CornerRadius = UDim.new(1, 0)
    fbc.Parent = floatBtn
    
    local fbs = Instance.new("UIStroke")
    fbs.Color = Color3.fromRGB(255, 255, 255)
    fbs.Thickness = 2
    fbs.Parent = floatBtn
    
    local uiVisible = true
    floatBtn.MouseButton1Click:Connect(function()
        uiVisible = not uiVisible
        main.Visible = uiVisible
        floatBtn.BackgroundColor3 = uiVisible and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(80, 80, 80)
    end)
    
    --// MOBILE JOYSTICK
    local joyFrame = Instance.new("Frame")
    joyFrame.Name = "FlyJoystick"
    joyFrame.Size = UDim2.new(0, 150, 0, 150)
    joyFrame.Position = UDim2.new(0.05, 0, 0.55, 0)
    joyFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    joyFrame.BackgroundTransparency = 0.4
    joyFrame.BorderSizePixel = 0
    joyFrame.Visible = true
    joyFrame.Parent = sg
    
    local jfc = Instance.new("UICorner")
    jfc.CornerRadius = UDim.new(1, 0)
    jfc.Parent = joyFrame
    
    local jfs = Instance.new("UIStroke")
    jfs.Color = Color3.fromRGB(0, 255, 150)
    jfs.Thickness = 2
    jfs.Parent = joyFrame
    
    local joyKnob = Instance.new("Frame")
    joyKnob.Size = UDim2.new(0, 50, 0, 50)
    joyKnob.Position = UDim2.new(0.5, -25, 0.5, -25)
    joyKnob.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
    joyKnob.BorderSizePixel = 0
    joyKnob.Parent = joyFrame
    
    local jkc = Instance.new("UICorner")
    jkc.CornerRadius = UDim.new(1, 0)
    jkc.Parent = joyKnob
    
    local joyActive = false
    local joyCenter = Vector2.new(75, 75)
    local joyMax = 40
    
    joyFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            joyActive = true
        end
    end)
    
    joyFrame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            joyActive = false
            joyKnob.Position = UDim2.new(0.5, -25, 0.5, -25)
            State.JoystickDir = Vector3.zero
        end
    end)
    
    joyFrame.InputChanged:Connect(function(input)
        if joyActive and input.UserInputType == Enum.UserInputType.Touch then
            local pos = Vector2.new(input.Position.X, input.Position.Y) - joyFrame.AbsolutePosition
            local offset = pos - joyCenter
            local dist = math.min(offset.Magnitude, joyMax)
            local dir = offset.Unit
            
            local newPos = joyCenter + dir * dist
            joyKnob.Position = UDim2.new(0, newPos.X - 25, 0, newPos.Y - 25)
            
            State.JoystickDir = Vector3.new(dir.X, 0, -dir.Y) * (dist / joyMax)
        end
    end)
    
    -- Parent
    sg.Parent = LocalPlayer:WaitForChild("PlayerGui")
    
    State.UI = {
        ScreenGui = sg,
        MainFrame = main,
        FlyButton = State.UI and State.UI.FlyButton,
        Joystick = joyFrame,
        ToggleButton = floatBtn
    }
    
    -- Initial fly button ref
    State.UI.FlyButton = State.UI.FlyButton
    
    Notify("Skyfall Arsenal", "v4.0 Loaded! 25+ features ready")
end


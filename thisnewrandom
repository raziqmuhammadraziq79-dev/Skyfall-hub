local function StartFly()
    if Config.FlyEnabled then return end
    Config.FlyEnabled = true
    
    local root = GetRoot()
    local hum = GetHum()
    if not (root and hum) then return end
    
    SetupNetwork()
    
    -- Save original
    State.OriginalSettings.WalkSpeed = hum.WalkSpeed
    State.OriginalSettings.JumpPower = hum.JumpPower
    
    Workspace.Gravity = 0
    
    -- Disable default movement but keep humanoid alive
    hum.WalkSpeed = 0
    hum.JumpPower = 0
    
    -- Body movers
    local bg = Instance.new("BodyGyro")
    bg.Name = "SkyfallFlyGyro"
    bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bg.P = 20000
    bg.D = 1000
    bg.CFrame = root.CFrame
    bg.Parent = root
    
    local bv = Instance.new("BodyVelocity")
    bv.Name = "SkyfallFlyVel"
    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bv.Velocity = Vector3.zero
    bv.Parent = root
    
    State.BodyMovers.Gyro = bg
    State.BodyMovers.Vel = bv
    
    -- Noclip during fly
    if Config.FlyNoclip then
        State.Connections.Noclip = RunService.Stepped:Connect(function()
            if not Config.FlyEnabled then return end
            local c = GetChar()
            if c then
                for _, p in ipairs(c:GetDescendants()) do
                    if p:IsA("BasePart") then
                        p.CanCollide = false
                    end
                end
            end
        end)
    end
    
    -- Fly control loop
    State.Connections.Fly = RunService.RenderStepped:Connect(function()
        if not Config.FlyEnabled then return end
        local r = GetRoot()
        if not r then StopFly() return end
        
        local move = Vector3.zero
        
        -- Keyboard
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            move = move + Camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            move = move - Camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            move = move - Camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            move = move + Camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            move = move + Vector3.new(0, 1, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            move = move - Vector3.new(0, 1, 0)
        end
        
        -- Mobile joystick
        if State.JoystickDir.Magnitude > 0.1 then
            local cl = Camera.CFrame.LookVector
            local cr = Camera.CFrame.RightVector
            move = move + (cl * State.JoystickDir.Y + cr * State.JoystickDir.X)
            move = move + Vector3.new(0, State.JoystickDir.Y * 0.5, 0)
        end
        
        if move.Magnitude > 0 then
            move = move.Unit * Config.FlySpeed * 60
        end
        
        bv.Velocity = move
        bg.CFrame = Camera.CFrame
        
        -- Reclaim network periodically
        if tick() % 2 < 0.05 then
            SetupNetwork()
        end
    end)
    
    -- Infinite jump during fly
    if Config.FlyInfiniteJump then
        State.Connections.InfJump = UserInputService.InputBegan:Connect(function(input, gpe)
            if gpe then return end
            if input.KeyCode == Enum.KeyCode.Space and Config.FlyEnabled then
                local r = GetRoot()
                if r then
                    bv.Velocity = Vector3.new(0, Config.FlySpeed * 100, 0)
                end
            end
        end)
    end
    
    Notify("Skyfall Fly", "Unlocked fly activated! Speed: " .. Config.FlySpeed)
    UpdateUIFlyButton(true)
end

local function StopFly()
    if not Config.FlyEnabled then return end
    Config.FlyEnabled = false
    
    if State.Connections.Fly then
        State.Connections.Fly:Disconnect()
        State.Connections.Fly = nil
    end
    if State.Connections.Noclip then
        State.Connections.Noclip:Disconnect()
        State.Connections.Noclip = nil
    end
    if State.Connections.InfJump then
        State.Connections.InfJump:Disconnect()
        State.Connections.InfJump = nil
    end
    
    if State.BodyMovers.Gyro then
        pcall(function() State.BodyMovers.Gyro:Destroy() end)
        State.BodyMovers.Gyro = nil
    end
    if State.BodyMovers.Vel then
        pcall(function() State.BodyMovers.Vel:Destroy() end)
        State.BodyMovers.Vel = nil
    end
    
    Workspace.Gravity = Config.Gravity
    
    local hum = GetHum()
    if hum then
        hum.WalkSpeed = State.OriginalSettings.WalkSpeed or 16
        hum.JumpPower = State.OriginalSettings.JumpPower or 50
    end
    
    -- Restore collision
    local c = GetChar()
    if c then
        for _, p in ipairs(c:GetDescendants()) do
            if p:IsA("BasePart") then
                p.CanCollide = true
            end
        end
    end
    
    Notify("Skyfall Fly", "Fly deactivated")
    UpdateUIFlyButton(false)
end


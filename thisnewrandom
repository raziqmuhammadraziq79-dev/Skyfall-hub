local function Init()
    if not GetChar() then
        LocalPlayer.CharacterAdded:Wait()
    end
    
    pcall(SetupAntiCheat)
    pcall(SetupNetwork)
    CreateSkyfallArsenal()
    
    -- Auto-reclaim on respawn
    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(0.5)
        pcall(SetupNetwork)
        if Config.FlyEnabled then
            task.wait(0.5)
            StartFly()
        end
    end)
    
    -- Anti-AFK base
    game:GetService("VirtualUser"):CaptureController()
    game:GetService("VirtualUser"):ClickButton2(Vector2.new())
    
    print([[
    ╔═══════════════════════════════════════════════════════════════╗
    ║  ☢️ SKYFALL ARSENAL v4.0 — LOADED SUCCESSFULLY               ║
    ║  Features: Fly | Fling | Kill Aura | ESP | Aimbot | God Mode   ║
    ║  Speed | NoClip | Chams | FullBright | XRay | +15 more        ║
    ╚═══════════════════════════════════════════════════════════════╝
    ]])
end

Init()


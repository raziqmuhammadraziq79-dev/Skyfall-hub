local function FlingPlayer(target, power)
    if not target or target == LocalPlayer then return false end
    power = power or Config.FlingPower
    
    local tc = GetChar(target)
    if not tc then return false end
    
    local tr = GetRoot(target)
    local th = GetHum(target)
    if not (tr and th) then return false end
    if th.Health <= 0 then return false end
    
    local mr = GetRoot()
    if not mr then return false end
    
    -- Method 1: Direct velocity (most reliable)
    local dir = (tr.Position - mr.Position).Unit
    if dir.Magnitude == 0 then dir = Vector3.new(0, 1, 0) end
    
    local vel = dir * power + Vector3.new(0, power * 0.5, 0)
    
    -- Apply multiple times for reliability
    for i = 1, 5 do
        task.delay(i * 0.05, function()
            pcall(function()
                tr.Velocity = vel
                tr.AssemblyLinearVelocity = vel
                tr.RotVelocity = Vector3.new(math.random(-100,100), math.random(-100,100), math.random(-100,100))
            end)
        end)
    end
    
    -- Method 2: BodyVelocity injection
    pcall(function()
        local existing = tr:FindFirstChild("SkyfallFling")
        if existing then existing:Destroy() end
        
        local bv = Instance.new("BodyVelocity")
        bv.Name = "SkyfallFling"
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.Velocity = vel * 2
        bv.Parent = tr
        
        game:GetService("Debris"):AddItem(bv, 0.5)
    end)
    
    -- Method 3: BodyAngularVelocity spin
    if Config.FlingSpin then
        pcall(function()
            local ba = Instance.new("BodyAngularVelocity")
            ba.Name = "SkyfallSpin"
            ba.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            ba.AngularVelocity = Vector3.new(math.random(-50,50), math.random(-50,50), math.random(-50,50)) * 200
            ba.Parent = tr
            game:GetService("Debris"):AddItem(ba, 1)
        end)
    end
    
    -- Method 4: CFrame teleport fling (bypasses some protections)
    pcall(function()
        local offset = dir * 10 + Vector3.new(0, 20, 0)
        tr.CFrame = tr.CFrame + offset
    end)
    
    -- Method 5: Destroy fling (extreme)
    if Config.FlingDestroy then
        pcall(function()
            th.Health = 0
        end)
    end
    
    return true
end

local function FlingAll()
    local count = 0
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            if FlingPlayer(plr) then
                count = count + 1
            end
        end
    end
    Notify("Fling All", "Flinged " .. count .. " players!")
    return count
end

local function StartFlingLoop()
    if Config.FlingLoopActive then return end
    Config.FlingLoopActive = true
    
    State.Connections.FlingLoop = RunService.Heartbeat:Connect(function()
        if not Config.FlingLoopActive then return end
        
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                local tr = GetRoot(plr)
                local mr = GetRoot()
                if tr and mr then
                    if GetDistance(tr.Position, mr.Position) <= Config.FlingRadius then
                        FlingPlayer(plr)
                    end
                end
            end
        end
    end)
    
    Notify("Fling Loop", "Auto-fling activated! Radius: " .. Config.FlingRadius)
end

local function StopFlingLoop()
    Config.FlingLoopActive = false
    if State.Connections.FlingLoop then
        State.Connections.FlingLoop:Disconnect()
        State.Connections.FlingLoop = nil
    end
    Notify("Fling Loop", "Auto-fling stopped")
end

--// Kill Functions
local function KillPlayer(target)
    if not target then return false end
    local th = GetHum(target)
    if not th then return false end
    
    -- Method 1: Direct health
    pcall(function() th.Health = 0 end)
    
    -- Method 2: Damage
    pcall(function() th:TakeDamage(9e9) end)
    
    -- Method 3: Break joints
    pcall(function()
        local c = GetChar(target)
        if c then c:BreakJoints() end
    end)
    
    -- Method 4: Fling into void
    pcall(function()
        local tr = GetRoot(target)
        if tr then
            tr.CFrame = CFrame.new(0, -500, 0)
        end
    end)
    
    return true
end

local function StartKillAura()
    if Config.KillAura then return end
    Config.KillAura = true
    
    State.Connections.KillAura = RunService.Heartbeat:Connect(function()
        if not Config.KillAura then return end
        local mr = GetRoot()
        if not mr then return end
        
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                local tr = GetRoot(plr)
                if tr and GetDistance(tr.Position, mr.Position) <= Config.KillAuraRange then
                    KillPlayer(plr)
                end
            end
        end
    end)
    
    Notify("Kill Aura", "Activated! Range: " .. Config.KillAuraRange)
end

local function StopKillAura()
    Config.KillAura = false
    if State.Connections.KillAura then
        State.Connections.KillAura:Disconnect()
        State.Connections.KillAura = nil
    end
    Notify("Kill Aura", "Deactivated")
end


local SelectedPlayer = nil
local function CreatePlayerSelector(Page)
    local Box = New("Frame", {Size = UDim2.new(1, 0, 0, 120), BackgroundColor3 = Color3.fromRGB(25, 25, 25), BorderSizePixel = 0, Parent = Page})
    New("UICorner", {CornerRadius = UDim.new(0, 6), Parent = Box})
    New("TextLabel", {
        Size = UDim2.new(1, 0, 0, 20), Position = UDim2.new(0, 0, 0, 5), BackgroundTransparency = 1,
        Text = "TARGET SELECTOR", TextColor3 = CONFIG.BaseColor, TextSize = 10, Font = Enum.Font.GothamBold, Parent = Box
    })
    
    local List = New("ScrollingFrame", {
        Size = UDim2.new(1, -10, 1, -30), Position = UDim2.new(0, 5, 0, 25),
        BackgroundTransparency = 1, CanvasSize = UDim2.new(0, 0, 0, 200),
        ScrollBarThickness = 3, Parent = Box
    })
    New("UIListLayout", {Padding = UDim.new(0, 2), SortOrder = Enum.SortOrder.LayoutOrder, Parent = List})
    
    local function RefreshList()
        for _, child in ipairs(List:GetChildren()) do if child:IsA("GuiObject") then child:Destroy() end end
        for _, plr in ipairs(Players:GetPlayers()) do
            local PlrBtn = New("TextButton", {
                Size = UDim2.new(1, 0, 0, 25), BackgroundColor3 = Color3.fromRGB(40, 40, 40),
                Text = plr.Name, TextColor3 = CONFIG.Text_Color, TextSize = 11, Font = Enum.Font.GothamMedium, Parent = List
            })
            New("UICorner", {CornerRadius = UDim.new(0, 4), Parent = PlrBtn})
            
            PlrBtn.MouseButton1Click:Connect(function()
                SelectedPlayer = plr
                -- Visual feedback
                for _, btn in ipairs(List:GetChildren()) do
                    if btn:IsA("TextButton") then btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40) end
                end
                PlrBtn.BackgroundColor3 = CONFIG.BaseColor
                print("[DELTA] Target Selected: " .. plr.Name)
            end)
        end
    end
    
    RefreshList()
    Players.PlayerAdded:Connect(RefreshList)
    Players.PlayerRemoving:Connect(RefreshList)
end


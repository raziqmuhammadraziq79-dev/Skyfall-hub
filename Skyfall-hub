-- Tab Button Factory
local function CreateTab(Name, Icon)
    local Btn = New("TextButton", {
        Size = UDim2.new(1, 0, 0, 40), BackgroundColor3 = Color3.fromRGB(30, 30, 30),
        Text = "  " .. Name, TextColor3 = CONFIG.Text_Color, TextSize = 13, Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left, Parent = Sidebar
    })
    New("UICorner", {CornerRadius = UDim.new(0, 6), Parent = Btn})
    
    -- Page Frame
    local Page = New("ScrollingFrame", {
        Name = Name, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1,
        CanvasSize = UDim2.new(0, 400, 0, 800), ScrollBarThickness = 4,
        ScrollBarImageColor3 = CONFIG.BaseColor, Visible = false, Parent = ContentArea
    })
    New("UIListLayout", {Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder, Parent = Page})
    New("UIPadding", {PaddingBottom = UDim.new(0, 20), PaddingLeft = UDim.new(0, 15), PaddingRight = UDim.new(0, 15), Parent = Page})
    Pages[Name] = Page
    
    -- Click Logic
    Btn.MouseButton1Click:Connect(function()
        for _, p in pairs(Pages) do p.Visible = false end
        Page.Visible = true
        
        -- Reset all buttons style
        for _, child in ipairs(Sidebar:GetChildren()) do
            if child:IsA("TextButton") and child ~= LogoLabel then
                child.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                child.TextColor3 = CONFIG.Text_Color
            end
        end
        -- Active style
        Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        Btn.TextColor3 = CONFIG.BaseColor
    end)
    
    return Page
end

-- Components
local function Toggle(Page, Name, Callback)
    local Box = New("Frame", {Size = UDim2.new(1, 0, 0, 40), BackgroundColor3 = Color3.fromRGB(25, 25, 25), BorderSizePixel = 0, Parent = Page})
    New("UICorner", {CornerRadius = UDim.new(0, 6), Parent = Box})
    New("TextLabel", {
        Size = UDim2.new(1, -60, 1, 0), Position = UDim2.new(0, 10, 0, 0), BackgroundTransparency = 1,
        Text = Name, TextColor3 = CONFIG.Text_Color, TextSize = 12, Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left, Parent = Box
    })
    local Btn = New("TextButton", {
        Size = UDim2.new(0, 50, 0, 24), Position = UDim2.new(1, -55, 0.5, -12),
        BackgroundColor3 = Color3.fromRGB(50, 50, 50), Text = "OFF", TextColor3 = Color3.fromRGB(150, 150, 150),
        TextSize = 10, Font = Enum.Font.GothamBold, Parent = Box
    })
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Btn})
    
    local State = false
    Btn.MouseButton1Click:Connect(function()
        State = not State
        Btn.Text = State and "ON" or "OFF"
        Btn.BackgroundColor3 = State and CONFIG.BaseColor or Color3.fromRGB(50, 50, 50)
        Callback(State)
    end)
end

local function Slider(Page, Name, Min, Max, Def, Callback)
    local Box = New("Frame", {Size = UDim2.new(1, 0, 0, 50), BackgroundColor3 = Color3.fromRGB(25, 25, 25), BorderSizePixel = 0, Parent = Page})
    New("UICorner", {CornerRadius = UDim.new(0, 6), Parent = Box})
    local Label = New("TextLabel", {
        Size = UDim2.new(1, -20, 0, 20), Position = UDim2.new(0, 10, 0, 5), BackgroundTransparency = 1,
        Text = Name .. ": " .. Def, TextColor3 = CONFIG.Text_Color, TextSize = 11, Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left, Parent = Box
    })
    local Track = New("Frame", {Size = UDim2.new(1, -20, 0, 6), Position = UDim2.new(0, 10, 1, -18), BackgroundColor3 = Color3.fromRGB(40, 40, 40), Parent = Box})
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Track})
    local Fill = New("Frame", {Size = UDim2.new((Def - Min) / (Max - Min), 0, 1, 0), BackgroundColor3 = CONFIG.BaseColor, Parent = Track})
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Fill})
    
    local Dragging = false
    Track.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.Touch or Input.UserInputType == Enum.UserInputType.MouseButton1 then
            Dragging = true
            local Percent = math.clamp((Input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
            local Val = math.floor(Min + (Max - Min) * Percent)
            Fill.Size = UDim2.new(Percent, 0, 1, 0)
            Label.Text = Name .. ": " .. Val
            Callback(Val)
        end
    end)
    UserInputService.InputChanged:Connect(function(Input)
        if Dragging and (Input.UserInputType == Enum.UserInputType.Touch or Input.UserInputType == Enum.UserInputType.MouseMovement) then
            local Percent = math.clamp((Input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
            local Val = math.floor(Min + (Max - Min) * Percent)
            Fill.Size = UDim2.new(Percent, 0, 1, 0)
            Label.Text = Name .. ": " .. Val
            Callback(Val)
        end
    end)
    UserInputService.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.Touch or Input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = false end
    end)
end


-- Component: Toggle Button
local function Toggle(Name, Callback)
    local Box = New("Frame", {Size = UDim2.new(1, 0, 0, 45), BackgroundColor3 = THEME.Secondary, BorderSizePixel = 0, Parent = Scroll})
    New("UICorner", {CornerRadius = UDim.new(0, 8), Parent = Box})
    
    local Label = New("TextLabel", {
        Size = UDim2.new(1, -70, 1, 0), Position = UDim2.new(0, 12, 0, 0), BackgroundTransparency = 1,
        Text = Name, TextColor3 = THEME.Text, TextSize = 13, Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left, Parent = Box
    })
    
    local Btn = New("TextButton", {
        Size = UDim2.new(0, 55, 0, 28), Position = UDim2.new(1, -62, 0.5, -14),
        BackgroundColor3 = Color3.fromRGB(50, 50, 50), Text = "OFF", TextColor3 = Color3.fromRGB(150, 150, 150),
        TextSize = 11, Font = Enum.Font.GothamBold, Parent = Box
    })
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Btn})
    
    local State = false
    Btn.MouseButton1Click:Connect(function()
        State = not State
        Btn.Text = State and "ON" or "OFF"
        Btn.BackgroundColor3 = State and THEME.Accent or Color3.fromRGB(50, 50, 50)
        Btn.TextColor3 = State and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(150, 150, 150)
        Callback(State)
    end)
end

-- Component: Slider
local function Slider(Name, Min, Max, Def, Callback)
    local Box = New("Frame", {Size = UDim2.new(1, 0, 0, 55), BackgroundColor3 = THEME.Secondary, BorderSizePixel = 0, Parent = Scroll})
    New("UICorner", {CornerRadius = UDim.new(0, 8), Parent = Box})
    
    local Label = New("TextLabel", {
        Size = UDim2.new(1, -20, 0, 20), Position = UDim2.new(0, 12, 0, 5), BackgroundTransparency = 1,
        Text = Name .. ": " .. Def, TextColor3 = THEME.Text, TextSize = 12, Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left, Parent = Box
    })
    
    local Track = New("Frame", {Size = UDim2.new(1, -24, 0, 8), Position = UDim2.new(0, 12, 1, -20), BackgroundColor3 = Color3.fromRGB(40, 40, 40), Parent = Box})
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Track})
    
    local Fill = New("Frame", {Size = UDim2.new((Def - Min) / (Max - Min), 0, 1, 0), BackgroundColor3 = THEME.Accent, Parent = Track})
    New("UICorner", {CornerRadius = UDim.new(1, 0), Parent = Fill})
    
    local Dragging = false
    Track.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true
            local Percent = math.clamp((Input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
            local Val = math.floor(Min + (Max - Min) * Percent)
            Fill.Size = UDim2.new(Percent, 0, 1, 0)
            Label.Text = Name .. ": " .. Val
            Callback(Val)
        end
    end)
    UserInputService.InputChanged:Connect(function(Input)
        if Dragging and Input.UserInputType == Enum.UserInputType.Touch then
            local Percent = math.clamp((Input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
            local Val = math.floor(Min + (Max - Min) * Percent)
            Fill.Size = UDim2.new(Percent, 0, 1, 0)
            Label.Text = Name .. ": " .. Val
            Callback(Val)
        end
    end)
    UserInputService.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.Touch then Dragging = false end
    end)
end


-- Fly Logic Loop (Optimized)
RunService.RenderStepped:Connect(function(DT)
    if Humanoid.PlatformStand then
        local Move = Vector3.new(0,0,0)
        local Look = Camera.CFrame.LookVector
        local Right = Camera.CFrame.RightVector
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then Move = Move + Look end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then Move = Move - Look end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then Move = Move - Right end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then Move = Move + Right end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then Move = Move + Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then Move = Move - Vector3.new(0,1,0) end
        
        if Move.Magnitude > 0 then
            RootPart.CFrame = CFrame.new(RootPart.Position + (Move.Unit * (_G.FlySpeed * DT))) * RootPart.CFrame.Rotation
        end
    end
end)

-- Draggable & Minimize
local DragStart, StartPos
Header.InputBegan:Connect(function(Input)
    if Input.UserInputType == Enum.UserInputType.Touch then
        DragStart = Input.Position; StartPos = Main.Position
        Input.Changed:Connect(function()
            if Input.UserInputState == Enum.UserInputState.End then else
                local Delta = Input.Position - DragStart
                Main.Position = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + Delta.X, StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y)
            end
        end)
    end
end)


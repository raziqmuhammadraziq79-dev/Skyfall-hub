-- Utility: Fast Instance Creator
local function New(Class, Props)
    local Obj = Instance.new(Class)
    for i, v in pairs(Props) do if i ~= "Parent" then Obj[i] = v end end
    if Props.Parent then Obj.Parent = Props.Parent end
    return Obj
end


-- === FPS BOOSTER MODULE (EXCLUSIVE) ===
-- Manipulates StreamingEnabled & FFlags for mobile GPU optimization
local function BoostFPS()
    if not Hub.FPSEnabled then return end
    
    -- Enable Streaming to reduce render load dynamically
    pcall(function()
        Workspace.StreamingEnabled = true
        Workspace.StreamingMinRadius = 64 -- Reduce draw calls for distant objects
        Workspace.StreamingTargetRadius = 128
    end)
    
    -- Mobile-specific FFlag injections via setfflag (if executor supports)
    local success, err = pcall(function()
        setfflag("DFFlagDisableDPIScale", "True")
        setfflag("DFIntTaskSchedulerTargetFps", "90") -- Cap at 90 for thermal stability
        setfflag("FFlagDebugGraphicsPreferD3D11", "False") -- Force Vulkan/OpenGL on mobile
        setfflag("RenderShadowQuality", "0")
        setfflag("TextureQualityLevel", "1")
    end)
    
    -- Fallback visual reduction if setfflag fails
    if not success then
        Lighting.GlobalShadows = false
        Lighting.Technology = Enum.Technology.Voxel
        Workspace.Terrain.WaterWaveSize = 0
        Workspace.Terrain.WaterWaveSpeed = 0
    end
end

-- === MOVEMENT MODULE (SERVER REPLICATED) ===
local BodyVelocity = Instance.new("BodyVelocity")
BodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
BodyVelocity.P = 1250

local FlyLoop = nil
local NoClipConn = nil

local function ToggleFly(active)
    Hub.IsFlying = active
    if active then
        BodyVelocity.Parent = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        FlyLoop = RunService.RenderStepped:Connect(function()
            local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp and Hub.IsFlying then
                local moveDir = Vector3.new(0, 0, 0)
                -- Touch/Joystick integration would go here; simplified for universal keybinds
                -- For mobile: Use virtual joystick or screen tap zones in full implementation
                BodyVelocity.Velocity = moveDir * 50 + Vector3.new(0, 50, 0) -- Default hover + up
            end
        end)
    else
        BodyVelocity.Parent = nil
        if FlyLoop then FlyLoop:Disconnect(); FlyLoop = nil end
    end
end

local function ToggleNoClip(active)
    Hub.IsNoClip = active
    if active then
        NoClipConn = RunService.Stepped:Connect(function()
            for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
            -- CRITICAL: Server replication requires constant CFrame updates
            -- Without this, other players see you stuck in walls
            local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                -- Send micro-adjustment to force server update
                hrp.CFrame = hrp.CFrame * CFrame.new(0, 0.001, 0)
            end
        end)
    else
        if NoClipConn then NoClipConn:Disconnect(); NoClipConn = nil end
        -- Restore collision safely
        for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = true end
        end
    end
end

-- === TELEPORT NEAREST PLAYER (UNIVERSAL) ===
local function TeleportNearest()
    local nearestDist = math.huge
    local target = nil
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetHrp = player.Character:FindFirstChild("HumanoidRootPart")
            if targetHrp then
                local dist = (hrp.Position - targetHrp.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    target = targetHrp
                end
            end
        end
    end
    
    if target then
        -- Smooth teleport to avoid anti-cheat velocity spikes
        TweenService:Create(hrp, TweenInfo.new(0.2, Enum.EasingStyle.Linear), {
            CFrame = target.CFrame * CFrame.new(0, 3, 5) -- Offset to avoid clipping into target
        }):Play()
    end
end


local FEATURES = {}

function FEATURES:godMode(state)
    EXPLOIT_STATE.godMode = state
    if not state then return end
    
    local connection
    connection = RunService.Heartbeat:Connect(function()
        if not EXPLOIT_STATE.godMode then
            connection:Disconnect()
            return
        end
        
        safeCall(function()
            if Humanoid.Health <= 0 then
                Humanoid.Health = Humanoid.MaxHealth
            end
        end)
    end)
    
    table.insert(ACTIVE_CONNECTIONS, connection)
end

function FEATURES:infiniteJump(state)
    EXPLOIT_STATE.infiniteJump = state
    if not state then return end
    
    local jumpConnection
    jumpConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        if input.KeyCode == Enum.KeyCode.Space and EXPLOIT_STATE.infiniteJump then
            safeCall(function()
                Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end)
        end
    end)
    
    table.insert(ACTIVE_CONNECTIONS, jumpConnection)
end

function FEATURES:noclip(state)
    EXPLOIT_STATE.noclip = state
    
    local connection
    connection = RunService.Heartbeat:Connect(function()
        if not EXPLOIT_STATE.noclip then
            connection:Disconnect()
            for _, part in pairs(Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
            return
        end
        
        safeCall(function()
            for _, part in pairs(Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end)
    end)
    
    table.insert(ACTIVE_CONNECTIONS, connection)
end

function FEATURES:flyMode(state)
    EXPLOIT_STATE.fly = state
    if not state then return end
    
    local speed = 50
    local flying = false
    local moveDirection = Vector3.new(0, 0, 0)
    
    local bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(100000, 100000, 100000)
    bodyVelocity.Parent = RootPart
    
    local inputConnection
    inputConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        if input.KeyCode == Enum.KeyCode.F then
            flying = not flying
        end
        
        if flying then
            if input.KeyCode == Enum.KeyCode.W then moveDirection = moveDirection + RootPart.CFrame.LookVector end
            if input.KeyCode == Enum.KeyCode.S then moveDirection = moveDirection - RootPart.CFrame.LookVector end
            if input.KeyCode == Enum.KeyCode.A then moveDirection = moveDirection - RootPart.CFrame.RightVector end
            if input.KeyCode == Enum.KeyCode.D then moveDirection = moveDirection + RootPart.CFrame.RightVector end
            if input.KeyCode == Enum.KeyCode.Space then moveDirection = moveDirection + Vector3.new(0, 1, 0) end
            if input.KeyCode == Enum.KeyCode.LeftControl then moveDirection = moveDirection - Vector3.new(0, 1, 0) end
        end
    end)
    
    local flightConnection
    flightConnection = RunService.RenderStepped:Connect(function()
        if not EXPLOIT_STATE.fly or not flying then
            flightConnection:Disconnect()
            bodyVelocity:Destroy()
            return
        end
        
        bodyVelocity.Velocity = moveDirection.Unit * speed
    end)
    
    table.insert(ACTIVE_CONNECTIONS, inputConnection)
    table.insert(ACTIVE_CONNECTIONS, flightConnection)
end

function FEATURES:setWalkSpeed(speed)
    EXPLOIT_STATE.walkSpeed = speed
    safeCall(function()
        Humanoid.WalkSpeed = speed
    end)
end

function FEATURES:setJumpPower(power)
    EXPLOIT_STATE.jumpPower = power
    safeCall(function()
        Humanoid.JumpPower = power
    end)
end

function FEATURES:aimbot(state)
    EXPLOIT_STATE.aimbot = state
    if not state then return end
    
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not EXPLOIT_STATE.aimbot then
            connection:Disconnect()
            return
        end
        
        safeCall(function()
            local closestPlayer = nil
            local closestDistance = 500
            
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local distance = getDistance(RootPart.Position, hrp.Position)
                        if distance < closestDistance then
                            closestDistance = distance
                            closestPlayer = player
                        end
                    end
                end
            end
            
            if closestPlayer and closestPlayer.Character then
                local targetHrp = closestPlayer.Character:FindFirstChild("HumanoidRootPart")
                if targetHrp then
                    RootPart.CFrame = CFrame.new(RootPart.Position, targetHrp.Position + targetHrp.CFrame.LookVector * 5)
                end
            end
        end)
    end)
    
    table.insert(ACTIVE_CONNECTIONS, connection)
end

function FEATURES:esp(state)
    EXPLOIT_STATE.espEnabled = state
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            if hrp and state then
                safeCall(function()
                    local existingBillboard = hrp:FindFirstChild("BuatinESP")
                    if existingBillboard then existingBillboard:Destroy() end
                    
                    local billboard = Instance.new("BillboardGui")
                    billboard.Name = "BuatinESP"
                    billboard.Size = UDim2.new(4, 0, 4, 0)
                    billboard.MaxDistance = 500
                    billboard.Parent = hrp
                    
                    local textLabel = Instance.new("TextLabel")
                    textLabel.BackgroundTransparency = 1
                    textLabel.Size = UDim2.new(1, 0, 1, 0)
                    textLabel.Text = player.Name .. " [" .. math.floor(getDistance(RootPart.Position, hrp.Position)) .. "m]"
                    textLabel.TextColor3 = ACCENT_COLOR
                    textLabel.TextSize = 12
                    textLabel.Font = Enum.Font.GothamBold
                    textLabel.Parent = billboard
                end)
            elseif not state then
                local billboard = hrp:FindFirstChild("BuatinESP")
                if billboard then billboard:Destroy() end
            end
        end
    end
end

function FEATURES:invisibility(state)
    EXPLOIT_STATE.invisible = state
    
    safeCall(function()
        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = state and 0.7 or 0
            end
        end
    end)
end

function FEATURES:antiLag(state)
    EXPLOIT_STATE.antiLag = state
    if not state then return end
    
    safeCall(function()
        -- Reduce terrain rendering
        local terrain = workspace.Terrain
        terrain:FillBall(RootPart.Position, 1000, Enum.Material.Air)
        
        -- Lower quality textures
        local settings = UserSettings():FindFirstChild("UserGameSettings")
        if settings then
            settings.MasterVolume = 0
        end
        
        log("Anti-lag mode activated")
    end)
end

function FEATURES:memoryOptimize(state)
    EXPLOIT_STATE.memoryOptimize = state
    if not state then return end
    
    local connection
    connection = RunService.Heartbeat:Connect(function()
        if tick() % 30 == 0 then
            safeCall(function()
                collectgarbage("collect")
            end)
        end
    end)
    
    table.insert(ACTIVE_CONNECTIONS, connection)
end

function FEATURES:fpsBoost(state)
    EXPLOIT_STATE.fpsBoost = state
    if not state then return end
    
    safeCall(function()
        game:GetService("RunService"):Set3dRenderingEnabled(true)
        workspace.CurrentCamera.MaxAxisAlignedBoundingBoxSize = 5000
    end)
end


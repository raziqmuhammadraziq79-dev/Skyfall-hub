local ANTI_TROLL = {}

function ANTI_TROLL:detectTroll(player)
    if not player or player == LocalPlayer then return false end
    if not player.Character then return false end
    
    local char = player.Character
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local distance = getDistance(RootPart.Position, hrp.Position)
    
    -- Detection signatures
    local isTroll = false
    local reasons = {}
    
    -- Check 1: Abnormal walkspeed
    if char:FindFirstChild("Humanoid") then
        local speed = char.Humanoid.WalkSpeed
        if speed > 100 then
            isTroll = true
            table.insert(reasons, "Speedhack detected")
        end
    end
    
    -- Check 2: Suspicious tool usage
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            if tool:FindFirstChild("Handle") then
                local handle = tool.Handle
                if handle.Velocity.Magnitude > 200 then
                    isTroll = true
                    table.insert(reasons, "Tool velocity anomaly")
                end
            end
        end
    end
    
    -- Check 3: Position teleport detection
    if TROLL_DETECTION_LOG[player.UserId] then
        local lastPos = TROLL_DETECTION_LOG[player.UserId].lastPos
        local timeDiff = tick() - TROLL_DETECTION_LOG[player.UserId].lastTime
        local distDiff = getDistance(lastPos, hrp.Position)
        
        if distDiff > 100 and timeDiff < 0.1 then
            isTroll = true
            table.insert(reasons, "Teleport exploit detected")
        end
    end
    
    TROLL_DETECTION_LOG[player.UserId] = {
        lastPos = hrp.Position,
        lastTime = tick(),
        isTroll = isTroll,
        reasons = reasons
    }
    
    return isTroll
end

function ANTI_TROLL:protectCharacter()
    if not EXPLOIT_STATE.antiTroll then return end
    
    -- Deflect incoming damage from exploiters
    local connection
    connection = Humanoid.Damaged:Connect(function(damage)
        if not EXPLOIT_STATE.antiTroll then
            connection:Disconnect()
            return
        end
        
        safeCall(function()
            local lastHealth = Humanoid.Health + damage
            Humanoid.Health = lastHealth
            
            -- Identify attacker
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and ANTI_TROLL:detectTroll(player) then
                    -- Counter-attack or evasion
                    RootPart.CFrame = RootPart.CFrame + Vector3.new(math.random(-20, 20), math.random(-5, 20), math.random(-20, 20))
                    log("Anti-troll activated! Evaded attacker: " .. player.Name)
                end
            end
        end)
    end)
    
    table.insert(ACTIVE_CONNECTIONS, connection)
end

function ANTI_TROLL:blockExploitAttacks()
    -- Monitor RemoteEvents for malicious calls
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local remotes = {}
    
    local function scanRemotes(parent)
        for _, child in pairs(parent:GetChildren()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                table.insert(remotes, child)
            end
            scanRemotes(child)
        end
    end
    
    scanRemotes(game)
    
    for _, remote in pairs(remotes) do
        local originalFire = remote.FireServer
        remote.FireServer = function(self, ...)
            local args = {...}
            -- Validate arguments
            safeCall(function()
                if #args > 0 and type(args[1]) == "userdata" then
                    -- Suspicious
                    return
                end
            end)
            return originalFire(self, ...)
        end
    end
    
    log("Remote event monitoring activated")
end


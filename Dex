local function initializeExploit()
    log("Initializing " .. EXPLOIT_NAME .. " v" .. SCRIPT_VERSION)
    
    -- Create GUI
    GUI:createPanel()
    
    -- Add sections and features
    GUI:addSection("CORE FEATURES")
    GUI:addToggle("God Mode", function(state) FEATURES:godMode(state) end)
    GUI:addToggle("Infinite Jump", function(state) FEATURES:infiniteJump(state) end)
    GUI:addToggle("Noclip", function(state) FEATURES:noclip(state) end)
    GUI:addToggle("Fly Mode", function(state) FEATURES:flyMode(state) end)
    
    GUI:addSection("COMBAT")
    GUI:addToggle("Aimbot", function(state) FEATURES:aimbot(state) end)
    GUI:addToggle("Fast Attack", function(state) FEATURES:fastAttack(state) end)
    
    GUI:addSection("CUSTOMIZATION")
    GUI:addSlider("Walk Speed", 16, 150, function(val) FEATURES:setWalkSpeed(val) end)
    GUI:addSlider("Jump Power", 50, 200, function(val) FEATURES:setJumpPower(val) end)
    
    GUI:addSection("UTILITY")
    GUI:addToggle("ESP (See Players)", function(state) FEATURES:esp(state) end)
    GUI:addToggle("Invisibility", function(state) FEATURES:invisibility(state) end)
    
    GUI:addSection("PROTECTION")
    GUI:addToggle("Anti-Troll Shield", function(state) EXPLOIT_STATE.antiTroll = state; if state then ANTI_TROLL:protectCharacter() end end)
    
    GUI:addSection("URBAN WARFARE")
    GUI:addToggle("Activate Urban Mode", function(state) EXPLOIT_STATE.urbanWarfareActive = state; if state then URBAN_WARFARE:activateForAllPlayers() end end)
    GUI:addSlider("Weapon Power", 1.0, 3.0, function(val) EXPLOIT_STATE.weaponMultiplier = val / 10 end)
    
    GUI:addSection("OPTIMIZATION")
    GUI:addToggle("FPS Booster", function(state) FEATURES:fpsBoost(state) end)
    GUI:addToggle("Anti-Lag", function(state) FEATURES:antiLag(state) end)
    GUI:addToggle("Memory Optimize", function(state) FEATURES:memoryOptimize(state) end)
    
    -- Activate default protections
    ANTI_TROLL:blockExploitAttacks()
    ANTI_TROLL:protectCharacter()
    FEATURES:memoryOptimize(true)
    
    log("✓ Exploit fully initialized")
    log("✓ GUI Panel ready")
    log("✓ Anti-troll protection active")
    log("✓ Urban Warfare system ready")
    log("✓ All systems nominal")
    
    return true
end

-- ============================================
-- ERROR HANDLING & SAFETY
-- ============================================

local function safeInitialize()
    local success, err = pcall(initializeExploit)
    if not success then
        logWarning("Initialization error: " .. tostring(err))
        logWarning("Attempting fallback initialization...")
        wait(2)
        initializeExploit()
    end
end


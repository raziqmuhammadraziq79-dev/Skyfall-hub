-- ==================== CREATE TOGGLE FUNCTION ====================
local function createToggle(name, description, icon)
    local toggleContainer = Instance.new("Frame")
    toggleContainer.Name = name
    toggleContainer.Size = UDim2.new(1, 0, 0, 65)
    toggleContainer.BackgroundColor3 = Color3.fromRGB(30, 25, 50)
    toggleContainer.BorderSizePixel = 0
    toggleContainer.Parent = contentFrame

    local toggleCorner = Instance.new("UICorner")
    toggleCorner.CornerRadius = UDim.new(0, 10)
    toggleCorner.Parent = toggleContainer

    local toggleStroke = Instance.new("UIStroke")
    toggleStroke.Color = Color3.fromRGB(80, 50, 150)
    toggleStroke.Thickness = 1
    toggleStroke.Parent = toggleContainer

    local textContainer = Instance.new("Frame")
    textContainer.Size = UDim2.new(1, -60, 1, 0)
    textContainer.Position = UDim2.new(0, 12, 0, 0)
    textContainer.BackgroundTransparency = 1
    textContainer.Parent = toggleContainer

    local featureLabel = Instance.new("TextLabel")
    featureLabel.Size = UDim2.new(1, 0, 0, 25)
    featureLabel.BackgroundTransparency = 1
    featureLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    featureLabel.TextSize = 13
    featureLabel.Font = Enum.Font.GothamBold
    featureLabel.Text = icon .. " " .. name
    featureLabel.TextXAlignment = Enum.TextXAlignment.Left
    featureLabel.Parent = textContainer

    local descLabel = Instance.new("TextLabel")
    descLabel.Size = UDim2.new(1, 0, 0, 20)
    descLabel.Position = UDim2.new(0, 0, 0, 25)
    descLabel.BackgroundTransparency = 1
    descLabel.TextColor3 = Color3.fromRGB(120, 120, 150)
    descLabel.TextSize = 10
    descLabel.Font = Enum.Font.Gotham
    descLabel.Text = description
    descLabel.TextXAlignment = Enum.TextXAlignment.Left
    descLabel.Parent = textContainer

    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Name = "Toggle"
    toggleBtn.Size = UDim2.new(0, 50, 0, 30)
    toggleBtn.Position = UDim2.new(1, -55, 0.5, -15)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
    toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggleBtn.TextSize = 9
    toggleBtn.Font = Enum.Font.GothamBold
    toggleBtn.Text = "OFF"
    toggleBtn.BorderSizePixel = 0
    toggleBtn.Parent = toggleContainer

    local toggleCorner2 = Instance.new("UICorner")
    toggleCorner2.CornerRadius = UDim.new(0, 6)
    toggleCorner2.Parent = toggleBtn

    local isOn = false
    
    toggleBtn.MouseButton1Click:Connect(function()
        isOn = not isOn
        if isOn then
            toggleBtn.BackgroundColor3 = Color3.fromRGB(147, 51, 234)
            toggleBtn.Text = "ON"
        else
            toggleBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
            toggleBtn.Text = "OFF"
        end
    end)

    return toggleContainer
end

-- ==================== CREATE SLIDER FUNCTION ====================
local function createSlider(name, description, minVal, maxVal, defaultVal, icon)
    local sliderContainer = Instance.new("Frame")
    sliderContainer.Name = name
    sliderContainer.Size = UDim2.new(1, 0, 0, 85)
    sliderContainer.BackgroundColor3 = Color3.fromRGB(30, 25, 50)
    sliderContainer.BorderSizePixel = 0
    sliderContainer.Parent = contentFrame

    local sliderCorner = Instance.new("UICorner")
    sliderCorner.CornerRadius = UDim.new(0, 10)
    sliderCorner.Parent = sliderContainer

    local sliderStroke = Instance.new("UIStroke")
    sliderStroke.Color = Color3.fromRGB(80, 50, 150)
    sliderStroke.Thickness = 1
    sliderStroke.Parent = sliderContainer

    local featureLabel = Instance.new("TextLabel")
    featureLabel.Size = UDim2.new(1, -30, 0, 22)
    featureLabel.Position = UDim2.new(0, 12, 0, 8)
    featureLabel.BackgroundTransparency = 1
    featureLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    featureLabel.TextSize = 13
    featureLabel.Font = Enum.Font.GothamBold
    featureLabel.Text = icon .. " " .. name
    featureLabel.TextXAlignment = Enum.TextXAlignment.Left
    featureLabel.Parent = sliderContainer

    local descLabel = Instance.new("TextLabel")
    descLabel.Size = UDim2.new(0.6, 0, 0, 15)
    descLabel.Position = UDim2.new(0, 12, 0, 30)
    descLabel.BackgroundTransparency = 1
    descLabel.TextColor3 = Color3.fromRGB(120, 120, 150)
    descLabel.TextSize = 9
    descLabel.Font = Enum.Font.Gotham
    descLabel.Text = description
    descLabel.TextXAlignment = Enum.TextXAlignment.Left
    descLabel.Parent = sliderContainer

    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0, 35, 0, 15)
    valueLabel.Position = UDim2.new(1, -47, 0, 30)
    valueLabel.BackgroundTransparency = 1
    valueLabel.TextColor3 = Color3.fromRGB(147, 51, 234)
    valueLabel.TextSize = 11
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.Text = tostring(defaultVal)
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Parent = sliderContainer

    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(1, -24, 0, 6)
    sliderBg.Position = UDim2.new(0, 12, 0, 50)
    sliderBg.BackgroundColor3 = Color3.fromRGB(50, 45, 80)
    sliderBg.BorderSizePixel = 0
    sliderBg.Parent = sliderContainer

    local sliderBgCorner = Instance.new("UICorner")
    sliderBgCorner.CornerRadius = UDim.new(0, 3)
    sliderBgCorner.Parent = sliderBg

    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new((defaultVal - minVal) / (maxVal - minVal), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(147, 51, 234)
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderBg

    local sliderFillCorner = Instance.new("UICorner")
    sliderFillCorner.CornerRadius = UDim.new(0, 3)
    sliderFillCorner.Parent = sliderFill

    local sliderHandle = Instance.new("Frame")
    sliderHandle.Size = UDim2.new(0, 18, 0, 18)
    sliderHandle.Position = UDim2.new((defaultVal - minVal) / (maxVal - minVal), -9, 0.5, -9)
    sliderHandle.BackgroundColor3 = Color3.fromRGB(200, 100, 255)
    sliderHandle.BorderSizePixel = 0
    sliderHandle.Parent = sliderBg
    sliderHandle.ZIndex = 3

    local handleCorner = Instance.new("UICorner")
    handleCorner.CornerRadius = UDim.new(0, 9)
    handleCorner.Parent = sliderHandle

    local isDragging = false
    
    sliderHandle.MouseButton1Down:Connect(function()
        isDragging = true
    end)

    UserInputService.InputEnded:Connect(function(input, gameProcessed)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = false
        end
    end)

    RunService.RenderStepped:Connect(function()
        if isDragging then
            local mousePos = UserInputService:GetMouseLocation()
            local sliderPos = sliderBg.AbsolutePosition.X
            local sliderSize = sliderBg.AbsoluteSize.X
            local relativePos = math.clamp(mousePos.X - sliderPos, 0, sliderSize)
            local percentage = relativePos / sliderSize
            local value = math.floor(minVal + (maxVal - minVal) * percentage)
            
            sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
            sliderHandle.Position = UDim2.new(percentage, -9, 0.5, -9)
            valueLabel.Text = tostring(value)
        end
    end)

    return sliderContainer
end


Players.PlayerAdded:Connect(createESPForPlayer)
Players.PlayerRemoving:Connect(removeESPForPlayer)

Features["ESP Player"] = function(state)
	activeFeatures["ESP Player"] = state
	for _, obj in pairs(espObjects) do
		obj.highlight.Enabled = state
		obj.billboard.Enabled = state
	end
end

RunService.RenderStepped:Connect(function()
	if not activeFeatures["ESP Player"] then return end
	for targetPlayer, obj in pairs(espObjects) do
		local character = targetPlayer.Character
		local root = character and character:FindFirstChild("HumanoidRootPart")
		if root then
			obj.highlight.Adornee = character

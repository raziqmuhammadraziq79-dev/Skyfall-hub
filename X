local function renderPage(pageKey)
	clearContent()
	if pageKey == "Home" then renderHome() return end
	if pageKey == "Info" then renderInfo() return end
	local items = pageItems[pageKey] or {}
	for _, itemName in ipairs(items) do
		if itemName == "Teleport Home" or itemName == "Teleport Spawn" then
			createActionButton(itemName)
		else
			createToggleRow(itemName)
		end
	end
	if pageKey == "Misc" then
		local ascendBtn = Instance.new("TextButton")
		ascendBtn.Text = "^ Ascend (hold)"
		ascendBtn.Font = Enum.Font.Gotham
		ascendBtn.TextSize = 13
		ascendBtn.TextColor3 = THEME.Text
		ascendBtn.Size = UDim2.new(1, 0, 0, 40)
		ascendBtn.BackgroundColor3 = THEME.Dark
		ascendBtn.BorderSizePixel = 0
		ascendBtn.Parent = mainContent
		local ac = Instance.new("UICorner") ac.CornerRadius = UDim.new(0, 8) ac.Parent = ascendBtn
		ascendBtn.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				pcall(Features["Fly Ascend"], true) ascendBtn.BackgroundColor3 = THEME.ToggleOn
			end
		end)
		ascendBtn.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				pcall(Features["Fly Ascend"], false) ascendBtn.BackgroundColor3 = THEME.Dark
			end
		end)

		local descendBtn = Instance.new("TextButton")
		descendBtn.Text = "v Descend (hold)"
		descendBtn.Font = Enum.Font.Gotham
		descendBtn.TextSize = 13
		descendBtn.TextColor3 = THEME.Text
		descendBtn.Size = UDim2.new(1, 0, 0, 40)
		descendBtn.BackgroundColor3 = THEME.Dark
		descendBtn.BorderSizePixel = 0
		descendBtn.Parent = mainContent
		local dc = Instance.new("UICorner") dc.CornerRadius = UDim.new(0, 8) dc.Parent = descendBtn
		descendBtn.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				pcall(Features["Fly Descend"], true) descendBtn.BackgroundColor3 = THEME.ToggleOn
			end
		end)
		descendBtn.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				pcall(Features["Fly Descend"], false) descendBtn.BackgroundColor3 = THEME.Dark
			end
		end)
	end
end


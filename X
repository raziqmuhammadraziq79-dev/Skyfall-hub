    Btn.MouseLeave:Connect(function() 
        if Btn.TextColor3 ~= CFG.Accent then 
            TweenService:Create(Btn, TweenInfo.new(0.15), {BackgroundColor3=Color3.fromRGB(25,25,25)}):Play() 

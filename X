	FogEnd = Lighting.FogEnd, Ambient = Lighting.Ambient, OutdoorAmbient = Lighting.OutdoorAmbient
}
local ORIGINAL_WALKSPEED = 16
local flying, flySpeed, verticalInput = false, 50, 0
local flyVelocity, flyGyro

local function safeGetCharacterParts()
	local character = player.Character
	if not character then return nil, nil, nil end
	return character, character:FindFirstChildOfClass("Humanoid"), character:FindFirstChild("HumanoidRootPart")
end

local function disconnectFeature(name)
	if connections[name] then connections[name]:Disconnect() connections[name] = nil end
end

-- ============ FEATURES (movement/visual, unchanged mechanics) ============
local Features = {}

Features["God Mode"] = function(state)
	activeFeatures["God Mode"] = state
	disconnectFeature("God Mode")
	local _, humanoid = safeGetCharacterParts()
	if not humanoid then return end
	if state then
		humanoid.MaxHealth = math.huge
		humanoid.Health = math.huge
		connections["God Mode"] = humanoid.HealthChanged:Connect(function()
			if activeFeatures["God Mode"] then pcall(function() humanoid.Health = humanoid.MaxHealth end) end
		end)
	else
		humanoid.MaxHealth = 100
		humanoid.Health = 100
	end
end

Features["Speed Hack"] = function(state)
	activeFeatures["Speed Hack"] = state
	local _, humanoid = safeGetCharacterParts()
	if not humanoid then return end
	humanoid.WalkSpeed = state and (ORIGINAL_WALKSPEED * 3) or ORIGINAL_WALKSPEED
end

Features["Tidak Ada Klip"] = function(state)
	activeFeatures["Tidak Ada Klip"] = state
	disconnectFeature("Noclip")
	if state then
		connections["Noclip"] = RunService.Stepped:Connect(function()
			local character = player.Character
			if not character then return end
			for _, part in ipairs(character:GetDescendants()) do
				if part:IsA("BasePart") then part.CanCollide = false end
			end
		end)
	else
		local character = player.Character
		if character then
			for _, part in ipairs(character:GetDescendants()) do
				if part:IsA("BasePart") then part.CanCollide = true end
			end
		end
	end
end

Features["Inf Jump"] = function(state)
	activeFeatures["Inf Jump"] = state
	disconnectFeature("Inf Jump")
	if state then
		connections["Inf Jump"] = UserInputService.JumpRequest:Connect(function()
			local _, humanoid = safeGetCharacterParts()
			if humanoid then pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end) end
		end)
	end
end

Features["Fullbright"] = function(state)
	activeFeatures["Fullbright"] = state
	if state then
		Lighting.Brightness = 2
		Lighting.FogEnd = 100000
		Lighting.Ambient = Color3.fromRGB(150, 150, 150)
		Lighting.OutdoorAmbient = Color3.fromRGB(150, 150, 150)
	else
		Lighting.Brightness = originalLighting.Brightness
		Lighting.FogEnd = originalLighting.FogEnd
		Lighting.Ambient = originalLighting.Ambient
		Lighting.OutdoorAmbient = originalLighting.OutdoorAmbient
	end
end

Features["Night Mode"] = function(state)
	activeFeatures["Night Mode"] = state
	Lighting.ClockTime = state and 0 or originalLighting.ClockTime
end

local function cleanupFlightPhysics()
	if flyVelocity and flyVelocity.Parent then flyVelocity:Destroy() flyVelocity = nil end
	if flyGyro and flyGyro.Parent then flyGyro:Destroy() flyGyro = nil end
end
local function setupFlightPhysics()
	cleanupFlightPhysics()
	local _, _, root = safeGetCharacterParts()
	if not root then return end
	flyVelocity = Instance.new("BodyVelocity")
	flyVelocity.Velocity = Vector3.new(0, 0, 0)
	flyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
	flyVelocity.Parent = root
	flyGyro = Instance.new("BodyGyro")
	flyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
	flyGyro.P = 9375
	flyGyro.D = 375
	flyGyro.CFrame = root.CFrame
	flyGyro.Parent = root
end

Features["Terbang"] = function(state)
	activeFeatures["Terbang"] = state
	local character, humanoid, root = safeGetCharacterParts()
	if not humanoid or not root then return end
	if state then
		flying = true
		setupFlightPhysics()
		humanoid.AutoRotate = false
	else
		flying = false
		humanoid.AutoRotate = true
		verticalInput = 0
		if flyVelocity and flyVelocity.Parent then flyVelocity.Velocity = Vector3.new(0, 0, 0) end
		cleanupFlightPhysics()
	end
end
Features["Fly Ascend"] = function(active) if flying then verticalInput = active and 1 or 0 end end
Features["Fly Descend"] = function(active) if flying then verticalInput = active and -1 or 0 end end

RunService.RenderStepped:Connect(function()
	if not flying then return end
	local character, humanoid, root = safeGetCharacterParts()
	if not character or not humanoid or not root then return end
	local moveDir = humanoid.MoveDirection
	local worldMove = Vector3.new(moveDir.X, 0, moveDir.Z) + Vector3.new(0, verticalInput, 0)
	if flyVelocity and flyVelocity.Parent then flyVelocity.Velocity = worldMove * flySpeed end
	if flyGyro and flyGyro.Parent then
		flyGyro.CFrame = CFrame.new(root.Position, root.Position + Camera.CFrame.LookVector)
	end
end)


		if fn then
			local ok, err = pcall(fn, newState)
			if not ok then warn("[SKYFALL] " .. name .. ": " .. tostring(err)) return end
		end
		toggleBg.BackgroundColor3 = newState and THEME.ToggleOn or THEME.ToggleOff
		TweenService:Create(toggleCircle, TweenInfo.new(0.15), {
			Position = newState and UDim2.new(0, 26, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
		}):Play()
	end)
end


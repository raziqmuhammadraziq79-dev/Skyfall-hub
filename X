local function createToggleButton(name, description, icon)
    local toggleContainer = Instance.new("Frame")
    toggleContainer.Name = name
    toggleContainer.Size = UDim2.new(1, 0, 0, 65)
    toggleContainer.BackgroundColor3 = Color3.fromRGB(30, 25, 50)
    toggleContainer.BorderSizePixel = 0
    toggleContainer.Parent = ContentFrame

    local toggleCorner = Instance.new("UICorner")
    toggleCorner.CornerRadius = UDim.new(0, 10)
    toggleCorner.Parent = toggleContainer

    local toggleStroke = Instance.new("UIStroke")
    toggleStroke.Color = Color3.fromRGB(80, 50, 150)
    toggleStroke.Thickness = 1
    toggleStroke.Parent = toggleContainer

    local textContainer = Instance.new("Frame")
    textContainer.Size = UDim2.new(1, -60, 1, 0)
    textContainer.Position = UDim2.new(0, 12, 0, 0)
    textContainer.BackgroundTransparency = 1
    textContainer.Parent = toggleContainer

    local featureLabel = Instance.new("TextLabel")
    featureLabel.Size = UDim2.new(1, 0, 0, 25)
    featureLabel.BackgroundTransparency = 1
    featureLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    featureLabel.TextSize = 13
    featureLabel.Font = Enum.Font.GothamBold
    featureLabel.Text = icon .. " " .. name
    featureLabel.TextXAlignment = Enum.TextXAlignment.Left
    featureLabel.Parent = textContainer

    local descLabel = Instance.new("TextLabel")
    descLabel.Size = UDim2.new(1, 0, 0, 20)
    descLabel.Position = UDim2.new(0, 0, 0, 25)
    descLabel.BackgroundTransparency = 1
    descLabel.TextColor3 = Color3.fromRGB(120, 120, 150)
    descLabel.TextSize = 10
    descLabel.Font = Enum.Font.Gotham
    descLabel.Text = description
    descLabel.TextXAlignment = Enum.TextXAlignment.Left
    descLabel.Parent = textContainer

    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Name = "Toggle"
    toggleBtn.Size = UDim2.new(0, 50, 0, 30)
    toggleBtn.Position = UDim2.new(1, -55, 0.5, -15)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
    toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggleBtn.TextSize = 9
    toggleBtn.Font = Enum.Font.GothamBold
    toggleBtn.Text = "OFF"
    toggleBtn.BorderSizePixel = 0
    toggleBtn.Parent = toggleContainer

    local toggleCorner2 = Instance.new("UICorner")
    toggleCorner2.CornerRadius = UDim.new(0, 6)
    toggleCorner2.Parent = toggleBtn

    local isOn = false
    
    toggleBtn.MouseButton1Click:Connect(function()
        isOn = not isOn
        if isOn then
            toggleBtn.BackgroundColor3 = Color3.fromRGB(147, 51, 234)
            toggleBtn.Text = "ON"
            StatusLabel.Text = "✓ " .. name .. " Activated"
        else
            toggleBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
            toggleBtn.Text = "OFF"
            StatusLabel.Text = "✓ " .. name .. " Deactivated"
        end
    end)

    return toggleContainer
end


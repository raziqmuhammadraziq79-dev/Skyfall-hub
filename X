-- ============ RADAR — Prison Life guards / Evade monster ============
-- Passive proximity awareness only. Reads publicly visible Workspace state
-- (position, name/team tags) that's already rendered on screen. Does not
-- touch door locks, keycard items, or the monster's AI/pathfinding state.
local radarContainer = Instance.new("Folder")
radarContainer.Name = "SkyFallRadar"
radarContainer.Parent = CoreGui
local radarBillboards = {}

local function isLikelyGuard(targetPlayer)
	local ok, team = pcall(function() return targetPlayer.Team end)
	if ok and team then
		local teamName = team.Name:lower()
		if teamName:find("cop") or teamName:find("guard") or teamName:find("police") then
			return true
		end
	end
	return false
end

local function isLikelyMonster(instance)
	local n = instance.Name:lower()
	return n:find("monster") or n:find("enemy") or n:find("chaser") or n:find("boss")
end

local function makeRadarTag(targetName, color)
	local billboard = Instance.new("BillboardGui")
	billboard.Size = UDim2.new(0, 150, 0, 40)
	billboard.AlwaysOnTop = true
	billboard.Enabled = false
	billboard.Parent = radarContainer
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 0.5, 0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.TextSize = 13
	label.TextColor3 = color
	label.TextStrokeTransparency = 0
	label.Text = targetName
	label.Parent = billboard
	local distLabel = Instance.new("TextLabel")
	distLabel.Size = UDim2.new(1, 0, 0.5, 0)
	distLabel.Position = UDim2.new(0, 0, 0.5, 0)
	distLabel.BackgroundTransparency = 1
	distLabel.Font = Enum.Font.Gotham
	distLabel.TextSize = 11
	distLabel.TextColor3 = THEME.Text
	distLabel.TextStrokeTransparency = 0
	distLabel.Parent = billboard
	return billboard, distLabel
end

Features["Guard Radar"] = function(state)
	activeFeatures["Guard Radar"] = state
	if not state then
		for _, obj in pairs(radarBillboards) do obj.billboard.Enabled = false end
		return
	end
	for _, targetPlayer in ipairs(Players:GetPlayers()) do
		if targetPlayer ~= player and isLikelyGuard(targetPlayer) then
			if not radarBillboards[targetPlayer] then
				local bb, dl = makeRadarTag(targetPlayer.Name .. " [GUARD]", THEME.Warn)
				radarBillboards[targetPlayer] = { billboard = bb, distLabel = dl }
			end
			radarBillboards[targetPlayer].billboard.Enabled = true
		end
	end
end

Features["Monster Radar"] = function(state)
	activeFeatures["Monster Radar"] = state
	if not state then return end
	-- scans Workspace once on activation; re-scan on toggle rather than every frame
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("Model") and isLikelyMonster(obj) and not radarBillboards[obj] then
			local bb, dl = makeRadarTag(obj.Name .. " [THREAT]", Color3.fromRGB(255, 60, 60))
			radarBillboards[obj] = { billboard = bb, distLabel = dl, isMonster = true }
		end
	end
end

RunService.RenderStepped:Connect(function()
	if not (activeFeatures["Guard Radar"] or activeFeatures["Monster Radar"]) then return end
	for target, obj in pairs(radarBillboards) do
		local root
		if target:IsA("Player") then
			local character = target.Character
			root = character and character:FindFirstChild("HumanoidRootPart")
		elseif target:IsA("Model") then
			root = target.PrimaryPart or target:FindFirstChild("HumanoidRootPart") or target:FindFirstChildWhichIsA("BasePart")
		end
		if root and obj.billboard.Enabled then
			obj.billboard.Adornee = root
			obj.distLabel.Text = string.format("%.0fm", (Camera.CFrame.Position - root.Position).Magnitude)
		end
	end
end)

player.CharacterAdded:Connect(function()
	task.wait(1)
	for name, state in pairs(activeFeatures) do
		if state and Features[name] then pcall(Features[name], true) end
	end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.F then pcall(Features["Terbang"], not activeFeatures["Terbang"]) end
	if flying then
		if input.KeyCode == Enum.KeyCode.Space then verticalInput = 1 end
		if input.KeyCode == Enum.KeyCode.LeftControl then verticalInput = -1 end
	end
end)
UserInputService.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.Space and verticalInput == 1 then verticalInput = 0 end
	if input.KeyCode == Enum.KeyCode.LeftControl and verticalInput == -1 then verticalInput = 0 end
end)


-- ================================================================================
-- DRAGGING FUNCTIONALITY
-- ================================================================================
local dragging = false
local dragStart
local dragStartPos

Header.InputBegan:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and not gameProcessed then
        dragging = true
        dragStart = UserInputService:GetMouseLocation()
        dragStartPos = MainPanel.Position
    end
end)

Header.InputEnded:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

RunService.RenderStepped:Connect(function()
    if dragging then
        local mousePos = UserInputService:GetMouseLocation()
        local delta = mousePos - dragStart
        MainPanel.Position = dragStartPos + UDim2.new(0, delta.X, 0, delta.Y)
    end
end)


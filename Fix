    task.spawn(function()
        -- Inject fake kick message into their chat
        pcall(function()
            local ChatRemote = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
            if ChatRemote then
                ChatRemote:FireServer("SayMessageRequest", {
                    Message = "⚠️ SYSTEM NOTICE ⚠️\nYou have been kicked from the server.\nReason: Exploiting detected by SKYFALL HUB v6.0\nDuration: Permanent\nAppeal: None",
                    Channel = "All"
                })
            end
        end)
        
        -- Flood their screen with error-like particles
        local TargetHR = TargetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if TargetHR then
            for i = 1, 100 do
                local ErrorPart = Instance.new("Part")
                ErrorPart.Size = Vector3.new(0.1, 0.1, 0.1)
                ErrorPart.Transparency = 0.8
                ErrorPart.Color = Color3.fromRGB(255, 0, 0)
                ErrorPart.Material = Enum.Material.Neon
                ErrorPart.CanCollide = false
                ErrorPart.Anchored = true
                ErrorPart.Position = TargetHR.Position + Vector3.new(math.random(-5, 5), math.random(-5, 5), math.random(-5, 5))
                ErrorPart.Parent = Workspace
                
                task.delay(2, function() 
                    if ErrorPart and ErrorPart.Parent then ErrorPart:Destroy() end 
                end)
            end
        end
        
        warn("[DEVIL KICK] Illusion deployed on: " .. TargetPlayer.Name)
    end)
end

-- 4. INFINITE HEALTH & AMMO (OPTIMIZED)
local function InitSurvivalSystems()
    -- Health
    if Humanoid then
        Humanoid.MaxHealth = MAX_HEALTH
        Humanoid.Health = MAX_HEALTH
        Humanoid.HealthChanged:Connect(function(NewHealth)
            if NewHealth < MAX_HEALTH then Humanoid.Health = MAX_HEALTH end
        end)
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
    end
    
    -- Ammo
    task.spawn(function()
        while true do
            task.wait(AMMO_REFILL_INTERVAL)
            if LocalPlayer.Character then
                for _, Container in ipairs({LocalPlayer.Backpack, LocalPlayer.Character}) do
                    for _, Tool in ipairs(Container:GetChildren()) do
                        if Tool:IsA("Tool") then
                            for _, Child in ipairs(Tool:GetDescendants()) do
                                if Child:IsA("IntValue") and Child.Name:lower():match("ammo|mag|clip") then
                                    Child.Value = 9999
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
end

-- 5. AUTO-DETECT EXPLOITER + ANTI-FLING TRIGGER
local function InitDetectionSystem()
    task.spawn(function()
        while true do
            task.wait(1)
            for _, Player in ipairs(Players:GetPlayers()) do
                if Player ~= LocalPlayer and Player.Character then
                    local HR = Player.Character:FindFirstChild("HumanoidRootPart")
                    if HR then
                        local VelocityMag = HR.Velocity.Magnitude
                        local YVelocity = math.abs(HR.Velocity.Y)
                        
                        -- FLING DETECTION SIGNATURE
                        if YVelocity > 50 or VelocityMag > 100 then
                            if not table.find(DetectedExploiters, Player) then
                                table.insert(DetectedExploiters, Player)
                                warn("[ANTI-FLING] Exploiter detected: " .. Player.Name .. " | Velocity: " .. tostring(VelocityMag))
                                
                                -- Trigger Illusion Kick immediately
                                TriggerIllusionKick(Player)
                            end
                        end
                    end
                end
            end
        end
    end)
end

-- [INITIALIZATION & STEALTH REINFORCEMENT]
local function Initialize()
    Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    Character:WaitForChild("HumanoidRootPart")
    Humanoid = Character:WaitForChild("Humanoid")
    RootPart = Character:FindFirstChild("HumanoidRootPart")
    LastPosition = RootPart.Position
    
    -- Absolute Stealth Masking (Re-applied every frame via separate loop)
    task.spawn(function()
        while true do
            task.wait()
            if Character and Character.Parent then
                for _, Desc in ipairs(Character:GetDescendants()) do
                    if Desc:IsA("BasePart") then
                        Desc.LocalTransparencyModifier = 1
                        Desc.Material = Enum.Material.SmoothPlastic
                        Desc.Color = Color3.fromRGB(0, 0, 0)
                    end
                end
                -- NameTag Removal
                local Head = Character:FindFirstChild("Head")
                if Head then
                    for _, Tag in ipairs(Head:GetChildren()) do
                        if Tag:IsA("BillboardGui") then Tag:Destroy() end
                    end
                end
            end
        end
    end)
    
    -- Activate All Systems
    InitPhysicsLock()
    InitDevilESP()
    InitSurvivalSystems()
    InitDetectionSystem()
    
    warn("[SKYFALL HUB v6.0] SUPER MAX BRUTAL KERNEL ONLINE. PHYSICS LOCKED. DEVIL VISION ACTIVE.")
end


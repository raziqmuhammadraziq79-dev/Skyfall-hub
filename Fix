-- [CORE MODULES]

-- 1. TRIPLE-LAYER PHYSICS ANTI-FLING LOCK
local function InitPhysicsLock()
    if not RootPart or not Humanoid then return end
    
    -- Layer 1: Anchor State
    RootPart.Anchored = true
    
    -- Layer 2: WeldConstraint to Baseplate (Prevents server override)
    local Baseplate = Workspace:FindFirstChild("Baseplate") or Workspace.Terrain
    local Weld = Instance.new("WeldConstraint")
    Weld.Part0 = RootPart
    Weld.Part1 = Baseplate
    Weld.Parent = RootPart
    
    -- Layer 3: CFrame Override Loop (Renders any external force useless)
    RunService.RenderStepped:Connect(function(dt)
        if not RootPart or not RootPart.Parent then return end
        
        -- Force position lock
        RootPart.CFrame = CFrame.new(LastPosition) * CFrame.Angles(0, RootPart.Orientation.Y, 0)
        
        -- Re-anchor in case script removed it
        RootPart.Anchored = true
        
        -- Update last known safe position
        LastPosition = RootPart.Position
    end)
    
    -- Prevent unanchoring via property change
    RootPart:GetPropertyChangedSignal("Anchored"):Connect(function()
        if not RootPart.Anchored then
            RootPart.Anchored = true
        end
    end)
end

-- 2. DEVIL ESP OVERLAY (VISUAL TERROR SYSTEM)
local function InitDevilESP()
    -- Create persistent GUI
    DevilEspGui = Instance.new("ScreenGui")
    DevilEspGui.Name = "DevilVisionOverlay"
    DevilEspGui.ResetOnSpawn = false
    DevilEspGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    DevilEspGui.IgnoreGuiInset = true
    DevilEspGui.Parent = game:GetService("CoreGui")
    
    local Camera = Workspace.CurrentCamera
    
    local function UpdateDevilVision()
        -- Clear previous frames
        for _, Child in ipairs(DevilEspGui:GetChildren()) do
            if Child:IsA("Frame") or Child:IsA("TextLabel") then Child:Destroy() end
        end
        
        for _, Player in ipairs(Players:GetPlayers()) do
            if Player ~= LocalPlayer and Player.Character then
                local HR = Player.Character:FindFirstChild("HumanoidRootPart")
                local Hum = Player.Character:FindFirstChildOfClass("Humanoid")
                
                -- THREAT ASSESSMENT
                local IsThreat = false
                local ThreatType = "Unknown"
                
                -- Check for weapons/hostile tools
                for _, Tool in ipairs(Player.Character:GetChildren()) do
                    if Tool:IsA("Tool") and Tool.Name:lower():match("gun|knife|bat|fling|kill") then
                        IsThreat = true
                        ThreatType = "ARMED"
                    end
                end
                
                -- Check for anomalous movement (exploiter signature)
                if HR and math.abs(HR.Velocity.Y) > 15 then
                    IsThreat = true
                    ThreatType = "FLYING/FLINGING"
                end
                
                if IsThreat and HR then
                    local ScreenPos, OnScreen = Camera:WorldToViewportPoint(HR.Position + Vector3.new(0, 4, 0))
                    
                    if OnScreen then
                        -- Devil Silhouette Frame
                        local DevilFrame = Instance.new("Frame")
                        DevilFrame.Size = UDim2.new(0, 60, 0, 80)
                        DevilFrame.BackgroundColor3 = DEVIL_ESP_COLOR
                        DevilFrame.BackgroundTransparency = 0.2
                        DevilFrame.BorderSizePixel = 3
                        DevilFrame.BorderColor3 = DEVIL_ESP_GLOW
                        DevilFrame.Parent = DevilEspGui
                        
                        -- Position with pulsing effect
                        local Pulse = math.sin(tick() * 5) * 2
                        DevilFrame.Position = UDim2.new(0, ScreenPos.X - 30 + Pulse, 0, ScreenPos.Y - 40)
                        
                        -- Threat Label
                        local Label = Instance.new("TextLabel")
                        Label.Size = UDim2.new(0, 100, 0, 20)
                        Label.Position = UDim2.new(0, ScreenPos.X - 50, 0, ScreenPos.Y + 45)
                        Label.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                        Label.BackgroundTransparency = 0.5
                        Label.Text = "[DEVIL] " .. Player.Name .. " - " .. ThreatType
                        Label.TextColor3 = Color3.fromRGB(255, 0, 0)
                        Label.TextScaled = true
                        Label.Font = Enum.Font.GothamBlack
                        Label.Parent = DevilEspGui
                        
                        -- Tracking Line to Center Screen
                        local Line = Instance.new("Frame")
                        local Center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                        local Target = Vector2.new(ScreenPos.X, ScreenPos.Y)
                        local Distance = (Target - Center).Magnitude
                        local Angle = math.atan2(Target.Y - Center.Y, Target.X - Center.X)
                        
                        Line.Size = UDim2.new(0, 3, 0, Distance)
                        Line.BackgroundColor3 = DEVIL_ESP_GLOW
                        Line.Rotation = math.deg(Angle)
                        Line.AnchorPoint = Vector2.new(0.5, 0)
                        Line.Position = UDim2.new(0, Center.X, 0, Center.Y)
                        Line.Parent = DevilEspGui
                    end
                end
            end
        end
    end
    
    RunService.RenderStepped:Connect(UpdateDevilVision)
end

-- 3. ILLUSION KICK PROTOCOL (PSYCHOLOGICAL WARFARE)

-- helper: all players
local function allP(includeSelf)
    local t={}
    for _,p in pairs(Players:GetPlayers()) do
        if includeSelf or p~=LP then table.insert(t,p) end
    end
    return t
end

-- ─── FLY (FIXED) ──────────────────────────────────────────
local function startFly()
    -- clean old
    if S._flyBV then pcall(function() S._flyBV:Destroy() end) end
    if S._flyBG then pcall(function() S._flyBG:Destroy() end) end

    local root = getRoot()
    if not root then return end

    local bv = Instance.new("BodyVelocity", root)
    bv.Name      = "_UW_BV"
    bv.MaxForce  = Vector3.new(1e6,1e6,1e6)
    bv.Velocity  = Vector3.zero
    S._flyBV     = bv

    local bg = Instance.new("BodyGyro", root)
    bg.Name      = "_UW_BG"
    bg.MaxTorque = Vector3.new(1e6,1e6,1e6)
    bg.P         = 1e5
    S._flyBG     = bg

    -- disable humanoid jumping interference
    local hum = getHum()
    if hum then
        hum.PlatformStand = true
    end
end

local function stopFly()
    if S._flyBV then pcall(function() S._flyBV:Destroy() end); S._flyBV=nil end
    if S._flyBG then pcall(function() S._flyBG:Destroy() end); S._flyBG=nil end
    local hum = getHum()
    if hum then hum.PlatformStand = false end
end

RunService.RenderStepped:Connect(function()
    if not S.Fly or not S._flyBV or not S._flyBG then return end
    local cam = workspace.CurrentCamera
    local dir = Vector3.zero
    if UIS:IsKeyDown(Enum.KeyCode.W) then dir+=cam.CFrame.LookVector end
    if UIS:IsKeyDown(Enum.KeyCode.S) then dir-=cam.CFrame.LookVector end
    if UIS:IsKeyDown(Enum.KeyCode.A) then dir-=cam.CFrame.RightVector end
    if UIS:IsKeyDown(Enum.KeyCode.D) then dir+=cam.CFrame.RightVector end
    if UIS:IsKeyDown(Enum.KeyCode.Space) then dir+=Vector3.new(0,1,0) end
    if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then dir-=Vector3.new(0,1,0) end
    -- mobile: use camera tilt for direction
    dir = dir.Magnitude==0 and Vector3.zero or dir.Unit
    S._flyBV.Velocity = dir * S.FlySpeed
    S._flyBG.CFrame   = cam.CFrame
end)


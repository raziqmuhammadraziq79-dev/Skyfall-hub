-- TOGGLE (fixed: tap anywhere on row)
local function tog(parent, label, key, cb, accentCol)
    accentCol = accentCol or C.Acc
    local row = Frame{
        Parent=parent,
        Size=UDim2.new(1,0,0,RH),
        BackgroundColor3=C.BG3,
        BorderSizePixel=0,
    }
    corner(row)

    local lbl = Label{
        Parent=row,
        Size=UDim2.new(0.64,0,1,0),
        Position=UDim2.new(0,9,0,0),
        BackgroundTransparency=1,
        Text=label,
        TextColor3=C.Text,
        Font=Enum.Font.Gotham,
        TextScaled=true,
        TextXAlignment=Enum.TextXAlignment.Left,
    }

    local TRW, TRH = s(40), s(20)
    local KSZ = s(14)

    local track = Frame{
        Parent=row,
        Size=UDim2.new(0,TRW,0,TRH),
        Position=UDim2.new(1,-(TRW+8),0.5,-TRH/2),
        BackgroundColor3=Color3.fromRGB(22,28,52),
        BorderSizePixel=0,
    }
    corner(track, 99)

    local knob = Frame{
        Parent=track,
        Size=UDim2.new(0,KSZ,0,KSZ),
        Position=UDim2.new(0,3,0.5,-KSZ/2),
        BackgroundColor3=C.TextDim,
        BorderSizePixel=0,
    }
    corner(knob, 99)

    -- indicator dot on left
    local dot = Frame{
        Parent=row,
        Size=UDim2.new(0,s(4),0,s(4)),
        Position=UDim2.new(0,4,0.5,-s(2)),
        BackgroundColor3=C.TextDim,
        BorderSizePixel=0,
    }
    corner(dot, 99)

    local function refresh(v)
        local onP  = UDim2.new(0, TRW-KSZ-3, 0.5, -KSZ/2)
        local offP = UDim2.new(0, 3,          0.5, -KSZ/2)
        TweenService:Create(knob, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {
            Position         = v and onP or offP,
            BackgroundColor3 = v and C.White or C.TextDim,
        }):Play()
        TweenService:Create(track, TweenInfo.new(0.12), {
            BackgroundColor3 = v and accentCol or Color3.fromRGB(22,28,52),
        }):Play()
        TweenService:Create(dot, TweenInfo.new(0.12), {
            BackgroundColor3 = v and accentCol or C.TextDim,
        }):Play()
        lbl.TextColor3 = v and C.White or C.Text
    end

    refresh(S[key] or false)

    -- USE DetectorButton so entire row is tappable
    local btn = Instance.new("TextButton", row)
    btn.Size               = UDim2.new(1,0,1,0)
    btn.BackgroundTransparency = 1
    btn.Text               = ""
    btn.ZIndex             = 5

    local function fire()
        S[key] = not S[key]
        refresh(S[key])
        if cb then pcall(cb, S[key]) end
    end
    btn.MouseButton1Click:Connect(fire)
    btn.TouchTap:Connect(fire)

    return row, function(v)
        S[key] = v
        refresh(v)
    end
end

-- BUTTON
local function mkB(parent, lbl, col, cb, textCol)
    col = col or C.AccDim
    local b = Instance.new("TextButton", parent)
    b.Size             = UDim2.new(1,0,0,RH)
    b.BackgroundColor3 = col
    b.Text             = lbl
    b.TextColor3       = textCol or C.White
    b.Font             = Enum.Font.GothamBold
    b.TextScaled       = true
    b.BorderSizePixel  = 0
    corner(b)
    stroke(b, C.Border, 1)

    local function fire()
        TweenService:Create(b,TweenInfo.new(0.07),{BackgroundColor3=C.AccLit}):Play()
        task.delay(0.16,function()
            if b and b.Parent then
                TweenService:Create(b,TweenInfo.new(0.07),{BackgroundColor3=col}):Play()
            end
        end)
        if cb then pcall(cb) end
    end
    b.MouseButton1Click:Connect(fire)
    b.TouchTap:Connect(fire)
    return b
end


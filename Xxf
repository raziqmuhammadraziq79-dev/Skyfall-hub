    for k,b  in pairs(TabBtns) do
        if k==key then
            TweenService:Create(b,TweenInfo.new(0.11),{BackgroundColor3=C.Acc}):Play()
            b.TextColor3=C.White
        else
            TweenService:Create(b,TweenInfo.new(0.11),{BackgroundColor3=C.BG3}):Play()
            b.TextColor3=C.TextDim
        end
    end
end

local function grid(parent, items)
    local rows = math.ceil(#items/2)
    local g = Frame{
        Parent=parent,
        Size=UDim2.new(1,0,0,rows*(RH+4)),
        BackgroundTransparency=1,
        BorderSizePixel=0,
    }
    local gl = Instance.new("UIGridLayout", g)
    gl.CellSize    = UDim2.new(0.5,-3,0,RH)
    gl.CellPadding = UDim2.new(0,4,0,4)
    for _, it in ipairs(items) do
        mkB(g, it[1], it[3] or C.AccDim, it[2])
    end
    return g
end

-- SLIDER
local function mkSlider(parent, label, mn, mx, def, cb)
    local CH = s(52)
    local KS = s(14)
    local TH = s(5)

    local c = Frame{
        Parent=parent,
        Size=UDim2.new(1,0,0,CH),
        BackgroundColor3=C.BG3,
        BorderSizePixel=0,
    }
    corner(c)

    local ll = Label{
        Parent=c,
        Size=UDim2.new(0.64,0,0,s(20)),
        Position=UDim2.new(0,8,0,s(4)),
        BackgroundTransparency=1,
        Text=label,
        TextColor3=C.Text,
        Font=Enum.Font.Gotham,
        TextScaled=true,
        TextXAlignment=Enum.TextXAlignment.Left,
    }
    local vl = Label{
        Parent=c,
        Size=UDim2.new(0.32,0,0,s(20)),
        Position=UDim2.new(0.66,0,0,s(4)),
        BackgroundTransparency=1,
        Text=tostring(def),
        TextColor3=C.AccLit,
        Font=Enum.Font.GothamBold,
        TextScaled=true,
        TextXAlignment=Enum.TextXAlignment.Right,
    }

    local tr = Frame{
        Parent=c,
        Size=UDim2.new(1,-16,0,TH),
        Position=UDim2.new(0,8,0,CH-s(15)),
        BackgroundColor3=Color3.fromRGB(20,26,50),
        BorderSizePixel=0,
    }
    corner(tr, 99)

    local fl = Frame{
        Parent=tr,
        Size=UDim2.new(math.clamp((def-mn)/(mx-mn),0,1),0,1,0),
        BackgroundColor3=C.Acc,
        BorderSizePixel=0,
    }
    corner(fl, 99)

    local kn = Frame{
        Parent=tr,
        Size=UDim2.new(0,KS,0,KS),
        Position=UDim2.new(math.clamp((def-mn)/(mx-mn),0,1),-KS/2,0.5,-KS/2),
        BackgroundColor3=C.White,
        BorderSizePixel=0,
        ZIndex=4,
    }
    corner(kn, 99)

    local dragging = false

    local function updateSlider(inputX)
        local ratio = math.clamp(
            (inputX - tr.AbsolutePosition.X) / tr.AbsoluteSize.X, 0, 1
        )
        local v = math.floor(mn + ratio * (mx - mn))
        fl.Size       = UDim2.new(ratio,0,1,0)
        kn.Position   = UDim2.new(ratio,-KS/2,0.5,-KS/2)
        vl.Text       = tostring(v)
        if cb then pcall(cb, v) end
    end

    tr.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch
        or i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateSlider(i.Position.X)
        end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch
        or i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if dragging then
            updateSlider(i.Position.X)
        end
    end)
    return c
end


-- ─── ANTI-FLING (FIXED — uses Position delta not CFrame) ──
local _lastPos, _validPos
RunService.Heartbeat:Connect(function()
    local root = getRoot()
    if not root then _lastPos=nil; _validPos=nil; return end

    if _lastPos then
        local dist = (root.Position - _lastPos).Magnitude

        -- anti-fling: snap back if flung >60 studs in 1 frame (not flying)
        if S.AntiFling and not S.Fly and dist > 60 then
            root.CFrame = CFrame.new(_validPos or _lastPos)
            root.AssemblyLinearVelocity    = Vector3.zero
            root.AssemblyAngularVelocity   = Vector3.zero
        else
            _validPos = root.Position
        end

        -- anti-force: destroy external body movers
        if S.AntiForce then
            for _,v in pairs(root:GetChildren()) do
                if (v:IsA("BodyVelocity") or v:IsA("BodyForce")
                or  v:IsA("BodyPosition") or v:IsA("BodyAngularVelocity")
                or  v:IsA("RocketPropulsion"))
                and v.Name~="_UW_BV" and v.Name~="_UW_BG" then
                    v:Destroy()
                end
            end
        end

        -- anti-freeze
        if S.AntiFreeze then
            local char = LP.Character
            if char then
                for _,p in pairs(char:GetDescendants()) do
                    if p:IsA("BasePart") and p.Anchored then p.Anchored=false end
                end
            end
        end

        -- anti-spin
        if S.AntiSpin then
            if root.AssemblyAngularVelocity.Magnitude > 3 then
                root.AssemblyAngularVelocity = Vector3.zero
            end
        end

        -- anti-unauthorized-tp
        if S.AntiTP and not S.Fly and dist > 250 then
            root.CFrame = CFrame.new(_validPos or _lastPos)
        end
    end
    _lastPos = root.Position

    -- ── core state every heartbeat ─────────────────────────
    local char = LP.Character
    local hum  = getHum()

    if hum then
        if S.GodMode    then hum.MaxHealth=math.huge; hum.Health=math.huge end
        if S.Invincible then
            if hum.Health < hum.MaxHealth then hum.Health = hum.MaxHealth end
        end
        if S.InfStamina then
            for _,v in pairs(hum:GetChildren()) do
                if (v:IsA("NumberValue") or v:IsA("IntValue"))
                and v.Name:lower():find("stamina") then v.Value=9999 end
            end
        end
        if S.AntiKB     then hum.Sit=false end
        if S.AutoJump   then hum.Jump=true end
        if S.SpeedHack  then hum.WalkSpeed=S.WalkSpeed end
        if S.AntiRagdoll then
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll,false)
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown,false)
        end
        if S.AutoParry then
            if hum:GetState()==Enum.HumanoidStateType.FallingDown then
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
        end
        if S.AutoRespawn and hum.Health<=0 then
            task.delay(0.05,function() LP:LoadCharacter() end)
        end
    end

    -- noclip
    if S.Noclip and char then
        for _,p in pairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide=false end
        end
    end

    -- low gravity self
    if S.LowGrav and root then
        if root.AssemblyLinearVelocity.Y < -4 then
            root.AssemblyLinearVelocity = Vector3.new(
                root.AssemblyLinearVelocity.X, -4,
                root.AssemblyLinearVelocity.Z
            )
        end
    end

    -- wall climb
    if S.WallClimb and root then
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.FilterDescendantsInstances = {char}
        local cam = workspace.CurrentCamera
        local ray = workspace:Raycast(root.Position, cam.CFrame.LookVector*3, params)
        if ray then
            root.AssemblyLinearVelocity = Vector3.new(
                root.AssemblyLinearVelocity.X, 30,
                root.AssemblyLinearVelocity.Z
            )
        end
    end

    -- item magnet
    if S.ItemMagnet and root then
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("Tool") then
                pcall(function()
                    local h=v:FindFirstChild("Handle")
                    if h then h.CFrame=CFrame.new(root.Position+Vector3.new(0,2,0)) end
                end)
            end
        end
    end

    -- satellite view
    if S.SatView then workspace.CurrentCamera.FieldOfView=170 end

    -- xray
    if S.XRay then
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not Players:GetPlayerFromCharacter(v.Parent) then
                if v.Transparency<0.7 and not v:IsA("Terrain") then
                    v.LocalTransparencyModifier = 0.8
                end
            end
        end
    end

    -- vehicle boost
    if S.VehicleBoost then
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("VehicleSeat") then v.MaxSpeed=999; v.Torque=9999 end
        end
    end

    -- breach doors
    if S.BreachDoors then
        for _,v in pairs(workspace:GetDescendants()) do
            local n=v.Name:lower()
            if n:find("door") or n:find("gate") or n:find("cell") or n:find("lock") then
                if v:IsA("BasePart") then v.CanCollide=false end
            end
        end
    end

    -- map reveal
    if S.MapReveal then
        Lighting.FogEnd=1e6; Lighting.FogStart=1e6
    end

    -- auto delete
    if S.AntiDelete and char then
        if not char:FindFirstChild("HumanoidRootPart") then
            task.delay(0.05,function() LP:LoadCharacter() end)
        end
    end

    -- speed all
    if S.SpeedAll then
        for _,p in pairs(allP(false)) do
            local h=p.Character and p.Character:FindFirstChild("Humanoid")
            if h then h.WalkSpeed=S.WalkSpeed end
        end
    end

    -- crouch spam
    if S.CrouchSpam and hum then
        hum.CameraOffset=Vector3.new(0,math.sin(tick()*28)*0.9,0)
    end

    -- cam lock nearest
    if S.CamLock and root then
        local cam=workspace.CurrentCamera
        local best,bd=nil,math.huge
        for _,p in pairs(allP(false)) do
            local h2=p.Character and p.Character:FindFirstChild("Head")
            if h2 then
                local d=(h2.Position-root.Position).Magnitude
                if d<bd then bd=d;best=h2 end
            end
        end
        if best then cam.CFrame=CFrame.new(cam.CFrame.Position,best.Position) end
    end

    -- loop kill nearest
    if S.LoopKill and root then
        local best,bd=nil,math.huge
        for _,p in pairs(allP(false)) do
            local r2=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
            if r2 then
                local d=(r2.Position-root.Position).Magnitude
                if d<bd then bd=d;best=p end
            end
        end
        if best and best.Character then
            local bh=best.Character:FindFirstChild("Humanoid")
            if bh then bh.Health=0 end
        end
    end

    -- lightning (one shot)
    if S.LightStrike and root then
        local best,bd=nil,math.huge
        for _,p in pairs(allP(false)) do
            local r2=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
            if r2 then
                local d=(r2.Position-root.Position).Magnitude
                if d<bd then bd=d;best=r2 end
            end
        end
        if best then
            local e=Instance.new("Explosion",workspace)
            e.Position=best.Position;e.BlastRadius=8;e.BlastPressure=6e5
        end
        S.LightStrike=false
    end

    -- anti noclip push
    if S.AntiNoclip and root then
        for _,p in pairs(allP(false)) do
            local r2=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
            if r2 then
                local diff=r2.Position-root.Position
                if diff.Magnitude<4 then
                    r2.AssemblyLinearVelocity=diff.Unit*70
                end
            end
        end
    end

    -- inf ammo
    if S.InfAmmo then
        local function doAmmo(char2)
            if not char2 then return end
            for _,tool in pairs(char2:GetChildren()) do
                if tool:IsA("Tool") then
                    for _,v in pairs(tool:GetDescendants()) do
                        if v:IsA("IntValue") or v:IsA("NumberValue") then
                            local n=v.Name:lower()
                            if n:find("ammo") or n:find("bullet") or n:find("mag") or n:find("clip") then
                                v.Value=9999
                            end
                        end
                    end
                end
            end
        end
        doAmmo(LP.Character)
        local bp=LP:FindFirstChild("Backpack")
        if bp then doAmmo(bp) end
    end

    -- auto farm
    if S.AutoFarm and root then
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("UnionOperation") then
                local n=v.Name:lower()
                if n:find("coin") or n:find("cash") or n:find("gem") or n:find("orb")
                or n:find("collect") or n:find("pickup") or n:find("star") or n:find("money") then
                    pcall(function() v.CFrame=CFrame.new(root.Position) end)
                end
            end
        end
    end

    -- aimbot
    if S.AimbotOn then
        local cam=workspace.CurrentCamera
        local best,bd=nil,math.huge
        for _,p in pairs(allP(false)) do
            local h2=p.Character and p.Character:FindFirstChild("Head")
            if h2 then
                local sp,vis=cam:WorldToViewportPoint(h2.Position)
                if vis then
                    local d=(Vector2.new(sp.X,sp.Y)-cam.ViewportSize/2).Magnitude
                    if d<bd then bd=d;best=h2 end
                end
            end
        end
        if best then cam.CFrame=CFrame.new(cam.CFrame.Position,best.Position) end
    end
end)


-- ─── ESP (FIXED — rebuilds on char change) ────────────────
local function clearESP()
    for _,b in pairs(S._espPool) do pcall(function() b:Destroy() end) end
    S._espPool = {}
end

local function buildESP()
    clearESP()
    if not S.ESPOn then return end
    for _,p in pairs(allP(false)) do
        local function attachESP(character)
            task.wait(0.1)
            local root = character:FindFirstChild("HumanoidRootPart")
            if not root then return end

            local bb = Instance.new("BillboardGui", root)
            bb.Name         = "_UW_ESP"
            bb.Size         = UDim2.new(0,s(82),0,s(44))
            bb.AlwaysOnTop  = true
            bb.MaxDistance  = 1000
            bb.StudsOffset  = Vector3.new(0,s(3.5),0)

            local nl = Label{
                Parent=bb,
                Size=UDim2.new(1,0,0.55,0),
                BackgroundTransparency=1,
                Text="⊛ "..p.Name,
                TextColor3=C.AccLit,
                Font=Enum.Font.GothamBold,
                TextScaled=true,
            }
            local hl = Label{
                Parent=bb,
                Size=UDim2.new(1,0,0.45,0),
                Position=UDim2.new(0,0,0.55,0),
                BackgroundTransparency=1,
                Font=Enum.Font.Gotham,
                TextScaled=true,
            }
            RunService.Heartbeat:Connect(function()
                local hum = character:FindFirstChild("Humanoid")
                if hum and bb and bb.Parent then
                    local pct = math.clamp(hum.Health/math.max(hum.MaxHealth,1),0,1)
                    hl.TextColor3 = Color3.new(1-pct, pct*0.85, 0)
                    hl.Text = string.format("HP %d/%d", math.floor(hum.Health), math.floor(hum.MaxHealth))
                end
            end)
            table.insert(S._espPool, bb)
        end

        if p.Character then attachESP(p.Character) end
        p.CharacterAdded:Connect(attachESP)
    end
end


-- ─── ANTI-BAN SWEEP ───────────────────────────────────────
local function antiBan()
    local keywords={"ban","kick","anticheat","detect","punish","censor","moderate"}
    local function sweep(parent)
        pcall(function()
            for _,v in pairs(parent:GetDescendants()) do
                if v:IsA("Script") or v:IsA("LocalScript") or v:IsA("ModuleScript") then
                    local n=v.Name:lower()
                    for _,kw in pairs(keywords) do
                        if n:find(kw) then pcall(function() v.Disabled=true end) break end
                    end
                end
            end
        end)
    end
    sweep(workspace)
    sweep(game:GetService("ReplicatedStorage"))
    pcall(function() sweep(game:GetService("ServerScriptService")) end)
    StarterGui:SetCore("ChatMakeSystemMessage",{
        Text="[UW] Anti-Ban sweep complete.",
        Color=C.Green, Font=Enum.Font.GothamBold, TextSize=16,
    })
end


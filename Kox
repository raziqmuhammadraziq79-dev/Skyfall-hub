-- ============================================================================
-- UTILITY FUNCTIONS
-- ============================================================================

local function CreateConnection(signal, callback)
	local conn = signal:Connect(callback)
	table.insert(State.ConnectedSignals, conn)
	return conn
end

local function DisconnectAll()
	for _, conn in ipairs(State.ConnectedSignals) do
		if conn then conn:Disconnect() end
	end
	State.ConnectedSignals = {}
end

local function GetCharacter()
	if not LocalPlayer.Character then
		LocalPlayer.CharacterAdded:Wait()
	end
	return LocalPlayer.Character
end

-- ============================================================================
-- FLY SYSTEM
-- ============================================================================

local function StartFly()
	if State.FlyActive then return end
	State.FlyActive = true
	
	local char = GetCharacter()
	local hrp = char:WaitForChild("HumanoidRootPart")
	
	-- Create invisible BodyVelocity
	local bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
	bodyVelocity.Parent = hrp
	
	CreateConnection(RunService.RenderStepped, function()
		if not State.FlyActive then
			bodyVelocity:Destroy()
			return
		end
		
		local moveDirection = Vector3.new(0, 0, 0)
		
		-- Input handling (WASD + Space/Ctrl)
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then
			moveDirection = moveDirection + (Camera.CFrame.LookVector * Vector3.new(1, 0, 1)).Unit
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then
			moveDirection = moveDirection - Camera.CFrame.RightVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then
			moveDirection = moveDirection - (Camera.CFrame.LookVector * Vector3.new(1, 0, 1)).Unit
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then
			moveDirection = moveDirection + Camera.CFrame.RightVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
			moveDirection = moveDirection + Vector3.new(0, 1, 0)
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
			moveDirection = moveDirection - Vector3.new(0, 1, 0)
		end
		
		bodyVelocity.Velocity = moveDirection.Unit * State.SpeedValue
	end)
end

local function StopFly()
	State.FlyActive = false
end

-- ============================================================================
-- NOCLIP SYSTEM
-- ============================================================================

local function StartNoclip()
	if State.NoclipActive then return end
	State.NoclipActive = true
	
	CreateConnection(RunService.Stepped, function()
		if not State.NoclipActive then return end
		
		local char = GetCharacter()
		for _, part in pairs(char:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = false
			end
		end
	end)
end

local function StopNoclip()
	State.NoclipActive = false
	
	local char = GetCharacter()
	for _, part in pairs(char:GetDescendants()) do
		if part:IsA("BasePart") then
			part.CanCollide = true
		end
	end
end

-- ============================================================================
-- INFINITE JUMP SYSTEM
-- ============================================================================

local function StartInfiniteJump()
	if State.JumpActive then return end
	State.JumpActive = true
	
	CreateConnection(UserInputService.InputBegan, function(input, gameProcessed)
		if gameProcessed then return end
		
		if input.KeyCode == Enum.KeyCode.Space and State.JumpActive then
			local char = GetCharacter()
			local humanoid = char:WaitForChild("Humanoid")
			humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
			humanoid:ChangeState(Enum.HumanoidStateType.Landed)
		end
	end)
end

local function StopInfiniteJump()
	State.JumpActive = false
end

-- ============================================================================
-- INFINITE HEALTH SYSTEM
-- ============================================================================

local function StartInfiniteHealth()
	if State.HealthActive then return end
	State.HealthActive = true
	
	CreateConnection(RunService.Heartbeat, function()
		if not State.HealthActive then return end
		
		local char = GetCharacter()
		local humanoid = char:WaitForChild("Humanoid")
		humanoid.Health = humanoid.MaxHealth
	end)
end

local function StopInfiniteHealth()
	State.HealthActive = false
end

-- ============================================================================
-- IMMORTALITY SYSTEM (kombinasi Health + Damage Block)
-- ============================================================================

local function StartImmortality()
	if State.ImmortalActive then return end
	State.ImmortalActive = true
	
	local char = GetCharacter()
	local humanoid = char:WaitForChild("Humanoid")
	
	-- Block damage dengan mendeteksi perubahan health
	CreateConnection(humanoid.HealthChanged, function()
		if State.ImmortalActive then
			humanoid.Health = humanoid.MaxHealth
		end
	end)
	
	-- Juga maintain max health setiap frame
	CreateConnection(RunService.Heartbeat, function()
		if not State.ImmortalActive then return end
		humanoid.Health = humanoid.MaxHealth
	end)
end

local function StopImmortality()
	State.ImmortalActive = false
end


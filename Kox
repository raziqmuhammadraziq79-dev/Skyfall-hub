CreateConnection(LocalPlayer.CharacterAdded, function(newChar)
	Character = newChar
	Humanoid = Character:WaitForChild("Humanoid")
	HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
	
	-- Restart active features
	if State.FlyActive then
		StopFly()
		task.wait(0.1)
		StartFly()
	end
	if State.NoclipActive then
		StopNoclip()
		task.wait(0.1)
		StartNoclip()
	end
	if State.HealthActive then
		StopInfiniteHealth()
		task.wait(0.1)
		StartInfiniteHealth()
	end
	if State.ImmortalActive then
		StopImmortality()
		task.wait(0.1)
		StartImmortality()
	end
end)


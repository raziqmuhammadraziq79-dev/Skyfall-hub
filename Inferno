-- ESP
local espObjects = {}
local espConn, espDistConn
local function SetESP(s)
    Hub.ESPEnabled = s
    if s then
        local function addESP(player)
            if player == LP then return end
            local function onChar(char)
                if not char then return end
                pcall(function()
                    local hrp = char:WaitForChild("HumanoidRootPart", 5)
                    if not hrp then return end
                    local box = Instance.new("BoxHandleAdornment")
                    box.Adornee = hrp
                    box.Size = Vector3.new(4, 5, 1)
                    box.AlwaysOnTop = true
                    box.Color3 = C.Accent
                    box.Transparency = 0.4
                    box.Parent = hrp
                    espObjects[#espObjects+1] = box
                    Track(box, "Color3")

                    local bb = Instance.new("BillboardGui")
                    bb.Adornee = hrp
                    bb.Size = UDim2.new(0, 140, 0, 50)
                    bb.StudsOffset = Vector3.new(0, 3, 0)
                    bb.AlwaysOnTop = true
                    bb.Parent = hrp

                    local nt = Instance.new("TextLabel", bb)
                    nt.Size = UDim2.new(1, 0, 0, 16)
                    nt.BackgroundTransparency = 1
                    nt.Text = player.Name
                    nt.TextColor3 = C.Accent
                    nt.TextSize = 12
                    nt.Font = Enum.Font.GothamBold
                    nt.TextStrokeTransparency = 0.2
                    Track(nt, "TextColor3")

                    local dt = Instance.new("TextLabel", bb)
                    dt.Name = "DistLabel"
                    dt.Size = UDim2.new(1, 0, 0, 14)
                    dt.Position = UDim2.new(0, 0, 0, 18)
                    dt.BackgroundTransparency = 1
                    dt.TextColor3 = C.TextSub
                    dt.TextSize = 10
                    dt.Font = Enum.Font.Gotham
                    dt.TextStrokeTransparency = 0.3

                    local ht = Instance.new("TextLabel", bb)
                    ht.Name = "HealthLabel"
                    ht.Size = UDim2.new(1, 0, 0, 14)
                    ht.Position = UDim2.new(0, 0, 0, 34)
                    ht.BackgroundTransparency = 1
                    ht.TextColor3 = C.Success
                    ht.TextSize = 10
                    ht.Font = Enum.Font.GothamBold
                    ht.TextStrokeTransparency = 0.3
                    espObjects[#espObjects+1] = bb
                end)
            end
            if player.Character then onChar(player.Character) end
            player.CharacterAdded:Connect(function(c) if Hub.ESPEnabled then onChar(c) end end)
        end
        for _, p in ipairs(Players:GetPlayers()) do addESP(p) end
        espConn = Players.PlayerAdded:Connect(addESP)
        espDistConn = RunService.Heartbeat:Connect(function()
            pcall(function()
                local myHRP = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                if not myHRP then return end
                for _, obj in ipairs(espObjects) do
                    if obj:IsA("BillboardGui") and obj.Adornee and obj.Adornee.Parent then
                        local dist = (myHRP.Position - obj.Adornee.Position).Magnitude
                        local distLbl = obj:FindFirstChild("DistLabel")
                        local healthLbl = obj:FindFirstChild("HealthLabel")
                        if distLbl then distLbl.Text = math.floor(dist) .. "m" end
                        if healthLbl then
                            local hum = obj.Adornee.Parent:FindFirstChild("Humanoid")
                            if hum then healthLbl.Text = math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth) end
                        end
                    end
                end
            end)
        end)
    else
        for _, o in ipairs(espObjects) do pcall(function() o:Destroy() end) end
        espObjects = {}
        if espConn then espConn:Disconnect(); espConn = nil end
        if espDistConn then espDistConn:Disconnect(); espDistConn = nil end
    end
end


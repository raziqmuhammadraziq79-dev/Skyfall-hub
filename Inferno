-- SWITCH TAB
local function SwitchTab(name)
    Hub.ActiveTab = name
    for tabName, data in pairs(NavButtons) do
        local active = tabName == name
        if active then
            pcall(function()
                data.btn.BackgroundTransparency = 0.1
                data.btn.BackgroundColor3 = Color3.fromRGB(35, 35, 48)
                data.indicator.Visible = true
                data.label.TextColor3 = C.Accent
                data.label.Font = Enum.Font.GothamBold
                data.icon.ImageColor3 = C.Accent
            end)
        else
            pcall(function()
                data.btn.BackgroundTransparency = 0.6
                data.btn.BackgroundColor3 = C.Card
                data.indicator.Visible = false
                data.label.TextColor3 = C.TextSub
                data.label.Font = Enum.Font.GothamMedium
                data.icon.ImageColor3 = C.TextSub
            end)
        end
        if TabContents[tabName] then TabContents[tabName].Visible = active end
    end
    HeaderTitle.Text = name
    for _, t in ipairs(TabDefs) do
        if t.name == name then HeaderIcon.Image = t.icon; break end
    end
    if name == "Players" then RefreshPlayerList() end
end


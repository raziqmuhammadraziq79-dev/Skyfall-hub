local function createToggle(name, default, layoutOrder, callback)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -6, 0, 36)
	btn.BackgroundColor3 = default and Color3.fromRGB(35, 20, 25) or Color3.fromRGB(15, 15, 18)
	btn.Text = name .. (default and " : ACTIVE" or " : OFF")
	btn.TextColor3 = default and Color3.fromRGB(255, 50, 120) or Color3.fromRGB(180, 180, 180)
	btn.Font = Enum.Font.SourceSansBold
	btn.TextSize = 14
	btn.LayoutOrder = layoutOrder
	btn.Parent = scrollingFrame
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 6)
	btnCorner.Parent = btn
	
	local active = default
	btn.MouseButton1Click:Connect(function()
		active = not active
		if active then
			btn.Text = name .. " : ACTIVE"
			btn.TextColor3 = Color3.fromRGB(255, 50, 120)
			btn.BackgroundColor3 = Color3.fromRGB(35, 20, 25)
		else
			btn.Text = name .. " : OFF"
			btn.TextColor3 = Color3.fromRGB(180, 180, 180)
			btn.BackgroundColor3 = Color3.fromRGB(15, 15, 18)
		end
		callback(active)
	end)
end

createToggle("FLIGHT CORE ENGINE (FIXED)", false, 1, function(bool) States.Fly = bool toggleFlightEngine(bool) end)

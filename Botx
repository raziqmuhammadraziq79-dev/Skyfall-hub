-------------------------------
-- CORNER BOX HELPER
-------------------------------
local function drawCorners(esp, bx, by, bw, bh, color)
    local cw, ch = bw*0.28, bh*0.28
    local corners = {
        {esp.CTL1,esp.CTL2, bx,      by,      cw,  ch,  1, 1},
        {esp.CTR1,esp.CTR2, bx+bw,   by,      -cw, ch,  1, 1},
        {esp.CBL1,esp.CBL2, bx,      by+bh,   cw,  -ch, 1, 1},
        {esp.CBR1,esp.CBR2, bx+bw,   by+bh,   -cw, -ch, 1, 1},
    }
    for _,c in pairs(corners) do
        c[1].From=Vector2.new(c[3],c[4]) c[1].To=Vector2.new(c[3]+c[5],c[4])
        c[2].From=Vector2.new(c[3],c[4]) c[2].To=Vector2.new(c[3],c[4]+c[6])
        c[1].Color=color c[2].Color=color
        c[1].Visible=true c[2].Visible=true
    end
end

-------------------------------
-- AIMBOT CORE
-------------------------------
local function getPredictedPos(player)
    local char = player.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local vel = hrp.AssemblyLinearVelocity
    local pred = hrp.Position + vel * 0.08
    return pred + Vector3.new(0, CFG.AimPart == "Head" and 1.5 or 0, 0)
end

local function getTarget()
    local sc = screenCenter()
    local bestPlayer = nil
    local bestScore = math.huge

    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        if not isEnemy(p) then continue end
        local char = p.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not char or not hum or not hrp or hum.Health <= 0 then continue end

        local d = distTo(hrp.Position)
        if d > CFG.MaxDistance then continue end

        local sp, onScreen = wp(hrp.Position + Vector3.new(0,1.5,0))
        if not onScreen then continue end

        local screenDist = (sp - sc).Magnitude
        if screenDist > CFG.AimbotFOV then continue end

        local score
        if CFG.PriorityMode == "LowestHP" then
            score = hum.Health
        else
            score = screenDist
        end

        if score < bestScore then
            bestScore = score
            bestPlayer = p
        end
    end
    return bestPlayer
end

local function doAimbot()
    if not CFG.Aimbot_Enabled then return end
    if not aimbotActive and not CFG.SilentAim then return end

    local target = getTarget()
    currentTarget = target
    if not target then return end

    local predicted = getPredictedPos(target)
    if not predicted then return end

    if CFG.SilentAim then
        -- Silent aim: redirect camera CFrame toward target silently
        local camCF = Camera.CFrame
        local dir = (predicted - camCF.Position).Unit
        local targetCF = CFrame.new(camCF.Position, camCF.Position + dir)
        Camera.CFrame = camCF:Lerp(targetCF, CFG.AimbotSmooth)
    else
        -- Hard aim
        local camCF = Camera.CFrame
        local dir = (predicted - camCF.Position).Unit
        local targetCF = CFrame.new(camCF.Position, camCF.Position + dir)
        Camera.CFrame = camCF:Lerp(targetCF, CFG.AimbotSmooth)
    end
end

-- Aimbot toggle input (touch = 2-finger tap / mouse = hold right click)
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        aimbotActive = true
    end
    if input.UserInputType == Enum.UserInputType.Touch then
        aimbotActive = true
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        aimbotActive = false
    end
    if input.UserInputType == Enum.UserInputType.Touch then
        aimbotActive = false
    end
end)


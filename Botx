local function updateESP()
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local esp = ESPObjects[player]
        if not esp then continue end

        local char   = player.Character
        local hum    = char and char:FindFirstChildOfClass("Humanoid")
        local hrp    = char and char:FindFirstChild("HumanoidRootPart")
        local head   = char and char:FindFirstChild("Head")

        if not CFG.ESP_Enabled or not char or not hrp or not hum or hum.Health <= 0 then
            for _,o in pairs(esp) do o.Visible = false end
            continue
        end

        local enemy = isEnemy(player)
        if (enemy and not CFG.ShowEnemy) or (not enemy and not CFG.ShowTeam) then
            for _,o in pairs(esp) do o.Visible = false end
            continue
        end

        local d = distTo(hrp.Position)
        if d > CFG.MaxDistance then
            for _,o in pairs(esp) do o.Visible = false end
            continue
        end

        local color = enemy and CFG.EnemyColor or CFG.TeamColor
        local tag   = enemy and " [ENEMY]" or " [TEAM]"
        local isTarget = (currentTarget == player) and CFG.ShowAimTarget

        local headSP, onScreen = wp(head and head.Position or hrp.Position + Vector3.new(0,1.5,0))
        local footSP           = wp(hrp.Position - Vector3.new(0,3,0))
        if not onScreen then
            for _,o in pairs(esp) do o.Visible = false end
            continue
        end

        local bh = math.abs(headSP.Y - footSP.Y)
        local bw = bh * 0.55
        local bx = headSP.X - bw/2
        local by = headSP.Y

        -- Name
        local nameColor = isTarget and CFG.AimTargetColor or color
        esp.NameTag.Text  = player.Name .. tag .. (isTarget and " ◎" or "")
        esp.NameTag.Color = nameColor
        esp.NameTag.Position = Vector2.new(headSP.X, by - 17)
        esp.NameTag.Visible = true

        -- Aim target label
        esp.AimTxt.Visible = isTarget
        if isTarget then
            esp.AimTxt.Position = Vector2.new(headSP.X, by - 30)
        end

        -- Health text
        if CFG.ShowHealth then
            local hp  = math.floor(hum.Health)
            local mhp = math.floor(hum.MaxHealth)
            local ratio = hp/mhp
            esp.HealthTxt.Text = "♥ "..hp.."/"..mhp
            esp.HealthTxt.Color = Color3.fromRGB(math.floor(255*(1-ratio)), math.floor(255*ratio), 0)
            esp.HealthTxt.Position = Vector2.new(headSP.X, by - 4)
            esp.HealthTxt.Visible = true
        else esp.HealthTxt.Visible = false end

        -- Distance
        if CFG.ShowDistance then
            esp.DistTxt.Text = math.floor(d).."m"
            esp.DistTxt.Position = Vector2.new(headSP.X, footSP.Y + 3)
            esp.DistTxt.Visible = true
        else esp.DistTxt.Visible = false end

        -- Box + corners
        if CFG.ShowBox then
            local bc = isTarget and CFG.AimTargetColor or nameColor
            esp.BT.From=Vector2.new(bx,by)       esp.BT.To=Vector2.new(bx+bw,by)       esp.BT.Visible=true
            esp.BB.From=Vector2.new(bx,by+bh)    esp.BB.To=Vector2.new(bx+bw,by+bh)    esp.BB.Visible=true
            esp.BL.From=Vector2.new(bx,by)       esp.BL.To=Vector2.new(bx,by+bh)       esp.BL.Visible=true
            esp.BR.From=Vector2.new(bx+bw,by)    esp.BR.To=Vector2.new(bx+bw,by+bh)    esp.BR.Visible=true
            drawCorners(esp, bx, by, bw, bh, bc)
        else
            for _,k in pairs({"BT","BB","BL","BR","CTL1","CTL2","CTR1","CTR2","CBL1","CBL2","CBR1","CBR2"}) do
                esp[k].Visible = false
            end
        end

        -- Health bar
        if CFG.ShowHealth then
            local ratio = hum.Health / hum.MaxHealth
            local barX = bx - 7
            esp.HpBG.From=Vector2.new(barX,by)      esp.HpBG.To=Vector2.new(barX,by+bh)         esp.HpBG.Visible=true
            esp.HpFG.From=Vector2.new(barX,by+bh)   esp.HpFG.To=Vector2.new(barX,by+bh-(bh*ratio))
            esp.HpFG.Color=Color3.fromRGB(math.floor(255*(1-ratio)),math.floor(255*ratio),0)     esp.HpFG.Visible=true
        else esp.HpBG.Visible=false esp.HpFG.Visible=false end

        -- Tracer
        if CFG.ShowTracers then
            esp.Tracer.From  = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
            esp.Tracer.To    = footSP
            esp.Tracer.Color = isTarget and CFG.AimTargetColor or color
            esp.Tracer.Visible = true
        else esp.Tracer.Visible = false end

        -- Snap
        if CFG.ShowSnapLine then
            esp.Snap.From    = Vector2.new(bx, by+bh)
            esp.Snap.To      = Vector2.new(bx+bw, by+bh)
            esp.Snap.Color   = CFG.SnapColor
            esp.Snap.Visible = true
        else esp.Snap.Visible = false end

        -- Head dot
        if CFG.ShowHeadDot then
            esp.HeadDot.Position = headSP
            esp.HeadDot.Color    = isTarget and CFG.AimTargetColor or color
            esp.HeadDot.Visible  = true
        else esp.HeadDot.Visible = false end

        -- Prediction dot
        if isTarget then
            local pred = getPredictedPos(player)
            if pred then
                local psp, pon = wp(pred)
                esp.PredDot.Position = psp
                esp.PredDot.Visible  = pon
            end
        else esp.PredDot.Visible = false end

        -- Chams
        if CFG.ShowChams then
            removeChams(char)
            applyChams(char, enemy and CFG.ChamsEnemy or CFG.ChamsTeam)
        end
    end
end


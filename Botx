-------------------------------
-- UTILITY
-------------------------------
local function wp(pos)
    local s, vis = Camera:WorldToViewportPoint(pos)
    return Vector2.new(s.X, s.Y), vis, s.Z
end

local function distTo(pos)
    local c = LocalPlayer.Character
    if not c or not c:FindFirstChild("HumanoidRootPart") then return math.huge end
    return (c.HumanoidRootPart.Position - pos).Magnitude
end

local function isEnemy(p)
    if not LocalPlayer.Team or not p.Team then return true end
    return p.Team ~= LocalPlayer.Team
end

local function newDraw(t, props)
    local o = Drawing.new(t)
    for k,v in pairs(props) do o[k]=v end
    return o
end

local function screenCenter()
    return Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
end

-------------------------------
-- CHAMS
-------------------------------
local function applyChams(char, color)
    for _, p in pairs(char:GetDescendants()) do
        if p:IsA("BasePart") then
            local existing = p:FindFirstChild("ESPCham")
            if existing then existing:Destroy() end
            local h = Instance.new("SelectionBox")
            h.Name = "ESPCham"
            h.Color3 = color
            h.LineThickness = 0.025
            h.SurfaceTransparency = 0.55
            h.SurfaceColor3 = color
            h.Adornee = p
            h.Parent = p
        end
    end
end

local function removeChams(char)
    if not char then return end
    for _, d in pairs(char:GetDescendants()) do
        if d.Name == "ESPCham" then d:Destroy() end
    end
end


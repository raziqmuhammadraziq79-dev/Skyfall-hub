        track.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                sliding = true
            end
        end)
        UIS.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                sliding = false
            end
        end)
        UIS.InputChanged:Connect(function(i)
            if sliding and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                local trackPos = track.AbsolutePosition.X
                local trackW   = track.AbsoluteSize.X
                local rel = math.clamp((i.Position.X - trackPos)/trackW, 0, 1)
                local val = math.floor(min + rel*(max-min))
                CFG[key] = val
                fill.Size = UDim2.new(rel,0,1,0)
                label.Text = lbl..": "..val
            end
        end)
    end

    -- Priority toggle
    local function addPriorityToggle()
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1,-16,0,32)
        row.BackgroundTransparency = 1
        row.Parent = scroll
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1,0,1,0)
        btn.BackgroundColor3 = Color3.fromRGB(80,0,120)
        btn.TextColor3 = Color3.fromRGB(255,255,255)
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 12
        btn.Text = "Priority: "..CFG.PriorityMode
        btn.Parent = row
        Instance.new("UICorner",btn).CornerRadius = UDim.new(0,6)
        btn.MouseButton1Click:Connect(function()
            CFG.PriorityMode = CFG.PriorityMode=="Nearest" and "LowestHP" or "Nearest"
            btn.Text = "Priority: "..CFG.PriorityMode
        end)
    end

    -- Build sections
    addSection("  ── ESP ──")
    addToggle("ESP Master",    "ESP_Enabled",  Color3.fromRGB(200,0,0))
    addToggle("Enemy ESP",     "ShowEnemy",    Color3.fromRGB(180,30,30))
    addToggle("Team ESP",      "ShowTeam",     Color3.fromRGB(0,140,50))
    addToggle("Box ESP",       "ShowBox",      Color3.fromRGB(50,50,180))
    addToggle("Tracers",       "ShowTracers",  Color3.fromRGB(180,80,0))
    addToggle("Health Bar",    "ShowHealth",   Color3.fromRGB(0,150,70))
    addToggle("Distance",      "ShowDistance", Color3.fromRGB(70,70,80))
    addToggle("Chams",         "ShowChams",    Color3.fromRGB(150,0,150))
    addToggle("Snap Line",     "ShowSnapLine", Color3.fromRGB(150,130,0))
    addToggle("Head Dot",      "ShowHeadDot",  Color3.fromRGB(200,40,40))
    addToggle("FOV Circle",    "ShowFOV",      Color3.fromRGB(70,70,80))
    addToggle("Target Label",  "ShowAimTarget",Color3.fromRGB(200,180,0))

    addSection("  ── AIMBOT ──")
    addToggle("Aimbot",        "Aimbot_Enabled", Color3.fromRGB(200,0,0))
    addToggle("Silent Aim",    "SilentAim",      Color3.fromRGB(120,0,160))
    addPriorityToggle()
    addSlider("Smooth",        "AimbotSmooth", 0.02, 0.5)  -- shown *100 feel
    addSlider("Aimbot FOV",    "AimbotFOV",    50,   400)
    addSlider("FOV Display",   "FOVRadius",    30,   300)
    addSlider("Max Distance",  "MaxDistance",  100,  2000)

    -- Minimize
    local minimized = false
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        scroll.Visible = not minimized
        main.Size = minimized and UDim2.new(0,240,0,36) or UDim2.new(0,240,0,560)
        minBtn.Text = minimized and "+" or "−"
    end)

    -- Close
    closeBtn.MouseButton1Click:Connect(function()
        CFG.ESP_Enabled = false
        CFG.Aimbot_Enabled = false
        fovCircle.Visible = false
        aimCircle.Visible = false
        gui:Destroy()
    end)
end


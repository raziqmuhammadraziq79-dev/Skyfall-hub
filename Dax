                        end
                    end
                    btn.BackgroundColor3 = THEME.ACCENT_DIM
                    btn.UIStroke.Color = THEME.ACCENT
                end)
                
                count = count + 1
            end
        end
        
        playerListContainer.Size = UDim2.new(1, 0, 0, math.max(count * 40, 100))

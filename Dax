-- [FAKE ADMIN ENGINE]
local function SendFakeAdminMessage(targetName, actionType, reason)
    local ChatRemote = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
    local message
    
    if actionType == "KICK" then
        message = string.format("[SERVER] ⚠️ Player %s has been KICKED\nReason: %s\nAdmin: Skyfall System", targetName, reason)
    elseif actionType == "BAN" then
        message = string.format("[SERVER] 🚫 Player %s has been PERMANENTLY BANNED\nReason: %s\nAppeal: DENIED", targetName, reason)
    elseif actionType == "MUTE" then
        message = string.format("[SERVER] 🔇 Player %s has been MUTED for 24h\nReason: %s", targetName, reason)
    elseif actionType == "WARN" then
        message = string.format("[SERVER] ⚠️ WARNING issued to %s\nReason: %s\nNext: Temporary Ban", targetName, reason)
    end
    
    pcall(function()
        if ChatRemote and ChatRemote:FindFirstChild("SayMessageRequest") then
            ChatRemote.SayMessageRequest:FireServer(message, "All")
        end
    end)
    
    -- Add to log
    if _G.AdminLogScroll then
        local logEntry = Instance.new("TextLabel")
        logEntry.Size = UDim2.new(1, 0, 0, 18)
        logEntry.BackgroundTransparency = 1
        logEntry.Text = "[" .. os.date("%H:%M") .. "] " .. actionType .. " → " .. targetName
        logEntry.TextColor3 = actionType == "BAN" and THEME.DANGER or THEME.WARNING
        logEntry.Font = TYPOGRAPHY.CAPTION.Font
        logEntry.TextSize = TYPOGRAPHY.CAPTION.Size
        logEntry.TextXAlignment = Enum.TextXAlignment.Left
        logEntry.Parent = _G.AdminLogScroll
    end
end

-- [DEVIL MORPH (PHYSICS-SAFE)]
local function ToggleMorph()
    if not Character then return end
    
    if Character:FindFirstChild("DevilMorphRoot") then
        -- Remove morph
        Character:FindFirstChild("DevilMorphRoot"):Destroy()
        for _, p in ipairs(Character:GetDescendants()) do
            if p:IsA("BasePart") and p:FindFirstChild("OriginalColor") then
                p.Color = p.OriginalColor.Value
                p.OriginalColor:Destroy()
            end
        end
        return
    end
    
    -- Save original colors and apply morph
    local morphRoot = Instance.new("Folder")
    morphRoot.Name = "DevilMorphRoot"
    morphRoot.Parent = Character
    
    for _, p in ipairs(Character:GetDescendants()) do
        if p:IsA("BasePart") and p.Name ~= "Handle" then
            local orig = Instance.new("Color3Value")
            orig.Name = "OriginalColor"
            orig.Value = p.Color
            orig.Parent = p
            p.Color = Color3.fromRGB(20, 5, 5)
            p.Material = Enum.Material.SmoothPlastic
        end
    end
    
    -- Horns
    local head = Character:FindFirstChild("Head")
    if head then
        for i, offset in ipairs({-0.5, 0.5}) do
            local horn = Instance.new("Part")
            horn.Name = "DevilHorn"
            horn.Size = Vector3.new(0.3, 1, 0.3)
            horn.Color = Color3.fromRGB(150, 0, 0)
            horn.Material = Enum.Material.Neon
            horn.CanCollide = false
            horn.Anchored = false
            horn.Parent = morphRoot
            
            local weld = Instance.new("WeldConstraint")
            weld.Part0 = head
            weld.Part1 = horn
            weld.Parent = horn
            
            horn.CFrame = head.CFrame * CFrame.new(offset, 0.8, 0) * CFrame.Angles(math.rad(15), 0, math.rad(offset * 30))
        end
    end
    
    -- Wings
    local torso = Character:FindFirstChild("UpperTorso") or Character:FindFirstChild("Torso")
    if torso then
        for i, side in ipairs({-1, 1}) do
            local wing = Instance.new("Part")
            wing.Name = "DevilWing"
            wing.Size = Vector3.new(0.1, 2.5, 1.8)
            wing.Color = Color3.fromRGB(80, 0, 0)
            wing.Material = Enum.Material.Neon
            wing.Transparency = 0.3
            wing.CanCollide = false
            wing.Anchored = false
            wing.Parent = morphRoot
            
            local weld = Instance.new("WeldConstraint")
            weld.Part0 = torso
            weld.Part1 = wing
            weld.Parent = wing
            
            wing.CFrame = torso.CFrame * CFrame.new(side * 1, 0.3, -0.5) * CFrame.Angles(0, math.rad(side * 20), 0)
        end
    end
end


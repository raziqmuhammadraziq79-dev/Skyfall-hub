-- EXTREME FPS BOOSTER MODULE (100+ TARGET)
-- ==========================================
local originalSettings = {}
local function ToggleExtremeFPS(state)
    Hub.FPSBoost = state
    pcall(function()
        if state then
            -- CACHE ORIGINAL SETTINGS
            originalSettings.Shadows = Lighting.GlobalShadows
            originalSettings.FogEnd = Lighting.FogEnd
            originalSettings.TerrainDetail = Workspace.Terrain.DetailLevel
            
            -- APPLY EXTREME OPTIMIZATIONS
            Lighting.GlobalShadows = false
            Lighting.FogEnd = 100000
            Workspace.Terrain.DetailLevel = Enum.TerrainDetailLevel.Level1 -- LOWEST DETAIL
            Workspace.Terrain.WaterWaveSize = 0
            Workspace.Terrain.WaterWaveSpeed = 0
            Workspace.Terrain.WaterReflectance = 0
            
            -- DISABLE ALL POST EFFECTS
            for _, effect in ipairs(Lighting:GetChildren()) do
                if effect:IsA("PostEffect") then
                    originalSettings[effect] = effect.Enabled
                    effect.Enabled = false
                end
            end
            
            -- FORCE RENDER DISTANCE REDUCTION (CLIENT SIDE ONLY)
            settings().Rendering.QualityLevel = 1
            
            SafeFPS(999)
        else
            -- RESTORE ORIGINAL SETTINGS
            Lighting.GlobalShadows = originalSettings.Shadows or true
            Lighting.FogEnd = originalSettings.FogEnd or 1000
            Workspace.Terrain.DetailLevel = originalSettings.TerrainDetail or Enum.TerrainDetailLevel.Level3
            
            for obj, enabled in pairs(originalSettings) do
                if typeof(obj) == "Instance" and obj:IsA("PostEffect") and obj.Parent then
                    obj.Enabled = enabled
                end
            end
            
            settings().Rendering.QualityLevel = 8
        end
    end)
end

-- RTX MODULE (CLIENT-SIDE ONLY)
local originalMaterials = {}
local rtxCC
local function ToggleRTX(state)
    Hub.RTXActive = state
    pcall(function()
        if not rtxCC then
            rtxCC = Instance.new("ColorCorrectionEffect")
            rtxCC.Name = "HyperionRTX_CC"
            rtxCC.Parent = Lighting
        end
        
        if state then
            rtxCC.Brightness = 0.05
            rtxCC.Contrast = 0.2
            rtxCC.Saturation = 0.15
            rtxCC.Enabled = true
            Lighting.Ambient = Color3.fromRGB(30, 30, 35)
            Lighting.OutdoorAmbient = Color3.fromRGB(45, 45, 50)
            
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj:IsA("BasePart") and not obj:IsDescendantOf(character) and obj.Transparency < 0.9 then
                    if not originalMaterials[obj] then
                        originalMaterials[obj] = {Material = obj.Material, Reflectance = obj.Reflectance}
                    end
                    obj.Material = Enum.Material.SmoothPlastic
                    obj.Reflectance = 0.1
                end
            end
        else
            rtxCC.Enabled = false
            Lighting.Ambient = Color3.fromRGB(128, 128, 128)
            for obj, props in pairs(originalMaterials) do
                if obj and obj.Parent then
                    obj.Material = props.Material
                    obj.Reflectance = props.Reflectance
                end
            end
            table.clear(originalMaterials)
        end
    end)
end


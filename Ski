local alignPos, alignOri, flyAttachment
local function SetupPhysics(char)
    pcall(function()
        if alignPos then alignPos:Destroy() end
        if alignOri then alignOri:Destroy() end
        if flyAttachment then flyAttachment:Destroy() end
        
        local hrp = char:WaitForChild("HumanoidRootPart")
        
        -- CREATE DEDICATED ATTACHMENT FOR ALIGNPOSITION TARGET
        flyAttachment = Instance.new("Attachment")
        flyAttachment.Name = "HyperionFlyTarget"
        flyAttachment.Parent = hrp
        
        alignPos = Instance.new("AlignPosition")
        alignPos.Name = "HyperionAlignPos"
        alignPos.Attachment0 = flyAttachment
        alignPos.MaxForce = 4000
        alignPos.Responsiveness = 30 -- HIGHER RESPONSIVENESS FOR MOBILE TOUCH
        alignPos.Parent = hrp
        
        alignOri = Instance.new("AlignOrientation")
        alignOri.Name = "HyperionAlignOri"
        alignOri.Attachment0 = flyAttachment
        alignOri.MaxTorque = 3000
        alignOri.Responsiveness = 30
        alignOri.Parent = hrp
    end)
end
SetupPhysics(character)


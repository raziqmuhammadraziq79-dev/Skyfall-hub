-- TOUCH BINDERS FOR VERTICAL MOVEMENT
local function BindTouch(button, dirValue)
    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            Hub.VerticalDir = dirValue
        end
    end)
    button.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            if Hub.VerticalDir == dirValue then Hub.VerticalDir = 0 end
        end
    end)
end
BindTouch(UpBtn, 1)
BindTouch(DownBtn, -1)

-- FIXED FLY PHYSICS LOOP
RunService.Heartbeat:Connect(function(dt)
    if not Hub.IsFlying or not rootPart or not humanoid or not alignPos or not flyAttachment then return end
    
    local moveDir = humanoid.MoveDirection
    
    -- AUTO-SPRINT MOMENTUM
    if moveDir.Magnitude > 0 or Hub.VerticalDir ~= 0 then
        Hub.CurrentSpeed = math.min(Hub.CurrentSpeed + (dt * Hub.BaseSpeed * 2.5), Hub.BaseSpeed * Hub.MaxMultiplier)
    else
        Hub.CurrentSpeed = Hub.BaseSpeed
    end
    
    local rawTarget = (moveDir * Hub.CurrentSpeed) + Vector3.new(0, Hub.VerticalDir * Hub.CurrentSpeed, 0)
    
    -- CRITICAL FIX: UPDATE ATTACHMENT WORLD CFRAME EVERY FRAME
    flyAttachment.WorldCFrame = rootPart.CFrame
    alignPos.Position = rootPart.Position + rawTarget
end)


-- ═══════════════ PLAYER SELECTOR ═══════════════
local SelectedPlr = nil
local PlayerListFrame = nil

local function UpdatePL(f)
    if not PlayerListFrame then return end
    for _, c in ipairs(PlayerListFrame:GetChildren()) do
        if c:IsA("GuiObject") and c.Name ~= "UIListLayout" then c:Destroy() end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            if not f or string.find(string.lower(p.Name), string.lower(f)) then
                local B = New("TextButton", {
                    Size = UDim2.new(1, 0, 0, 22),
                    BackgroundColor3 = SelectedPlr == p and CFG.Accent or CFG.BG,
                    Text = "  " .. p.Name,
                    TextColor3 = SelectedPlr == p and Color3.new(1, 1, 1) or CFG.Text,
                    TextSize = 10, Font = Enum.Font.GothamMedium,
                    TextXAlignment = Enum.TextXAlignment.Left, Parent = PlayerListFrame
                })
                New("UICorner", {CornerRadius = UDim.new(0, 3), Parent = B})
                B.MouseButton1Click:Connect(function()
                    SelectedPlr = p; UpdatePL(f); Log("Target: " .. p.Name)
                end)
            end
        end
    end
end


                H = (H + 0.003) % 1
                local NC = Color3.fromHSV(H, 1, 1)
                CFG.Accent = NC
                MainStroke.Color = NC
                FloatStroke.Color = NC
                FloatBtn.ImageColor3 = NC
                task.wait()
            end
        end)
        Log("RGB ON")
    end
end)


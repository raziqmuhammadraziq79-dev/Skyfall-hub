local function FindExitDoor()
    local ek = {"exit","escape","gate","end","finish","leave","win","victory","checkpoint","out"}
    local dk = {"door","portal","teleport","warp"}
    local cands = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Model") then
            local n = string.lower(obj.Name); local isE, pr = false, 0
            for _, k in ipairs(ek) do if string.find(n, k) then isE=true; pr=pr+10 end end
            for _, k in ipairs(dk) do if string.find(n, k) then isE=true; pr=pr+5 end end
            if isE then
                local pos = obj:IsA("Model") and obj:GetPivot().Position or obj.Position
                table.insert(cands, {obj=obj, pos=pos, dist=(pos-RootPart.Position).Magnitude, name=obj.Name, priority=pr})
            end
        end
    end
    table.sort(cands, function(a,b) return a.priority~=b.priority and a.priority>b.priority or a.dist<b.dist end)
    return cands[1]
end

local function GetGroundHeight(position)
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {Character}
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local result = Workspace:Raycast(Vector3.new(position.X, position.Y+200, position.Z), Vector3.new(0,-600,0), rp)
    if result then return result.Position.Y end
    for y = position.Y, position.Y-300, -10 do
        local r2 = Workspace:Raycast(Vector3.new(position.X,y,position.Z), Vector3.new(0,-10,0), rp)
        if r2 then return r2.Position.Y end
    end
    return 0
end


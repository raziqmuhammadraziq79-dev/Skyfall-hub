local function CreatePL(Pg)
    local B = New("Frame", {Size=UDim2.new(1,0,0,130), BackgroundColor3=CFG.BG3, BackgroundTransparency=0.4, Parent=Pg})
    New("UICorner", {CornerRadius=UDim.new(0,6), Parent=B})

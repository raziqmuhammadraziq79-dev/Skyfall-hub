-- RESPAWN HANDLER
LocalPlayer.CharacterAdded:Connect(function(char)
    Character=char; Humanoid=char:WaitForChild("Humanoid"); RootPart=char:WaitForChild("HumanoidRootPart"); Camera=Workspace.CurrentCamera; LastSafePos=RootPart.CFrame
    task.wait(0.5); ApplyStats()
    if PS.NoClipEnabled then Bind("NoClip",Enum.RenderPriority.Character.Value+1,function() for _,P in ipairs(Character:GetDescendants()) do if P:IsA("BasePart") then P.CanCollide=false end end end) end
    if PS.FlyEnabled then Humanoid.PlatformStand=true; Bind("Fly",Enum.RenderPriority.Character.Value+1,function() if PS.FlyEnabled and RootPart then local mv=Vector3.zero; local lk=Camera.CFrame.LookVector; local rt=Camera.CFrame.RightVector; if UserInputService:IsKeyDown(Enum.KeyCode.W) then mv=mv+lk end; if UserInputService:IsKeyDown(Enum.KeyCode.S) then mv=mv-lk end; if UserInputService:IsKeyDown(Enum.KeyCode.A) then mv=mv-rt end; if UserInputService:IsKeyDown(Enum.KeyCode.D) then mv=mv+rt end; if UserInputService:IsKeyDown(Enum.KeyCode.Space) then mv=mv+Vector3.new(0,1,0) end; if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then mv=mv-Vector3.new(0,1,0) end; RootPart.AssemblyLinearVelocity=mv.Magnitude>0 and mv.Unit*PS.FlySpeed or Vector3.zero end end) end
    if PS.FollowEnabled and FollowTarget then Bind("FollowPlayer",Enum.RenderPriority.Character.Value+1,function() if not PS.FollowEnabled or not FollowTarget then return end; local tc=FollowTarget.Character; if not tc or not tc:FindFirstChild("HumanoidRootPart") then return end; local tRP=tc.HumanoidRootPart; local tPos=tRP.Position; local myGY=GetGroundHeight(RootPart.Position); local hoverY=myGY+PS.FollowHeight; if hoverY>myGY+40 then hoverY=myGY+40 end; local tLook=tRP.CFrame.LookVector; local bo=-tLook*PS.FollowDistance; local fp=Vector3.new(tPos.X+bo.X,hoverY,tPos.Z+bo.Z); local d3=(RootPart.Position-fp).Magnitude; local sp=d3>50 and 0.35 or d3>20 and 0.2 or 0.12; local np=RootPart.Position:Lerp(fp,sp); local mv=(np-RootPart.Position)*15; RootPart.AssemblyLinearVelocity=Vector3.new(math.clamp(mv.X,-80,80),math.clamp(mv.Y,-40,40),math.clamp(mv.Z,-80,80)) end) end
    if PS.TrollHoverEnabled then Bind("TrollHover",Enum.RenderPriority.Character.Value+1,function() if PS.TrollHoverEnabled and RootPart and Humanoid and Humanoid.FloorMaterial==Enum.Material.Air then local gY=GetGroundHeight(RootPart.Position); local tY=gY+PS.HoverHeight; if tY>gY+30 then tY=gY+30 end; local cv=RootPart.AssemblyLinearVelocity; RootPart.AssemblyLinearVelocity=Vector3.new(cv.X,math.clamp((tY-RootPart.Position.Y)*5,-30,30),cv.Z) end end) end
    Log("RESPAWN: Stats re-applied!")
end)


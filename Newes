local function DetectExploits()
    local suspects = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hum = p.Character:FindFirstChild("Humanoid")
            local rp = p.Character:FindFirstChild("HumanoidRootPart")
            if hum and rp then
                local flags = {}
                if hum.WalkSpeed > 100 then table.insert(flags, "Speed("..math.floor(hum.WalkSpeed)..")") end
                if hum.MaxHealth > 500 or hum.Health > 500 then table.insert(flags, "InfHP("..math.floor(hum.Health)..")") end
                if hum.JumpPower > 150 then table.insert(flags, "JumpHack("..math.floor(hum.JumpPower)..")") end
                local gY = GetGroundHeight(rp.Position)
                if rp.Position.Y - gY > 25 then table.insert(flags, "Fly("..math.floor(rp.Position.Y-gY)..")") end
                local lp = p:GetAttribute("SF_LastPos")
                if lp and typeof(lp)=="Vector3" and (rp.Position-lp).Magnitude > 100 then
                    table.insert(flags, "TP("..math.floor((rp.Position-lp).Magnitude)..")")
                end
                p:SetAttribute("SF_LastPos", rp.Position)
                if #flags > 0 then table.insert(suspects, {Player=p, Flags=flags, Severity=#flags}) end
            end
        end
    end
    table.sort(suspects, function(a,b) return a.Severity > b.Severity end)
    return suspects
end


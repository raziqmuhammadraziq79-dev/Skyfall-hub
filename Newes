        BackgroundColor3=CFG.BG, BorderSizePixel=0, PlaceholderText="Search player...", PlaceholderColor3=CFG.Dim,
        Text="", TextColor3=CFG.Text, TextSize=9, Font=Enum.Font.GothamMedium, Parent=B})
    New("UICorner", {CornerRadius=UDim.new(0,5), Parent=Sb})
    local PLF = New("ScrollingFrame", {Size=UDim2.new(1,-16,0,48), Position=UDim2.new(0,8,0,46),
        BackgroundTransparency=1, CanvasSize=UDim2.new(0,0,0,0), ScrollBarThickness=2, ScrollBarImageColor3=CFG.Accent, Parent=B})
    local PLL = New("UIListLayout", {Padding=UDim.new(0,2), Parent=PLF})
    PLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() PLF.CanvasSize=UDim2.new(0,0,0,PLL.AbsoluteContentSize.Y+5) end)
    local SelLbl = New("TextLabel", {Size=UDim2.new(1,-16,0,24), Position=UDim2.new(0,8,1,-30),
        BackgroundColor3=CFG.BG, BorderSizePixel=0, Text="TARGET: None", TextColor3=CFG.Dim, TextSize=9, Font=Enum.Font.Code, TextXAlignment=Enum.TextXAlignment.Left, Parent=B})
    New("UICorner", {CornerRadius=UDim.new(0,5), Parent=SelLbl})
    local function UpdPL(f)
        for _,c in ipairs(PLF:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=LocalPlayer and (not f or string.find(string.lower(p.Name),string.lower(f or "")) or string.find(string.lower(p.DisplayName),string.lower(f or ""))) then
                local Bt = New("TextButton", {Size=UDim2.new(1,0,0,22), BackgroundColor3=SelectedPlr==p and CFG.Accent or CFG.BG,
                    Text=" "..p.DisplayName.." (@"..p.Name..")", TextColor3=SelectedPlr==p and Color3.new(1,1,1) or CFG.Text,
                    TextSize=9, Font=Enum.Font.GothamMedium, TextXAlignment=Enum.TextXAlignment.Left, TextTruncate=Enum.TextTruncate.AtEnd, Parent=PLF})
                New("UICorner", {CornerRadius=UDim.new(0,5), Parent=Bt})
                Bt.MouseButton1Click:Connect(function() SelectedPlr=p; UpdPL(f); SelLbl.Text="TARGET: "..p.DisplayName.." (@"..p.Name..")"; SelLbl.TextColor3=CFG.Green end)
            end
        end
    end
    Sb:GetPropertyChangedSignal("Text"):Connect(function() UpdPL(Sb.Text) end)
    UpdPL("")
    Players.PlayerAdded:Connect(function() task.wait(0.5) UpdPL(Sb.Text) end)
    Players.PlayerRemoving:Connect(function() task.wait(0.5) UpdPL(Sb.Text) end)
    return PLF, SelLbl
end


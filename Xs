end

function UI:slider(scroll, name, min, max, cb)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, -20, 0, 65)
    f.BackgroundColor3 = Color3.fromRGB(25, 25, 45)
    f.BorderSizePixel = 0
    f.Parent = scroll
    
    local fc = Instance.new("UICorner")
    fc.CornerRadius = UDim.new(0, 8)
    fc.Parent = f
    
    local lbl = Instance.new("TextLabel")
    lbl.Text = "• " .. name .. ": " .. min
    lbl.TextColor3 = Color3.fromRGB(200, 200, 220)
    lbl.TextSize = 11
    lbl.Font = Enum.Font.GothamBold
    lbl.Size = UDim2.new(1, -20, 0, 20)
    lbl.Position = UDim2.new(0, 10, 0, 5)
    lbl.BackgroundTransparency = 1
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = f
    
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, -20, 0, 8)
    bg.Position = UDim2.new(0, 10, 0, 30)
    bg.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    bg.BorderSizePixel = 0
    bg.Parent = f
    
    local bgc = Instance.new("UICorner")
    bgc.CornerRadius = UDim.new(0, 4)
    bgc.Parent = bg
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = CFG.THEME
    fill.BorderSizePixel = 0
    fill.Parent = bg
    
    local fillc = Instance.new("UICorner")
    fillc.CornerRadius = UDim.new(0, 4)
    fillc.Parent = fill
    
    local btn = Instance.new("Frame")
    btn.Size = UDim2.new(0, 14, 0, 14)
    btn.Position = UDim2.new(0, -7, 0.5, -7)
    btn.BackgroundColor3 = CFG.THEME
    btn.BorderSizePixel = 0
    btn.Parent = bg
    
    local btnc = Instance.new("UICorner")
    btnc.CornerRadius = UDim.new(0, 7)
    btnc.Parent = btn
    
    local val = min
    local drag = false
    
    local function upd(mx)
        local pos = bg.AbsolutePosition.X
        local size = bg.AbsoluteSize.X
        local rel = math.clamp(mx - pos, 0, size)
        local pct = size > 0 and rel / size or 0
        val = math.floor(min + pct * (max - min))
        fill.Size = UDim2.new(pct, 0, 1, 0)
        btn.Position = UDim2.new(pct, -7, 0.5, -7)
        lbl.Text = "• " .. name .. ": " .. val
        safe(cb, val)
    end
    
    btn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
    UserInputService.InputChanged:Connect(function(i) if drag and i.UserInputType == Enum.UserInputType.MouseMovement then upd(UserInputService:GetMouseLocation().X) end end)
end

function UI:section(scroll, name)
    local lbl = Instance.new("TextLabel")
    lbl.Text = "━━━ " .. name .. " ━━━"
    lbl.TextColor3 = CFG.THEME
    lbl.TextSize = 11
    lbl.Font = Enum.Font.GothamBold
    lbl.Size = UDim2.new(1, -20, 0, 25)
    lbl.BackgroundTransparency = 1
    lbl.Parent = scroll
end

-- INIT
local function init()
    log("Loading...")
    
    F.power(true)
    
    local scroll = UI:create()
    
    UI:section(scroll, "CORE")
    UI:toggle(scroll, "God Mode", function(s) F.god(s) end)
    UI:toggle(scroll, "Infinite Jump", function(s) F.jump(s) end)
    UI:toggle(scroll, "Noclip", function(s) F.clip(s) end)
    UI:toggle(scroll, "Fly", function(s) F.fly(s) end)
    
    UI:section(scroll, "COMBAT")
    UI:toggle(scroll, "Aimbot", function(s) F.aim(s) end)
    
    UI:section(scroll, "STATS")
    UI:slider(scroll, "Walk Speed", 16, 150, function(v) F.speed(v) end)
    UI:slider(scroll, "Jump Power", 50, 200, function(v) F.power(v) end)
    
    UI:section(scroll, "VISION")
    UI:toggle(scroll, "ESP", function(s) F.esp(s) end)
    UI:slider(scroll, "ESP Distance", 100, 1000, function(v) STATE.espDist = v end)
    
    UI:section(scroll, "PLAYER")
    UI:toggle(scroll, "Invisibility", function(s) F.invis(s) end)
    
    log("✓ LOADED v" .. CFG.VER)
end


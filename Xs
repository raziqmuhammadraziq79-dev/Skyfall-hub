	btn.BorderColor3 = THEME.Border
	btn.BorderSizePixel = 1
	btn.Parent = sidebar
	sidebarButtons[cat.key] = btn
	btn.MouseButton1Click:Connect(function()
		currentPage = cat.key
		for key, b in pairs(sidebarButtons) do
			b.BackgroundColor3 = (key == currentPage) and THEME.Accent or THEME.Dark
			b.TextColor3 = (key == currentPage) and Color3.fromRGB(0, 0, 0) or THEME.Text
		end
		renderPage(currentPage)
	end)
end

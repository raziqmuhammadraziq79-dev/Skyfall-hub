-- 15. Anti-Grab (Break free from grabs)
local function fAntiGrab(v) S.AntiGrab=v dC("AG")
    if v then aC("AG",RunService.Heartbeat:Connect(function()
        local h=gH() if h then
            if h:GetState()==Enum.HumanoidStateType.Physics then
                h:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
            -- Break welds
            local c=LP.Character if c then
                for _,w in ipairs(c:GetDescendants()) do
                    if w:IsA("Weld") or w:IsA("WeldConstraint") then
                        if w.Part0 and not w.Part0:IsDescendantOf(c) then
                            w:Destroy()
                        end
                    end
                end
            end
        end
    end)) end
end


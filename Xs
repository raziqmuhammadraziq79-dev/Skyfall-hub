local game = game
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local LP = Players.LocalPlayer
if not LP then return end

local Char = LP.Character or LP.CharacterAdded:Wait()
local Hum = Char:WaitForChild("Humanoid")
local Root = Char:WaitForChild("HumanoidRootPart")

-- CONFIG
local CFG = {
    VER = "5.0.0",
    NAME = "SKYFALL",
    THEME = Color3.fromRGB(100, 200, 255),
    DARK = Color3.fromRGB(15, 15, 30),
}

local STATE = {
    god = false,
    jump = false,
    clip = false,
    fly = false,
    aim = false,
    esp = false,
    invis = false,
    speed = 16,
    power = 50,
    espDist = 500,
}

local CONS = {}

-- UTILS
local function safe(f, ...)
    if type(f) ~= "function" then return end
    pcall(f, ...)
end

local function log(m)
    print("[SKYFALL] " .. m)
end

local function conn(e, c)
    if not e or type(c) ~= "function" then return end
    local x = e:Connect(c)
    table.insert(CONS, x)
end

-- FEATURES
local F = {}

function F.god(s)
    STATE.god = s
    if not s then return end
    conn(RunService.Heartbeat, function()
        if STATE.god and Hum then
            if Hum.Health <= 0 then
                Hum.Health = Hum.MaxHealth
            end
        end
    end)
end

function F.jump(s)
    STATE.jump = s
    if not s then return end
    conn(UserInputService.InputBegan, function(i, g)
        if g then return end
        if i.KeyCode == Enum.KeyCode.Space and STATE.jump then
            safe(function() Hum:ChangeState(Enum.HumanoidStateType.Jumping) end)
        end
    end)
end

function F.clip(s)
    STATE.clip = s
    conn(RunService.Heartbeat, function()
        if not STATE.clip then return end
        safe(function()
            for _, p in pairs(Char:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
        end)
    end)
end

function F.fly(s)
    STATE.fly = s
    if not s then return end
    
    local spd = 50
    local dir = Vector3.new(0, 0, 0)
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Parent = Root
    
    conn(UserInputService.InputBegan, function(i, g)
        if g then return end
        if i.KeyCode == Enum.KeyCode.W then dir = dir + Root.CFrame.LookVector
        elseif i.KeyCode == Enum.KeyCode.S then dir = dir - Root.CFrame.LookVector
        elseif i.KeyCode == Enum.KeyCode.A then dir = dir - Root.CFrame.RightVector
        elseif i.KeyCode == Enum.KeyCode.D then dir = dir + Root.CFrame.RightVector
        elseif i.KeyCode == Enum.KeyCode.Space then dir = dir + Vector3.new(0, 1, 0)
        elseif i.KeyCode == Enum.KeyCode.LeftControl then dir = dir - Vector3.new(0, 1, 0) end
    end)
    
    conn(RunService.RenderStepped, function()
        if STATE.fly then
            bv.Velocity = dir.Unit * spd
        else
            safe(function() bv:Destroy() end)
        end
    end)
end

function F.aim(s)
    STATE.aim = s
    if not s then return end
    conn(RunService.RenderStepped, function()
        if not STATE.aim then return end
        local closest, closestDist = nil, 500
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then
                local h = p.Character:FindFirstChild("HumanoidRootPart")
                if h then
                    local d = (Root.Position - h.Position).Magnitude
                    if d < closestDist then closestDist = d; closest = p end
                end
            end
        end
        if closest and closest.Character then
            local h = closest.Character:FindFirstChild("HumanoidRootPart")
            if h then Root.CFrame = CFrame.new(Root.Position, h.Position + h.CFrame.LookVector * 5) end
        end
    end)
end

function F.esp(s)
    STATE.esp = s
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local h = p.Character:FindFirstChild("HumanoidRootPart")
            if h then
                local old = h:FindFirstChild("ESP")
                if old then old:Destroy() end
                if s then
                    local bb = Instance.new("BillboardGui")
                    bb.Name = "ESP"
                    bb.Size = UDim2.new(4, 0, 4, 0)
                    bb.MaxDistance = STATE.espDist
                    bb.Parent = h
                    local t = Instance.new("TextLabel")
                    t.BackgroundTransparency = 1
                    t.Size = UDim2.new(1, 0, 1, 0)
                    t.Text = p.Name
                    t.TextColor3 = Color3.fromRGB(0, 255, 150)
                    t.TextSize = 12
                    t.Font = Enum.Font.GothamBold
                    t.Parent = bb
                end
            end
        end
    end
end

function F.invis(s)
    STATE.invis = s
    safe(function()
        for _, p in pairs(Char:GetDescendants()) do
            if p:IsA("BasePart") then p.Transparency = s and 0.8 or 0 end
        end
    end)
end

function F.speed(v)
    STATE.speed = v
    safe(function() if Hum then Hum.WalkSpeed = v end end)
end

function F.power(v)
    STATE.power = v
    safe(function() if Hum then Hum.JumpPower = v end end)
end


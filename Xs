local function ToggleDevilMorph()
    if not Char then return end

    if Char:FindFirstChild("DevilMorphRoot") then
        Char:FindFirstChild("DevilMorphRoot"):Destroy()
        return
    end

    local morphRoot = Instance.new("Folder")
    morphRoot.Name = "DevilMorphRoot"
    morphRoot.Parent = Char

    -- Horns
    local head = Char:FindFirstChild("Head")
    if head then
        for _, offset in ipairs({-0.4, 0.4}) do
            local horn = Instance.new("Part")
            horn.Name = "DevilHorn"
            horn.Size = Vector3.new(0.25, 0.9, 0.25)
            horn.Color = Color3.fromRGB(140, 0, 0)
            horn.Material = Enum.Material.Neon
            horn.CanCollide = false
            horn.Anchored = false
            horn.Parent = morphRoot

            local tag = Instance.new("BoolValue")
            tag.Name = "IsMorphPart"
            tag.Parent = horn

            local weld = Instance.new("WeldConstraint")
            weld.Part0 = head
            weld.Part1 = horn
            weld.Parent = horn
            horn.CFrame = head.CFrame * CFrame.new(offset, 0.7, 0) * CFrame.Angles(math.rad(20), 0, math.rad(offset * 40))
        end
    end

    -- Wings
    local torso = Char:FindFirstChild("UpperTorso") or Char:FindFirstChild("Torso")
    if torso then
        for _, side in ipairs({-1, 1}) do
            local wing = Instance.new("Part")
            wing.Name = "DevilWing"
            wing.Size = Vector3.new(0.08, 2.2, 1.5)
            wing.Color = Color3.fromRGB(80, 0, 0)
            wing.Material = Enum.Material.Neon
            wing.Transparency = 0.35
            wing.CanCollide = false
            wing.Anchored = false
            wing.Parent = morphRoot

            local tag = Instance.new("BoolValue")
            tag.Name = "IsMorphPart"
            tag.Parent = wing

            local weld = Instance.new("WeldConstraint")
            weld.Part0 = torso
            weld.Part1 = wing
            weld.Parent = wing
            wing.CFrame = torso.CFrame * CFrame.new(side * 0.9, 0.2, -0.4) * CFrame.Angles(0, math.rad(side * 25), 0)
        end
    end
end


-- ============================================
-- UI UTILITIES
-- ============================================
local function corner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 6)
    c.Parent = p
    return c
end

local function stroke(p, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or D.BORDER
    s.Thickness = thickness or 1
    s.Parent = p
    return s
end

-- ============================================
-- TOGGLE SWITCH (FIXED - PROPER SIZING)
-- ============================================
local function createToggle(parent, name, stateKey, callback)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 36)
    row.BackgroundColor3 = D.BG_CARD
    row.Parent = parent
    corner(row, 6)

    -- Left accent line
    local accent = Instance.new("Frame")
    accent.Size = UDim2.new(0, 3, 0.55, 0)
    accent.Position = UDim2.new(0, 0, 0.225, 0)
    accent.BackgroundColor3 = States[stateKey] and D.ACCENT or D.ACCENT_DIM
    accent.Parent = row
    corner(accent, 2)

    -- Label
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -65, 1, 0)
    lbl.Position = UDim2.new(0, 14, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = name
    lbl.TextColor3 = D.TEXT
    lbl.Font = Enum.Font.GothamMedium
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = row

    -- Toggle track
    local track = Instance.new("Frame")
    track.Size = UDim2.new(0, 38, 0, 20)
    track.Position = UDim2.new(1, -50, 0.5, -10)
    track.BackgroundColor3 = States[stateKey] and D.TOGGLE_ON or D.TOGGLE_OFF
    track.Parent = row
    corner(track, 10)

    -- Toggle knob
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = States[stateKey] and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.Parent = track
    corner(knob, 8)

    -- Click zone
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = row

    btn.MouseButton1Click:Connect(function()
        States[stateKey] = not States[stateKey]
        local targetPos = States[stateKey] and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
        local targetCol = States[stateKey] and D.TOGGLE_ON or D.TOGGLE_OFF
        TweenService:Create(knob, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Position = targetPos}):Play()
        TweenService:Create(track, TweenInfo.new(0.2), {BackgroundColor3 = targetCol}):Play()
        accent.BackgroundColor3 = States[stateKey] and D.ACCENT or D.ACCENT_DIM
        if callback then callback(States[stateKey]) end
    end)

    return row
end


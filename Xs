-- 2. Anti-Fling (Resist velocity changes)
local function fAntiFling(v) S.AntiFling=v dC("AF")
    if v then aC("AF",RunService.Heartbeat:Connect(function()
        local r=gR() if r then
            r.AssemblyLinearVelocity=Vector3.new(0,r.AssemblyLinearVelocity.Y,0)
            r.AssemblyAngularVelocity=Vector3.zero
        end
    end)) end
end

-- 3. Anti-Kill Loop (Detect dan counter kill scripts)
local function fAntiKill(v) S.AntiKill=v dC("AK")
    if v then aC("AK",RunService.Heartbeat:Connect(function()
        local h=gH() if h and h.Health<1 then
            h.Health=h.MaxHealth
            pcall(function()
                for _,rem in ipairs(game:GetDescendants()) do
                    if rem:IsA("RemoteEvent") and rem.Name:lower():find("kill") then
                        rem:FireServer("cancel")
                    end
                end
            end)
        end
    end)) end
end

-- 4. Position Lock (Anti-Teleport)
local savedPos
local function fPosLock(v) S.PosLock=v dC("PL")
    if v then
        savedPos=gR() and gR().CFrame
        aC("PL",RunService.Heartbeat:Connect(function()
            local r=gR() if r and savedPos then
                if (r.Position-savedPos.Position).Magnitude>100 then
                    r.CFrame=savedPos
                end
            end
        end))
    end
end


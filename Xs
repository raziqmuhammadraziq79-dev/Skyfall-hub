-- INVISIBLE MODE
-- ═══════════════════════════════════════════════════════════

function SetInvisible(state)
    local char = Player.Character
    if not char then return end
    
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            if state then
                part.Transparency = 1
            else
                if part.Parent:FindFirstChild("Humanoid") then
                    part.Transparency = 0
                end
            end
        end
    end
end


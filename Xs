-- Noclip
local function fNoclip(v) S.Noclip=v dC("NC")
    if v then aC("NC",RunService.Stepped:Connect(function()
        local c=LP.Character if c then
            for _,p in ipairs(c:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide=false end
            end
        end
    end)) end
end

-- Infinite Jump
local function fInfJump(v) S.InfJump=v dC("IJ")
    if v then aC("IJ",UIS.JumpRequest:Connect(function()
        local h=gH() if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
    end)) end
end

-- Fly
local fbv,fbg
local function fFly(v) S.Fly=v dC("Fly")
    local h,r=gH(),gR()
    if v and h and r then
        h.PlatformStand=true
        fbv=Instance.new("BodyVelocity") fbv.MaxForce=Vector3.new(1e9,1e9,1e9) fbv.Parent=r
        fbg=Instance.new("BodyGyro") fbg.MaxTorque=Vector3.new(1e9,1e9,1e9) fbg.P=10000 fbg.Parent=r
        aC("Fly",RunService.RenderStepped:Connect(function()
            local cam=WS.CurrentCamera local d=Vector3.zero
            if UIS:IsKeyDown(Enum.KeyCode.W) then d+=cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S) then d-=cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A) then d-=cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D) then d+=cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then d+=Vector3.yAxis end
            if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then d-=Vector3.yAxis end
            fbv.Velocity=(d.Magnitude>0 and d.Unit or d)*S.FlySpd
            fbg.CFrame=CFrame.lookAt(Vector3.zero,cam.CFrame.LookVector)
        end))
    else
        if fbv then fbv:Destroy() fbv=nil end
        if fbg then fbg:Destroy() fbg=nil end
        if h then h.PlatformStand=false end
    end
end


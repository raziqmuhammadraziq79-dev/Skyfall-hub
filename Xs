-- COMBAT LOOPS (KILL AURA FIXED)
-- ============================================
local function InitLoops()
    -- Anti-fling
    task.spawn(function()
        while true do
            task.wait()
            if States.AntiFling and Root and Root.Parent then
                if Root.Velocity.Magnitude > 150 then
                    Root.Velocity = Vector3.zero
                    Root.RotVelocity = Vector3.zero
                end
            end
        end
    end)

    -- Infinite ammo
    task.spawn(function()
        while true do
            task.wait(0.2)
            if States.InfAmmo and LocalPlayer.Character then
                for _, c in ipairs({LocalPlayer.Backpack, LocalPlayer.Character}) do
                    for _, t in ipairs(c:GetChildren()) do
                        if t:IsA("Tool") then
                            for _, v in ipairs(t:GetDescendants()) do
                                if v:IsA("IntValue") and v.Name:lower():match("ammo|mag|clip") then v.Value = 9999 end
                            end
                        end
                    end
                end
            end
        end
    end)

    -- KILL AURA (WORKING - ACTUAL DAMAGE)
    task.spawn(function()
        while true do
            task.wait(0.1)
            if States.KillAura and Root and Root.Parent then
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character then
                        local targetRoot = p.Character:FindFirstChild("HumanoidRootPart")
                        local targetHum = p.Character:FindFirstChildOfClass("Humanoid")
                        if targetRoot and targetHum and targetHum.Health > 0 then
                            local dist = (targetRoot.Position - Root.Position).Magnitude
                            if dist < 15 then -- 15 stud radius
                                -- Damage the target
                                targetHum:TakeDamage(25) -- 25 damage per tick
                            end
                        end
                    end
                end
            end
        end
    end)

    -- ESP
    task.spawn(function()
        local espGui = Instance.new("ScreenGui")
        espGui.Name = "SkyfallESP_v20"
        espGui.ResetOnSpawn = false
        espGui.Parent = game:GetService("CoreGui")

        while true do
            task.wait(0.1)
            local showESP = (States.PlayerESP or States.DevilESP or States.WeaponESP)
            if not showESP then
                for _, c in ipairs(espGui:GetChildren()) do c:Destroy() end
                continue
            end
            for _, c in ipairs(espGui:GetChildren()) do c:Destroy() end

            local cam = Workspace.CurrentCamera
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                    local hum = p.Character:FindFirstChildOfClass("Humanoid")
                    if hrp and hum and hum.Health > 0 then
                        local pos, on = cam:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
                        if on then
                            local box = Instance.new("Frame")
                            box.Size = UDim2.new(0, 30, 0, 44)
                            box.Position = UDim2.new(0, pos.X - 15, 0, pos.Y - 22)
                            box.BackgroundColor3 = States.DevilESP and D.ACCENT or D.ACCENT_CYAN
                            box.BackgroundTransparency = 0.5
                            box.Parent = espGui
                            corner(box, 3)
                            stroke(box, States.DevilESP and Color3.fromRGB(255, 80, 100) or Color3.fromRGB(100, 220, 255), 1)

                            local txt = Instance.new("TextLabel")
                            txt.Size = UDim2.new(0, 70, 0, 12)
                            txt.Position = UDim2.new(0, pos.X - 35, 0, pos.Y + 24)
                            txt.BackgroundTransparency = 1
                            txt.Text = p.DisplayName or p.Name
                            txt.TextColor3 = D.TEXT
                            txt.Font = Enum.Font.GothamBold
                            txt.TextSize = 8
                            txt.TextStrokeTransparency = 0
                            txt.TextStrokeColor3 = Color3.new(0, 0, 0)
                            txt.Parent = espGui

                            -- Tracers
                            if States.Tracers then
                                local center = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y)
                                local target = Vector2.new(pos.X, pos.Y)
                                local dist = (target - center).Magnitude
                                local angle = math.atan2(target.Y - center.Y, target.X - center.X)
                                local line = Instance.new("Frame")
                                line.Size = UDim2.new(0, 1, 0, dist)
                                line.BackgroundColor3 = D.ACCENT
                                line.BackgroundTransparency = 0.6
                                line.AnchorPoint = Vector2.new(0.5, 0)
                                line.Position = UDim2.new(0, center.X, 0, center.Y)
                                line.Rotation = math.deg(angle)
                                line.Parent = espGui
                            end
                        end
                    end
                end
            end
        end
    end)

    -- Fullbright
    task.spawn(function()
        while true do
            task.wait(0.5)
            if States.Fullbright then
                local lighting = game:GetService("Lighting")
                lighting.Brightness = 2
                lighting.ClockTime = 14
                lighting.FogEnd = 100000
                lighting.GlobalShadows = false
            end
        end
    end)

    -- Aura
    task.spawn(function()
        while true do
            task.wait(0.5)
            if States.RedAura and Root and Root.Parent then
                if not Root:FindFirstChild("DevilAura") then
                    local aura = Instance.new("ParticleEmitter")
                    aura.Name = "DevilAura"
                    aura.Color = ColorSequence.new(Color3.fromRGB(220, 20, 60))
                    aura.LightEmission = 1
                    aura.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.4), NumberSequenceKeypoint.new(1, 0)})
                    aura.Lifetime = NumberRange.new(1, 2)
                    aura.Rate = 25
                    aura.Speed = NumberRange.new(2, 4)
                    aura.Parent = Root
                end
            else
                if Root and Root:FindFirstChild("DevilAura") then Root.DevilAura:Destroy() end
            end
        end
    end)

    -- NoClip
    task.spawn(function()
        while true do
            task.wait()
            if States.NoClip and Char then
                for _, p in ipairs(Char:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
        end
    end)

    -- Anti-AFK
    task.spawn(function()
        while true do
            task.wait(60)
            if States.AntiAFK then
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new())
            end
        end
    end)
end


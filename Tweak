-- Premium Button Creator
local function createPremiumBtn(parent, name, text, yPos, callback)
    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(1, -20, 0, 50)
    Container.Position = UDim2.new(0, 10, 0, yPos)
    Container.BackgroundTransparency = 1
    Container.Parent = parent

    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, 0, 1, 0)
    Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    Btn.BorderSizePixel = 0
    Btn.Text = text
    Btn.TextColor3 = CONFIG.TextColor
    Btn.Font = CONFIG.Font
    Btn.TextSize = 14
    Btn.AutoButtonColor = false
    Btn.Parent = Container

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 6)
    BtnCorner.Parent = Btn

    -- Touch/Mouse Effects
    local function onHover() Btn.BackgroundColor3 = Color3.fromRGB(55, 55, 60) end
    local function onLeave() Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 50) end
    
    Btn.MouseEnter:Connect(onHover)
    Btn.MouseLeave:Connect(onLeave)
    Btn.MouseButton1Click:Connect(callback)
    
    -- Restore visibility logic
    MinBtn.MouseButton1Click:Connect(function()
        MainFrame:TweenPosition(UDim2.new(0.5, -190, 0.5, -250), "Out", "Quad", 0.5, true)
        MinBtn.Visible = false
    end)
end


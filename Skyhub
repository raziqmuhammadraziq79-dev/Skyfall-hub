    Fly = {Start = StartFly, Stop = StopFly},
    Fling = FlingPlayer,
    FlingAll = FlingAll,
    Kill = KillPlayer,
    KillAll = KillAll,
    Speed = ToggleSpeed,
    God = ToggleGod,
    NoClip = ToggleNoClip,
    Config = Config
}

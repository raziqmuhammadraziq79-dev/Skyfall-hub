    targetLabel.Parent = scroll
    
    local targetFrame = Instance.new("Frame")
    targetFrame.Size = UDim2.new(0.95, 0, 0, 100)
    targetFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    targetFrame.Parent = scroll
    
    local tfc = Instance.new("UICorner")
    tfc.CornerRadius = UDim.new(0, 10)
    tfc.Parent = targetFrame
    
    local targetScroll = Instance.new("ScrollingFrame")
    targetScroll.Size = UDim2.new(1, -10, 1, -10)
    targetScroll.Position = UDim2.new(0, 5, 0, 5)
    targetScroll.BackgroundTransparency = 1
    targetScroll.ScrollBarThickness = 2
    targetScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    targetScroll.Parent = targetFrame
    
    local targetList = Instance.new("UIListLayout")
    targetList.Padding = UDim.new(0, 3)
    targetList.Parent = targetScroll
    

local Lighting = game:GetService("Lighting")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

--// CONFIG
getgenv().Skyfall = {
    FlySpeed = 5,
    FlyEnabled = false,
    FlingPower = 999999,
    KillTarget = nil,
    SpeedHack = false,
    WalkSpeed = 100,
    ESP = false,
    GodMode = false,
    NoClip = false,
    Aimbot = false,
    FullBright = false
}

local Config = getgenv().Skyfall
local State = {
    Connections = {},
    BodyMovers = {},
    UI = nil,
    JoystickDir = Vector3.zero
}

--// UTILITIES
local function GetChar(plr)
    plr = plr or LocalPlayer
    return plr and plr.Character
end

local function GetRoot(plr)
    local c = GetChar(plr)
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function GetHum(plr)
    local c = GetChar(plr)
    return c and c:FindFirstChildOfClass("Humanoid")
end

local function Notify(title, text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "☢️ " .. title,
            Text = text,
            Duration = 3
        })
    end)
end

--// FLY
local function StartFly()
    if Config.FlyEnabled then return end
    Config.FlyEnabled = true
    
    local root = GetRoot()
    local hum = GetHum()
    if not (root and hum) then return end
    
    Workspace.Gravity = 0
    hum.WalkSpeed = 0
    hum.JumpPower = 0
    
    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bg.P = 25000
    bg.CFrame = root.CFrame
    bg.Parent = root
    
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bv.Velocity = Vector3.zero
    bv.Parent = root
    
    State.BodyMovers.Gyro = bg
    State.BodyMovers.Vel = bv
    
    State.Connections.Fly = RunService.RenderStepped:Connect(function()
        if not Config.FlyEnabled then return end
        local r = GetRoot()
        if not r then StopFly() return end
        
        local move = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then move = move + Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move - Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then move = move - Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then move = move - Vector3.new(0, 1, 0) end
        
        if State.JoystickDir.Magnitude > 0.1 then
            local cl = Camera.CFrame.LookVector
            local cr = Camera.CFrame.RightVector
            move = move + (cl * State.JoystickDir.Y + cr * State.JoystickDir.X)
        end
        
        if move.Magnitude > 0 then move = move.Unit * Config.FlySpeed * 60 end
        bv.Velocity = move
        bg.CFrame = Camera.CFrame
    end)
    
    Notify("Fly", "Activated!")
end

local function StopFly()
    if not Config.FlyEnabled then return end
    Config.FlyEnabled = false
    if State.Connections.Fly then State.Connections.Fly:Disconnect() State.Connections.Fly = nil end
    if State.BodyMovers.Gyro then pcall(function() State.BodyMovers.Gyro:Destroy() end) State.BodyMovers.Gyro = nil end
    if State.BodyMovers.Vel then pcall(function() State.BodyMovers.Vel:Destroy() end) State.BodyMovers.Vel = nil end
    Workspace.Gravity = 196.2
    local hum = GetHum()
    if hum then hum.WalkSpeed = 16 hum.JumpPower = 50 end
end

--// FLING
local function FlingPlayer(target)
    if not target or target == LocalPlayer then return false end
    local tr = GetRoot(target)
    local th = GetHum(target)
    if not (tr and th) then return false end
    if th.Health <= 0 then return false end
    
    local mr = GetRoot()
    if not mr then return false end
    
    local dir = (tr.Position - mr.Position).Unit
    if dir.Magnitude < 0.01 then dir = Vector3.new(0, 1, 0) end
    local vel = dir * Config.FlingPower + Vector3.new(0, Config.FlingPower * 0.5, 0)
    
    for i = 1, 5 do
        task.delay(i * 0.05, function()
            pcall(function()
                tr.Velocity = vel
                tr.AssemblyLinearVelocity = vel
            end)
        end)
    end
    
    pcall(function()
        local bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.Velocity = vel * 2
        bv.Parent = tr
        game:GetService("Debris"):AddItem(bv, 0.5)
    end)
    
    return true
end

local function FlingAll()
    local count = 0
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and FlingPlayer(plr) then count = count + 1 end
    end
    Notify("Fling All", "Launched " .. count .. " players!")
end

--// KILL
local function KillPlayer(target)
    if not target then return false end
    local th = GetHum(target)
    if not th then return false end
    pcall(function() th.Health = 0 end)
    pcall(function() th:TakeDamage(9e9) end)
    local c = GetChar(target)
    if c then pcall(function() c:BreakJoints() end) end
    return true
end

local function KillAll()
    local count = 0
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and KillPlayer(plr) then count = count + 1 end
    end
    Notify("Kill All", "Killed " .. count .. " players!")
end

--// SPEED
local function ToggleSpeed(enabled)
    Config.SpeedHack = enabled
    local hum = GetHum()
    if not hum then return end
    if enabled then
        hum.WalkSpeed = Config.WalkSpeed
        State.Connections.Speed = RunService.Heartbeat:Connect(function()
            local h = GetHum()
            if h and Config.SpeedHack then h.WalkSpeed = Config.WalkSpeed end
        end)
    else
        if State.Connections.Speed then State.Connections.Speed:Disconnect() State.Connections.Speed = nil end
        hum.WalkSpeed = 16
    end
end

--// NOCLIP
local function ToggleNoClip(enabled)
    Config.NoClip = enabled
    if enabled then
        State.Connections.NoClip = RunService.Stepped:Connect(function()
            local c = GetChar()
            if c then for _, p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end
        end)
    else
        if State.Connections.NoClip then State.Connections.NoClip:Disconnect() State.Connections.NoClip = nil end
        local c = GetChar()
        if c then for _, p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = true end end end
    end
end

--// GOD
local function ToggleGod(enabled)
    Config.GodMode = enabled
    local hum = GetHum()
    if not hum then return end
    if enabled then
        hum.MaxHealth = 9e9
        hum.Health = 9e9
        State.Connections.God = hum.HealthChanged:Connect(function()
            if Config.GodMode then hum.Health = hum.MaxHealth end
        end)
    else
        if State.Connections.God then State.Connections.God:Disconnect() State.Connections.God = nil end
        hum.MaxHealth = 100
        hum.Health = 100
    end
end

--// FULLBRIGHT
local function ToggleFullBright(enabled)
    Config.FullBright = enabled
    if enabled then
        Lighting.Brightness = 10
        Lighting.GlobalShadows = false
    else
        Lighting.Brightness = 2
        Lighting.GlobalShadows = true
    end
end

--// AIMBOT
local function ToggleAimbot(enabled)
    Config.Aimbot = enabled
    if enabled then
        State.Connections.Aimbot = RunService.RenderStepped:Connect(function()
            if not Config.Aimbot then return end
            local closest = nil
            local minDist = 200
            local myRoot = GetRoot()
            if not myRoot then return end
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer then
                    local head = GetChar(plr) and GetChar(plr):FindFirstChild("Head")
                    if head then
                        local pos = Camera:WorldToViewportPoint(head.Position)
                        local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                        if dist < minDist then minDist = dist closest = plr end
                    end
                end
            end
            if closest then
                local head = GetChar(closest):FindFirstChild("Head")
                if head then
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, head.Position)
                end
            end
        end)
    else
        if State.Connections.Aimbot then State.Connections.Aimbot:Disconnect() State.Connections.Aimbot = nil end
    end
end


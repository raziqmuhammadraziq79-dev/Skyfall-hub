    Toggle("Fly", function(v) if v then StartFly() else StopFly() end end)
    Toggle("Speed", ToggleSpeed)
    Toggle("NoClip", ToggleNoClip)
    Toggle("God", ToggleGod)
    Toggle("Aimbot", ToggleAimbot)
    Toggle("FullBright", ToggleFullBright)
    
    -- Joystick
    local joy = Instance.new("Frame")
    joy.Size = UDim2.new(0, 120, 0, 120)
    joy.Position = UDim2.new(0.05, 0, 0.6, 0)
    joy.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    joy.BackgroundTransparency = 0.3
    joy.BorderSizePixel = 0
    joy.Parent = sg
    
    local jc = Instance.new("UICorner")
    jc.CornerRadius = UDim.new(1, 0)
    jc.Parent = joy
    
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 40, 0, 40)
    knob.Position = UDim2.new(0.5, -20, 0.5, -20)
    knob.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
    knob.BorderSizePixel = 0
    knob.Parent = joy
    
    local kc = Instance.new("UICorner")
    kc.CornerRadius = UDim.new(1, 0)
    kc.Parent = knob
    
    local joyActive = false
    joy.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then joyActive = true end
    end)
    joy.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            joyActive = false
            knob.Position = UDim2.new(0.5, -20, 0.5, -20)
            State.JoystickDir = Vector3.zero
        end
    end)
    joy.InputChanged:Connect(function(input)
        if joyActive and input.UserInputType == Enum.UserInputType.Touch then
            local pos = Vector2.new(input.Position.X, input.Position.Y) - joy.AbsolutePosition
            local center = Vector2.new(60, 60)
            local offset = pos - center
            local dist = math.min(offset.Magnitude, 30)
            local dir = offset.Unit
            local newPos = center + dir * dist
            knob.Position = UDim2.new(0, newPos.X - 20, 0, newPos.Y - 20)
            State.JoystickDir = Vector3.new(dir.X, 0, -dir.Y) * (dist / 30)
        end
    end)
    
    -- Toggle button
    local floatBtn = Instance.new("TextButton")
    floatBtn.Size = UDim2.new(0, 50, 0, 50)
    floatBtn.Position = UDim2.new(0.02, 0, 0.02, 0)

-- EXPLOITER DETECTION
-- ══════════════════════════════
local KnownExploitNames = {
    "synapse","krnl","fluxus","sentinel","executor","inject",
    "delta","script","hack","cheat","exploit","skid","hax"
}

local function isExploiter(p)
    if not p or p == player then return false end
    -- Speed check
    safe(function()
        if p.Character then
            local h = p.Character:FindFirstChild("Humanoid")
            if h and h.WalkSpeed > 50 then
                return true
            end
        end
    end)
    -- Name check
    local lname = p.Name:lower()
    for _, kw in ipairs(KnownExploitNames) do
        if lname:find(kw) then return true end
    end
    return false
end

local exploiterDetectConn
local function startExploiterDetect()
    exploiterDetectConn = RunService.Heartbeat:Connect(function()
        if not State.ExploiterESP and not State.AutoBanExploiter then return end
        for _, p in pairs(Players:GetPlayers()) do
            safe(function()
                if p ~= player and p.Character then
                    local h = p.Character:FindFirstChild("Humanoid")
                    local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                    if h and hrp then
                        local flagged = false
                        -- Speed exploit detection
                        if h.WalkSpeed > 60 then flagged = true end
                        -- Fly detection (high Y velocity)
                        if hrp.Velocity.Y > 100 then flagged = true end
                        -- Noclip detection (inside walls)
                        if flagged then
                            State.ExploiterList[p.Name] = true
                            if State.AutoBanExploiter then
                                -- Kill exploiter server sided
                                serverKill(p)
                                task.wait(0.5)
                            end
                        end
                    end
                end
            end)
        end
    end)
end


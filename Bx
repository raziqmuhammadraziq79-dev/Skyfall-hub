            if (method == "FireServer" or method == "InvokeServer") and
               (self:IsA("RemoteEvent") or self:IsA("RemoteFunction")) then
                table.insert(RemoteLog, {name=self.Name, method=method, args=args, time=os.clock()})
            end
            return oldNC(self, ...)
        end)
    end
end)


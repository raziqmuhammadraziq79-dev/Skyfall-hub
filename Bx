local function serverGrabKey()
    local keyR = findRemote("key","grabkey","pickup","pickupitem","item")
    for _, obj in pairs(workspace:GetDescendants()) do
        safe(function()
            if obj.Name:lower():find("key") then
                local pos = obj:IsA("Model") and obj:GetModelCFrame().Position or obj.Position

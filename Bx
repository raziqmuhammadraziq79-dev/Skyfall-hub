-- SERVER KILL
-- ══════════════════════════════
local function serverKill(target)
    if not target or not target.Character then return end
    local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local tHUM = target.Character:FindFirstChild("Humanoid")
    if not tHRP then return end

    local dmgR = findRemote("damage","dealDamage","hurt","hit","takeDamage")
    local killR = findRemote("kill","killPlayer","pkill","eliminate","die")

    safe(function() if dmgR then dmgR:FireServer(target, 9999) end end)
    safe(function() if dmgR then dmgR:FireServer(target.Character, 9999) end end)
    safe(function() if dmgR then dmgR:FireServer(tHRP, 9999) end end)
    safe(function() if killR then killR:FireServer(target) end end)
    safe(function() if killR then killR:FireServer(target.Character) end end)
    safe(function() if tHUM then tHUM.Health = 0 end end)

    -- Gun fire method
    local shootR = findRemote("shoot","fire","bullet","gunhit","gunfire")
    safe(function()
        if shootR then
            shootR:FireServer(tHRP.Position, tHRP, 9999)
        end
    end)
end


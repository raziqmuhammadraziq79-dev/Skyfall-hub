-- ══════════════════════════════
-- REMOTE SCANNER
-- ══════════════════════════════
local Remotes = {}
local RemoteLog = {}

local function scanRemotes()
    local function scanParent(parent)
        safe(function()
            for _, obj in pairs(parent:GetDescendants()) do
                if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                    Remotes[obj.Name:lower()] = obj
                    table.insert(RemoteLog, {name=obj.Name, path=obj:GetFullName(), class=obj.ClassName})
                end
            end
        end)
    end
    scanParent(ReplicatedStorage)
    scanParent(workspace)
    safe(function() scanParent(game:GetService("ServerStorage")) end)
end
scanRemotes()

local function findRemote(...)
    for _, key in ipairs({...}) do
        for name, remote in pairs(Remotes) do
            if name:lower():find(key:lower()) then return remote end
        end
    end
    return nil
end

-- Hook namecall for remote logging
safe(function()
    if hookmetamethod then
        local oldNC = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()

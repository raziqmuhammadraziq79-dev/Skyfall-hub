local drag3, dStart, dOrig
Hdr.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        drag3 = true
        dStart = input.Position
        dOrig = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then drag3 = false end
        end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if drag3 and (input.UserInputType == Enum.UserInputType.MouseMovement or
                  input.UserInputType == Enum.UserInputType.Touch) then
        safe(function()
            local d = input.Position - dStart
            MainFrame.Position = UDim2.new(dOrig.X.Scale, dOrig.X.Offset+d.X, dOrig.Y.Scale, dOrig.Y.Offset+d.Y)
        end)
    end
end)


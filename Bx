-- [COMBAT LOOPS]
local function InitLoops()
    -- Anti-fling
    task.spawn(function()
        while true do
            task.wait()
            if States.AntiFling and Root and Root.Parent then
                if Root.Velocity.Magnitude > 150 then
                    Root.Velocity = Vector3.zero
                    Root.RotVelocity = Vector3.zero
                end
            end
        end
    end)
    
    -- Infinite ammo
    task.spawn(function()
        while true do
            task.wait(0.2)
            if States.InfAmmo and LocalPlayer.Character then
                for _, c in ipairs({LocalPlayer.Backpack, LocalPlayer.Character}) do
                    for _, t in ipairs(c:GetChildren()) do
                        if t:IsA("Tool") then
                            for _, v in ipairs(t:GetDescendants()) do
                                if v:IsA("IntValue") and v.Name:lower():match("ammo|mag|clip") then
                                    v.Value = 9999
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
    
    -- ESP
    task.spawn(function()
        local espGui = Instance.new("ScreenGui")
        espGui.Name = "SkyfallESP"
        espGui.ResetOnSpawn = false
        espGui.Parent = game:GetService("CoreGui")
        
        while true do
            task.wait(0.1)
            if not States.ESP then
                for _, c in ipairs(espGui:GetChildren()) do c:Destroy() end
                continue
            end
            for _, c in ipairs(espGui:GetChildren()) do c:Destroy() end
            
            local cam = Workspace.CurrentCamera
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                    local hum = p.Character:FindFirstChildOfClass("Humanoid")
                    if hrp and hum and hum.Health > 0 then
                        local pos, on = cam:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
                        if on then
                            local box = Instance.new("Frame")
                            box.Size = UDim2.new(0, 32, 0, 48)
                            box.Position = UDim2.new(0, pos.X - 16, 0, pos.Y - 24)
                            box.BackgroundColor3 = IS_PL and T.DANGER or Color3.fromRGB(0, 200, 255)
                            box.BackgroundTransparency = 0.5
                            box.Parent = espGui
                            Corner(box, 4)
                            Stroke(box, T.ACCENT2, 1)
                            
                            local txt = Instance.new("TextLabel")
                            txt.Size = UDim2.new(0, 80, 0, 12)
                            txt.Position = UDim2.new(0, pos.X - 40, 0, pos.Y + 26)
                            txt.BackgroundTransparency = 1
                            txt.Text = p.DisplayName or p.Name
                            txt.TextColor3 = T.TEXT
                            txt.Font = Enum.Font.Gotham
                            txt.TextSize = 9
                            txt.TextStrokeTransparency = 0
                            txt.Parent = espGui
                        end
                    end
                end
            end
        end
    end)
end

-- [INIT]
local function Initialize()
    -- Destroy old GUIs
    for _, gui in ipairs(game:GetService("CoreGui"):GetChildren()) do
        if gui.Name:match("Skyfall") then gui:Destroy() end
    end
    
    Gui = Instance.new("ScreenGui")
    Gui.Name = "SkyfallMobile_v92"
    Gui.ResetOnSpawn = false
    Gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    Gui.IgnoreGuiInset = true
    Gui.Parent = game:GetService("CoreGui")
    
    Char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    Hum = Char:WaitForChild("Humanoid")
    Root = Char:WaitForChild("HumanoidRootPart")
    
    CreateFAB()
    CreateCompactPanel()
    InitLoops()
    
    warn("[SKYFALL v9.2] MOBILE COMPACT WARFARE ONLINE")
    warn("[INFO] Tap FAB (bottom-right) to open panel")
end

LocalPlayer.CharacterAdded:Connect(function(c)
    task.wait(0.5)
    Char = c
    Hum = c:FindFirstChildOfClass("Humanoid")
    Root = c:FindFirstChild("HumanoidRootPart")
end)

task.spawn(Initialize)

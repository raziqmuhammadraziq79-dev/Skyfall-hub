                    hrp.CFrame = CFrame.new(pos + Vector3.new(0,3,0))
                    task.wait(0.2)
                    if obj:IsA("BasePart") then
                        safe(function() firetouchinterest(hrp, obj, 0) end)
                        task.wait(0.1)

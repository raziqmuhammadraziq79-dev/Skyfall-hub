local ESPFolder = Instance.new("Folder")
ESPFolder.Name = "SkyFallESP"
ESPFolder.Parent = player.PlayerGui

local function clearESP()
    for _, v in pairs(ESPFolder:GetChildren()) do v:Destroy() end
    State.ESPBoxes = {}
    State.TracerLines = {}
end

local function buildESP(p)
    if not p or not p.Character then return end
    local hrp = p.Character:FindFirstChild("HumanoidRootPart")
    local hum = p.Character:FindFirstChild("Humanoid")
    if not hrp then return end

    -- Remove old
    local old = ESPFolder:FindFirstChild(p.Name)
    if old then old:Destroy() end

    local container = Instance.new("Folder")
    container.Name = p.Name
    container.Parent = ESPFolder

    -- Billboard GUI
    local bb = Instance.new("BillboardGui")
    bb.Size = UDim2.new(0, 80, 0, 100)
    bb.StudsOffset = Vector3.new(0, 3.5, 0)
    bb.AlwaysOnTop = true
    bb.Parent = hrp

    -- Box
    local box = Instance.new("Frame")
    box.Size = UDim2.new(1, 0, 1, 0)
    box.BackgroundTransparency = 1
    box.BorderSizePixel = 0
    box.Parent = bb

    -- Box outline (4 lines)
    local colors = {
        friend = Color3.fromRGB(0, 200, 255),
        enemy  = Color3.fromRGB(255, 50, 50),
        exploiter = Color3.fromRGB(255, 200, 0),
    }
    local isExploit = State.ExploiterList[p.Name]
    local isFriend = p.Team == player.Team
    local col = isExploit and colors.exploiter or (isFriend and colors.friend or colors.enemy)

    for _, pos in ipairs({
        {UDim2.new(0,0,0,0), UDim2.new(1,0,0,2)},   -- top
        {UDim2.new(0,0,1,-2), UDim2.new(1,0,0,2)},  -- bottom
        {UDim2.new(0,0,0,0), UDim2.new(0,2,1,0)},   -- left
        {UDim2.new(1,-2,0,0), UDim2.new(0,2,1,0)},  -- right
    }) do
        local line = Instance.new("Frame")
        line.Position = pos[1]
        line.Size = pos[2]
        line.BackgroundColor3 = col
        line.BorderSizePixel = 0
        line.Parent = box
    end

    -- Name label
    local namelbl = Instance.new("TextLabel")
    namelbl.Size = UDim2.new(1, 0, 0, 16)
    namelbl.Position = UDim2.new(0, 0, -0.22, 0)
    namelbl.BackgroundTransparency = 1
    namelbl.Text = (isExploit and "⚠ " or "") .. p.Name
    namelbl.TextColor3 = col
    namelbl.TextScaled = true
    namelbl.Font = Enum.Font.GothamBold
    namelbl.Parent = bb

    -- Health bar
    if State.HealthBar and hum then
        local hpBg = Instance.new("Frame")
        hpBg.Size = UDim2.new(0, 6, 1, 0)
        hpBg.Position = UDim2.new(0, -10, 0, 0)
        hpBg.BackgroundColor3 = Color3.fromRGB(30,30,30)
        hpBg.BorderSizePixel = 0
        hpBg.Parent = bb

        local hpFill = Instance.new("Frame")
        hpFill.Size = UDim2.new(1, 0, hum.Health/hum.MaxHealth, 0)
        hpFill.AnchorPoint = Vector2.new(0, 1)
        hpFill.Position = UDim2.new(0, 0, 1, 0)
        hpFill.BackgroundColor3 = Color3.fromRGB(
            math.floor(255 * (1 - hum.Health/hum.MaxHealth)),
            math.floor(255 * (hum.Health/hum.MaxHealth)),
            0
        )
        hpFill.BorderSizePixel = 0
        hpFill.Parent = hpBg

        -- Update hp live
        RunService.Heartbeat:Connect(function()
            safe(function()
                if hum and hum.Parent then
                    local pct = hum.Health/hum.MaxHealth
                    hpFill.Size = UDim2.new(1, 0, pct, 0)
                    hpFill.BackgroundColor3 = Color3.fromRGB(
                        math.floor(255*(1-pct)),
                        math.floor(255*pct),
                        0
                    )
                end
            end)
        end)
    end

    -- Distance label
    local distLbl = Instance.new("TextLabel")
    distLbl.Size = UDim2.new(1, 0, 0, 14)
    distLbl.Position = UDim2.new(0, 0, 1.05, 0)
    distLbl.BackgroundTransparency = 1
    distLbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    distLbl.TextScaled = true
    distLbl.Font = Enum.Font.Gotham
    distLbl.Parent = bb

    RunService.Heartbeat:Connect(function()
        safe(function()
            local hrp2 = getHRP()
            if hrp2 and hrp and hrp.Parent then
                local dist = math.floor((hrp2.Position - hrp.Position).Magnitude)
                distLbl.Text = dist .. "m"
            end
        end)
    end)

    -- Tracer line
    if State.Tracer then
        local tracer = Instance.new("SelectionBox")
        tracer.LineThickness = 0.05
        tracer.Color3 = col
        tracer.SurfaceColor3 = col
        tracer.SurfaceTransparency = 0.9
        tracer.Adornee = hrp
        tracer.Parent = container
    end

    -- Chams (see through walls highlight)
    if State.Chams then
        safe(function()
            for _, part in pairs(p.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    local hi = Instance.new("SelectionBox")
                    hi.Adornee = part
                    hi.Color3 = col
                    hi.LineThickness = 0.05
                    hi.SurfaceColor3 = col
                    hi.SurfaceTransparency = 0.7
                    hi.Parent = container
                end
            end
        end)
    end

    table.insert(State.ESPBoxes, bb)
end


-- [UI HELPERS]
local function Corner(p, r) local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 8); c.Parent = p; return c end
local function Stroke(p, c, t) local s = Instance.new("UIStroke"); s.Color = c or T.BORDER; s.Thickness = t or 1; s.Parent = p; return s end

-- [FLOATING ACTION BUTTON (FAB) - ALWAYS VISIBLE]
local function CreateFAB()
    FAB = Instance.new("ImageButton")
    FAB.Name = "SkyfallFAB"
    FAB.Size = UDim2.new(0, 52, 0, 52)
    FAB.Position = UDim2.new(1, -70, 1, -120) -- Bottom right, thumb-reachable
    FAB.BackgroundColor3 = T.ACCENT
    FAB.Image = "rbxassetid://7059346373" -- Devil icon
    FAB.ScaleType = Enum.ScaleType.Fit
    FAB.ImageColor3 = T.TEXT
    FAB.Parent = Gui
    Corner(FAB, 26)
    Stroke(FAB, T.TEXT, 2)
    
    -- Pulse animation
    task.spawn(function()
        while FAB and FAB.Parent do
            TweenService:Create(FAB, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {
                Size = UDim2.new(0, 56, 0, 56),
                BackgroundColor3 = T.ACCENT2
            }):Play()
            task.wait(0.8)
        end
    end)
    
    FAB.MouseButton1Click:Connect(function()
        IsExpanded = not IsExpanded
        Panel.Visible = IsExpanded
        FAB.Visible = not IsExpanded
    end)
    
    -- Drag FAB
    local dragging, dragStart, startPos
    FAB.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = FAB.Position
        end
    end)
    FAB.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local delta = input.Position - dragStart
            FAB.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end


    BuildTacticalGUI()
    UpdatePlayerList()
    InitCombatLoops()
    DetectAndLoadGame() -- Auto-detect PL or Universal
    
    Players.PlayerAdded:Connect(UpdatePlayerList)
    Players.PlayerRemoving:Connect(UpdatePlayerList)
    
    warn("[SKYFALL v9.0] URBAN WARFARE COMMANDER ONLINE.")
    warn("[INFO] Use 'Hide' button to minimize. Script persists.")
end


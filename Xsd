local function ToggleMorph()
    if not Character then return end
    IsMorphed = not IsMorphed
    
    if IsMorphed then
        -- Add Devil Accessories (Horns/Wings/Tail)
        -- Using procedural parts if assets fail, but accessories are better for animation
        local hum = Character:FindFirstChildOfClass("Humanoid")
        
        -- Horns
        local acc1 = Instance.new("Accessory")
        acc1.Name = "DevilHorns"
        local handle1 = Instance.new("Part")
        handle1.Name = "Handle"
        handle1.Size = Vector3.new(0.8, 0.8, 0.4)
        handle1.BrickColor = BrickColor.new("Really black")
        handle1.Material = Enum.Material.Neon
        handle1.Parent = acc1
        
        local weld1 = Instance.new("Weld")
        weld1.Part0 = handle1
        weld1.C0 = CFrame.new(0, 0.5, 0)
        weld1.Parent = handle1
        
        acc1.Parent = Character
        if hum then hum:AddAccessory(acc1) end
        
        -- Wings (Back)
        local acc2 = Instance.new("Accessory")
        acc2.Name = "DevilWings"
        local handle2 = Instance.new("Part")
        handle2.Name = "Handle"
        handle2.Size = Vector3.new(2, 1.5, 0.2)
        handle2.BrickColor = BrickColor.new("Dark red")
        handle2.Material = Enum.Material.Neon
        handle2.Transparency = 0.2
        handle2.Parent = acc2
        
        local weld2 = Instance.new("Weld")
        weld2.Part0 = handle2
        weld2.C0 = CFrame.new(0, 0, -0.8)
        weld2.Parent = handle2
        
        acc2.Parent = Character
        if hum then hum:AddAccessory(acc2) end
        
        -- Change Body Colors
        for _, p in ipairs(Character:GetDescendants()) do
            if p:IsA("BasePart") and p.Name ~= "Handle" then
                p.BrickColor = BrickColor.new("Really black")
                p.Material = Enum.Material.SmoothPlastic
            end
        end
        
    else
        -- Remove Accessories
        for _, child in ipairs(Character:GetChildren()) do
            if child:IsA("Accessory") and (child.Name == "DevilHorns" or child.Name == "DevilWings") then
                child:Destroy()
            end
        end
        
        -- Reset Colors (Simple reset)
        for _, p in ipairs(Character:GetDescendants()) do
            if p:IsA("BasePart") then
                p.BrickColor = BrickColor.new("Medium stone grey")
                p.Material = Enum.Material.Plastic
            end
        end
    end
end

-- [5. COMBAT LOOPS (UNIVERSAL)]
local function InitCombatLoops()
    -- God Mode Loop
    task.spawn(function()
        while true do
            task.wait(0.1)
            if Humanoid and Humanoid.Parent then
                if Humanoid.Health < MAX_HEALTH then Humanoid.Health = MAX_HEALTH end
            end
        end
    end)
    
    -- Infinite Ammo Loop
    task.spawn(function()
        while true do
            task.wait(0.2)
            if _G.InfAmmoActive and LocalPlayer.Character then
                for _, c in ipairs({LocalPlayer.Backpack, LocalPlayer.Character}) do
                    for _, t in ipairs(c:GetChildren()) do
                        if t:IsA("Tool") then
                            for _, v in ipairs(t:GetDescendants()) do
                                if v:IsA("IntValue") and v.Name:lower():match("ammo|mag|clip") then
                                    v.Value = 9999
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
    
    -- Smart Anti-Fling (Velocity Check Only)
    task.spawn(function()
        while true do
            task.wait()
            if _G.AntiFlingActive and RootPart and RootPart.Parent then
                local vel = RootPart.Velocity.Magnitude
                if vel > 150 then -- Fling threshold
                    RootPart.Velocity = Vector3.zero
                    RootPart.RotVelocity = Vector3.zero
                end
            end
        end
    end)
    
    -- Universal ESP
    task.spawn(function()
        local espGui = Instance.new("ScreenGui")
        espGui.Name = "UrbanWarfareESP"
        espGui.ResetOnSpawn = false
        espGui.Parent = game:GetService("CoreGui")
        
        while true do
            task.wait(0.1)
            if not _G.EspActive then 
                for _, c in ipairs(espGui:GetChildren()) do c:Destroy() end
                continue 
            end
            
            for _, c in ipairs(espGui:GetChildren()) do c:Destroy() end
            
            local cam = Workspace.CurrentCamera
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local pos, on = cam:WorldToViewportPoint(hrp.Position + Vector3.new(0,3,0))
                        if on then
                            local box = Instance.new("Frame")
                            box.Size = UDim2.new(0, 40, 0, 60)
                            box.Position = UDim2.new(0, pos.X-20, 0, pos.Y-30)
                            box.BackgroundColor3 = IS_PL and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 200, 255)
                            box.BackgroundTransparency = 0.5
                            box.BorderSizePixel = 1
                            box.Parent = espGui
                            
                            local txt = Instance.new("TextLabel")
                            txt.Size = UDim2.new(0, 80, 0, 15)
                            txt.Position = UDim2.new(0, pos.X-40, 0, pos.Y+35)
                            txt.BackgroundTransparency = 1
                            txt.Text = p.Name .. (IS_PL and " [CRIM]" or "")
                            txt.TextColor3 = Color3.fromRGB(255, 255, 255)
                            txt.TextScaled = true
                            txt.Font = Enum.Font.GothamBold
                            txt.Parent = espGui
                        end
                    end
                end
            end
        end
    end)
end


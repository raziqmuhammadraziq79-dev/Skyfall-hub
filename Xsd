-- [1. FAKE ADMIN ENGINE (SOCIAL ENGINEERING)]
local function SendFakeAdminMessage(TargetName, ActionType, Reason)
    local ChatRemote = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
    if not ChatRemote then 
        warn("[WARN] Chat Remote not found. Fake Admin disabled.")
        return 
    end
    
    local Message = ""
    if ActionType == "KICK" then
        Message = string.format("⚠️ SYSTEM ALERT ⚠️\nPlayer '%s' has been kicked from the server.\nReason: %s\nAction By: SKYFALL COMMAND", TargetName, Reason)
    elseif ActionType == "BAN" then
        Message = string.format("🚫 PERMANENT BAN 🚫\nPlayer '%s' has been banned.\nReason: %s\nDuration: ∞\nAppeal: Denied", TargetName, Reason)
    elseif ActionType == "MUTE" then
        Message = string.format("🔇 MUTE ACTION 🔇\nPlayer '%s' has been muted.\nReason: %s\nDuration: 24h", TargetName, Reason)
    end
    
    -- Send to Global Chat
    pcall(function()
        ChatRemote:FireServer("SayMessageRequest", {
            Message = Message,
            Channel = "All"
        })
    end)
    
    -- Optional: Whisper to target for extra fear
    pcall(function()
        ChatRemote:FireServer("WhisperMessageRequest", {
            ToUserId = Players:FindFirstChild(TargetName).UserId,
            Message = "[SYSTEM] You have been punished by Skyfall Hub Urban Warfare Kernel."
        })
    end)
end


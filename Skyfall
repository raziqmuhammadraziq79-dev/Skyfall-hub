    })
    local List = New("ScrollingFrame", {
        Size = UDim2.new(1, -8, 1, -22), Position = UDim2.new(0, 4, 0, 20),
        BackgroundTransparency = 1, CanvasSize = UDim2.new(0, 0, 0, 150),
        ScrollBarThickness = 2, Parent = Box
    })
    New("UIListLayout", {Padding = UDim.new(0, 2), SortOrder = Enum.SortOrder.LayoutOrder, Parent = List})
    
    local function RefreshList()
        for _, child in ipairs(List:GetChildren()) do if child:IsA("GuiObject") then child:Destroy() end end
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                local PlrBtn = New("TextButton", {
                    Size = UDim2.new(1, 0, 0, 20), BackgroundColor3 = Color3.fromRGB(35, 35, 35),
                    Text = plr.Name, TextColor3 = CONFIG.Text_Color, TextSize = 9, Font = Enum.Font.GothamMedium, Parent = List

                    SelectedPlayer = plr
                    for _, btn in ipairs(List:GetChildren()) do if btn:IsA("TextButton") then btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35) end end
                    PlrBtn.BackgroundColor3 = CONFIG.BaseColor
                end)
            end
        end
    end
    RefreshList()
    Players.PlayerAdded:Connect(RefreshList)
    Players.PlayerRemoving:Connect(RefreshList)
end


local function teleportTo(p)
    local target=findPlayer(p)
    if not target then notify("Tele","❌ Not found",1) return end
    local tChar=target.Character
    if not tChar then notify("Tele","❌ No char",1) return end
    local tHrp=tChar:FindFirstChild("HumanoidRootPart")
    if not tHrp then notify("Tele","❌ No HRP",1) return end
    local hrp=getHRP()
    if hrp then hrp.CFrame=tHrp.CFrame+Vector3.new(0,3,0) notify("Tele","✅ "..target.Name,1) end
end

local function killPlayer(p)
    local target=findPlayer(p)
    if not target then notify("Kill","❌ Not found",1) return end
    if target==plr then notify("Kill","❌ Self",1) return end
    local char=target.Character
    if char then
        local hum=char:FindFirstChild("Humanoid")
        if hum then hum.Health=0 notify("Kill","💀 "..target.Name,1) end
    end
end

local function freezePlayer(p)
    local target=findPlayer(p)
    if not target then notify("Freeze","❌ Not found",1) return end
    local tChar=target.Character
    if not tChar then notify("Freeze","❌ No char",1) return end
    local tHum=tChar:FindFirstChild("Humanoid")
    if not tHum then notify("Freeze","❌ No hum",1) return end
    tHum.WalkSpeed=0 tHum.JumpPower=0
    state.frozen[target.Name]=true
    notify("Freeze","🧊 "..target.Name,1)
end

local function kickPlayer(p)
    local target=findPlayer(p)
    if not target then notify("Kick","❌ Not found",1) return end
    if target==plr then notify("Kick","❌ Self",1) return end
    local char=target.Character
    if char then
        local hrp=char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame=CFrame.new(0,-99999,0) end
    end
    spawn(function()
        for i=1,30 do wait(0.3)
            local c2=target.Character
            if c2 then
                local hrp2=c2:FindFirstChild("HumanoidRootPart")
                if hrp2 then hrp2.CFrame=CFrame.new(0,-99999,0) end
            end
        end
    end)
    notify("Kick","👢 "..target.Name,1)
end


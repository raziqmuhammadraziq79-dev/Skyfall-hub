            if state.antiSensor and msg.FromPlayer==plr then
                pcall(function()
                    local remote=ReplicatedStorage:FindFirstChild("SendMessage")
                    if remote then remote:FireServer(msg.Message) end
                end)
            end
        end)
        pcall(function()
            local oldFilter=ChatService.FilterMessage
            ChatService.FilterMessage=function(msg)
                if state.antiSensor then return msg end
                return oldFilter and oldFilter(msg) or msg
            end
        end)
        notify("AntiSensor","🛡️ BYPASS ON",1)
    else

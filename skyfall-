                    end
                end
            end
        end)
        notify("Black Hole","🌀 ON",1)
    else
        if state.blackHoleConn then state.blackHoleConn:Disconnect() state.blackHoleConn=nil end
        notify("Black Hole","🌀 OFF",1)
    end
end


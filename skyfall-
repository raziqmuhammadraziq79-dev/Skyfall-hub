        state.blackHoleConn=RunService.Heartbeat:Connect(function()
            if not state.blackHoleActive then return end
            local hrp=getHRP() if not hrp then return end
            local center=hrp.Position
            for _,p in pairs(getAllTargets()) do
                local char=p.Character
                if char then
                    local targetHrp=char:FindFirstChild("HumanoidRootPart")
                    if targetHrp then
                        local dir=(center-targetHrp.Position).Unit
                        local dist=(center-targetHrp.Position).Magnitude

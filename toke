		S.Night = false
		Lighting.Brightness = 3 Lighting.ClockTime = 14
		Lighting.Ambient = Color3.fromRGB(178,178,178)
		Lighting.OutdoorAmbient = Color3.fromRGB(178,178,178)
	else
		Lighting.Brightness = sL.B Lighting.ClockTime = sL.T
		Lighting.Ambient = sL.A Lighting.OutdoorAmbient = sL.O
	end
end

-- 8. Night Mode
local function fNight(v) S.Night=v
	if v then
		S.Full = false Lighting.ClockTime = 0
		Lighting.Ambient = Color3.fromRGB(6,8,18)
		Lighting.OutdoorAmbient = Color3.fromRGB(6,8,18)
	else
		Lighting.ClockTime = sL.T
		Lighting.Ambient = sL.A Lighting.OutdoorAmbient = sL.O

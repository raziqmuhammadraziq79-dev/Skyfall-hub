-- 24. Click Teleport (right mouse button)
local function fClickTP(v) S.ClickTP=v dC("CTP")
	if v then
		aC("CTP", UIS.InputBegan:Connect(function(inp,gpe)
			if gpe then return end
			if inp.UserInputType == Enum.UserInputType.MouseButton2 then
				local ur = WS.CurrentCamera:ScreenPointToRay(inp.Position.X, inp.Position.Y)
				local res = WS:Raycast(ur.Origin, ur.Direction * 2000)
				if res then
					local r=gR() if r then r.CFrame=CFrame.new(res.Position+Vector3.yAxis*4) end
				end
			end
		end))
	end
end


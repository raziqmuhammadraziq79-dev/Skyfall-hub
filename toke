local function uC(p,r2)
	local c=Instance.new("UICorner") c.CornerRadius=UDim.new(0,r2 or 8) c.Parent=p return c
end
local function uSt(p,col,th)
	local s=Instance.new("UIStroke") s.Color=col or C.Stroke s.Thickness=th or 1 s.Parent=p return s
end
local function uPad(p,t,b,l,r2)
	local u=Instance.new("UIPadding")
	u.PaddingTop=UDim.new(0,t) u.PaddingBottom=UDim.new(0,b)
	u.PaddingLeft=UDim.new(0,l) u.PaddingRight=UDim.new(0,r2) u.Parent=p
end
local function uGr(p,c1,c2,rot)
	local g=Instance.new("UIGradient")
	g.Color=ColorSequence.new(c1,c2) g.Rotation=rot or 90 g.Parent=p return g
end
local function uLbl(p,txt,sz,col,xa,fnt)
	local l=Instance.new("TextLabel") l.BackgroundTransparency=1
	l.Size=UDim2.new(1,0,0,sz+4) l.Font=fnt or Enum.Font.GothamMedium
	l.Text=txt l.TextSize=sz l.TextColor3=col or C.Text
	l.TextXAlignment=xa or Enum.TextXAlignment.Left
	l.TextScaled=false l.Parent=p return l
end
local function uPulse(s2)
	task.spawn(function()
		while s2 and s2.Parent do
			TS:Create(s2,TweenInfo.new(1.4,Enum.EasingStyle.Sine),{Transparency=0.5}):Play()
			task.wait(1.4)
			TS:Create(s2,TweenInfo.new(1.4,Enum.EasingStyle.Sine),{Transparency=0}):Play()
			task.wait(1.4)
		end
	end)
end


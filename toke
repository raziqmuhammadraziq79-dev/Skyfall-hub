-- Teleport by name
local function fTeleport(name)
	local r=gR() if not r then return end
	for _,inst in ipairs(WS:GetDescendants()) do
		if inst.Name:lower()==name:lower()
			and (inst:IsA("BasePart") or inst:IsA("Model")) then
			local cf = inst:IsA("Model") and inst:GetPivot() or inst.CFrame
			r.CFrame = cf + Vector3.yAxis*5
			return
		end
	end
	warn("[SkyfallHub] Location not found: "..name)
end


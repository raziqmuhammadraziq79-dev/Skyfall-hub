-- 1. God Mode
local function fGod(v) S.God=v dC("God")
	if v then aC("God", RunService.Heartbeat:Connect(function()
		local h=gH() if h and h.Health < h.MaxHealth then h.Health=h.MaxHealth end
	end)) end
end

-- 2. Noclip
local function fNoclip(v) S.Noclip=v dC("NC")
	if v then
		aC("NC", RunService.Stepped:Connect(function()
			local c=LP.Character if not c then return end
			for _,p in ipairs(c:GetDescendants()) do
				if p:IsA("BasePart") then p.CanCollide=false end
			end
		end))
	else
		local c=LP.Character if c then
			for _,p in ipairs(c:GetDescendants()) do
				if p:IsA("BasePart") and p.Name~="HumanoidRootPart" then p.CanCollide=true end
			end
		end
	end
end

-- 3. Infinite Jump
local function fInfJump(v) S.InfJump=v dC("IJ")
	if v then aC("IJ", UIS.JumpRequest:Connect(function()
		local h=gH() if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
	end)) end
end

-- 4. Fly
local fbv, fbg
local function fFly(v) S.Fly=v dC("Fly")
	local h=gH() local r=gR() if not h or not r then return end
	if v then
		h.PlatformStand = true
		fbv = Instance.new("BodyVelocity")
		fbv.MaxForce = Vector3.one * 1e5
		fbv.Velocity = Vector3.zero
		fbv.Parent = r
		fbg = Instance.new("BodyGyro")
		fbg.MaxTorque = Vector3.one * 1e5
		fbg.P = 3000
		fbg.CFrame = r.CFrame
		fbg.Parent = r
		aC("Fly", RunService.RenderStepped:Connect(function()
			local cam = WS.CurrentCamera
			local d = Vector3.zero
			if UIS:IsKeyDown(Enum.KeyCode.W)           then d += cam.CFrame.LookVector  end
			if UIS:IsKeyDown(Enum.KeyCode.S)           then d -= cam.CFrame.LookVector  end
			if UIS:IsKeyDown(Enum.KeyCode.A)           then d -= cam.CFrame.RightVector end
			if UIS:IsKeyDown(Enum.KeyCode.D)           then d += cam.CFrame.RightVector end
			if UIS:IsKeyDown(Enum.KeyCode.Space)       then d += Vector3.yAxis end
			if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then d -= Vector3.yAxis end
			if fbv then fbv.Velocity = (d.Magnitude > 0 and d.Unit or d) * S.FlySpd end
			if fbg and gR() then fbg.CFrame = CFrame.lookAt(Vector3.zero, cam.CFrame.LookVector) end
		end))
	else
		h.PlatformStand = false
		if fbv then fbv:Destroy() fbv=nil end
		if fbg then fbg:Destroy() fbg=nil end
	end
end

-- 5. ESP Players
local function applyESPP(char)
	if char:FindFirstChild("_SF_ESP") then return end
	local hl = Instance.new("Highlight") hl.Name = "_SF_ESP"
	hl.FillColor = C.Blue hl.OutlineColor = C.W
	hl.FillTransparency = 0.55
	hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	hl.Parent = char
end
local function fESPP(v) S.ESPP=v
	for _,p in ipairs(Players:GetPlayers()) do
		if p ~= LP and p.Character then
			local hl = p.Character:FindFirstChild("_SF_ESP")
			if v and not hl then applyESPP(p.Character)
			elseif not v and hl then hl:Destroy() end
		end
	end
end
Players.PlayerAdded:Connect(function(p)
	p.CharacterAdded:Connect(function(c)
		if S.ESPP and p ~= LP then task.wait(0.15) applyESPP(c) end
	end)
end)

-- 6. ESP Items (universal keyword scan)
local iHL = {}
local function fESPI(v) S.ESPI=v
	for _,h in ipairs(iHL) do pcall(function() h:Destroy() end) end
	table.clear(iHL)
	if not v then return end
	local kw = {"item","drop","chest","coin","gem","loot","pickup","collect","reward","ore","fruit"}
	for _,inst in ipairs(WS:GetDescendants()) do
		local n = inst.Name:lower()
		local hit = ColSvc:HasTag(inst, "SkyfallItem")
		if not hit then
			for _,k in ipairs(kw) do if n:find(k) then hit=true break end end
		end
		if hit and (inst:IsA("BasePart") or inst:IsA("Model") or inst:IsA("Tool")) then
			local hl = Instance.new("Highlight")
			hl.FillColor = C.Green hl.OutlineColor = C.Green
			hl.FillTransparency = 0.45
			hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
			hl.Parent = inst
			table.insert(iHL, hl)
		end
	end
end

-- 7. Fullbright
local sL = {B=Lighting.Brightness,T=Lighting.ClockTime,A=Lighting.Ambient,O=Lighting.OutdoorAmbient}

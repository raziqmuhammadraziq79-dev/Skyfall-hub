-- ══════════════════════════════════════════
--         HEALTH BAR DRAW
-- ══════════════════════════════════════════
local function drawHealthBar(e, b, hum)
    if not CFG.HealthBar or not hum then
        e.hpBg.Visible   = false
        e.hpFill.Visible = false
        return
    end
    local ratio  = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
    local barX   = b.BL.X - 6
    local topY   = b.TL.Y
    local botY   = b.BL.Y
    local fillY  = topY + (botY - topY) * (1 - ratio)

    e.hpBg.From    = Vector2.new(barX, topY)
    e.hpBg.To      = Vector2.new(barX, botY)
    e.hpBg.Color   = Color3.fromRGB(60,0,0)
    e.hpBg.Visible = true

    e.hpFill.From    = Vector2.new(barX, fillY)
    e.hpFill.To      = Vector2.new(barX, botY)
    e.hpFill.Color   = Color3.fromRGB(
        math.floor(255*(1-ratio)),
        math.floor(255*ratio),
        0
    )
    e.hpFill.Visible = true
end

-- ══════════════════════════════════════════
--         MAIN RENDER LOOP
-- ══════════════════════════════════════════
RunService.RenderStepped:Connect(function()
    local vp      = Camera.ViewportSize
    local cx      = vp.X / 2
    local cy      = vp.Y / 2

    -- HUD
    fovCircle.Position = Vector2.new(cx, cy)
    fovCircle.Visible  = CFG.FOVCircle and CFG.Aimbot

    local chLen = 12
    crosshairH.From    = Vector2.new(cx - chLen, cy)
    crosshairH.To      = Vector2.new(cx + chLen, cy)
    crosshairH.Visible = CFG.CrossHair
    crosshairV.From    = Vector2.new(cx, cy - chLen)
    crosshairV.To      = Vector2.new(cx, cy + chLen)
    crosshairV.Visible = CFG.CrossHair
    crosshairDot.Position = Vector2.new(cx, cy)
    crosshairDot.Visible  = CFG.CrossHair

    -- Misc
    if CFG.NoRecoil  then applyNoRecoil() end
    if CFG.SpeedHack then applySpeed()    end
    if CFG.BunnyHop  then doBunnyHop()   end
    tryAutoReload(LP.Character)

    -- ── ESP ──
    local active = {}

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and isAlive(p) then
            local enemy   = isEnemy(p)
            local teammate= isTeammate(p)
            active[p.UserId] = true

            if not ESPCache[p.UserId] then buildESP(p.UserId) end
            local e      = ESPCache[p.UserId]
            local bounds = getBounds(p.Character)
            local locked = (LockedTarget == p)
            local hum    = p.Character:FindFirstChildOfClass("Humanoid")
            local dist   = getDistance(p)

            -- Chams
            if CFG.Chams then
                if enemy    then applyChams(p, CFG.ChamsEnemy)
                elseif teammate then applyChams(p, CFG.ChamsTeam)
                end
            else
                removeChams(p)
            end

            if not bounds or not CFG.ESP then
                hideAll(e) ; hideCorners(e) ; goto continue
            end

            -- Determine tracer visibility
            local showTracer = false
            local tracerColor = CFG.EnemyTracer
            if CFG.TracerMode == "enemy"    and enemy    then showTracer = true ; tracerColor = CFG.EnemyTracer
            elseif CFG.TracerMode == "team" and teammate then showTracer = true ; tracerColor = CFG.TeamTracer
            elseif CFG.TracerMode == "all"               then showTracer = true
                tracerColor = enemy and CFG.EnemyTracer or CFG.TeamTracer
            end

            -- Box color
            local bc = locked and CFG.LockedColor or (enemy and CFG.EnemyBox or CFG.TeamBox)

            -- Tracer
            local tracerFrom = CFG.SnapLine
                and Vector2.new(cx, cy)
                or  Vector2.new(cx, vp.Y)
            e.tracer.From    = tracerFrom
            e.tracer.To      = bounds.botPos
            e.tracer.Color   = tracerColor
            e.tracer.Visible = showTracer

            -- Corner box (always for enemy, blue for team)
            drawCorners(e, bounds, bc)
            e.bTop.Visible = false
            e.bBot.Visible = false
            e.bL.Visible   = false
            e.bR.Visible   = false

            -- Dot
            if CFG.HeadDot then
                e.dot.Position = bounds.headPos
                e.dot.Color    = locked and CFG.LockedColor or (enemy and CFG.EnemyDot or CFG.TeamBox)
                e.dot.Radius   = locked and 8 or 5
                e.dot.Visible  = true
            else
                e.dot.Visible  = false
            end

            -- Lock ring
            e.ring.Position = bounds.headPos
            e.ring.Visible  = locked and enemy

            -- Name
            local prefix = enemy and (locked and "🔒 " or "💀 ") or "👥 "
            e.name.Text     = prefix .. p.DisplayName
            e.name.Position = Vector2.new(bounds.headPos.X, bounds.headPos.Y - 20)
            e.name.Color    = enemy and Color3.new(1,1,1) or CFG.TeamBox
            e.name.Visible  = true

            -- Distance
            if CFG.DistanceESP then
                e.distLbl.Text     = dist .. "m"
                e.distLbl.Position = Vector2.new(bounds.headPos.X, bounds.botPos.Y + 4)
                e.distLbl.Visible  = true
            else
                e.distLbl.Visible = false
            end

            -- Health bar
            drawHealthBar(e, bounds, hum)
        end
        ::continue::
    end

    -- Cleanup
    for uid in pairs(ESPCache) do
        if not active[uid] then clearPlayer(uid) end
    end

    -- ── AIMBOT ULTRA FAST ──
    if CFG.Aimbot then
        local target = getNearestEnemy()
        if target then
            LockedTarget = target
            IsLocked     = true
            local head   = target.Character and target.Character:FindFirstChild(CFG.AimPart)
            if head then
                local aimPos = CFG.Prediction and getPredicted(target) or head.Position
                if aimPos then
                    local targetCF = CFrame.new(Camera.CFrame.Position, aimPos)
                    -- Ultra fast lerp (SmoothFactor=0.05 = near instant, FPS feel)
                    Camera.CFrame  = Camera.CFrame:Lerp(targetCF, 1 - CFG.SmoothFactor)
                end
            end
            if CFG.AutoShoot then fireWeapon(target) end
        else
            LockedTarget = nil
            IsLocked     = false
        end
    end
end)


-- ══════════════════════════════════════════
--           CORNER BOX DRAW
-- ══════════════════════════════════════════
local function drawCorners(e, b, color)
    local cLen = math.min(b.TR.X - b.TL.X, b.BL.Y - b.TL.Y) * 0.28
    local function setLine(ln, f, t)
        ln.From=f ; ln.To=t ; ln.Color=color ; ln.Visible=true
    end
    setLine(e.cTL1, b.TL, Vector2.new(b.TL.X+cLen, b.TL.Y))
    setLine(e.cTL2, b.TL, Vector2.new(b.TL.X, b.TL.Y+cLen))
    setLine(e.cTR1, b.TR, Vector2.new(b.TR.X-cLen, b.TR.Y))
    setLine(e.cTR2, b.TR, Vector2.new(b.TR.X, b.TR.Y+cLen))
    setLine(e.cBL1, b.BL, Vector2.new(b.BL.X+cLen, b.BL.Y))
    setLine(e.cBL2, b.BL, Vector2.new(b.BL.X, b.BL.Y-cLen))
    setLine(e.cBR1, b.BR, Vector2.new(b.BR.X-cLen, b.BR.Y))
    setLine(e.cBR2, b.BR, Vector2.new(b.BR.X, b.BR.Y-cLen))
end

local function hideCorners(e)
    for _, k in ipairs({"cTL1","cTL2","cTR1","cTR2","cBL1","cBL2","cBR1","cBR2"}) do
        e[k].Visible = false
    end
end

local function hideAll(e)
    for _, d in pairs(e) do pcall(function() d.Visible = false end) end
end

-- ══════════════════════════════════════════
--         CHAMS (thru wall highlight)
-- ══════════════════════════════════════════
local function applyChams(p, color)
    if ChamsApplied[p.UserId] then return end
    local c = p.Character ; if not c then return end
    for _, part in ipairs(c:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            pcall(function()
                local sel = Instance.new("SelectionBox")
                sel.Color3               = color
                sel.LineThickness        = 0.03
                sel.SurfaceTransparency  = 0.65
                sel.SurfaceColor3        = color
                sel.Adornee              = part
                sel.Parent               = part
            end)
        end
    end
    ChamsApplied[p.UserId] = true
end

local function removeChams(p)
    if not p.Character then return end
    for _, part in ipairs(p.Character:GetDescendants()) do
        for _, v in ipairs(part:GetChildren()) do
            if v:IsA("SelectionBox") then v:Destroy() end
        end
    end
    ChamsApplied[p.UserId] = nil
end

-- ══════════════════════════════════════════
--         NEAREST ENEMY (ULTRA FAST)
-- ══════════════════════════════════════════
local function getNearestEnemy()
    local cx, cy = Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2
    local best, bDist = nil, CFG.FOV
    for _, p in ipairs(Players:GetPlayers()) do
        if isEnemy(p) and isAlive(p) then
            local head = p.Character:FindFirstChild(CFG.AimPart)
            if head then
                local aimPos = CFG.Prediction and getPredicted(p) or head.Position
                if aimPos then
                    local sp, onScreen = Camera:WorldToViewportPoint(aimPos)
                    if onScreen and sp.Z > 0 then
                        local dist = (sp.X-cx)^2 + (sp.Y-cy)^2
                        if dist < bDist then
                            bDist = dist
                            best  = p
                        end
                    end
                end
            end
        end
    end
    return best
end

-- ══════════════════════════════════════════
--         FIRE WEAPON (FPS SUPPORT)
-- ══════════════════════════════════════════
local function fireWeapon(target)
    local char = LP.Character ; if not char then return end
    local head = target and target.Character and target.Character:FindFirstChild("Head")
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            pcall(function() tool:Activate() end)
            for _, v in ipairs(tool:GetDescendants()) do
                if v:IsA("RemoteEvent") then
                    pcall(function()
                        -- multi-arg fire: supports Arsenal, Hypershot, etc
                        if head then
                            v:FireServer(head.Position, head.Position, head, true)
                            v:FireServer(head.Position)
                            v:FireServer()
                        else
                            v:FireServer()
                        end
                    end)
                end
                -- BindableEvent support
                if v:IsA("BindableEvent") then
                    pcall(function() v:Fire() end)
                end
            end
        end
    end
end

-- ══════════════════════════════════════════
--         INFINITE AMMO
-- ══════════════════════════════════════════
local function patchAmmo(char)
    if not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        for _, v in ipairs(tool:GetDescendants()) do
            if v:IsA("IntValue") or v:IsA("NumberValue") then
                local n = v.Name:lower()
                if n:find("ammo") or n:find("bullet") or n:find("clip") or n:find("mag") or n:find("round") then
                    pcall(function()
                        v.Value = 999999
                        v.Changed:Connect(function()
                            if CFG.InfAmmo then v.Value = 999999 end
                        end)
                    end)
                end
            end
        end
    end
end

-- ══════════════════════════════════════════
--         AUTO RELOAD (FPS)
-- ══════════════════════════════════════════
local function tryAutoReload(char)
    if not CFG.AutoReload or not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            for _, v in ipairs(tool:GetDescendants()) do
                if v:IsA("IntValue") or v:IsA("NumberValue") then
                    local n = v.Name:lower()
                    if (n:find("ammo") or n:find("bullet") or n:find("mag")) and v.Value <= 0 then
                        -- fire reload remote
                        for _, re in ipairs(tool:GetDescendants()) do
                            if re:IsA("RemoteEvent") and re.Name:lower():find("reload") then
                                pcall(function() re:FireServer() end)
                            end
                        end
                    end
                end
            end
        end
    end
end


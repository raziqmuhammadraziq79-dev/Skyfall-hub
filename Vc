-- ══════════════════════════════════════════
--            TEAM / ENEMY CHECK
-- ══════════════════════════════════════════
local function isEnemy(p)
    if p == LP then return false end
    if LP.Team and p.Team then
        return LP.Team ~= p.Team
    end
    return true
end

local function isTeammate(p)
    if p == LP then return false end
    if LP.Team and p.Team then
        return LP.Team == p.Team
    end
    return false
end

local function isAlive(p)
    local c = p.Character
    if not c then return false end
    local h = c:FindFirstChildOfClass("Humanoid")
    local r = c:FindFirstChild("HumanoidRootPart")
    return h and h.Health > 0 and r ~= nil
end

-- ══════════════════════════════════════════
--           VELOCITY PREDICTION
-- ══════════════════════════════════════════
local function getPredicted(p)
    local c   = p.Character
    if not c then return nil end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local uid = p.UserId
    local cur = hrp.Position
    if PrevPos[uid] then
        local vel  = (cur - PrevPos[uid]) / 0.016
        local pred = cur + vel * CFG.PredictionFactor
        PrevPos[uid] = cur
        return pred
    end
    PrevPos[uid] = cur
    return cur
end

-- ══════════════════════════════════════════
--             SCREEN BOUNDS
-- ══════════════════════════════════════════
local function getBounds(char)
    local hrp  = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not hrp or not head then return nil end
    local rS, rV = Camera:WorldToViewportPoint(hrp.Position)
    local hS, _  = Camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.8,0))
    local fS, _  = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0,3.2,0))
    if not rV or rS.Z <= 0 then return nil end
    local ht = math.abs(hS.Y - fS.Y)
    local wd = ht * 0.55
    local cx = rS.X
    return {
        screenRoot = Vector2.new(rS.X, rS.Y),
        headPos    = Vector2.new(hS.X, hS.Y),
        botPos     = Vector2.new(cx, fS.Y),
        TL = Vector2.new(cx-wd/2, hS.Y),
        TR = Vector2.new(cx+wd/2, hS.Y),
        BL = Vector2.new(cx-wd/2, fS.Y),
        BR = Vector2.new(cx+wd/2, fS.Y),
        width  = wd,
        height = ht,
        depth  = rS.Z,
    }
end

local function getDistance(p)
    local c   = p.Character
    if not c then return 0 end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    local lhr = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp or not lhr then return 0 end
    return math.floor((hrp.Position - lhr.Position).Magnitude)
end


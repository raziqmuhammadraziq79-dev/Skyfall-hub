-- ── Toggle factory ──
local toggleOrder = 10
local function mkToggle(icon, label, setting)
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1,-16,0,38)
    row.BackgroundColor3 = Color3.fromRGB(20,20,20)
    row.BorderSizePixel  = 0
    row.LayoutOrder      = toggleOrder
    row.Parent           = Main
    toggleOrder          = toggleOrder + 1
    Instance.new("UICorner",row).CornerRadius = UDim.new(0,8)

    local lbl = Instance.new("TextLabel")
    lbl.Size               = UDim2.new(0.62,0,1,0)
    lbl.Position           = UDim2.new(0,10,0,0)
    lbl.BackgroundTransparency = 1
    lbl.Text               = icon .. "  " .. label
    lbl.TextColor3         = Color3.new(1,1,1)
    lbl.Font               = Enum.Font.Gotham
    lbl.TextSize           = 12
    lbl.TextXAlignment     = Enum.TextXAlignment.Left
    lbl.Parent             = row

    local btn = Instance.new("TextButton")
    btn.Size             = UDim2.new(0,64,0,26)
    btn.Position         = UDim2.new(1,-72,0.5,-13)
    btn.BackgroundColor3 = CFG[setting] and Color3.fromRGB(0,190,0) or Color3.fromRGB(190,0,0)
    btn.Text             = CFG[setting] and "ON" or "OFF"
    btn.TextColor3       = Color3.new(1,1,1)
    btn.Font             = Enum.Font.GothamBold
    btn.TextSize         = 13
    btn.Parent           = row
    Instance.new("UICorner",btn).CornerRadius = UDim.new(0,6)

    btn.MouseButton1Click:Connect(function()
        CFG[setting]         = not CFG[setting]
        btn.BackgroundColor3 = CFG[setting] and Color3.fromRGB(0,190,0) or Color3.fromRGB(190,0,0)
        btn.Text             = CFG[setting] and "ON" or "OFF"
    end)
end


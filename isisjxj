            btn.Text = "🔥 KILL AURA (Rapid Fling)"
            btn.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
            Config.FlingOnTouch = false
        else
            btn.Text = "🔥 KILL AURA: ON"
            btn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
            Config.FlingOnTouch = true
            Config.FlingRadius = 50
            if not Config.Flying then StartFly() end
        end
    end)
    
    CreateSection("📱 MOBILE CONTROLS")
    
    -- TOGGLE MOBILE JOYSTICK
    CreateToggle("Show Fly Joystick", true, function(val)
        if State.UI and State.UI.Joystick then
            State.UI.Joystick.Visible = val
        end
    end)
    
    --// MOBILE JOYSTICK (Outside main frame)
    local joyFrame = Instance.new("Frame")
    joyFrame.Name = "FlyJoystick"
    joyFrame.Size = UDim2.new(0, 140, 0, 140)
    joyFrame.Position = UDim2.new(0.05, 0, 0.6, 0)
    joyFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    joyFrame.BackgroundTransparency = 0.3
    joyFrame.BorderSizePixel = 0
    joyFrame.Visible = true
    joyFrame.Parent = sg
    
    local jc = Instance.new("UICorner")
    jc.CornerRadius = UDim.new(1, 0)
    jc.Parent = joyFrame
    
    local js = Instance.new("UIStroke")
    js.Color = Color3.fromRGB(0, 255, 150)
    js.Thickness = 2
    js.Parent = joyFrame
    
    local joyKnob = Instance.new("Frame")
    joyKnob.Size = UDim2.new(0, 45, 0, 45)
    joyKnob.Position = UDim2.new(0.5, -22.5, 0.5, -22.5)
    joyKnob.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
    joyKnob.BorderSizePixel = 0
    joyKnob.Parent = joyFrame
    
    local jkc = Instance.new("UICorner")
    jkc.CornerRadius = UDim.new(1, 0)
    jkc.Parent = joyKnob
    
    local joyActive = false
    local joyCenter = Vector2.new(70, 70)
    local joyMax = 35
    
    joyFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            joyActive = true
        end
    end)
    
    joyFrame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            joyActive = false
            joyKnob.Position = UDim2.new(0.5, -22.5, 0.5, -22.5)
            State.JoystickDir = Vector3.zero
        end
    end)
    
    joyFrame.InputChanged:Connect(function(input)
        if joyActive and input.UserInputType == Enum.UserInputType.Touch then
            local pos = Vector2.new(input.Position.X, input.Position.Y) - joyFrame.AbsolutePosition
            local offset = pos - joyCenter
            local dist = math.min(offset.Magnitude, joyMax)
            local dir = offset.Unit
            
            local newPos = joyCenter + dir * dist
            joyKnob.Position = UDim2.new(0, newPos.X - 22.5, 0, newPos.Y - 22.5)
            
            State.JoystickDir = Vector3.new(dir.X, 0, -dir.Y) * (dist / joyMax)
        end
    end)
    
    --// TOGGLE UI BUTTON (Small floating button)
    local toggleUI = Instance.new("TextButton")
    toggleUI.Name = "ToggleSkyfall"
    toggleUI.Size = UDim2.new(0, 50, 0, 50)
    toggleUI.Position = UDim2.new(0.02, 0, 0.02, 0)
    toggleUI.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
    toggleUI.Text = "☢️"
    toggleUI.TextColor3 = Color3.fromRGB(15, 15, 20)
    toggleUI.TextSize = 24
    toggleUI.Font = Enum.Font.GothamBold
    toggleUI.BorderSizePixel = 0
    toggleUI.Parent = sg
    
    local tuc = Instance.new("UICorner")
    tuc.CornerRadius = UDim.new(1, 0)
    tuc.Parent = toggleUI
    
    local uiVisible = true
    toggleUI.MouseButton1Click:Connect(function()
        uiVisible = not uiVisible
        main.Visible = uiVisible
        joyFrame.Visible = uiVisible
        toggleUI.BackgroundColor3 = uiVisible and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(80, 80, 80)
    end)
    
    -- Parent UI
    sg.Parent = LocalPlayer:WaitForChild("PlayerGui")
    
    -- Store references
    State.UI = {
        ScreenGui = sg,
        MainFrame = main,
        FlyButton = flyBtn,
        Joystick = joyFrame,
        ToggleButton = toggleUI
    }
end

--// INIT
local function Init()
    if not GetChar() then
        LocalPlayer.CharacterAdded:Wait()
    end
    
    pcall(SetupAntiCheatBypass)
    CreateSkyfallUI()
    
    -- Auto-restart on respawn
    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(0.5)
        pcall(ClaimNetwork)
        if Config.Flying then
            task.wait(0.5)
            StartFly()
        end
    end)
    
    print([[
    ╔══════════════════════════════════════╗
    ║     ☢️ SKYFALL FLY v3.0 LOADED       ║
    ║     Delta Mobile | All-in-One UI     ║
    ║     Unlocked Movement | Real Physics ║
    ╚══════════════════════════════════════╝
    ]])
end

Init()

--// EXPORTS
getgenv().SkyfallFly = {
    Start = StartFly,
    Stop = StopFly,
    Fling = FlingTarget,
    FlingAll = function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then FlingTarget(p) end
        end
    end,
    Config = Config,
    State = State
}

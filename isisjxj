--// UTILITIES
local function GetChar() return LocalPlayer.Character end
local function GetRoot()
    local c = GetChar()
    return c and c:FindFirstChild("HumanoidRootPart")
end
local function GetHum()
    local c = GetChar()
    return c and c:FindFirstChildOfClass("Humanoid")
end

--// NETWORK OWNERSHIP
local function ClaimNetwork()
    local c = GetChar()
    if not c then return end
    for _, p in ipairs(c:GetDescendants()) do
        if p:IsA("BasePart") then
            pcall(function() p:SetNetworkOwner(LocalPlayer) end)
        end
    end
end

--// ANTI-DETECTION
local function SetupAntiCheatBypass()
    if not Config.AntiDetection then return end
    local mt = getrawmetatable(game)
    local old = mt.__namecall
    setreadonly(mt, false)
    mt.__namecall = newcclosure(function(self, ...)
        local m = getnamecallmethod()
        if Config.Flying and m == "FireServer" then
            local n = tostring(self):lower()
            if n:find("ac") or n:find("anti") or n:find("check") or n:find("detect") then
                return nil
            end
        end
        return old(self, ...)
    end)
    setreadonly(mt, true)
end

--// FLING ENGINE
local function FlingTarget(target)
    if not target or target == LocalPlayer then return end
    local tc = target.Character
    if not tc then return end
    local tr = tc:FindFirstChild("HumanoidRootPart")
    if not tr then return end
    local mr = GetRoot()
    if not mr then return end
    
    local dir = (tr.Position - mr.Position).Unit
    local vel = dir * Config.FlingPower + Vector3.new(0, Config.FlingPower * 0.3, 0)
    
    pcall(function()
        tr.Velocity = vel
        tr.AssemblyLinearVelocity = vel
    end)
    
    pcall(function()
        local bv = Instance.new("BodyVelocity")
        bv.Name = "SkyfallFling"
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.Velocity = vel
        bv.Parent = tr
        game:GetService("Debris"):AddItem(bv, 0.2)
    end)
    
    pcall(function()
        local ba = Instance.new("BodyAngularVelocity")
        ba.Name = "SkyfallSpin"
        ba.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        ba.AngularVelocity = Vector3.new(math.random(-30,30), math.random(-30,30), math.random(-30,30)) * 50
        ba.Parent = tr
        game:GetService("Debris"):AddItem(ba, 0.4)
    end)
end

--// FLING LOOP
local function StartFlingLoop()
    if State.FlingConnection then return end
    State.FlingConnection = RunService.Heartbeat:Connect(function()
        if not Config.Flying or not Config.FlingOnTouch then return end
        local mr = GetRoot()
        if not mr then return end
        
        if Config.TargetMode and Config.TargetPlayer then
            local tc = Config.TargetPlayer.Character
            if tc then
                local tr = tc:FindFirstChild("HumanoidRootPart")
                if tr and (mr.Position - tr.Position).Magnitude <= Config.FlingRadius then
                    FlingTarget(Config.TargetPlayer)
                end
            end
        else
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer then
                    local tc = plr.Character
                    if tc then
                        local tr = tc:FindFirstChild("HumanoidRootPart")
                        if tr and (mr.Position - tr.Position).Magnitude <= Config.FlingRadius then
                            FlingTarget(plr)
                        end
                    end
                end
            end
        end
    end)
end

local function StopFlingLoop()
    if State.FlingConnection then
        State.FlingConnection:Disconnect()
        State.FlingConnection = nil
    end
end

--// ============================================
--// FIXED FLY ENGINE — UNLOCKED MOVEMENT
--// ============================================

local function StartFly()
    if Config.Flying then return end
    
    local char = GetChar()
    local root = GetRoot()
    local hum = GetHum()
    if not (char and root and hum) then return end
    
    Config.Flying = true
    ClaimNetwork()
    
    -- DON'T use PlatformStand — that's what locks you!
    -- Instead we use BodyMovers while keeping humanoid active
    
    Workspace.Gravity = 0
    
    -- Create BodyGyro for rotation control
    State.BodyGyro = Instance.new("BodyGyro")
    State.BodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    State.BodyGyro.P = 15000
    State.BodyGyro.D = 800
    State.BodyGyro.CFrame = root.CFrame
    State.BodyGyro.Parent = root
    
    -- Create BodyVelocity for movement
    State.BodyVel = Instance.new("BodyVelocity")
    State.BodyVel.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    State.BodyVel.Velocity = Vector3.zero
    State.BodyVel.Parent = root
    
    -- Keep humanoid state normal but disable default movement
    hum.WalkSpeed = 0
    hum.JumpPower = 0
    
    -- Fly loop
    State.FlyConnection = RunService.RenderStepped:Connect(function()
        if not Config.Flying then return end
        local r = GetRoot()
        local h = GetHum()
        if not (r and h) then StopFly() return end
        
        local move = Vector3.zero
        
        -- Keyboard
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            move = move + Camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            move = move - Camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            move = move - Camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            move = move + Camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            move = move + Vector3.new(0, 1, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            move = move - Vector3.new(0, 1, 0)
        end
        
        -- Mobile joystick
        if State.JoystickDir.Magnitude > 0.1 then
            local cl = Camera.CFrame.LookVector
            local cr = Camera.CFrame.RightVector
            move = move + (cl * State.JoystickDir.Y + cr * State.JoystickDir.X)
            move = move + Vector3.new(0, State.JoystickDir.Y * 0.5, 0)
        end
        
        if move.Magnitude > 0 then
            move = move.Unit * Config.Speed * 60
        end
        
        State.BodyVel.Velocity = move
        State.BodyGyro.CFrame = Camera.CFrame
        
        -- Periodic network reclaim
        if math.random(1, 120) == 1 then
            ClaimNetwork()
        end
    end)
    
    StartFlingLoop()
    
    -- Update UI
    if State.UI and State.UI.FlyButton then
        State.UI.FlyButton.Text = "FLY: ON"
        State.UI.FlyButton.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
    end
    
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "Skyfall Fly",
            Text = "Unlocked fly activated! Speed: " .. Config.Speed,
            Duration = 2
        })
    end)
end

local function StopFly()
    if not Config.Flying then return end
    Config.Flying = false
    
    if State.FlyConnection then
        State.FlyConnection:Disconnect()
        State.FlyConnection = nil
    end
    
    StopFlingLoop()
    
    if State.BodyGyro then
        pcall(function() State.BodyGyro:Destroy() end)
        State.BodyGyro = nil
    end
    if State.BodyVel then
        pcall(function() State.BodyVel:Destroy() end)
        State.BodyVel = nil
    end
    
    Workspace.Gravity = State.OriginalGravity
    
    local hum = GetHum()
    if hum then
        hum.WalkSpeed = 16
        hum.JumpPower = 50
    end
    
    if State.UI and State.UI.FlyButton then
        State.UI.FlyButton.Text = "FLY: OFF"
        State.UI.FlyButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    end
end


if GameType == "Evade" then
    Toggle(PgGame, "Auto-Run Forward", function(S) if S then RunService:BindToRenderStep("EvadeAutoRun", Enum.RenderPriority.Character.Value + 1, function() if Humanoid then Humanoid:MoveTo(RootPart.Position + RootPart.CFrame.LookVector * 100) end end) else RunService:UnbindFromRenderStep("EvadeAutoRun") end end)
    Toggle(PgGame, "Anti-Grab NoClip", function(S) if S then RunService:BindToRenderStep("EvadeAntiGrab", Enum.RenderPriority.Character.Value + 1, function() for _, P in pairs(Character:GetDescendants()) do if P:IsA("BasePart") then P.CanCollide = false end end end) else RunService:UnbindFromRenderStep("EvadeAntiGrab"); for _, P in pairs(Character:GetDescendants()) do if P:IsA("BasePart") then P.CanCollide = true end end end end)
    Toggle(PgGame, "Speed Boost 200", function(S) if S then RunService:BindToRenderStep("EvadeSpeed", Enum.RenderPriority.Character.Value + 1, function() if Humanoid then Humanoid.WalkSpeed = 200 end end) else RunService:UnbindFromRenderStep("EvadeSpeed"); Humanoid.WalkSpeed = 16 end end)
    ActBtn(PgGame, "TP to Safe Zone", CFG.Green, function() local safe = Workspace:FindFirstChild("SafeZone") or Workspace:FindFirstChild("Lobby") or Workspace:FindFirstChild("Spawn"); if safe then RootPart.CFrame = safe.CFrame + Vector3.new(0, 3, 0) else Log("Safe zone not found") end end)
    ActBtn(PgGame, "TP to Exit", CFG.Accent, function() local exit = Workspace:FindFirstChild("Exit") or Workspace:FindFirstChild("Goal") or Workspace:FindFirstChild("End"); if exit then RootPart.CFrame = exit.CFrame else Log("Exit not found") end end)
    Toggle(PgGame, "Anti-Nextbot", function(S) if S then RunService:BindToRenderStep("AntiNextbot", Enum.RenderPriority.Character.Value + 1, function() for _, obj in pairs(Workspace:GetDescendants()) do if obj:IsA("BasePart") and (string.find(string.lower(obj.Name), "nextbot") or string.find(string.lower(obj.Name), "enemy")) then if (obj.Position - RootPart.Position).Magnitude < 15 then RootPart.AssemblyLinearVelocity = (RootPart.Position - obj.Position).Unit * 100 end end end end) else RunService:UnbindFromRenderStep("AntiNextbot") end end)
    Toggle(PgGame, "ESP Enemies", function(S)
        if S then for _, obj in pairs(Workspace:GetDescendants()) do if obj:IsA("Model") and (string.find(string.lower(obj.Name), "nextbot") or string.find(string.lower(obj.Name), "enemy") or string.find(string.lower(obj.Name), "killer")) then if not obj:FindFirstChildOfClass("Highlight") then New("Highlight", {FillColor = CFG.Red, OutlineColor = Color3.new(1, 0, 0), FillTransparency = 0.5, Parent = obj}) end end end
        else for _, obj in pairs(Workspace:GetDescendants()) do if obj:IsA("Highlight") and obj.Parent and (string.find(string.lower(obj.Parent.Name), "nextbot") or string.find(string.lower(obj.Parent.Name), "enemy")) then obj:Destroy() end end end
    end)
    Slider(PgGame, "Jump Boost", 50, 500, 50, function(V) Humanoid.JumpPower = V; Humanoid.UseJumpPower = true end)
    Toggle(PgGame, "Auto-Dodge", function(S) if S then RunService:BindToRenderStep("AutoDodge", Enum.RenderPriority.Character.Value + 1, function() for _, obj in pairs(Workspace:GetDescendants()) do if obj:IsA("BasePart") and (string.find(string.lower(obj.Name), "nextbot") or string.find(string.lower(obj.Name), "enemy")) then if (obj.Position - RootPart.Position).Magnitude < 20 then RootPart.CFrame = RootPart.CFrame + RootPart.CFrame.RightVector * (math.random() > 0.5 and 30 or -30) end end end end) else RunService:UnbindFromRenderStep("AutoDodge") end end)

elseif GameType == "SurviveTheKiller" then
    Toggle(PgGame, "ESP Killer (Red)", function(S) if S then for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character then local isK = p.Team and string.find(string.lower(tostring(p.Team.Name)), "killer"); New("Highlight", {FillColor = isK and Color3.fromRGB(255, 0, 0) or CFG.Green, OutlineColor = Color3.new(0, 0, 0), FillTransparency = 0.5, Parent = p.Character}) end end else for _, p in pairs(Players:GetPlayers()) do if p.Character then local h = p.Character:FindFirstChildOfClass("Highlight") if h then h:Destroy() end end end end end)
    Toggle(PgGame, "ESP Survivors (Green)", function(S) if S then for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character then New("Highlight", {FillColor = CFG.Green, OutlineColor = Color3.new(0, 0, 0), FillTransparency = 0.5, Parent = p.Character}) end end else for _, p in pairs(Players:GetPlayers()) do if p.Character then local h = p.Character:FindFirstChildOfClass("Highlight") if h then h:Destroy() end end end end end)
    Toggle(PgGame, "NoClip Walls", function(S) if S then RunService:BindToRenderStep("STKNoClip", Enum.RenderPriority.Character.Value + 1, function() for _, P in pairs(Character:GetDescendants()) do if P:IsA("BasePart") then P.CanCollide = false end end end) else RunService:UnbindFromRenderStep("STKNoClip"); for _, P in pairs(Character:GetDescendants()) do if P:IsA("BasePart") then P.CanCollide = true end end end end)
    Toggle(PgGame, "Speed Boost 80", function(S) if S then RunService:BindToRenderStep("STKSpeed", Enum.RenderPriority.Character.Value + 1, function() if Humanoid then Humanoid.WalkSpeed = 80 end end) else RunService:UnbindFromRenderStep("STKSpeed"); Humanoid.WalkSpeed = 16 end end)
    ActBtn(PgGame, "TP Nearest Survivor", CFG.Green, function() local nearest = nil; local minDist = math.huge; for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then local dist = (p.Character.HumanoidRootPart.Position - RootPart.Position).Magnitude; if dist < minDist then minDist = dist; nearest = p end end end; if nearest then RootPart.CFrame = nearest.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3) end end)
    ActBtn(PgGame, "TP Safe Spot", CFG.Accent, function() local safe = Workspace:FindFirstChild("SafeZone") or Workspace:FindFirstChild("HidingSpot") or Workspace:FindFirstChild("Locker"); if safe then RootPart.CFrame = safe.CFrame + Vector3.new(0, 3, 0) else Log("Safe spot not found") end end)
    Toggle(PgGame, "Infinite Stamina", function(S) if S then RunService:BindToRenderStep("STKStamina", Enum.RenderPriority.Character.Value + 1, function() local stam = LocalPlayer:FindFirstChild("PlayerGui") and LocalPlayer.PlayerGui:FindFirstChild("Stamina") or LocalPlayer:FindFirstChild("Stamina"); if stam then pcall(function() stam.Value = stam.MaxValue or 100 end) end end) else RunService:UnbindFromRenderStep("STKStamina") end end)
    Toggle(PgGame, "Anti-Kill Aura", function(S) if S then RunService:BindToRenderStep("STKAntiKill", Enum.RenderPriority.Character.Value + 1, function() for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then if (p.Character.HumanoidRootPart.Position - RootPart.Position).Magnitude < 5 then RootPart.AssemblyLinearVelocity = (RootPart.Position - p.Character.HumanoidRootPart.Position).Unit * 50 end end end end) else RunService:UnbindFromRenderStep("STKAntiKill") end end)

else
    New("TextLabel", {Size = UDim2.new(1, 0, 0, 40), BackgroundTransparency = 1, Text = "Game: " .. GameName .. "\nUniversal mode — all features work.", TextColor3 = CFG.Dim, TextSize = 10, Font = Enum.Font.GothamMedium, TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top, Parent = PgGame})
    FeatureCount["Game"] = (FeatureCount["Game"] or 0) + 1
    ActBtn(PgGame, "TP to Spawn", CFG.Accent, function() local spawn = Workspace:FindFirstChild("Spawn") or Workspace:FindFirstChild("SpawnPoint") or Workspace:FindFirstChild("Lobby"); if spawn then RootPart.CFrame = spawn.CFrame + Vector3.new(0, 3, 0) else Log("Spawn not found") end end)
    ActBtn(PgGame, "TP Nearest Player", CFG.Accent, function() local nearest = nil; local minDist = math.huge; for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then local dist = (p.Character.HumanoidRootPart.Position - RootPart.Position).Magnitude; if dist < minDist then minDist = dist; nearest = p end end end; if nearest then RootPart.CFrame = nearest.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3) end end)
    Toggle(PgGame, "Universal Speed 80", function(S) if S then RunService:BindToRenderStep("UniSpeed", Enum.RenderPriority.Character.Value + 1, function() if Humanoid then Humanoid.WalkSpeed = 80 end end) else RunService:UnbindFromRenderStep("UniSpeed"); Humanoid.WalkSpeed = 16 end end)
    Toggle(PgGame, "Universal NoClip", function(S) if S then RunService:BindToRenderStep("UniNoClip", Enum.RenderPriority.Character.Value + 1, function() for _, P in pairs(Character:GetDescendants()) do if P:IsA("BasePart") then P.CanCollide = false end end end) else RunService:UnbindFromRenderStep("UniNoClip"); for _, P in pairs(Character:GetDescendants()) do if P:IsA("BasePart") then P.CanCollide = true end end end end)
    Toggle(PgGame, "ESP All Players", function(S) if S then for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character then New("Highlight", {FillColor = CFG.Accent, OutlineColor = Color3.new(0, 0, 0), FillTransparency = 0.5, Parent = p.Character}) end end else for _, p in pairs(Players:GetPlayers()) do if p.Character then local h = p.Character:FindFirstChildOfClass("Highlight") if h then h:Destroy() end end end end end)
    Toggle(PgGame, "God Mode", function(S) if S then Humanoid.MaxHealth = math.huge; Humanoid.Health = math.huge end end)
    Toggle(PgGame, "Anti-Void", function(S) if S then RunService:BindToRenderStep("UniAntiVoid", Enum.RenderPriority.Character.Value + 1, function() if RootPart and RootPart.Position.Y < -50 then RootPart.CFrame = CFrame.new(RootPart.Position.X, 50, RootPart.Position.Z) end end) else RunService:UnbindFromRenderStep("UniAntiVoid") end end)
    ActBtn(PgGame, "Kill All Players", CFG.Red, function() for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character then pcall(function() p.Character:BreakJoints() end) end end end)
    ActBtn(PgGame, "TP All to Me", CFG.Orange, function() for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then p.Character.HumanoidRootPart.CFrame = RootPart.CFrame * CFrame.new(math.random(-5, 5), 0, math.random(-5, 5)) end end end)
end


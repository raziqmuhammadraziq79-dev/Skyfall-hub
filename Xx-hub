Section(PgSet, "  THEME COLORS")
local function ColorBtn(Name, Col)
    FeatureCount["Settings"] = (FeatureCount["Settings"] or 0) + 1
    local B = New("TextButton", {Size = UDim2.new(0.22, -4, 0, 28), BackgroundColor3 = Col, Text = "", Parent = PgSet})
    New("UICorner", {CornerRadius = UDim.new(0, 5), Parent = B})
    New("UIStroke", {Color = Color3.fromRGB(255, 255, 255), Thickness = 1, Transparency = 0.7, Parent = B})
    B.MouseButton1Click:Connect(function() CFG.Accent = Col; MainStroke.Color = Col; FloatStroke.Color = Col; FloatBtn.ImageColor3 = Col; Log("Theme: " .. Name) end)
end
local ColorRow = New("Frame", {Size = UDim2.new(1, 0, 0, 30), BackgroundTransparency = 1, Parent = PgSet})
New("UIListLayout", {FillDirection = Enum.FillDirection.Horizontal, Padding = UDim.new(0, 4), Parent = ColorRow})
ColorBtn("Blue", Color3.fromRGB(99, 102, 241))
ColorBtn("Red", Color3.fromRGB(239, 68, 68))
ColorBtn("Green", Color3.fromRGB(34, 197, 94))
ColorBtn("Purple", Color3.fromRGB(168, 85, 247))

Section(PgSet, "  RGB & EFFECTS")
Toggle(PgSet, "RGB Animation", function(S)
    if S then task.spawn(function() local H = 0; while S and Screen.Parent do H = (H + 0.003) % 1; local NC = Color3.fromHSV(H, 1, 1); CFG.Accent = NC; MainStroke.Color = NC; FloatStroke.Color = NC; FloatBtn.ImageColor3 = NC; task.wait() end end) end
end)
Toggle(PgSet, "Glassmorphism", function(S) Main.BackgroundTransparency = S and 0.08 or 0; Sidebar.BackgroundTransparency = S and 0.08 or 0 end)
Toggle(PgSet, "Phantom Mode", function(S) if S then Main.BackgroundColor3 = Color3.fromRGB(0, 0, 0); Main.BackgroundTransparency = 0.85; MainStroke.Transparency = 0.7 else Main.BackgroundColor3 = CFG.BG; Main.BackgroundTransparency = 0; MainStroke.Transparency = 0 end end)

Section(PgSet, "  SIZE & POSITION")
Slider(PgSet, "GUI Scale %", 60, 160, 100, function(V) local s = V / 100; Main.Size = UDim2.new(0, 460 * s, 0, 320 * s); Main.Position = UDim2.new(0.5, -(230 * s), 0.5, -(160 * s)) end)
Slider(PgSet, "Sidebar Width", 80, 150, 115, function(V) Sidebar.Size = UDim2.new(0, V, 1, -36); Content.Size = UDim2.new(1, -V, 1, -36); Content.Position = UDim2.new(0, V, 0, 36) end)
Slider(PgSet, "Border Thickness", 0, 5, 1, function(V) MainStroke.Thickness = V end)

Section(PgSet, "  SYSTEM")
Toggle(PgSet, "Auto-Hide on Chat", function(S)
    if S then UserInputService.InputBegan:Connect(function(inp, gp) if S and not gp and inp.KeyCode == Enum.KeyCode.Slash then Main.Visible = false; FloatBtn.Visible = true end end) end
end)
Toggle(PgSet, "Save Config", function(S)
    if S then pcall(function() local config = {accent = {CFG.Accent.R, CFG.Accent.G, CFG.Accent.B}, scale = Main.Size.X.Offset / 460}; writefile("skyfall_config.json", game:GetService("HttpService"):JSONEncode(config)) end) end
end)
ActBtn(PgSet, "Destroy GUI", CFG.Red, function() Screen:Destroy() end)
ActBtn(PgSet, "Reset All Settings", CFG.Orange, function()
    CFG.Accent = Color3.fromRGB(99, 102, 241); Main.Size = UDim2.new(0, 460, 0, 320); Main.Position = UDim2.new(0.5, -230, 0.5, -160)
    Main.BackgroundColor3 = CFG.BG; Main.BackgroundTransparency = 0; Sidebar.Size = UDim2.new(0, 115, 1, -36)
    Content.Size = UDim2.new(1, -115, 1, -36); Content.Position = UDim2.new(0, 115, 0, 36); MainStroke.Thickness = 1
end)

-- ═══════════════ UI INTERACTION ═══════════════
HideBtn.MouseButton1Click:Connect(function() Main.Visible = false; FloatBtn.Visible = true end)
FloatBtn.MouseButton1Click:Connect(function() Main.Visible = true; FloatBtn.Visible = false end)
CloseBtn.MouseButton1Click:Connect(function() Screen:Destroy() end)

-- MAIN FRAME DRAG
local DS, SP
Header.InputBegan:Connect(function(I)
    if I.UserInputType == Enum.UserInputType.Touch or I.UserInputType == Enum.UserInputType.MouseButton1 then
        DS = I.Position; SP = Main.Position
        I.Changed:Connect(function() if I.UserInputState ~= Enum.UserInputState.End then local D = I.Position - DS; Main.Position = UDim2.new(SP.X.Scale, SP.X.Offset + D.X, SP.Y.Scale, SP.Y.Offset + D.Y) end end)
    end
end)


LocalPlayer.CharacterAdded:Connect(function(char)
    Character = char; Humanoid = char:WaitForChild("Humanoid"); RootPart = char:WaitForChild("HumanoidRootPart")
    Camera = Workspace.CurrentCamera; Log("Character respawned")
end)


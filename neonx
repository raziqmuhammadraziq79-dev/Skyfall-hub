-- ═══════════════ EXPLOIT DETECTION SYSTEM ═══════════════
local function DetectExploits()
    local suspects = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hum = p.Character:FindFirstChild("Humanoid")
            local rp = p.Character:FindFirstChild("HumanoidRootPart")
            if hum and rp then
                local flags = {}
                
                -- Speed check
                if hum.WalkSpeed > 100 then
                    table.insert(flags, "SpeedHack (WS: " .. hum.WalkSpeed .. ")")
                end
                
                -- Infinite health check
                if hum.MaxHealth > 500 or hum.Health > 500 then
                    table.insert(flags, "InfHealth (HP: " .. hum.Health .. ")")
                end
                
                -- Fly check (if high up with no collision)
                local groundY = GetGroundHeight(rp.Position)
                if rp.Position.Y - groundY > 20 then
                    local rayDown = Workspace:Raycast(rp.Position, Vector3.new(0, -30, 0))
                    if not rayDown then
                        table.insert(flags, "FlyHack (Altitude: " .. math.floor(rp.Position.Y - groundY) .. ")")
                    end
                end
                
                -- NoClip check (if inside walls)
                local region = Region3.new(rp.Position - Vector3.new(1, 1, 1), rp.Position + Vector3.new(1, 1, 1))
                local parts = Workspace:FindPartsInRegion3WithIgnoreList(region, {Character, p.Character})
                if #parts > 5 then
                    table.insert(flags, "NoClip (Inside " .. #parts .. " parts)")
                end
                
                -- Teleport check (sudden position change)
                local lastPos = p:GetAttribute("Skyfall_LastPos")
                if lastPos then
                    local dist = (rp.Position - lastPos).Magnitude
                    if dist > 100 then
                        table.insert(flags, "TeleportHack (Moved " .. math.floor(dist) .. " studs)")
                    end
                end
                p:SetAttribute("Skyfall_LastPos", rp.Position)
                
                if #flags > 0 then
                    table.insert(suspects, {
                        Player = p,
                        Flags = flags,
                        Severity = #flags,
                        UserId = p.UserId
                    })
                end
            end
        end
    end
    
    -- Sort by severity
    table.sort(suspects, function(a, b) return a.Severity > b.Severity end)
    
    return suspects
end


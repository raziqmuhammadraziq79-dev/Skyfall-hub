ActBtn(PgFollow, "🎯 START FOLLOWING TARGET", CFG.Cyan, function()
    if not SelectedPlr then
        StatusBanner.Text = "❌ Select a player first!"; StatusBanner.Visible = true
        task.delay(2, function() StatusBanner.Visible = false end)
        return
    end
    
    PERSISTENT_STATS.FollowEnabled = true
    MODES.Follow = true
    FollowTarget = SelectedPlr
    FollowIndicator.Visible = true
    FollowText.Text = "🎯 Following: " .. FollowTarget.DisplayName
    
    SafeBind("FollowPlayer", Enum.RenderPriority.Character.Value + 1, function()
        if not PERSISTENT_STATS.FollowEnabled or not FollowTarget then return end
        
        local targetChar = FollowTarget.Character
        if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then return end
        
        local targetRP = targetChar.HumanoidRootPart
        local targetPos = targetRP.Position
        
        -- Calculate follow position (behind target, slight hover)
        local groundY = GetGroundHeight(targetPos)
        local followY = groundY + PERSISTENT_STATS.FollowHeight
        
        -- Get direction behind target (opposite of their look vector)
        local targetLook = targetRP.CFrame.LookVector
        local behindOffset = -targetLook * PERSISTENT_STATS.FollowDistance
        
        local followPos = targetPos + behindOffset
        followPos = Vector3.new(followPos.X, followY, followPos.Z)
        
        -- Smooth movement using LERP
        local currentPos = RootPart.Position
        local lerpFactor = 0.1 -- Smoothness (0-1, lower = smoother)
        local newPos = currentPos:Lerp(followPos, lerpFactor)
        
        -- Apply movement
        RootPart.CFrame = CFrame.new(newPos, targetPos)
    end)
    
    StatusBanner.Text = "🎯 Following: " .. FollowTarget.DisplayName; StatusBanner.Visible = true
    task.delay(2, function() StatusBanner.Visible = false end)
    Log("FOLLOW: Now following " .. FollowTarget.DisplayName)
end)


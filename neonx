local function ReportPlayer(player, reason, evidence)
    local report = {
        Player = player,
        Reason = reason,
        Evidence = evidence,
        Timestamp = os.time(),
        GameId = game.PlaceId,
        JobId = game.JobId,
        Reporter = LocalPlayer.UserId
    }
    
    table.insert(ReportLog, report)
    
    -- Generate report message
    local msg = string.format(
        "🚨 EXPLOIT REPORT\nTarget: %s (@%s)\nUserID: %d\nReason: %s\nEvidence: %s\nGame: %d\nJobID: %s\nTime: %s",
        player.Name, player.DisplayName, player.UserId,
        reason, evidence,
        game.PlaceId, game.JobId,
        os.date("%Y-%m-%d %H:%M:%S")
    )
    
    -- Send to chat (public shaming)
    SendChat("🚨 REPORT: " .. player.DisplayName .. " - " .. reason)
    
    -- Log to console
    Log("REPORT SENT: " .. player.Name .. " | " .. reason)
    
    return msg
end

local function ReportAllExploiters()
    local suspects = DetectExploits()
    local count = 0
    
    for _, suspect in ipairs(suspects) do
        local reason = "Multiple Exploit Flags: " .. suspect.Severity
        local evidence = table.concat(suspect.Flags, " | ")
        ReportPlayer(suspect.Player, reason, evidence)
        count = count + 1
        task.wait(0.1) -- Rate limit
    end
    
    return count, suspects
end


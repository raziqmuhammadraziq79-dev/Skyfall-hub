    SliderUI("Time", 0, 24, 12, function(v) SetTime(v) end)
    
    Toggle("Kill Aura", false, function(v) ToggleKillAura(v) end)
    Toggle("Fling Loop", false, function(v)
        Config.FlingLoop = v
        if v then
            State.Connections.FlingLoop = RunService.Heartbeat:Connect(function()
                if not Config.FlingLoop then return end
                local mr = GetRoot()
                if not mr then return end
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer then
                        local tr = GetRoot(plr)
                        if tr and (tr.Position - mr.Position).Magnitude <= Config.FlingRadius then FlingPlayer(plr) end
                    end
                end
            end)
        else
            if State.Connections.FlingLoop then State.Connections.FlingLoop:Disconnect() State.Connections.FlingLoop = nil end
        end
    end)
    Toggle("Click TP", false, function(v) ToggleClickTP(v) end)
    Toggle("FullBright", false, function(v) ToggleFullBright(v) end)
    Toggle("NoFog", false, function(v) ToggleNoFog(v) end)
    Toggle("XRay", false, function(v) ToggleXRay(v) end)
    Toggle("Anti-Ragdoll", false, function(v)
        Config.AntiRagdoll = v
        if v then
            State.Connections.AntiRagdoll = RunService.Heartbeat:Connect(function()
                local hum = GetHum()
                if hum and Config.AntiRagdoll then
                    if hum.PlatformStand then hum.PlatformStand = false end
                    hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                end
            end)
        else
            if State.Connections.AntiRagdoll then State.Connections.AntiRagdoll:Disconnect() State.Connections.AntiRagdoll = nil end
        end
    end)
    Toggle("Anti-AFK", false, function(v) ToggleAntiAFK(v) end)
    Toggle("Low Graphics", false, function(v) ToggleLowGraphics(v) end)
    Toggle("FPS Unlock", true, function(v) ToggleFPS(v) end)
    
    Section("🌐 SERVER")
    Btn("🔄 Rejoin", Color3.fromRGB(80, 80, 120), Rejoin)
    Btn("🌐 Server Hop", Color3.fromRGB(80, 80, 120), ServerHop)
    Btn("❌ Destroy UI", Color3.fromRGB(200, 50, 50), function()
        sg:Destroy()
        State.UI = nil
        StopFly()
        ToggleNoClip(false)
        ToggleESP(false)
        ToggleAimbot(false)
        ToggleSpeed(false)
        ClearESP()
    end)
    
    --// FLOATING TOGGLE
    local floatBtn = Instance.new("TextButton")
    floatBtn.Name = "SkyfallToggle"
    floatBtn.Size = UDim2.new(0, 55, 0, 55)
    floatBtn.Position = UDim2.new(0.02, 0, 0.15, 0)
    floatBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
    floatBtn.Text = "☢️"
    floatBtn.TextColor3 = Color3.fromRGB(15, 15, 20)
    floatBtn.TextSize = 28
    floatBtn.Font = Enum.Font.GothamBlack
    floatBtn.BorderSizePixel = 0
    floatBtn.Parent = sg
    
    local fbc = Instance.new("UICorner")
    fbc.CornerRadius = UDim.new(1, 0)
    fbc.Parent = floatBtn
    
    local fbs = Instance.new("UIStroke")
    fbs.Color = Color3.fromRGB(255, 255, 255)
    fbs.Thickness = 2
    fbs.Parent = floatBtn
    
    local uiVisible = true
    floatBtn.MouseButton1Click:Connect(function()
        uiVisible = not uiVisible
        main.Visible = uiVisible
        floatBtn.BackgroundColor3 = uiVisible and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(80, 80, 80)
    end)
    
    --// MOBILE JOYSTICK
    local joyFrame = Instance.new("Frame")
    joyFrame.Name = "FlyJoystick"
    joyFrame.Size = UDim2.new(0, 150, 0, 150)
    joyFrame.Position = UDim2.new(0.05, 0, 0.55, 0)
    joyFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    joyFrame.BackgroundTransparency = 0.4
    joyFrame.BorderSizePixel = 0
    joyFrame.Visible = true
    joyFrame.Parent = sg
    
    local jfc = Instance.new("UICorner")
    jfc.CornerRadius = UDim.new(1, 0)
    jfc.Parent = joyFrame
    
    local jfs = Instance.new("UIStroke")
    jfs.Color = Color3.fromRGB(0, 255, 150)
    jfs.Thickness = 2
    jfs.Parent = joyFrame
    
    local joyKnob = Instance.new("Frame")
    joyKnob.Size = UDim2.new(0, 50, 0, 50)
    joyKnob.Position = UDim2.new(0.5, -25, 0.5, -25)
    joyKnob.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
    joyKnob.BorderSizePixel = 0
    joyKnob.Parent = joyFrame
    
    local jkc = Instance.new("UICorner")
    jkc.CornerRadius = UDim.new(1, 0)
    jkc.Parent = joyKnob
    
    local joyActive = false
    joyFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then joyActive = true end
    end)
    joyFrame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            joyActive = false
            joyKnob.Position = UDim2.new(0.5, -25, 0.5, -25)
            State.JoystickDir = Vector3.zero
        end
    end)
    joyFrame.InputChanged:Connect(function(input)
        if joyActive and input.UserInputType == Enum.UserInputType.Touch then
            local pos = Vector2.new(input.Position.X, input.Position.Y) - joyFrame.AbsolutePosition
            local center = Vector2.new(75, 75)
            local offset = pos - center
            local dist = math.min(offset.Magnitude, 40)
            local dir = offset.Unit
            local newPos = center + dir * dist
            joyKnob.Position = UDim2.new(0, newPos.X - 25, 0, newPos.Y - 25)
            State.JoystickDir = Vector3.new(dir.X, 0, -dir.Y) * (dist / 40)
        end
    end)
    
    sg.Parent = LocalPlayer:WaitForChild("PlayerGui")
    State.UI = {ScreenGui = sg, MainFrame = main, Joystick = joyFrame, ToggleButton = floatBtn}
    
    Notify("Skyfall Admin", "v5.0 Loaded! 35+ features ready")
end

--// INIT
local function Init()
    if not GetChar() then LocalPlayer.CharacterAdded:Wait() end
    pcall(ClaimNetwork)
    CreateSkyfallUI()
    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(0.5)
        pcall(ClaimNetwork)
        if Config.FlyEnabled then task.wait(0.5) StartFly() end
    end)
    print("Skyfall Admin v5.0 Loaded")
end

Init()


-- [CORE MECHANICS]
-- ================================================================================

local Mechanics = {}

function Mechanics:ToggleNoclip(bool)
	state.noclip = bool
	if bool then
		cache.connections.noclip = runService.Stepped:Connect(function()
			if character then
				for _, part in ipairs(character:GetDescendants()) do
					if part:IsA("BasePart") and part.CanCollide then
						part.CanCollide = false
					end
				end
			end
		end)
	else
		if cache.connections.noclip then cache.connections.noclip:Disconnect() end
	end
end

function Mechanics:ToggleFly(bool)
	state.fly = bool
	if bool then
		cache.connections.fly = runService.Heartbeat:Connect(function()
			if rootPart and character then
				local moveDir = humanoid.MoveDirection
				local cameraCFrame = workspace.CurrentCamera.CFrame
				local flyVec = Vector3.new(0, 0, 0)
				
				if moveDir.Magnitude > 0 then
					flyVec = cameraCFrame:VectorToWorldSpace(Vector3.new(moveDir.X, 0, moveDir.Z)) * state.flySpeed
				end
				
				if userInputService:IsKeyDown(Enum.KeyCode.Space) then
					flyVec = flyVec + Vector3.new(0, state.flySpeed, 0)
				end
				if userInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
					flyVec = flyVec + Vector3.new(0, -state.flySpeed, 0)
				end
				
				rootPart.Velocity = flyVec
			end
		end)
	else
		if cache.connections.fly then cache.connections.fly:Disconnect() end
	end
end

function Mechanics:TeleportTo(targetName)
	for _, p in ipairs(players:GetPlayers()) do
		if p ~= localPlayer and string.sub(string.toLowerCase(p.Name), 1, #targetName) == string.toLowerCase(targetName) then
			if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				rootPart.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 3, 0)
				return true
			end
		end
	end
	return false
end


-- Services
local playersService = game:GetService("Players")
local runService = game:GetService("RunService")
local coreGui = game:GetService("CoreGui")
local userInputService = game:GetService("UserInputService")

-- State
local localPlayer = playersService.LocalPlayer
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")
local humanoid = character:WaitForChild("Humanoid")

local isFlying = false
local flySpeed = 60
local verticalDirection = 0

-- Setup Physics Components Function
local attachment, linearVelocity
local function setupPhysics(char)
	local hrp = char:WaitForChild("HumanoidRootPart")
	
	if attachment then attachment:Destroy() end
	if linearVelocity then linearVelocity:Destroy() end
	
	attachment = Instance.new("Attachment")
	attachment.Name = "DeltaFlyAttachment"
	attachment.Parent = hrp

	linearVelocity = Instance.new("LinearVelocity")
	linearVelocity.Name = "DeltaFlyVelocity"
	linearVelocity.Attachment0 = attachment
	linearVelocity.MaxForce = 0
	linearVelocity.VectorVelocity = Vector3.new(0, 0, 0)
	linearVelocity.Parent = hrp
end
setupPhysics(character)

localPlayer.CharacterAdded:Connect(function(newChar)
	character = newChar
	humanoid = character:WaitForChild("Humanoid")
	rootPart = character:WaitForChild("HumanoidRootPart")
	setupPhysics(newChar)
	if isFlying then
		humanoid:ChangeState(Enum.HumanoidStateType.Physics)
		linearVelocity.MaxForce = math.huge
	end
end)


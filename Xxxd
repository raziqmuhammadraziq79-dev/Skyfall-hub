-- Fly Action Toggle
flyToggle.MouseButton1Click:Connect(function()
	isFlying = not isFlying
	if isFlying then
		flyToggle.Text = "STATUS: FLYING"
		flyToggle.TextColor3 = Color3.fromRGB(0, 255, 120)
		if humanoid and linearVelocity then
			humanoid:ChangeState(Enum.HumanoidStateType.Physics)
			linearVelocity.MaxForce = math.huge
		end
	else
		flyToggle.Text = "STATUS: OFF"
		flyToggle.TextColor3 = Color3.fromRGB(255, 60, 60)
		if humanoid and linearVelocity then
			humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
			linearVelocity.MaxForce = 0
			linearVelocity.VectorVelocity = Vector3.new(0, 0, 0)
		end
		verticalDirection = 0
	end
end)

-- Setup Mobile Touch Controls for Up/Down
local function bindTouch(button, dirValue)
	button.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			verticalDirection = dirValue
		end
	end)
	button.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			if verticalDirection == dirValue then verticalDirection = 0 end
		end
	end)
end

bindTouch(upBtn, 1)
bindTouch(downBtn, -1)

-- Main Physics Sync Loop
runService.Heartbeat:Connect(function()
	if not isFlying or not rootPart or not humanoid or not linearVelocity then return end
	
	local moveDirection = humanoid.MoveDirection
	local finalVelocity = (moveDirection * flySpeed) + Vector3.new(0, verticalDirection * flySpeed, 0)
	
	linearVelocity.VectorVelocity = finalVelocity
end)

print("[DELTA-FLY-PANEL] Clean Interface Loaded Boss! All Systems Optimal. 🔥")

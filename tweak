local function Slider(Page, Name, Min, Max, Def, Callback)
    local Box = New("Frame", {Size=UDim2.new(1,0,0,45), BackgroundColor3=CFG.BG3, BorderSizePixel=0, Parent=Page})
    New("UICorner", {CornerRadius=UDim.new(0,4), Parent=Box})
    local Label = New("TextLabel", {
        Size=UDim2.new(1,-20,0,20), Position=UDim2.new(0,10,0,5), BackgroundTransparency=1,
        Text=Name..": "..Def, TextColor3=CFG.Text, TextSize=11, Font=Enum.Font.GothamMedium,
        TextXAlignment=Enum.TextXAlignment.Left, Parent=Box
    })
    local Track = New("Frame", {Size=UDim2.new(1,-20,0,4), Position=UDim2.new(0,10,1,-12), BackgroundColor3=Color3.fromRGB(40,42,48), Parent=Box})
    New("UICorner", {CornerRadius=UDim.new(1,0), Parent=Track})
    local Fill = New("Frame", {Size=UDim2.new((Def-Min)/(Max-Min),0,1,0), BackgroundColor3=CFG.Accent, Parent=Track})
    New("UICorner", {CornerRadius=UDim.new(1,0), Parent=Fill})
    
    local Drag=false
    local function Update(I)
        local Pct=math.clamp((I.Position.X-Track.AbsolutePosition.X)/Track.AbsoluteSize.X,0,1)
        local V=math.floor(Min+(Max-Min)*Pct)
        Fill.Size=UDim2.new(Pct,0,1,0)
        Label.Text=Name..": "..V; Callback(V)
    end
    
    Track.InputBegan:Connect(function(I)
        if I.UserInputType==Enum.UserInputType.Touch or I.UserInputType==Enum.UserInputType.MouseButton1 then
            Drag=true; Update(I)
        end
    end)
    UserInputService.InputChanged:Connect(function(I)
        if Drag and (I.UserInputType==Enum.UserInputType.Touch or I.UserInputType==Enum.UserInputType.MouseMovement) then Update(I) end
    end)
    UserInputService.InputEnded:Connect(function(I) 
        if I.UserInputType==Enum.UserInputType.Touch or I.UserInputType==Enum.UserInputType.MouseButton1 then Drag=false end 
    end)
end


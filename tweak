-- PLAYER SELECTOR (Clean Dropdown Style)
local SelectedPlr = nil
local PlayerListFrame = nil

local function UpdatePlayerList(filterText)
    if not PlayerListFrame then return end
    for _,child in ipairs(PlayerListFrame:GetChildren()) do
        if child:IsA("GuiObject") and child.Name ~= "UIListLayout" then child:Destroy() end
    end
    
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local name = plr.Name
            if not filterText or string.find(string.lower(name), string.lower(filterText)) then
                local B = New("TextButton", {
                    Size=UDim2.new(1,0,0,24), BackgroundColor3=CFG.BG,
                    Text="  " .. name, TextColor3=SelectedPlr == plr and CFG.Accent or CFG.Text, 
                    TextSize=11, Font=Enum.Font.GothamMedium, TextXAlignment=Enum.TextXAlignment.Left, Parent=PlayerListFrame
                })
                New("UICorner", {CornerRadius=UDim.new(0,3), Parent=B})
                B.MouseButton1Click:Connect(function()
                    SelectedPlr = plr
                    UpdatePlayerList(filterText)
                    AddLog("Target locked: " .. plr.Name)
                end)
            end
        end
    end
end


                    dt.TextSize = 10
                    dt.Font = Enum.Font.Gotham
                    dt.TextStrokeTransparency = 0.3

                    local ht = Instance.new("TextLabel", bb)
                    ht.Name = "HealthLabel"
                    ht.Size = UDim2.new(1, 0, 0.3, 0)
                    ht.Position = UDim2.new(0, 0, 0.7, 0)
                    ht.BackgroundTransparency = 1
                    ht.TextColor3 = C.Success
                    ht.TextSize = 10
                    ht.Font = Enum.Font.GothamBold
                    ht.TextStrokeTransparency = 0.3
                    table.insert(espObjects, bb)
                end)
            end
            if player.Character then onChar(player.Character) end
            player.CharacterAdded:Connect(function(c)
                if Hub.ESPEnabled then onChar(c) end
            end)

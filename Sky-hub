    C.Accent = color
    C.AccentGlow = color
    for i = #AccentElements, 1, -1 do
        local el = AccentElements[i]
        if not el.obj or not el.obj.Parent then
            table.remove(AccentElements, i)
        else
            pcall(function()
                local tw = TweenInfo.new(0.3, Enum.EasingStyle.Quad)
                if el.prop == "BackgroundColor3" then
                    TweenService:Create(el.obj, tw, {BackgroundColor3 = color}):Play()
                elseif el.prop == "Color" then
                    TweenService:Create(el.obj, tw, {Color = color}):Play()
                elseif el.prop == "Color3" then
                    TweenService:Create(el.obj, tw, {Color3 = color}):Play()
                elseif el.prop == "TextColor3" then
                    TweenService:Create(el.obj, tw, {TextColor3 = color}):Play()
                elseif el.prop == "ImageColor3" then
                    TweenService:Create(el.obj, tw, {ImageColor3 = color}):Play()
                elseif el.prop == "ScrollBarImageColor3" then
                    el.obj.ScrollBarImageColor3 = color
                elseif el.prop == "FillColor" then
                    el.obj.FillColor = color
                elseif el.prop == "OutlineColor" then
                    el.obj.OutlineColor = color
                end
            end)
        end
    end
end)


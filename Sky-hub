        end)
    else
        for _, o in ipairs(espObjects) do
            pcall(function() o:Destroy() end)
        end
        espObjects = {}
        if espConn then espConn:Disconnect(); espConn = nil end
        if espDistConn then espDistConn:Disconnect(); espDistConn = nil end
    end
end


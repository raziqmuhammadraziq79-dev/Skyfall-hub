    padBottom.Size = UDim2.new(1, 0, 0, 35)
    padBottom.BackgroundTransparency = 1
    padBottom.LayoutOrder = 9999
    padBottom.Parent = scroll

    local function updateCanvas()
        pcall(function()
            local contentSize = layout.AbsoluteContentSize.Y
            scroll.CanvasSize = UDim2.new(0, 0, 0, contentSize + 40)
        end)
    end
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)
    scroll.ChildAdded:Connect(function()
        task.wait(0.05)
        updateCanvas()
    end)
    scroll.ChildRemoved:Connect(function()
        task.wait(0.05)
        updateCanvas()
    end)

    TabContents[name] = scroll
    return scroll
end


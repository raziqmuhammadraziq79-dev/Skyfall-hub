local function SwitchTab(name)
    Hub.ActiveTab = name
    for tabName, data in pairs(NavButtons) do
        local active = tabName == name
        if active then
            pcall(function()
                TweenService:Create(data.btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.05, BackgroundColor3 = Color3.fromRGB(32, 32, 46)}):Play()
                data.indicator.Visible = true
                TweenService:Create(data.indicator, TweenInfo.new(0.25, Enum.EasingStyle.Back), {Size = UDim2.new(0, 3, 0, 22)}):Play()
                data.label.TextColor3 = C.Accent
                data.label.Font = Enum.Font.GothamBold
                TweenService:Create(data.icon, TweenInfo.new(0.15), {ImageColor3 = C.Accent}):Play()
            end)
        else
            pcall(function()
                TweenService:Create(data.btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.7, BackgroundColor3 = C.Card}):Play()
                data.indicator.Visible = false
                data.label.TextColor3 = C.TextSub
                data.label.Font = Enum.Font.GothamMedium
                TweenService:Create(data.icon, TweenInfo.new(0.15), {ImageColor3 = C.TextSub}):Play()
            end)
        end
        if TabContents[tabName] then
            TabContents[tabName].Visible = active
            if active then
                TabContents[tabName].CanvasPosition = Vector2.new(0, 0)
            end
        end
    end
    HeaderTitle.Text = name
    for _, t in ipairs(TabDefs) do
        if t.name == name then
            HeaderIcon.Image = t.icon
            break
        end
    end
    if name == "Players" then
        RefreshPlayerList()
    end
end


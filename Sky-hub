-- === MOVEMENT MODULE (FIXED CONTROLLABLE FLY) ===
local BodyVelocity = Instance.new("BodyVelocity")
BodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
BodyVelocity.P = 1250
local FlyJoystick = nil -- Virtual joystick instance for mobile control

local function UpdateFlyVelocity()
    if not Hub.IsFlying then return end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local moveDir = Vector3.new(0, 0, 0)
    
    -- Get input from virtual joystick or keyboard fallback
    if FlyJoystick and FlyJoystick.Visible then
        local thumbPos = FlyJoystick.Thumb.Position
        moveDir = Vector3.new(thumbPos.X.Offset, 0, thumbPos.Y.Offset) * 50
    else
        -- Keyboard fallback for testing/desktop
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += Vector3.new(0, 0, -50) end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir += Vector3.new(0, 0, 50) end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir += Vector3.new(-50, 0, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += Vector3.new(50, 0, 0) end
    end
    
    -- Vertical control via separate mechanism (e.g., hold screen top/bottom)
    -- Simplified: Q/E for up/down in this version
    if UserInputService:IsKeyDown(Enum.KeyCode.Q) then moveDir += Vector3.new(0, 50, 0) end
    if UserInputService:IsKeyDown(Enum.KeyCode.E) then moveDir += Vector3.new(0, -50, 0) end
    
    BodyVelocity.Velocity = moveDir
end

local FlyLoop = nil
local function ToggleFly(active)
    Hub.IsFlying = active
    if active then
        BodyVelocity.Parent = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        FlyLoop = RunService.RenderStepped:Connect(UpdateFlyVelocity)
    else
        BodyVelocity.Parent = nil
        if FlyLoop then FlyLoop:Disconnect(); FlyLoop = nil end
    end
end

-- === NOCLIP MODULE (SERVER REPLICATED) ===
local NoClipConn = nil
local function ToggleNoClip(active)
    Hub.IsNoClip = active
    if active then
        NoClipConn = RunService.Stepped:Connect(function()
            for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
            local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.CFrame = hrp.CFrame * CFrame.new(0, 0.001, 0) end
        end)
    else
        if NoClipConn then NoClipConn:Disconnect(); NoClipConn = nil end
        for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = true end
        end
    end
end

-- === RARE FEATURES MODULE ===
-- ESP Hitbox: Visualize player hitboxes through walls
local espConnections = {}
local function ToggleESP(active)
    Hub.ESPEnabled = active
    if active then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local box = Instance.new("SelectionBox")
                    box.LineThickness = 0.05
                    box.Color3 = Color3.fromRGB(138, 43, 226) -- Purple
                    box.Adornee = hrp
                    box.Parent = Workspace
                    table.insert(espConnections, {player=player, box=box})
                end
            end
        end
        -- Monitor new players
        espConnections.playerAdded = Players.PlayerAdded:Connect(function(player)
            player.CharacterAdded:Connect(function(char)
                if Hub.ESPEnabled then
                    char:WaitForChild("HumanoidRootPart")
                    local box = Instance.new("SelectionBox")
                    box.LineThickness = 0.05
                    box.Color3 = Color3.fromRGB(138, 43, 226)
                    box.Adornee = char.HumanoidRootPart
                    box.Parent = Workspace
                    table.insert(espConnections, {player=player, box=box})
                end
            end)
        end)
    else
        for _, conn in ipairs(espConnections) do
            if conn.box then conn.box:Destroy() end
        end
        if espConnections.playerAdded then espConnections.playerAdded:Disconnect() end
        espConnections = {}
    end
end

-- Troll Stuck: Freeze target player in air when you jump
local trollConn = nil
local function ToggleTrollStuck(active)
    Hub.TrollStuck = active
    if active then
        trollConn = UserInputService.JumpRequest:Connect(function()
            local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                -- Find nearest player and anchor them
                local nearestDist = math.huge
                local target = nil
                for _, player in ipairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and player.Character then
                        local tHrp = player.Character:FindFirstChild("HumanoidRootPart")
                        if tHrp then
                            local dist = (hrp.Position - tHrp.Position).Magnitude
                            if dist < nearestDist then
                                nearestDist = dist
                                target = tHrp
                            end
                        end
                    end
                end
                if target and nearestDist < 50 then
                    target.Anchored = true
                    task.delay(2, function() target.Anchored = false end) -- Unstick after 2s
                end
            end
        end)
    else
        if trollConn then trollConn:Disconnect(); trollConn = nil end
    end
end


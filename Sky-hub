        Hub.PanelWidth = newW
        Hub.PanelHeight = newH
        MainFrame.Size = UDim2.new(0, newW, 0, newH)
        MainFrame.Position = UDim2.new(0.5, -newW/2, 0.5, -newH/2)
    end
end)


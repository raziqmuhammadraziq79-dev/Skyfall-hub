            if new == Enum.HumanoidStateType.Freefall then
                char.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
    end
    if Hub.SpeedBoost > 16 then char.Humanoid.WalkSpeed = Hub.SpeedBoost end
end)


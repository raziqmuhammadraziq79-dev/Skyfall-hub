local function SwitchTab(name)
    ActiveTab = name
    for tabName, data in pairs(TabButtons) do
        local isActive = (tabName == name)
        data.Button.BackgroundColor3 = isActive and T.Primary or T.Card
        data.Button.TextColor3 = isActive and T.Text or T.TextDim
        data.Indicator.Visible = isActive
        data.Indicator.BackgroundColor3 = isActive and T.Primary or T.Border
    end
    if TabBuilders[name] then
        TabBuilders[name]()
    end
end

for name, data in pairs(TabButtons) do

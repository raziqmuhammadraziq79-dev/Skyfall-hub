-- 31. TP Checkpoint
local function fTPCheckpoint()
    pcall(function()
        local r=gR() if not r then return end
        local checkpoints={}
        for _,inst in ipairs(WS:GetDescendants()) do
            local n=inst.Name:lower()
            if (n:find("checkpoint") or n:find("stage") or n:find("round") or n:find("zone"))
                and (inst:IsA("BasePart") or inst:IsA("Model")) then
                table.insert(checkpoints,inst)
            end
        end
        if #checkpoints>0 then
            local target=checkpoints[math.random(#checkpoints)]
            local cf=target:IsA("Model") and target:GetPivot() or target.CFrame
            r.CFrame=cf+Vector3.yAxis*5
        end
    end)
end


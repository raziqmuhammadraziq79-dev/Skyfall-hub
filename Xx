    NStroke.Parent = NotifFrame

    local NBar = Instance.new("Frame")
    NBar.Size = UDim2.new(0, 4, 1, -16)
    NBar.Position = UDim2.new(0, 8, 0, 8)
    NBar.BackgroundColor3 = color
    NBar.Parent = NotifFrame
    local NBarCorner = Instance.new("UICorner")
    NBarCorner.CornerRadius = UDim.new(0, 2)
    NBarCorner.Parent = NBar

    local NTitle = Instance.new("TextLabel")
    NTitle.Size = UDim2.new(1, -30, 0, 20)
    NTitle.Position = UDim2.new(0, 22, 0, 10)
    NTitle.BackgroundTransparency = 1
    NTitle.Font = Enum.Font.GothamBold
    NTitle.Text = title
    NTitle.TextColor3 = T.Text
    NTitle.TextSize = 12
    NTitle.TextXAlignment = Enum.TextXAlignment.Left
    NTitle.Parent = NotifFrame

    local NText = Instance.new("TextLabel")
    NText.Size = UDim2.new(1, -30, 0, 16)
    NText.Position = UDim2.new(0, 22, 0, 32)
    NText.BackgroundTransparency = 1
    NText.Font = Enum.Font.Gotham
    NText.Text = text
    NText.TextColor3 = T.TextDim
    NText.TextSize = 10
    NText.TextXAlignment = Enum.TextXAlignment.Left
    NText.Parent = NotifFrame

    -- Animate in
    TweenService:Create(NotifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Position = UDim2.new(1, -300, 1, -80)
    }):Play()

    -- Auto-remove
    task.delay(duration, function()
        TweenService:Create(NotifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 300, 1, -80)
        }):Play()
        task.delay(0.3, function()
            NotifFrame:Destroy()
        end)
    end)
end


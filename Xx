-- 18. Team Switch (force team)
local function fTeamSwitch()
    pcall(function()
        for _,team in ipairs(game:GetService("Teams"):GetChildren()) do
            if team.Name:lower():find("criminal") or team.Name:lower():find("prisoner")
                or team.Name:lower():find("inmate") or team.Name:lower():find("escapee") then
                LP.Team=team
                local r=gR() if r then
                    -- Respawn on new team
                    local h=gH() if h then h.Health=0 end
                end
                return
            end
        end
        -- Fallback: switch to first non-guard team
        for _,team in ipairs(game:GetService("Teams"):GetChildren()) do
            if not team.Name:lower():find("guard") and not team.Name:lower():find("police") then
                LP.Team=team return
            end
        end
    end)
end


-- 29. Auto Dodge (teleport sideways when projectile detected)
local function fAutoDodge(v) S.AutoDodge=v dC("AD")
    if v then aC("AD",RunService.Heartbeat:Connect(function()
        pcall(function()
            local r=gR() if not r then return end
            for _,inst in ipairs(WS:GetDescendants()) do
                if inst:IsA("BasePart") and not inst:IsDescendantOf(LP.Character or Instance.new("Folder")) then
                    local n=inst.Name:lower()
                    if n:find("bullet") or n:find("projectile") or n:find("rocket")
                        or n:find("grenade") or n:find("bomb") then
                        local dist=(inst.Position-r.Position).Magnitude
                        if dist<15 then
                            r.CFrame=r.CFrame*CFrame.new(math.random(-10,10),0,math.random(-10,10))
                        end
                    end
                end

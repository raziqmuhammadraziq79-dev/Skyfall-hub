-- 19. Aimbot
local function fAimbot(v) S.Aimbot=v dC("AIM")
    if v then aC("AIM",RunService.RenderStepped:Connect(function()
        pcall(function()
            local closest,closestDist=nil,S.AimFOV
            local myR=gR() if not myR then return end
            for _,p in ipairs(Players:GetPlayers()) do
                if p~=LP and p.Character then
                    if S.TeamCheck and p.Team==LP.Team then continue end
                    local head=p.Character:FindFirstChild("Head")
                    if head then
                        local screenPos=Cam:WorldToScreenPoint(head.Position)
                        local dist=(Vector2.new(screenPos.X,screenPos.Y)-Vector2.new(VP.X/2,VP.Y/2)).Magnitude
                        if dist<closestDist then
                            closestDist=dist closest=head
                        end
                    end
                end
            end
            if closest then
                Cam.CFrame=Cam.CFrame:Lerp(CFrame.lookAt(Cam.CFrame.Position,closest.Position),1-S.AimSmooth)
            end
        end)
    end)) end
end


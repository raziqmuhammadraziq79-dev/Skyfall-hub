table.insert(activeConnections, runService.RenderStepped:Connect(function()
	local char = localPlayer.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	
	-- Fly Execution
	if config.Fly and root and hum then
		local moveDir = Vector3.new(0,0,0)
		if userInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camera.CFrame.LookVector end
		if userInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camera.CFrame.LookVector end
		if userInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camera.CFrame.RightVector end
		if userInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camera.CFrame.RightVector end
		
		local bv = root:FindFirstChild("GodFlyBV")
		local bg = root:FindFirstChild("GodFlyBG")
		if bv and bg then
			bv.Velocity = moveDir.Magnitude > 0 and moveDir.Unit * config.FlySpeed or Vector3.new(0,0,0)
			bg.CFrame = camera.CFrame
		end
	end
	
	-- Speed Hack Execution
	if config.SpeedHack and hum and not config.Fly then
		hum.WalkSpeed = config.SpeedValue
	end
end))


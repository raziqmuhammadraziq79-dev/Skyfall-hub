        Dragging = false
    end
end)

-- ============================================================================
-- FLY HANDLER (E Key)
-- ============================================================================
local FlyActive = false
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    -- Fly toggle with E
    if input.KeyCode == Enum.KeyCode.E and State.Fly then
        FlyActive = not FlyActive
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        if FlyActive then
            local bv = Instance.new("BodyVelocity")
            bv.Name = "TW_FlyBV"
            bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bv.Velocity = Vector3.new(0, 0, 0)
            bv.Parent = hrp

            local bg = Instance.new("BodyGyro")
            bg.Name = "TW_FlyBG"
            bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            bg.D = 200
            bg.Parent = hrp

            Threads.Fly = task.spawn(function()
                while FlyActive and bv.Parent do
                    local cam = workspace.CurrentCamera
                    local dir = Vector3.new(0, 0, 0)
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
                    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0, 1, 0) end
                    bv.Velocity = dir.Magnitude > 0 and dir.Unit * 80 or Vector3.new(0, 0, 0)
                    bg.CFrame = cam.CFrame
                    RunService.RenderStepped:Wait()
                end
                if bv then bv:Destroy() end
                if bg then bg:Destroy() end
            end)
            Notify("Fly", "Flight active — WASD + Space/Shift", T.Cyan)
        else
            local bv = hrp:FindFirstChild("TW_FlyBV")
            local bg = hrp:FindFirstChild("TW_FlyBG")
            if bv then bv:Destroy() end
            if bg then bg:Destroy() end
            Notify("Fly", "Flight deactivated", T.TextDim)
        end
    end

    -- RightShift toggle GUI
    if input.KeyCode == Enum.KeyCode.RightShift then
        ToggleBtn:MouseButton1Click(nil)
    end
end)


local function fAutoWin(v) S.AutoWin=v dC("AW")
    if v then aC("AW",RunService.Heartbeat:Connect(function()
        pcall(function()
            -- Fire any win/score/complete remotes
            for _,rem in ipairs(game:GetDescendants()) do
                if rem:IsA("RemoteEvent") then
                    local n=rem.Name:lower()
                    if n:find("win") or n:find("complete") or n:find("finish")
                        or n:find("score") or n:find("claim") or n:find("reward") then
                        pcall(function() rem:FireServer() end)
                    end
                end
            end
        end)

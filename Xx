-- TAB: GRAPHICS (Smooth FPS Unlocker + Quality)
-- ============================================================================
local function BuildGraphics()
    ClearContent()
    CreateSectionHeader("Performance")

    CreateToggle("FPS Unlocker (Smooth)", "Remove FPS cap + smooth rendering", function(state)
        State.GraphicsUnlocker = state
        if state then
            -- Smooth FPS unlock — gradual transition
            pcall(function()
                -- Step 1: Remove FPS cap
                if setfpscap then setfpscap(9999) end

                -- Step 2: Gradual lighting optimization (smooth, not instant)
                local info = TweenInfo.new(0.5, Enum.EasingStyle.Sine)

                -- Optimize shadow quality gradually
                local currentShadow = Lighting.ShadowSoftness
                TweenService:Create(Lighting, info, {ShadowSoftness = 0.3}):Play()

                -- Step 3: Set technology to ShadowMap (balanced quality/perf)
                task.wait(0.5)
                Lighting.Technology = Enum.Technology.ShadowMap
                Lighting.GlobalShadows = true

                -- Step 4: Disable heavy effects gradually
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("ParticleEmitter") then
                        pcall(function()
                            local origRate = obj.Rate
                            obj.Rate = math.min(origRate, 10)
                        end)
                    elseif obj:IsA("Trail") then
                        pcall(function() obj.Lifetime = 0.3 end)
                    end
                end
            end)
            Notify("FPS Unlocker", "Smooth unlock applied — FPS stabilized", T.Success)
        else
            pcall(function()
                if setfpscap then setfpscap(60) end
                Lighting.Technology = Enum.Technology.ShadowMap
                Lighting.ShadowSoftness = 0.5
            end)
            Notify("FPS Unlocker", "Reset to 60 FPS cap", T.TextDim)
        end
    end)

    CreateToggle("FPS Boost (Max)", "Maximum performance — low quality", function(state)
        State.FPSBoost = state
        if state then
            pcall(function()
                -- Smooth transition to low quality
                Lighting.Technology = Enum.Technology.Compatibility
                Lighting.GlobalShadows = false
                Lighting.FogEnd = 100000
                Lighting.Bloom = Instance.new("BloomEffect", Lighting)
                Lighting.Bloom.Enabled = false

                -- Disable all visual effects
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") or obj:IsA("Beam") then
                        pcall(function() obj.Enabled = false end)
                    end
                end

                if setfpscap then setfpscap(9999) end
            end)
            Notify("FPS Boost", "Maximum performance mode", T.Success)
        else
            pcall(function()
                Lighting.Technology = Enum.Technology.ShadowMap
                Lighting.GlobalShadows = true
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") or obj:IsA("Beam") then
                        pcall(function() obj.Enabled = true end)
                    end
                end
                if setfpscap then setfpscap(60) end
            end)
            Notify("FPS Boost", "Quality restored", T.TextDim)
        end
    end)

    CreateToggle("RTX Mode (Future)", "Ultra quality lighting (may lag)", function(state)
        State.RTX = state
        pcall(function()
            if state then
                -- Smooth transition to RTX
                TweenService:Create(Lighting, TweenInfo.new(1, Enum.EasingStyle.Sine), {
                    Brightness = 1.5,
                    ShadowSoftness = 0.05
                }):Play()
                task.wait(0.5)
                Lighting.Technology = Enum.Technology.Future
                Lighting.GlobalShadows = true
            else
                TweenService:Create(Lighting, TweenInfo.new(0.5), {
                    Brightness = 1,
                    ShadowSoftness = 0.5
                }):Play()
                Lighting.Technology = Enum.Technology.ShadowMap
            end
        end)
        Notify("RTX", state and "Future lighting enabled" or "Disabled", state and T.Primary or T.TextDim)
    end)

    CreateSectionHeader("Display")

    CreateToggle("FPS Counter", "Show real-time FPS on screen", function(state)
        State.FPSCounter = state
        if state then
            local FPSLabel = Instance.new("TextLabel")
            FPSLabel.Name = "TW_FPS"
            FPSLabel.Size = UDim2.new(0, 80, 0, 24)
            FPSLabel.Position = UDim2.new(0, 10, 0, 10)
            FPSLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            FPSLabel.BackgroundTransparency = 0.5
            FPSLabel.Font = Enum.Font.Code
            FPSLabel.Text = "FPS: --"
            FPSLabel.TextColor3 = T.Success
            FPSLabel.TextSize = 12
            FPSLabel.Parent = ScreenGui
            local FPSCorner = Instance.new("UICorner")
            FPSCorner.CornerRadius = UDim.new(0, 6)
            FPSCorner.Parent = FPSLabel

            local frameCount = 0
            local lastTime = tick()
            Connections.FPSCounter = RunService.RenderStepped:Connect(function()
                frameCount = frameCount + 1
                if tick() - lastTime >= 1 then
                    FPSLabel.Text = "FPS: " .. frameCount
                    if frameCount >= 50 then
                        FPSLabel.TextColor3 = T.Success
                    elseif frameCount >= 30 then
                        FPSLabel.TextColor3 = T.Warning
                    else
                        FPSLabel.TextColor3 = T.Danger
                    end
                    frameCount = 0
                    lastTime = tick()
                end
            end)
        else
            local fps = ScreenGui:FindFirstChild("TW_FPS")
            if fps then fps:Destroy() end
            if Connections.FPSCounter then
                Connections.FPSCounter:Disconnect()
                Connections.FPSCounter = nil
            end
        end
    end)
end


-- CHARACTER RESPAWN HANDLER
-- ============================================================================
LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(1.5)
    -- Re-apply active states
    if State.AntiFling then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp and not hrp:FindFirstChild("TW_AntiFling") then
            local bv = Instance.new("BodyVelocity")
            bv.Name = "TW_AntiFling"
            bv.MaxForce = Vector3.new(0, math.huge, 0)
            bv.Velocity = Vector3.new(0, 0, 0)
            bv.Parent = hrp
            Threads.AntiFling = task.spawn(function()
                while State.AntiFling and bv.Parent do
                    if hrp.Velocity.Y > 200 or hrp.Velocity.Y < -200 then
                        bv.Velocity = Vector3.new(0, -hrp.Velocity.Y, 0)
                    else
                        bv.Velocity = Vector3.new(0, 0, 0)
                    end
                    RunService.Heartbeat:Wait()
                end
            end)
        end
    end
    if State.GodMode then
        local hum = char:FindFirstChild("Humanoid")
        if hum then
            Threads.GodMode = task.spawn(function()
                while State.GodMode do
                    pcall(function() hum.Health = hum.MaxHealth end)
                    task.wait(0.05)
                end
            end)
        end
    end
    if State.SpeedHack then
        local hum = char:FindFirstChild("Humanoid")
        if hum then hum.WalkSpeed = 48 end
    end
end)


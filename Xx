-- Drag for toggle button
local TDrag = false
local TDragStart, TStartPos

ToggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        TDrag = true
        TDragStart = input.Position
        TStartPos = ToggleBtn.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then TDrag = false end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if TDrag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local Delta = input.Position - TDragStart
        ToggleBtn.Position = UDim2.new(TStartPos.X.Scale, TStartPos.X.Offset + Delta.X, TStartPos.Y.Scale, TStartPos.Y.Offset + Delta.Y)
    end
end)


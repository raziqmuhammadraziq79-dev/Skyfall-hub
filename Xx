                Connections.AntiAFK = nil
            end
        end
        Notify("Anti-AFK", state and "Active — no more AFK kick" or "Disabled", state and T.Warning or T.TextDim)
    end)

    CreateSectionHeader("Server")

    CreateButton("Rejoin Server", "Reconnect to current game", T.Cyan, function()
        pcall(function()
            TeleportService:Teleport(game.PlaceId, LocalPlayer)
        end)
    end)

    CreateButton("Server Hop", "Join a different server", T.Cyan, function()
        pcall(function()
            local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?limit=10"
            local response = game:HttpGet(url)
            local servers = HttpService:JSONDecode(response)
            if servers and servers.data then
                for _, server in ipairs(servers.data) do
                    if server.id ~= game.JobId then
                        TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                        break
                    end
                end
            end
        end)
        Notify("Server Hop", "Finding new server...", T.Cyan)
    end)

    CreateButton("Copy UserID", "Copy your Roblox UserID", T.Primary, function()
        if setclipboard then
            setclipboard(tostring(LocalPlayer.UserId))
            Notify("Copied", "UserID: " .. LocalPlayer.UserId, T.Success)
        end
    end)
end


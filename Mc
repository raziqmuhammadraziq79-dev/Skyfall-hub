    end)
end

local function FlingPlayer(targetPlayer, power)
    if not targetPlayer or not targetPlayer.Character then return false end

    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetHum = targetPlayer.Character:FindFirstChildOfClass("Humanoid")

    if not targetRoot or not targetHum then return false end

    -- Force ragdoll state (bypass normal physics)
    pcall(function()
        targetHum:ChangeState(Enum.HumanoidStateType.Physics)
    end)

    -- Direction: from LO to target + upward bias
    local direction = (targetRoot.Position - (Root and Root.Position or targetRoot.Position)).Unit
    local flingVector = Vector3.new(
        direction.X * power + math.random(-100, 100),
        power * 0.8 + math.random(50, 200),
        direction.Z * power + math.random(-100, 100)
    )

    -- Method 1: ApplyImpulse (R15/R6 modern)
    pcall(function()
        targetRoot:ApplyImpulse(flingVector * targetRoot.AssemblyMass)
    end)

    -- Method 2: BodyVelocity (legacy but reliable)
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Velocity = flingVector
    bv.Parent = targetRoot
    game:GetService("Debris"):AddItem(bv, 0.3)

    -- Method 3: Set network ownership to force server sync
    pcall(function()
        targetRoot:SetNetworkOwner(LocalPlayer)
    end)

    -- Visual impact
    CreateImpactEffect(targetRoot.Position)

    return true
end

local function FireRailgun()
    if not States.RailgunActive or not Root then return end

    local camera = Workspace.CurrentCamera
    local origin = camera.CFrame.Position
    local mousePos = UserInputService:GetMouseLocation()
    local ray = camera:ViewportPointToRay(mousePos.X, mousePos.Y)
    local direction = ray.Direction * 1000

    -- Raycast
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character, Workspace.CurrentCamera}
    params.FilterType = Enum.RaycastFilterType.Exclude

    local result = Workspace:Raycast(origin, direction, params)
    local hitPoint = result and result.Position or (origin + direction)

    -- Auto-aim: find nearest player in ray path
    local targetPlayer = nil
    local nearestDist = math.huge

    if States.AutoAim then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local toPlayer = hrp.Position - origin
                    local dot = toPlayer:Dot(direction.Unit)
                    if dot > 0 then
                        local closest = origin + direction.Unit * dot
                        local dist = (closest - hrp.Position).Magnitude
                        if dist < 5 and dist < nearestDist then
                            nearestDist = dist
                            targetPlayer = p
                            hitPoint = hrp.Position
                        end
                    end
                end
            end
        end
    end

    -- Check direct hit
    if not targetPlayer and result and result.Instance then
        local hitPart = result.Instance
        local hitChar = hitPart:FindFirstAncestorOfClass("Model")
        if hitChar then
            local hitPlayer = Players:GetPlayerFromCharacter(hitChar)
            if hitPlayer and hitPlayer ~= LocalPlayer then
                targetPlayer = hitPlayer
            end
        end
    end

    -- Fire beam visual
    CreateRailgunBeam(origin + direction.Unit * 3, hitPoint)

    -- Apply fling to target
    if targetPlayer then
        local success = FlingPlayer(targetPlayer, States.RailgunPower)
        if success then
            warn("[RAILGUN] 🎯 HIT: " .. targetPlayer.Name .. " | Power: " .. States.RailgunPower)
        end

        -- Multi-shot: fling nearby players too
        if States.MultiShot then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p ~= targetPlayer and p.Character then
                    local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local dist = (hrp.Position - hitPoint).Magnitude
                        if dist < 20 then
                            task.wait(0.05)
                            FlingPlayer(p, States.RailgunPower * 0.6)
                            warn("[MULTI] 🎯 Secondary hit: " .. p.Name)
                        end
                    end
                end
            end
        end

        -- Explosive: area effect
        if States.ExplosiveShot then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local dist = (hrp.Position - hitPoint).Magnitude
                        if dist < 30 then
                            task.wait(0.02)
                            FlingPlayer(p, States.RailgunPower * (1 - dist / 30))
                        end
                    end
                end
            end
            CreateImpactEffect(hitPoint)
            CreateImpactEffect(hitPoint + Vector3.new(5, 0, 0))
            CreateImpactEffect(hitPoint - Vector3.new(5, 0, 0))
        end
    end
end


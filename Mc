local function CreateRailgunBeam(origin, target)
    -- Visual beam effect
    local beam = Instance.new("Part")
    beam.Name = "RailBeam"
    beam.Anchored = true
    beam.CanCollide = false
    beam.Material = Enum.Material.Neon
    beam.Color = Color3.fromRGB(255, 50, 80)
    beam.Transparency = 0.2
    beam.Size = Vector3.new(0.3, 0.3, (origin - target).Magnitude)
    beam.CFrame = CFrame.lookAt(origin, target) * CFrame.new(0, 0, -(origin - target).Magnitude / 2)
    beam.Parent = Workspace

    -- Glow effect
    local light = Instance.new("PointLight")
    light.Color = Color3.fromRGB(255, 50, 80)
    light.Brightness = 5
    light.Range = 20
    light.Parent = beam

    -- Fade out
    task.spawn(function()
        for i = 1, 10 do
            beam.Transparency = 0.2 + (i * 0.08)
            task.wait(0.03)
        end
        beam:Destroy()
    end)
end

local function CreateImpactEffect(position)
    -- Explosion visual (no damage, just visual)
    local explosion = Instance.new("Part")
    explosion.Name = "RailImpact"

    for _, c in ipairs(ContentArea:GetChildren()) do
        if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then
            c:Destroy()
        end
    end

    if ActiveCategory == "RAILGUN" then
        sectionHeader(ContentArea, "🔫 RAILGUN CORE")

        createToggle(ContentArea, "Enable Railgun", "RailgunActive", function(s)
            Crosshair.Visible = s
            warn("[RAILGUN] " .. (s and "ARMED — Click to fire" or "DISARMED"))
        end)

        createSlider(ContentArea, "Power (Fling Force)", "RailgunPower", 100, 2000, 800, function(v)
            warn("[RAILGUN] Power set to: " .. v)
        end)

        sectionHeader(ContentArea, "🎯 TARGETING")

        createToggle(ContentArea, "Auto-Aim (Snap to Nearest)", "AutoAim", function(s) end)
        createToggle(ContentArea, "Multi-Shot (Area Fling)", "MultiShot", function(s) end)
        createToggle(ContentArea, "Explosive Impact (30 stud AOE)", "ExplosiveShot", function(s) end)

        sectionHeader(ContentArea, "⚡ ACTIONS")

        actionBtn(ContentArea, "TEST FIRE", "💥", D.ACCENT, function()
            FireRailgun()
        end)

        actionBtn(ContentArea, "FLING SELECTED TARGET", "🎯", D.DANGER, function()
            if SelectedTarget then
                local target = Players:FindFirstChild(SelectedTarget)
                if target then
                    FlingPlayer(target, States.RailgunPower)
                    warn("[RAILGUN] Targeted fling: " .. SelectedTarget)
                end
            else
                warn("[ERROR] Select target in 👥 panel first!")
            end
        end)

        actionBtn(ContentArea, "FLING ALL PLAYERS", "☠️", Color3.fromRGB(150, 0, 0), function()
            local count = 0
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    task.wait(0.05)
                    if FlingPlayer(p, States.RailgunPower) then
                        count = count + 1
                    end

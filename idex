-- Touch Movement Binders
local function bindTouch(button, dirValue)
	button.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			verticalDirection = dirValue
		end
	end)
	button.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			if verticalDirection == dirValue then verticalDirection = 0 end
		end
	end)
end
bindTouch(upBtn, 1)
bindTouch(downBtn, -1)

-- Core Heartbeat Motion Interpolation Sync
runService.Heartbeat:Connect(function(deltaTime)
	if not isFlying or not rootPart or not humanoid or not linearVelocity then return end
	
	local moveDirection = humanoid.MoveDirection
	
	-- Auto-Sprint Momentum Logic
	if moveDirection.Magnitude > 0 or verticalDirection ~= 0 then
		currentSpeed = math.min(currentSpeed + (deltaTime * baseSpeed * 2.5), baseSpeed * maxSpeedMultiplier)
	else
		currentSpeed = baseSpeed
	end
	
	local rawTargetVelocity = (moveDirection * currentSpeed) + Vector3.new(0, verticalDirection * currentSpeed, 0)
	currentVelocityTarget = currentVelocityTarget:Lerp(rawTargetVelocity, lerpAlpha)
	
	linearVelocity.VectorVelocity = currentVelocityTarget
end)


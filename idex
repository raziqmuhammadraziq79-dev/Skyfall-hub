local function toggleRTX(state)
	local cc = lightingService:FindFirstChild("RTX_ColorCorrection") or Instance.new("ColorCorrectionEffect", lightingService)
	cc.Name = "RTX_ColorCorrection"
	
	if state then
		cc.Brightness = 0.05
		cc.Contrast = 0.2
		cc.Saturation = 0.15
		cc.Enabled = true
		lightingService.Ambient = Color3.fromRGB(30, 30, 35)
		lightingService.OutdoorAmbient = Color3.fromRGB(45, 45, 50)
		
		-- Sederhanakan material tapi pertahankan estetika shader proxy
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("BasePart") and not obj:IsDescendantOf(character) then
				if not originalProps[obj] then
					originalProps[obj] = {Material = obj.Material, Reflectance = obj.Reflectance}
				end
				obj.Material = Enum.Material.SmoothPlastic
				obj.Reflectance = 0.1 -- Sedikit pantulan biar efek rtx dapet
			end
		end
	else
		cc.Enabled = false
		lightingService.Ambient = Color3.fromRGB(128, 128, 128)
		if originalProps then
			for obj, props in pairs(originalProps) do
				if obj and obj.Parent then
					obj.Material = props.Material
					obj.Reflectance = props.Reflectance
				end
			end
			table.clear(originalProps)
		end
	end
end

